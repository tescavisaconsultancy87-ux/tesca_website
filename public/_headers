# Content-hashed build assets never change — cache for a year, immutable.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Images, bank/university logos — cache a month (filenames are stable).
/images/*
  Cache-Control: public, max-age=2592000
/bank/*
  Cache-Control: public, max-age=2592000

# Downloadable study material — cache a day.
/material/*
  Cache-Control: public, max-age=86400

# Favicons — cache a week.
/favicon.svg
  Cache-Control: public, max-age=604800
/favicon.png
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800

# Sitemap / robots — short cache so updates propagate.
/sitemap.xml
  Cache-Control: public, max-age=3600
/sitemap-index.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
