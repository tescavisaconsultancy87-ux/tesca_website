# Default security headers for all responses (NO Cache-Control here — Cloudflare
# _headers APPENDS values across matching rules, which would corrupt the asset
# Cache-Control below. HTML page caching is handled by the Cloudflare Cache Rule.)
# Applies to static/prerendered files; SSR routes get headers from middleware.ts.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), geolocation=(), payment=(), usb=(), microphone=(), browsing-topics=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com; font-src 'self' data: https://api.fontshare.com https://fonts.gstatic.com; img-src 'self' data: blob: https://flagcdn.com https://*.supabase.co https://www.google-analytics.com https://www.googletagmanager.com; connect-src 'self' https://*.supabase.co https://script.google.com https://api.web3forms.com https://api.emailjs.com https://www.google-analytics.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://script.google.com; object-src 'none'; upgrade-insecure-requests

# Content-hashed build assets never change — cache for a year, immutable.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Images, bank/university logos — cache a month (filenames are stable).
/images/*
  Cache-Control: public, max-age=2592000
/bank/*
  Cache-Control: public, max-age=2592000

# Downloadable study material — cache a day.
/material/*
  Cache-Control: public, max-age=86400

# Favicons — cache a week.
/favicon.svg
  Cache-Control: public, max-age=604800
/favicon.png
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800

# Sitemap / robots — short cache so updates propagate.
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600

# llms.txt — served as plain text for AI crawlers (LLMO optimization)
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
  Access-Control-Allow-Origin: *
/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
  Access-Control-Allow-Origin: *

# security.txt — served as plain text for security researchers
/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=604800

