---
// PromoPopup.astro
// Promotional lead-generation popup displayed client-side based on admin settings
---

<div id="promo-popup-overlay" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-950/60 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 select-none">
  <div id="promo-popup-card" class="relative bg-white w-full max-w-[640px] aspect-square md:aspect-auto md:min-h-[420px] rounded-3xl overflow-hidden shadow-2xl border border-slate-100 flex flex-col md:flex-row transform scale-95 translate-y-4 opacity-0 transition-all duration-500 ease-out mx-4">
    
    <!-- Close Button -->
    <button type="button" id="promo-popup-close" class="absolute top-4 right-4 z-50 p-2 bg-slate-900/10 hover:bg-slate-900/20 text-slate-700 rounded-full transition-all cursor-pointer hover:scale-105" aria-label="Close popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

    <!-- Left Column: Photo with blurred background container to prevent image/flyer text clipping -->
    <div class="w-full md:w-1/2 h-[260px] md:h-auto relative bg-slate-950 shrink-0 overflow-hidden flex items-center justify-center">
      <!-- Blurred Background Cover -->
      <img id="promo-popup-image-blur" src="" alt="" class="absolute inset-0 w-full h-full object-cover blur-xl opacity-50 scale-110 pointer-events-none select-none" />
      <!-- Sharp Foreground Contain -->
      <img id="promo-popup-image" src="" alt="Latest Updates" class="relative z-10 max-w-full max-h-full object-contain pointer-events-none select-none" />
      <div class="absolute inset-0 z-20 bg-gradient-to-t md:bg-gradient-to-r from-transparent via-transparent to-white/5 pointer-events-none"></div>
    </div>

    <!-- Right Column: Content & Lead Form -->
    <div class="w-full md:w-1/2 p-6 md:p-8 flex flex-col justify-center text-left bg-white relative">
      <!-- Title & Subtitle -->
      <div class="mb-4">
        <span class="inline-block text-[9px] font-extrabold uppercase tracking-widest text-indigo-600 bg-indigo-50 border border-indigo-100 px-2.5 py-0.5 rounded-full mb-2">Featured Update</span>
        <h3 id="promo-popup-title" class="text-lg md:text-xl font-extrabold tracking-tight text-slate-800 leading-tight"></h3>
        <p id="promo-popup-subtitle" class="text-slate-500 text-xs mt-1.5 leading-relaxed"></p>
      </div>

      <!-- Action Button (Directly opens Counsellor Form instead of asking for info) -->
      <div class="mt-4">
        <button type="button" id="promo-popup-action-btn" class="w-full py-3 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 text-white font-bold text-xs rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] flex items-center justify-center gap-1.5 font-sans">
          Speak to Counsellor
        </button>
      </div>

    </div>

  </div>
</div>

<script>
  let hasTriggered = false;

  async function initPromoPopup() {
    const isClosedInSession = sessionStorage.getItem("promo_popup_closed");
    if (isClosedInSession === "true") return;

    try {
      const response = await fetch("/api/popup-settings");
      if (!response.ok) return;
      const settings = await response.json();

      if (!settings || !settings.is_active || !settings.image_url) return;

      const overlay = document.getElementById("promo-popup-overlay");
      const card = document.getElementById("promo-popup-card");
      const image = document.getElementById("promo-popup-image") as HTMLImageElement;
      const title = document.getElementById("promo-popup-title");
      const subtitle = document.getElementById("promo-popup-subtitle");
      const actionBtn = document.getElementById("promo-popup-action-btn") as HTMLButtonElement;

      if (!overlay || !card || !image || !title || !subtitle) return;

      // Populate contents
      image.src = settings.image_url;
      const blurImg = document.getElementById("promo-popup-image-blur") as HTMLImageElement;
      if (blurImg) {
        blurImg.src = settings.image_url;
      }
      title.innerText = settings.title || "Special Update";
      subtitle.innerText = settings.subtitle || "";
      if (settings.button_text && actionBtn) {
        actionBtn.innerText = settings.button_text;
      }

      const delayMs = (settings.delay_seconds || 5) * 1000;

      setTimeout(() => {
        if (sessionStorage.getItem("promo_popup_closed") === "true") return;
        
        // Show overlay & card with beautiful bounce transitions
        overlay.classList.remove("pointer-events-none", "opacity-0");
        overlay.classList.add("opacity-100");

        card.classList.remove("opacity-0", "scale-95", "translate-y-4");
        card.classList.add("opacity-100", "scale-100", "translate-y-0");
      }, delayMs);

      // Handle close
      const closePopup = () => {
        sessionStorage.setItem("promo_popup_closed", "true");
        
        card.classList.remove("opacity-100", "scale-100", "translate-y-0");
        card.classList.add("opacity-0", "scale-95", "translate-y-4");

        overlay.classList.remove("opacity-100");
        overlay.classList.add("opacity-0", "pointer-events-none");
      };

      document.getElementById("promo-popup-close")?.addEventListener("click", closePopup);
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) closePopup();
      });

      // Handle button click to open Counsellor Form
      actionBtn?.addEventListener("click", () => {
        closePopup();
        (window as any).openCounsellorForm?.();
      });

    } catch (e) {
      console.error("Failed to load promo popup settings:", e);
    }
  }

  // Handle load & page navigation in Astro (with View Transitions)
  document.addEventListener("astro:page-load", initPromoPopup);
  if (!hasTriggered) {
    hasTriggered = true;
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initPromoPopup();
    } else {
      document.addEventListener('DOMContentLoaded', initPromoPopup);
    }
  }
</script>
