---
// PromoPopup.astro
// Promotional lead-generation popup displayed client-side based on admin settings
---

<div id="promo-popup-overlay" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-950/60 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 select-none">
  <div id="promo-popup-card" class="relative bg-white w-full max-w-[920px] rounded-[2rem] overflow-hidden shadow-2xl border border-slate-100 flex flex-col md:flex-row transform scale-95 translate-y-4 opacity-0 transition-all duration-500 ease-out mx-4 min-h-[500px]">
    
    <!-- Close Button -->
    <button type="button" id="promo-popup-close" class="absolute top-4 right-4 z-50 p-2 bg-white/90 hover:bg-white text-slate-800 rounded-full shadow-md transition-all cursor-pointer hover:scale-105 md:bg-slate-900/10 md:hover:bg-slate-900/20 md:text-slate-700 md:shadow-none" aria-label="Close popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

    <!-- Navigation Arrows (only shown if > 1 popups) -->
    <button type="button" id="promo-popup-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-50 p-2 bg-white/95 hover:bg-white text-slate-700 hover:text-slate-900 rounded-full shadow-lg transition-all cursor-pointer hover:scale-105 border border-slate-100/80 hidden" aria-label="Previous popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button type="button" id="promo-popup-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-50 p-2 bg-white/95 hover:bg-white text-slate-700 hover:text-slate-900 rounded-full shadow-lg transition-all cursor-pointer hover:scale-105 border border-slate-100/80 hidden" aria-label="Next popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <!-- Slides Container -->
    <div id="promo-popup-slides-container" class="relative w-full flex flex-col md:flex-row flex-1 min-h-[500px]">
       <!-- Dynamic slides injected client-side -->
    </div>

    <!-- Slide Indicators -->
    <div id="promo-popup-indicators" class="absolute bottom-4 left-1/2 -translate-x-1/2 md:left-auto md:translate-x-0 md:right-8 z-40 flex gap-1.5 hidden">
       <!-- Dynamic dot indicators injected client-side -->
    </div>

  </div>
</div>

<style>
  .promo-slide {
    transition: opacity 0.4s ease-in-out, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>

<script>
  let hasTriggered = false;

  async function initPromoPopup() {
    const urlParams = new URLSearchParams(window.location.search);
    const isTestMode = urlParams.get("test-popup") === "true";
    const isClosedInSession = sessionStorage.getItem("promo_popup_closed");
    
    if (isClosedInSession === "true" && !isTestMode) return;

    try {
      const response = await fetch("/api/popup-settings");
      if (!response.ok) return;
      let popups = await response.json();

      // Seed mock popups for test mode if database is empty
      if (isTestMode && (!Array.isArray(popups) || popups.length === 0)) {
        popups = [
          {
            id: 999,
            title: "Test Popup Slide 1",
            subtitle: "This is a mock slide for visual validation. Aspect ratio and sliding transitions are working.",
            image_url: "/images/Hero/main1.webp",
            button_text: "Enquire Now",
            delay_seconds: 2,
            is_active: true
          },
          {
            id: 998,
            title: "Test Popup Slide 2",
            subtitle: "This is the second slide. Cycle back and forth using the navigation arrows on the sides.",
            image_url: "/images/Hero/main1.webp",
            button_text: "Speak to Counsellor",
            delay_seconds: 2,
            is_active: true
          }
        ];
      }

      if (!Array.isArray(popups) || popups.length === 0) return;

      const overlay = document.getElementById("promo-popup-overlay");
      const card = document.getElementById("promo-popup-card");
      const container = document.getElementById("promo-popup-slides-container");
      const prevBtn = document.getElementById("promo-popup-prev") as HTMLButtonElement;
      const nextBtn = document.getElementById("promo-popup-next") as HTMLButtonElement;
      const indicatorsContainer = document.getElementById("promo-popup-indicators");

      if (!overlay || !card || !container) return;

      // Injects slide elements
      container.innerHTML = popups.map((p, idx) => {
        const activeClasses = idx === 0 ? "opacity-100 z-10 scale-100" : "opacity-0 pointer-events-none z-0 scale-95";
        const reqFields = Array.isArray(p.required_fields) ? p.required_fields : ["name", "phone"];
        const isEmailReq = reqFields.includes("email");

        return `
          <div class="promo-slide absolute inset-0 w-full h-full flex flex-col md:flex-row ${activeClasses}" data-index="${idx}" data-capture-leads="${p.lead_capture_enabled || false}" data-popup-title="${p.title || 'Direct Popup Lead'}" data-popup-id="${p.id}">
            <!-- Left Column: Photo -->
            <div class="promo-media-container w-full md:w-1/2 h-full md:h-auto relative bg-slate-950 shrink-0 overflow-hidden flex items-center justify-center cursor-pointer">
              <img src="${p.image_url}" alt="" class="absolute inset-0 w-full h-full object-cover blur-xl opacity-50 scale-110 pointer-events-none select-none" />
              <img src="${p.image_url}" alt="${p.title}" class="absolute inset-0 m-auto max-w-full max-h-full object-contain p-2.5 pointer-events-none select-none" />
              <div class="absolute inset-0 z-20 bg-gradient-to-t md:bg-gradient-to-r from-transparent via-transparent to-white/5 pointer-events-none"></div>
            </div>

            <!-- Right Column: Content -->
            <div class="promo-content-container hidden md:flex md:w-1/2 p-6 md:p-10 flex-col justify-center text-left bg-white relative">
              <div class="mb-4">
                <span class="inline-block text-[9px] font-extrabold uppercase tracking-widest text-indigo-600 bg-indigo-50 border border-indigo-100 px-2.5 py-0.5 rounded-full mb-2">Featured Update</span>
                <h3 class="text-lg md:text-2xl font-extrabold tracking-tight text-slate-800 leading-tight">${p.title || "Special Update"}</h3>
                <p class="text-slate-500 text-[11px] md:text-xs mt-2 leading-relaxed font-sans font-normal">${p.subtitle || ""}</p>
              </div>

              <div class="mt-2 md:mt-4">
                <button type="button" class="promo-popup-action-trigger w-full py-2.5 md:py-3 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 text-white font-bold text-xs rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] flex items-center justify-center gap-1.5 font-sans">
                  ${p.button_text || "Speak to Counsellor"}
                </button>
              </div>
            </div>

            <!-- Inline Form Overlay (shown on click if capture enabled) -->
            ${p.lead_capture_enabled ? `
            <div class="promo-form-overlay absolute inset-0 bg-white z-30 flex flex-col md:flex-row opacity-0 pointer-events-none transition-all duration-300 transform translate-y-2">
              <!-- Left Column: Photo (keeps design consistent on desktop, hidden on mobile) -->
              <div class="hidden md:flex md:w-1/2 h-full relative bg-slate-950 shrink-0 overflow-hidden items-center justify-center">
                <img src="${p.image_url}" alt="" class="absolute inset-0 w-full h-full object-cover blur-xl opacity-50 scale-110 pointer-events-none select-none" />
                <img src="${p.image_url}" alt="${p.title}" class="absolute inset-0 m-auto max-w-full max-h-full object-contain p-2.5 pointer-events-none select-none" />
              </div>

              <!-- Right Column: Lead Form -->
              <div class="w-full md:w-1/2 p-6 md:p-10 flex flex-col justify-center text-left bg-white relative">
                <!-- Back Button -->
                <button type="button" class="promo-form-back absolute top-4 left-4 p-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-full cursor-pointer hover:scale-105 transition-all" aria-label="Go back">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>

                <div class="mb-3">
                  <span class="inline-block text-[8px] font-extrabold uppercase tracking-widest text-indigo-600 bg-indigo-50 border border-indigo-100 px-2 py-0.5 rounded-full mb-1">Quick Enquiry</span>
                  <h3 class="text-sm md:text-base font-extrabold tracking-tight text-slate-800 leading-tight">Register for ${p.title}</h3>
                </div>

                <form class="promo-lead-form space-y-2.5 text-xs font-semibold text-slate-600" autocomplete="off">
                  <div class="space-y-1">
                    <label class="text-[9px] text-slate-500 uppercase tracking-wide">Full Name *</label>
                    <input type="text" name="name" required class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans font-normal" placeholder="e.g. John Doe" />
                  </div>

                  <div class="space-y-1">
                    <label class="text-[9px] text-slate-500 uppercase tracking-wide">Mobile Number *</label>
                    <input type="tel" name="phone" required class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans font-normal" placeholder="e.g. +91 99999 99999" />
                  </div>

                  <div class="space-y-1">
                    <label class="text-[9px] text-slate-500 uppercase tracking-wide">Email Address ${isEmailReq ? '*' : '(Optional)'}</label>
                    <input type="email" name="email" ${isEmailReq ? 'required' : ''} class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans font-normal" placeholder="e.g. johndoe@gmail.com" />
                  </div>

                  <div class="pt-2">
                    <button type="submit" class="w-full py-2.5 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 text-white font-bold rounded-lg shadow-md cursor-pointer hover:scale-[1.01] transition-all flex items-center justify-center gap-1">
                      <span>Submit Details</span>
                    </button>
                  </div>
                </form>

                <!-- Success State (hidden initially) -->
                <div class="promo-form-success absolute inset-0 bg-white p-6 md:p-10 flex flex-col items-center justify-center text-center opacity-0 pointer-events-none transition-all duration-300">
                  <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mb-3.5 border border-emerald-100">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                  <h4 class="text-sm font-extrabold text-slate-800">Inquiry Submitted!</h4>
                  <p class="text-slate-500 text-[10px] mt-1.5 leading-relaxed">Thank you. Our visa advisor will call you shortly.</p>
                </div>
              </div>
            </div>
            ` : ''}
          </div>
        `;
      }).join("");

      // Setup slider states
      let currentIdx = 0;
      const slides = container.querySelectorAll(".promo-slide");

      const updateSlider = (newIdx: number) => {
        // Range validation
        if (newIdx < 0) newIdx = popups.length - 1;
        if (newIdx >= popups.length) newIdx = 0;
        
        slides.forEach((slide, idx) => {
          if (idx === newIdx) {
            slide.classList.remove("opacity-0", "pointer-events-none", "z-0", "scale-95");
            slide.classList.add("opacity-100", "z-10", "scale-100");
          } else {
            slide.classList.remove("opacity-100", "z-10", "scale-100");
            slide.classList.add("opacity-0", "pointer-events-none", "z-0", "scale-95");
          }
        });

        // Update dots
        if (indicatorsContainer) {
          const dots = indicatorsContainer.querySelectorAll(".indicator-dot");
          dots.forEach((dot, idx) => {
            if (idx === newIdx) {
              dot.classList.remove("bg-slate-200");
              dot.classList.add("bg-indigo-600", "w-4");
            } else {
              dot.classList.remove("bg-indigo-600", "w-4");
              dot.classList.add("bg-slate-200");
            }
          });
        }

        currentIdx = newIdx;
      };

      // Set up navigations if > 1 popups
      if (popups.length > 1) {
        prevBtn?.classList.remove("hidden");
        nextBtn?.classList.remove("hidden");
        indicatorsContainer?.classList.remove("hidden");

        // Inject dots
        if (indicatorsContainer) {
          indicatorsContainer.innerHTML = popups.map((_, idx) => {
            const widthClass = idx === 0 ? "w-4 bg-indigo-600" : "w-1.5 bg-slate-200";
            return `<button type="button" class="indicator-dot h-1.5 rounded-full transition-all duration-300 ${widthClass}" data-slide="${idx}" aria-label="Go to slide ${idx + 1}"></button>`;
          }).join("");

          // Dot click listeners
          indicatorsContainer.querySelectorAll(".indicator-dot").forEach((dot) => {
            dot.addEventListener("click", () => {
              const slideIdx = parseInt(dot.getAttribute("data-slide") || "0", 10);
              updateSlider(slideIdx);
            });
          });
        }

        // Arrow click listeners
        prevBtn?.addEventListener("click", () => updateSlider(currentIdx - 1));
        nextBtn?.addEventListener("click", () => updateSlider(currentIdx + 1));
      }

      // Event listeners for action triggers
      container.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;

        // 1. Back button in form
        const backBtn = target.closest(".promo-form-back");
        if (backBtn) {
          const formOverlay = backBtn.closest(".promo-form-overlay");
          if (formOverlay) {
            formOverlay.classList.add("opacity-0", "pointer-events-none", "translate-y-2");
            formOverlay.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
          }
          return;
        }

        // 2. Action triggers (image click or button click)
        const trigger = target.closest(".promo-media-container") || target.closest(".promo-popup-action-trigger");
        if (trigger) {
          const slide = trigger.closest(".promo-slide") as HTMLElement;
          if (!slide) return;

          const captureLeads = slide.getAttribute("data-capture-leads") === "true";
          if (captureLeads) {
            const formOverlay = slide.querySelector(".promo-form-overlay");
            if (formOverlay) {
              formOverlay.classList.remove("opacity-0", "pointer-events-none", "translate-y-2");
              formOverlay.classList.add("opacity-100", "pointer-events-auto", "translate-y-0");
            }
          } else {
            closePopup();
            (window as any).openCounsellorForm?.();
          }
          return;
        }
      });

      // Submit listener for inline forms
      container.querySelectorAll(".promo-lead-form").forEach((formEl) => {
        const form = formEl as HTMLFormElement;
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const slide = form.closest(".promo-slide") as HTMLElement;
          if (!slide) return;

          const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
          const originalBtnContent = submitBtn.innerHTML;
          submitBtn.disabled = true;
          submitBtn.innerHTML = `
            <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span>Submitting...</span>
          `;

          const popupId = slide.getAttribute("data-popup-id");
          const popupTitle = slide.getAttribute("data-popup-title");

          const formData = new FormData(form);
          const payload = {
            name: formData.get("name")?.toString(),
            phone: formData.get("phone")?.toString(),
            email: formData.get("email")?.toString() || null,
            popupId,
            popupTitle
          };

          try {
            const res = await fetch("/api/popup-lead", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload)
            });

            const data = await res.json();

            if (!res.ok) {
              throw new Error(data.error || "Form submission failed.");
            }

            // Show Success state overlay
            const successOverlay = slide.querySelector(".promo-form-success");
            if (successOverlay) {
              successOverlay.classList.remove("opacity-0", "pointer-events-none");
              successOverlay.classList.add("opacity-100", "pointer-events-auto");
            }

            // Close modal after brief delay
            setTimeout(() => {
              closePopup();
              // Reset overlays
              const formOverlay = slide.querySelector(".promo-form-overlay");
              if (formOverlay) {
                formOverlay.classList.add("opacity-0", "pointer-events-none", "translate-y-2");
                formOverlay.classList.remove("opacity-100", "pointer-events-auto", "translate-y-0");
              }
              if (successOverlay) {
                successOverlay.classList.add("opacity-0", "pointer-events-none");
                successOverlay.classList.remove("opacity-100", "pointer-events-auto");
              }
              form.reset();
            }, 2500);

          } catch (err: any) {
            alert(err.message || "An error occurred. Please try again.");
          } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnContent;
          }
        });
      });

      // Show modal after the delay from first popup (or 5 seconds)
      const delayMs = (isTestMode ? 1 : popups[0].delay_seconds || 5) * 1000;

      setTimeout(() => {
        if (sessionStorage.getItem("promo_popup_closed") === "true" && !isTestMode) return;
        
        overlay.classList.remove("pointer-events-none", "opacity-0");
        overlay.classList.add("opacity-100");

        card.classList.remove("opacity-0", "scale-95", "translate-y-4");
        card.classList.add("opacity-100", "scale-100", "translate-y-0");
      }, delayMs);

      // Handle close
      const closePopup = () => {
        if (!isTestMode) {
          sessionStorage.setItem("promo_popup_closed", "true");
        }
        
        card.classList.remove("opacity-100", "scale-100", "translate-y-0");
        card.classList.add("opacity-0", "scale-95", "translate-y-4");

        overlay.classList.remove("opacity-100");
        overlay.classList.add("opacity-0", "pointer-events-none");
      };

      document.getElementById("promo-popup-close")?.addEventListener("click", closePopup);
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) closePopup();
      });

    } catch (e) {
      console.error("Failed to load promo popup settings:", e);
    }
  }

  // Handle load & page navigation in Astro (with View Transitions)
  document.addEventListener("astro:page-load", initPromoPopup);
  if (!hasTriggered) {
    hasTriggered = true;
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initPromoPopup();
    } else {
      document.addEventListener('DOMContentLoaded', initPromoPopup);
    }
  }
</script>
