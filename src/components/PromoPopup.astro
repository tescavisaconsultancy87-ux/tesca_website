---
// PromoPopup.astro
// Promotional lead-generation popup displayed client-side based on admin settings
---

<div id="promo-popup-overlay" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-950/60 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 select-none">
  <div id="promo-popup-card" class="relative bg-white w-full max-w-[520px] rounded-[2rem] overflow-hidden shadow-2xl border border-slate-100 flex flex-col transform scale-95 translate-y-4 opacity-0 transition-all duration-500 ease-out mx-4">
    
    <!-- Close Button -->
    <button type="button" id="promo-popup-close" class="absolute top-4 right-4 z-50 p-2 bg-white/90 hover:bg-white text-slate-800 rounded-full shadow-md transition-all cursor-pointer hover:scale-105" aria-label="Close popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

    <!-- Navigation Arrows (only shown if > 1 popups) -->
    <button type="button" id="promo-popup-prev" class="absolute left-4 top-1/2 -translate-y-1/2 z-50 p-2 bg-white/95 hover:bg-white text-slate-700 hover:text-slate-900 rounded-full shadow-lg transition-all cursor-pointer hover:scale-105 border border-slate-100/80 hidden" aria-label="Previous popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button type="button" id="promo-popup-next" class="absolute right-4 top-1/2 -translate-y-1/2 z-50 p-2 bg-white/95 hover:bg-white text-slate-700 hover:text-slate-900 rounded-full shadow-lg transition-all cursor-pointer hover:scale-105 border border-slate-100/80 hidden" aria-label="Next popup">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <!-- Slides Container -->
    <div id="promo-popup-slides-container" class="relative w-full flex flex-col">
       <!-- Dynamic slides injected client-side -->
    </div>

    <!-- Slide Indicators -->
    <div id="promo-popup-indicators" class="absolute bottom-4 left-1/2 -translate-x-1/2 z-40 flex gap-1.5 hidden">
       <!-- Dynamic dot indicators injected client-side -->
    </div>

  </div>
</div>

<style>
  .promo-slide {
    transition: opacity 0.3s ease-in-out;
  }
</style>

<script>
  let hasTriggered = false;

  async function initPromoPopup() {
    const urlParams = new URLSearchParams(window.location.search);
    const isTestMode = urlParams.get("test-popup") === "true";
    const isClosedInSession = sessionStorage.getItem("promo_popup_closed");
    
    if (isClosedInSession === "true" && !isTestMode) return;

    try {
      const response = await fetch("/api/popup-settings");
      if (!response.ok) return;
      let popups = await response.json();

      // Seed mock popups for test mode if database is empty
      if (isTestMode && (!Array.isArray(popups) || popups.length === 0)) {
        popups = [
          {
            id: 999,
            title: "Test Popup Slide 1",
            subtitle: "Visual validation popup.",
            image_url: "/images/Hero/main1.webp",
            button_text: "Enquire Now",
            delay_seconds: 2,
            is_active: true
          }
        ];
      }

      if (!Array.isArray(popups) || popups.length === 0) return;

      const overlay = document.getElementById("promo-popup-overlay");
      const card = document.getElementById("promo-popup-card");
      const container = document.getElementById("promo-popup-slides-container");
      const prevBtn = document.getElementById("promo-popup-prev") as HTMLButtonElement;
      const nextBtn = document.getElementById("promo-popup-next") as HTMLButtonElement;
      const indicatorsContainer = document.getElementById("promo-popup-indicators");

      if (!overlay || !card || !container) return;

      // Injects slide elements
      container.innerHTML = popups.map((p, idx) => {
        // Active slide is relative flow so container dynamically scales to flyer aspect ratio. Inactive slides are absolute & hidden.
        const activeClasses = idx === 0 
          ? "relative block opacity-100 z-10" 
          : "absolute inset-0 opacity-0 pointer-events-none z-0";
        return `
          <div class="promo-slide w-full h-auto transition-all duration-300 cursor-pointer ${activeClasses}" data-index="${idx}" data-popup-id="${p.id}">
            <img src="${p.image_url}" alt="${p.title}" class="w-full h-auto block pointer-events-none select-none" />
          </div>
        `;
      }).join("");

      // Setup slider states
      let currentIdx = 0;
      const slides = container.querySelectorAll(".promo-slide");

      const updateSlider = (newIdx: number) => {
        // Range validation
        if (newIdx < 0) newIdx = popups.length - 1;
        if (newIdx >= popups.length) newIdx = 0;
        
        slides.forEach((slide, idx) => {
          if (idx === newIdx) {
            slide.classList.remove("absolute", "inset-0", "opacity-0", "pointer-events-none", "z-0");
            slide.classList.add("relative", "block", "opacity-100", "z-10");
          } else {
            slide.classList.remove("relative", "block", "opacity-100", "z-10");
            slide.classList.add("absolute", "inset-0", "opacity-0", "pointer-events-none", "z-0");
          }
        });

        // Update dots
        if (indicatorsContainer) {
          const dots = indicatorsContainer.querySelectorAll(".indicator-dot");
          dots.forEach((dot, idx) => {
            if (idx === newIdx) {
              dot.classList.remove("bg-slate-200");
              dot.classList.add("bg-indigo-600", "w-4");
            } else {
              dot.classList.remove("bg-indigo-600", "w-4");
              dot.classList.add("bg-slate-200");
            }
          });
        }

        currentIdx = newIdx;
      };

      // Set up navigations if > 1 popups
      if (popups.length > 1) {
        prevBtn?.classList.remove("hidden");
        nextBtn?.classList.remove("hidden");
        indicatorsContainer?.classList.remove("hidden");

        // Inject dots
        if (indicatorsContainer) {
          indicatorsContainer.innerHTML = popups.map((_, idx) => {
            const widthClass = idx === 0 ? "w-4 bg-indigo-600" : "w-1.5 bg-slate-200";
            return `<button type="button" class="indicator-dot h-1.5 rounded-full transition-all duration-300 ${widthClass}" data-slide="${idx}" aria-label="Go to slide ${idx + 1}"></button>`;
          }).join("");

          // Dot click listeners
          indicatorsContainer.querySelectorAll(".indicator-dot").forEach((dot) => {
            dot.addEventListener("click", () => {
              const slideIdx = parseInt(dot.getAttribute("data-slide") || "0", 10);
              updateSlider(slideIdx);
            });
          });
        }

        // Arrow click listeners
        prevBtn?.addEventListener("click", () => updateSlider(currentIdx - 1));
        nextBtn?.addEventListener("click", () => updateSlider(currentIdx + 1));
      }

      // Slide click listener - navigate to the dedicated promo landing page
      container.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const slide = target.closest(".promo-slide");
        if (slide) {
          const popupId = slide.getAttribute("data-popup-id");
          closePopup();
          window.location.href = `/promo/${popupId}`;
        }
      });

      // Show modal after the delay from first popup (or 5 seconds)
      const delayMs = (isTestMode ? 1 : popups[0].delay_seconds || 5) * 1000;

      setTimeout(() => {
        if (sessionStorage.getItem("promo_popup_closed") === "true" && !isTestMode) return;
        
        overlay.classList.remove("pointer-events-none", "opacity-0");
        overlay.classList.add("opacity-100");

        card.classList.remove("opacity-0", "scale-95", "translate-y-4");
        card.classList.add("opacity-100", "scale-100", "translate-y-0");
      }, delayMs);

      // Handle close
      const closePopup = () => {
        if (!isTestMode) {
          sessionStorage.setItem("promo_popup_closed", "true");
        }
        
        card.classList.remove("opacity-100", "scale-100", "translate-y-0");
        card.classList.add("opacity-0", "scale-95", "translate-y-4");

        overlay.classList.remove("opacity-100");
        overlay.classList.add("opacity-0", "pointer-events-none");
      };

      document.getElementById("promo-popup-close")?.addEventListener("click", closePopup);
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) closePopup();
      });

    } catch (e) {
      console.error("Failed to load promo popup settings:", e);
    }
  }

  // Handle load & page navigation in Astro (with View Transitions)
  document.addEventListener("astro:page-load", initPromoPopup);
  if (!hasTriggered) {
    hasTriggered = true;
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initPromoPopup();
    } else {
      document.addEventListener('DOMContentLoaded', initPromoPopup);
    }
  }
</script>
