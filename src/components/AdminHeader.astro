---
import { supabase } from "../utils/supabase";
import { ensureCsrfToken } from "../utils/csrf";

interface Props {
  activeTab: "dashboard" | "leads" | "universities" | "stories" | "announcements" | "updates" | "admins" | "gallery" | "our-social" | "partners" | "blogs";
}

const { activeTab } = Astro.props;
const csrfToken = ensureCsrfToken(Astro.cookies);

// Inline SVG icons - no lucide-react (causes SSR hook errors)
const svgBase = `xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"`;
const svgSm = `xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"`;

const navItems = [
  { id: "dashboard", label: "Dashboard", href: "/admin/dashboard", iconSvg: `<svg ${svgBase}><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>` },
  { id: "leads", label: "Leads Panel", href: "/admin/leads", iconSvg: `<svg ${svgBase}><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
  { id: "partners", label: "Partnerships", href: "/admin/partners", iconSvg: `<svg ${svgBase}><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>` },
  { id: "universities", label: "Universities", href: "/admin/universities", iconSvg: `<svg ${svgBase}><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>` },
  { id: "stories", label: "Success Stories", href: "/admin/success-stories", iconSvg: `<svg ${svgBase}><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>` },
  { id: "gallery", label: "Gallery Manager", href: "/admin/gallery", iconSvg: `<svg ${svgBase}><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>` },
  { id: "our-social", label: "Our Social", href: "/admin/our-social", iconSvg: `<svg ${svgBase}><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>` },
  { id: "announcements", label: "Announcement Bar", href: "/admin/announcements", iconSvg: `<svg ${svgBase}><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>` },
  { id: "updates", label: "Visa Bulletins", href: "/admin/visa-updates", iconSvg: `<svg ${svgBase}><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>` },
  { id: "blogs", label: "Blog Posts", href: "/admin/blogs", iconSvg: `<svg ${svgBase}><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>` },
  { id: "admins", label: "Manage Admins", href: "/admin/admins", iconSvg: `<svg ${svgBase}><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>` },
];

let totalLeadsCount = 0;
try {
  const { count, error } = await supabase
    .from('leads')
    .select('*', { count: 'exact', head: true })
    .neq('lead_type', 'partner');

  if (error) throw error;
  totalLeadsCount = count || 0;
} catch (err) {
  console.error("Failed to query leads count in AdminHeader:", err);
}

const bellSvg = `<svg ${svgBase}><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>`;
const logoutSvgBase = `<svg ${svgBase}><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>`;
const logoutSvgSm = `<svg ${svgSm}><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>`;
---

<script is:inline>
  if (localStorage.getItem("admin-sidebar-collapsed") === "true") {
    document.body.classList.add("admin-sidebar-collapsed");
  }
</script>

<div id="admin-header-data" class="hidden" data-total-leads={totalLeadsCount} data-csrf-token={csrfToken}></div>

  <!-- Desktop Sidebar -->
<aside class="hidden lg:flex flex-col w-64 bg-slate-900 border-r border-slate-800 text-white select-none shrink-0 fixed left-0 top-0 bottom-0 z-30">
  <!-- Brand & Bell -->
  <div class="flex items-center justify-between px-6 h-16 border-b border-slate-800 shrink-0 sidebar-header-container">
    <a href="/admin/dashboard" class="flex items-center gap-2.5 outline-none brand-logo-link">
      <img src="/images/Tesca_logo.png" alt="TESCA" class="h-8 w-auto object-contain brand-logo-expanded" />
      <img src="/favicon.svg" alt="T" class="h-8 w-8 object-contain hidden brand-logo-collapsed" />
    </a>
    <div class="flex items-center gap-3 sidebar-header-actions">
      <a href="/admin/leads" class="relative text-slate-400 hover:text-white transition-colors sidebar-bell" title="View Leads">
        <span set:html={bellSvg} />
        <span class="leads-nav-badge hidden absolute -top-1 -right-1 w-2.5 h-2.5 rounded-full bg-rose-500 ring-4 ring-rose-500/20 animate-pulse"></span>
      </a>
      <button type="button" id="sidebar-toggle" class="text-slate-400 hover:text-white transition-colors cursor-pointer focus:outline-none p-1.5 rounded-lg hover:bg-slate-800" title="Collapse Sidebar">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-toggle-icon">
          <rect width="18" height="18" x="3" y="3" rx="2"/>
          <path d="M9 3v18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Navigation (scrollable) -->
  <nav class="flex-1 flex flex-col gap-1 px-3 py-6 overflow-y-auto scrollbar-none">
    {navItems.map((item) => {
      const isActive = activeTab === item.id;
      return (
        <a
          href={item.href}
          class={`flex items-center justify-between px-4 py-3 rounded-xl text-sm font-bold transition-all shrink-0 ${
            isActive
              ? "bg-slate-800 text-indigo-400 border border-slate-700/60"
              : "text-slate-400 hover:bg-slate-800/40 hover:text-white border border-transparent"
          }`}
        >
          <div class="flex items-center gap-3">
            <span set:html={item.iconSvg} class="shrink-0" />
            <span class="sidebar-text-label">{item.label}</span>
          </div>
          {item.id === "leads" && (
            <span class="leads-nav-badge hidden w-2 h-2 rounded-full bg-rose-500 ring-4 ring-rose-500/20 animate-pulse"></span>
          )}
        </a>
      );
    })}
  </nav>

  <!-- Logout at bottom -->
  <div class="px-3 pb-6 shrink-0 logout-container">
    <form method="POST" action="/admin" class="logout-form">
      <input type="hidden" name="action" value="logout" />
      <button 
        type="submit" 
        class="w-full flex items-center gap-3 px-4 py-3 rounded-xl bg-rose-600/10 hover:bg-rose-600/20 text-rose-400 font-bold text-sm transition-all cursor-pointer border border-rose-600/20 logout-button"
      >
        <span set:html={logoutSvgBase} /> <span class="sidebar-text-label">Sign Out</span>
      </button>
    </form>
  </div>
</aside>

<!-- Mobile Top Bar -->
<header class="lg:hidden w-full bg-slate-900 border-b border-slate-800 text-white select-none">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center gap-4">
        <a href="/admin/dashboard" class="flex items-center gap-2.5 outline-none">
          <img src="/images/Tesca_logo.png" alt="TESCA" class="h-7 w-auto object-contain" />
        </a>
        <a href="/admin/leads" class="relative text-slate-400 hover:text-white transition-colors" title="View Leads">
          <span set:html={bellSvg} />
          <span class="leads-nav-badge hidden absolute -top-1 -right-1 w-2 h-2 rounded-full bg-rose-500 ring-2 ring-rose-500/20 animate-pulse"></span>
        </a>
      </div>
      <form method="POST" action="/admin" class="inline logout-form">
        <input type="hidden" name="action" value="logout" />
        <button 
          type="submit" 
          class="flex items-center gap-2 px-4 py-2 bg-rose-600/10 hover:bg-rose-600/20 text-rose-400 font-bold text-xs rounded-xl transition-all cursor-pointer border border-rose-600/20"
        >
          <span set:html={logoutSvgSm} /> Sign Out
        </button>
      </form>
    </div>
  </div>
  <!-- Mobile Tab List -->
  <div class="overflow-x-auto pb-3 px-4 gap-1 select-none scrollbar-none flex">
    {navItems.map((item) => {
      const isActive = activeTab === item.id;
      const iconSmSvg = item.iconSvg.replace(/width="20" height="20"/g, 'width="14" height="14"');
      return (
        <a
          href={item.href}
          class={`flex items-center gap-1.5 px-3 py-2 rounded-lg text-[11px] font-bold whitespace-nowrap transition-all shrink-0 relative ${
            isActive
              ? "bg-slate-800 text-indigo-400 border border-slate-700/60"
              : "text-slate-400 hover:bg-slate-800/40 hover:text-white border border-transparent"
          }`}
        >
          <span set:html={iconSmSvg} />
          {item.label}
          {item.id === "leads" && (
            <span class="leads-nav-badge hidden absolute -top-1 -right-1 w-2 h-2 rounded-full bg-rose-500 ring-2 ring-rose-500/20 animate-pulse"></span>
          )}
        </a>
      );
    })}
  </div>
</header>

<script>
  let pollInterval: any = null;

  function checkNewLeads() {
    const lastViewed = Number(localStorage.getItem("lastViewedLeadsCount") || 0);
    const totalLeadsAttr = document.getElementById("admin-header-data")?.getAttribute("data-total-leads");
    const currentTotal = Number(totalLeadsAttr || 0);

    const showBadges = (show: boolean) => {
      document.querySelectorAll(".leads-nav-badge").forEach(badge => {
        if (show) {
          badge.classList.remove("hidden");
        } else {
          badge.classList.add("hidden");
        }
      });
    };

    const isLeadsPage = window.location.pathname === "/admin/leads";
    if (isLeadsPage) {
      showBadges(false);
      const mainEl = document.querySelector("main");
      if (mainEl) {
        const total = mainEl.getAttribute("data-total-leads") || String(currentTotal);
        localStorage.setItem("lastViewedLeadsCount", total);
      }
    } else {
      if (currentTotal > lastViewed) {
        showBadges(true);
      } else {
        showBadges(false);
      }
    }

    if (pollInterval) {
      clearInterval(pollInterval);
    }

    pollInterval = setInterval(async () => {
      try {
        const res = await fetch("/api/leads-count");
        if (res.status === 401) {
          console.warn("[AdminHeader] Unauthorized (401) response. Clearing poll interval.");
          clearInterval(pollInterval);
          pollInterval = null;
          return;
        }
        if (res.ok) {
          const data = await res.json();
          const latestCount = Number(data.count || 0);
          
          const headerData = document.getElementById("admin-header-data");
          if (headerData) {
            headerData.setAttribute("data-total-leads", String(latestCount));
          }

          const updatedLastViewed = Number(localStorage.getItem("lastViewedLeadsCount") || 0);
          const isLeadsPageNow = window.location.pathname === "/admin/leads";
          
          if (isLeadsPageNow) {
            localStorage.setItem("lastViewedLeadsCount", String(latestCount));
            showBadges(false);
          } else {
            if (latestCount > updatedLastViewed) {
              showBadges(true);
            } else {
              showBadges(false);
            }
          }
        }
      } catch (err) {
        console.error("Failed to poll leads count:", err);
      }
    }, 12000);
  }

  document.addEventListener("astro:before-preparation", () => {
    if (pollInterval) {
      clearInterval(pollInterval);
      pollInterval = null;
    }
  });

  // Intercept logout forms for custom confirm dialog
  function setupLogoutConfirm() {
    const logoutForms = document.querySelectorAll(".logout-form");
    logoutForms.forEach(form => {
      if ((form as any)._bound) return;
      (form as any)._bound = true;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const confirmed = await (window as any).showConfirmDialog({
          title: "Sign Out?",
          description: "Are you sure you want to sign out of the administrative session?",
          actionText: "Sign Out",
          cancelText: "Cancel",
          variant: "destructive",
          from: "bottom"
        });
        if (confirmed) {
          (form as HTMLFormElement).submit();
        }
      });
    });
  }

  function setupSidebarToggle() {
    const toggleBtn = document.getElementById("sidebar-toggle");
    if (!toggleBtn) return;

    if ((toggleBtn as any)._boundToggle) return;
    (toggleBtn as any)._boundToggle = true;

    const updateToggleUI = () => {
      const isCollapsed = document.body.classList.contains("admin-sidebar-collapsed");
      toggleBtn.setAttribute("title", isCollapsed ? "Expand Sidebar" : "Collapse Sidebar");
      const icon = toggleBtn.querySelector(".sidebar-toggle-icon");
      if (icon) {
        if (isCollapsed) {
          icon.innerHTML = `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M15 3v18"/>`;
        } else {
          icon.innerHTML = `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/>`;
        }
      }
    };

    updateToggleUI();

    toggleBtn.addEventListener("click", () => {
      const isCollapsed = document.body.classList.toggle("admin-sidebar-collapsed");
      localStorage.setItem("admin-sidebar-collapsed", String(isCollapsed));
      updateToggleUI();
    });
  }

  // Handle sidebar recovery on swap/transitions
  document.addEventListener("astro:after-swap", () => {
    if (localStorage.getItem("admin-sidebar-collapsed") === "true") {
      document.body.classList.add("admin-sidebar-collapsed");
    }
  });

  checkNewLeads();
  setupLogoutConfirm();
  setupSidebarToggle();
  document.addEventListener("astro:page-load", () => {
    checkNewLeads();
    setupLogoutConfirm();
    setupSidebarToggle();
  });
</script>

<style is:global>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }

  /* Sidebar Transition and Collapse Override Styles */
  @media (min-width: 1024px) {
    aside.hidden.lg\:flex {
      transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }
    main.lg\:ml-64 {
      transition: margin-left 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    /* Collapsed Sidebar Styles */
    body.admin-sidebar-collapsed aside.hidden.lg\:flex {
      width: 5rem !important; /* 80px */
    }
    body.admin-sidebar-collapsed main.lg\:ml-64 {
      margin-left: 5rem !important;
    }

    /* Header adjustments in collapsed sidebar */
    body.admin-sidebar-collapsed .brand-logo-expanded {
      display: none !important;
    }
    body.admin-sidebar-collapsed .brand-logo-collapsed {
      display: block !important;
    }
    body.admin-sidebar-collapsed .sidebar-bell {
      display: none !important;
    }
    body.admin-sidebar-collapsed .sidebar-header-container {
      flex-direction: column !important;
      justify-content: center !important;
      align-items: center !important;
      gap: 0.75rem !important;
      padding-left: 0.5rem !important;
      padding-right: 0.5rem !important;
      height: auto !important;
      padding-top: 1.25rem !important;
      padding-bottom: 1.25rem !important;
    }
    body.admin-sidebar-collapsed .sidebar-header-actions {
      flex-direction: column !important;
      gap: 0.5rem !important;
    }

    /* Nav items adjustments in collapsed sidebar */
    body.admin-sidebar-collapsed aside nav {
      padding-left: 0.5rem !important;
      padding-right: 0.5rem !important;
      gap: 0.5rem !important;
      align-items: center !important;
    }
    body.admin-sidebar-collapsed aside nav a {
      justify-content: center !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
      width: 3.25rem !important;
      height: 3.25rem !important;
      border-radius: 0.75rem !important;
      position: relative !important;
    }
    body.admin-sidebar-collapsed aside nav a div {
      justify-content: center !important;
      gap: 0 !important;
    }
    body.admin-sidebar-collapsed aside nav a .sidebar-text-label {
      display: none !important;
    }
    body.admin-sidebar-collapsed aside nav a .leads-nav-badge {
      position: absolute !important;
      top: 0.6rem !important;
      right: 0.6rem !important;
      width: 0.5rem !important;
      height: 0.5rem !important;
    }

    /* Logout adjustments in collapsed sidebar */
    body.admin-sidebar-collapsed .logout-container {
      padding-left: 0.5rem !important;
      padding-right: 0.5rem !important;
    }
    body.admin-sidebar-collapsed .logout-button {
      justify-content: center !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
      width: 3.25rem !important;
      height: 3.25rem !important;
      margin-left: auto !important;
      margin-right: auto !important;
      gap: 0 !important;
    }
  }
</style>
