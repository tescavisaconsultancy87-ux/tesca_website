---
import "../styles/global.css";
import InquiryFormCRM from "../components/InquiryFormCRM";
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2HW0JXMF2Y"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2HW0JXMF2Y');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/Tesca_logo.png" />
    <link rel="shortcut icon" type="image/png" href="/images/Tesca_logo.png" />
    <title>Assessment Form | TESCA Visa Consultancy</title>
    <meta name="description" content="Study Abroad, Visa & Immigration Assessment Form. Please complete the form and our counselor will contact you within 24 hours." />
  </head>
  <body class="bg-gradient-to-br from-slate-50 to-[#0F4C81]/5 min-h-screen flex flex-col items-center justify-center p-3 md:p-8 font-sans">
    
    <!-- Multi-step lead capture component -->
    <main class="w-full flex justify-center">
      <InquiryFormCRM client:load />
    </main>

  </body>
</html>
