---
import Layout from "../layouts/Layout.astro";
import CountrySelector from "../components/CountrySelector";
import AICounsellor from "../components/AICounsellor";
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block">${d}</svg>`;
const SVG = {
  Landmark: _s('<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="22"/><line x1="10" x2="10" y1="18" y2="22"/><line x1="14" x2="14" y1="18" y2="22"/><line x1="18" x2="18" y1="18" y2="22"/><polygon points="12 2 20 7 4 7"/>'),
  Calendar: _s('<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>'),
  ShieldCheck: _s('<path d="M20 13c0 5-8 7-8 7s-8-2-8-7V5l8-3 8 3v8Z"/><path d="m9 12 2 2 4-4"/>'),
  Briefcase: _s('<path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/>'),
};

const countriesDetail = [
  {
    id: "us",
    name: "United States",
    flag: "us",
    tuition: "$25,000 - $55,000 /yr",
    living: "$12,000 - $24,000 /yr",
    visaType: "F-1 Student Visa",
    visaTimeline: "2 – 8 weeks ",
    workRights: "up to 36 months post-grad",
    prRoute: "STEM -> H-1B -> EB-2/EB-3 Green Card",
    prScore: 40,
    topSectors: ["Artificial Intelligence & Machine Learning", "Quantitative Finance & Fintech", "Biotech Research"],
    universities: ["Stanford University", "Massachusetts Institute of Technology (MIT)", "Harvard University", "UC Berkeley"]
  },
  {
    id: "uk",
    name: "United Kingdom",
    flag: "gb",
    tuition: "£15,000 - £35,000 /yr",
    living: "£10,000 - £18,000 /yr",
    visaType: "Student Visa (Subclass 4)",
    visaTimeline: "21 Days",
    workRights: "2-Year Graduate Route (Post-Study Work)",
    prRoute: "Graduate Route -> Skilled Worker Visa -> ILR (Indefinite Leave to Remain)",
    prScore: 50,
    topSectors: ["Financial Technology & Asset Management", "Healthcare Management", "Biotechnology"],
    universities: ["University of Oxford", "University of Cambridge", "Imperial College London", "London School of Economics (LSE)"]
  },
  {
    id: "ca",
    name: "Canada",
    flag: "ca",
    tuition: "C$20,000 - C$45,000 /yr",
    living: "C$12,000 - C$18,000 /yr",
    visaType: "Study Permit (via SDS / Non-SDS)",
    visaTimeline: "35 Days",
    workRights: "PGWP (Post-Graduation Work Permit) up to 3 years",
    prRoute: "PGWP -> Express Entry (CEC) -> Provincial Nominee Program (PNP)",
    prScore: 85,
    topSectors: ["Software Engineering & Cloud Infrastructure", "Supply Chain & Logistics", "Sustainable Construction"],
    universities: ["University of Toronto", "University of Waterloo", "University of British Columbia", "McGill University"]
  },
  {
    id: "au",
    name: "Australia",
    flag: "au",
    tuition: "A$28,000 - A$48,000 /yr",
    living: "A$14,000 - A$20,000 /yr",
    visaType: "Student Visa (Subclass 500)",
    visaTimeline: "28 Days",
    workRights: "Temporary Graduate Visa (Subclass 485) up to 4 years",
    prRoute: "GSM Points System -> Subclass 189/190/491 (Skilled Migration)",
    prScore: 82,
    topSectors: ["Resource & Environmental Engineering", "Data Analytics & Automation", "Healthcare Tech"],
    universities: ["University of Melbourne", "University of Sydney", "Australian National University (ANU)", "UNSW Sydney"]
  },
  {
    id: "de",
    name: "Germany",
    flag: "de",
    tuition: "€0 - €3,500 /yr (Public Universities)",
    living: "€11,904 /yr (Blocked Account Requirement)",
    visaType: "National Visa (Type D Student)",
    visaTimeline: "45 Days",
    workRights: "18-Month Post-Study Job Search Visa",
    prRoute: "Job Search Visa -> EU Blue Card -> Permanent Settlement (2 years)",
    prScore: 70,
    topSectors: ["Robotics & Industrial Systems", "Automotive & Mechanical Engineering", "Embedded Hardware"],
    universities: ["Technical University of Munich (TUM)", "Heidelberg University", "RWTH Aachen University", "Karlsruhe Institute of Technology (KIT)"]
  }
];
---

<Layout 
  title="Study Abroad Destinations & Student Visa Guides | TESCA"
  description="Compare study abroad options across USA, UK, Canada, Australia, and Germany. Read visa timelines, tuition fees, living costs, and permanent residency (PR) pathways."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-12">
    <!-- Premium Header Banner Card -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-8 items-center p-8 md:p-12 relative mb-16">
      
      {/* Subtle Background Auroras */}
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>

      {/* Left Column: Text Content */}
      <div class="md:col-span-7 space-y-6 text-left relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          STUDY DESTINATIONS
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
         Choose Your Future Destination
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          Compare top countries, tuition costs, visa pathways, and career opportunities to find the perfect place for your global journey.        </p>
      </div>

      {/* Right Column: Student Hero Image cutout */}
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-end">
        <div class="relative w-full max-w-[320px] md:max-w-none md:absolute md:-bottom-12 md:top-[-48px] flex items-end">
          <img 
            src="/images/destinations_hero.png" 
            alt="Study destinations consultant" 
            class="object-contain w-full h-full max-h-[380px] md:max-h-none select-none filter drop-shadow-[0_10px_20px_rgba(0,0,0,0.06)]"
          />
        </div>
      </div>

    </div>

    <CountrySelector client:load />
  </section>

  <!-- Complete country profile details -->
  <section class="max-w-7xl mx-auto px-6 md:px-8 py-20 space-y-20 relative text-left">
    <div class="aurora-bg w-[500px] h-[500px] bg-accent-blue/5 top-1/4 left-1/4 rounded-full blur-[100px]"></div>

    <div class="space-y-2 mb-12 border-b border-slate-200 pb-4">
      <h2 class="text-[28px] md:text-[36px] font-bold font-display text-support-white tracking-tight">Immigration & Fiscal Profiles</h2>
      <p class="text-sm text-support-gray/60 font-sans font-medium">Consolidated official compliance structures</p>
    </div>

    {countriesDetail.map(country => (
      <div id={country.id} class="glass-card rounded-3xl p-8 md:p-12 grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch border border-slate-200 relative hover:border-accent-blue/30 transition-all duration-300">
        
        {/* Left side details */}
        <div class="lg:col-span-5 space-y-6 flex flex-col justify-between">
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <img src={`https://flagcdn.com/w40/${country.flag}.png`} alt={`${country.name} flag`} class="w-10 h-7 rounded-sm object-cover shadow-sm" />
              <div>
                <h3 class="text-[20px] lg:text-[26px] font-bold font-display text-support-white tracking-tight">{country.name}</h3>
                <span class="text-sm font-medium text-accent-blue font-sans">{country.visaType}</span>
              </div>
            </div>
            <p class="text-sm text-support-gray/80 leading-relaxed font-sans font-normal">
              Matching candidates obtain automated entry evaluations via the TESCA admissions portal, with average visa dispatch timelines mapped below.
            </p>
          </div>

          <div class="space-y-3 pt-4 border-t border-slate-100">
            <div class="text-xs font-semibold text-support-gray/50 uppercase tracking-wider font-sans">Top Shortlisted Universities</div>
            <ul class="space-y-2">
              {country.universities.map(u => (
                <li class="flex items-center gap-2 text-sm text-support-gray font-sans font-normal">
                  <span class="w-1.5 h-1.5 bg-accent-blue rounded-full"></span>
                  <span>{u}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        {/* Right side charts / index cards */}
        <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
          
          {/* Card 1: Fiscal Estimates */}
          <div class="p-6 rounded-2xl border border-slate-200 bg-white shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
              <div class="p-2 rounded-lg bg-accent-blue/10 text-accent-indigo">
                <span set:html={SVG.Landmark} class="w-4 h-4 flex items-center justify-center" />
              </div>
              <h4 class="text-xs font-semibold text-support-white uppercase tracking-wider font-sans">Annual Tuition & Living</h4>
            </div>

            <div class="space-y-2 pt-4">
              <div class="flex justify-between text-sm items-center">
                <span class="text-support-gray font-sans font-normal">Tuition fees:</span>
                <span class="font-bold text-support-white font-display">{country.tuition}</span>
              </div>
              <div class="flex justify-between text-sm items-center">
                <span class="text-support-gray font-sans font-normal">Living expenses:</span>
                <span class="font-bold text-support-white font-display">{country.living}</span>
              </div>
            </div>
            
            <div class="text-[12px] text-support-gray/40 border-t border-slate-100 pt-3 mt-4 font-sans font-normal">
              Estimated without scholarships.
            </div>
          </div>

          {/* Card 2: Visa & Processing */}
          <div class="p-6 rounded-2xl border border-slate-200 bg-white shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
              <div class="p-2 rounded-lg bg-accent-indigo/10 text-accent-indigo">
                <span set:html={SVG.Calendar} class="w-4 h-4 flex items-center justify-center" />
              </div>
              <h4 class="text-xs font-semibold text-support-white uppercase tracking-wider font-sans">Visa Processing & Post-Work</h4>
            </div>

            <div class="space-y-2 pt-4">
              <div class="flex justify-between text-sm items-center">
                <span class="text-support-gray font-sans font-normal">Visa SLA:</span>
                <span class="font-bold text-support-white font-display">{country.visaTimeline}</span>
              </div>
              <div class="flex justify-between text-sm items-center">
                <span class="text-support-gray font-sans font-normal">Work permit:</span>
                <span class="font-bold text-support-white font-display text-right text-[13px] max-w-[150px] truncate">{country.workRights}</span>
              </div>
            </div>

            <div class="text-[12px] text-support-gray/40 border-t border-slate-100 pt-3 mt-4 font-sans font-normal">
              Standard post-graduation pathway criteria apply.
            </div>
          </div>

          {/* Card 3: Pathway to Citizenship */}
          <div class="p-6 rounded-2xl border border-slate-200 bg-white shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
              <div class="p-2 rounded-lg bg-accent-cyan/10 text-[#F08A00]">
                <span set:html={SVG.ShieldCheck} class="w-4 h-4 flex items-center justify-center" />
              </div>
              <h4 class="text-xs font-semibold text-support-white uppercase tracking-wider font-sans">PR Pathway Probability</h4>
            </div>

            <div class="space-y-3 pt-4">
              <div class="flex items-center gap-3">
                <div class="text-3xl font-extrabold font-display text-accent-blue">{country.prScore}%</div>
                <div class="text-[10px] font-semibold text-slate-800 bg-accent-blue/10 border border-accent-blue/20 px-2 py-0.5 rounded uppercase tracking-wider font-sans">PR INDEX</div>
              </div>
              <p class="text-[13px] text-support-gray leading-normal font-sans font-normal">
                {country.prRoute}
              </p>
            </div>
          </div>

          {/* Card 4: Job Market Index */}
          <div class="p-6 rounded-2xl border border-slate-200 bg-white shadow-sm flex flex-col justify-between">
            <div class="flex items-center gap-2">
              <div class="p-2 rounded-lg bg-accent-blue/10 text-accent-indigo">
                <span set:html={SVG.Briefcase} class="w-4 h-4 flex items-center justify-center" />
              </div>
              <h4 class="text-xs font-semibold text-support-white uppercase tracking-wider font-sans">High-Demand Employment</h4>
            </div>

            <div class="space-y-1.5 pt-4">
              {country.topSectors.map((sector) => (
                <div class="flex items-center gap-2 text-xs text-support-gray font-sans font-normal">
                  <span class="w-1.5 h-1.5 bg-accent-blue rounded-full shrink-0"></span>
                  <span class="truncate">{sector}</span>
                </div>
              ))}
            </div>
          </div>

        </div>

      </div>
    ))}
  </section>

  <!-- Client floating chatbot -->
  <AICounsellor client:only="react" />
</Layout>
