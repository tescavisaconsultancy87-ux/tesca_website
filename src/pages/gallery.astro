---
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
import { Camera, Building2, Users, GraduationCap } from "lucide-react";
---

<Layout 
  title="TESCA Gallery | Classroom Moments & Campus Success"
  description="Take a virtual tour of TESCA Visa Consultancy. Browse pictures of student career counseling, IELTS coaching, pre-departure orientations, and successful student placements."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 py-12">
    
    <!-- Premium Header Banner Card -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-8 items-center p-8 md:p-12 relative mb-16">
      
      {/* Subtle Background Auroras */}
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>

      {/* Left Column: Text Content */}
      <div class="md:col-span-7 space-y-6 text-left relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          Our Gallery
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Institute & Student Life
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          Take a virtual tour of our state-of-the-art facilities, classrooms, and vibrant student community.
        </p>
      </div>

      {/* Right Column: Hero Image cutout */}
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-center">
        <div class="relative w-full max-w-[320px] md:max-w-[400px] flex items-center aspect-[4/3] rounded-2xl overflow-hidden shadow-md border border-accent-blue/15">
          <img 
            src="/images/gallery_hero.png" 
            alt="Institute and student life gallery" 
            class="object-cover w-full h-full select-none"
          />
        </div>
      </div>

    </div>

    {/* Class Photos Section */}
    <div class="mb-20">
      <div class="flex items-center gap-3 mb-10">
        <div class="p-3 rounded-xl bg-blue-100 text-blue-600">
          <Users class="w-6 h-6" />
        </div>
        <div>
          <h2 class="text-[28px] sm:text-[32px] font-bold text-slate-800 font-display tracking-tight">Classroom Moments</h2>
          <p class="text-sm text-slate-500 font-sans font-normal">Training sessions, workshops & student interactions</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: "Personal Career Counselling", desc: "One-on-one guidance to help students choose the right country, university, and career pathway.", img: "/images/consultation_gallery.png" },
          { title: "Student Departure Support", desc: "Comprehensive assistance for travel planning, documentation checks, and departure readiness.", img: "/images/student_abroad_new.png" },
          { title: "Pre-Visa Preparation", desc: "Expert guidance on visa requirements, documentation, and interview preparation.", img: "/images/services_hero_gallery.png" },
          { title: "Academic Profile Evaluation", desc: "Detailed assessment of academic records and eligibility for study abroad opportunities.", img: "/images/consultation_new.png" },
          { title: "IELTS Practice & Assessment", desc: "Real exam-style mock tests designed to improve language proficiency and exam readiness.", img: "/images/testprep_hero_new.png" },
          { title: "University Admission Support", desc: "Professional assistance with university selection, applications, and admission processes.", img: "/images/university_support.png" },
          { title: "Visa Documentation Support", desc: "Step-by-step help with SOPs, financial documents, and visa application requirements.", img: "/images/visa_support.png" },
          { title: "Scholarship Guidance Services", desc: "Helping students identify and apply for scholarships to reduce study costs.", img: "/images/scholarship_new.png" },
          { title: "Study Abroad Workshops", desc: "Informative seminars covering admissions, visas, scholarships, and student life abroad.", img: "/images/workshop_new.png" },
          { title: "Career Planning Sessions", desc: "Personalized advice to align education choices with long-term career goals.", img: "/images/consultation.png" }
        ].map((item) => (
          <div class="rounded-2xl overflow-hidden border border-slate-200 bg-white shadow-sm hover:-translate-y-1 transition-all duration-300 group text-left">
            <div class="aspect-[4/3] relative overflow-hidden bg-slate-50">
              <img 
                src={item.img} 
                alt={item.title} 
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-550 select-none"
              />
              <div class="absolute inset-0 bg-accent-blue/0 group-hover:bg-accent-blue/5 transition-colors duration-300"></div>
            </div>
            <div class="p-5 border-t border-slate-100">
              <h3 class="text-base font-bold text-slate-800 font-display leading-snug">{item.title}</h3>
              <p class="text-xs text-slate-500 font-sans font-normal mt-1.5 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* Infrastructure Section */}
    <div class="mb-20">
      <div class="flex items-center gap-3 mb-10">
        <div class="p-3 rounded-xl bg-emerald-100 text-emerald-600">
          <GraduationCap class="w-6 h-6" />
        </div>
        <div>
          <h2 class="text-[28px] sm:text-[32px] font-bold text-slate-800 font-display tracking-tight">Global Placements & Campus Success</h2>
          <p class="text-sm text-slate-500 font-sans font-normal">Visa success milestones, pre-departure orientations & student network</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: "Successful Student Placements", desc: "Celebrating students who achieved admissions and visa approvals for their dream destinations.", img: "/images/graduating_students_new.png" },
          { title: "Global Education Opportunities", desc: "Exploring international study destinations and future career possibilities worldwide.", img: "/images/global_new.png" },
          { title: "Pre-Departure Orientation", desc: "Preparing students for life abroad through practical guidance and support sessions.", img: "/images/pre_new.png" },
          { title: "Admission Success Milestones", desc: "Supporting students from application submission to receiving university offer letters.", img: "/images/milestone_new.png" },
          { title: "International Student Network", desc: "Connecting aspiring students with alumni and current international students for guidance.", img: "/images/mock_new.png" },
          { title: "Application Review Support", desc: "Ensuring applications are complete, accurate, and ready for university submission.", img: "/images/support_new.png" },
          { title: "English Language Training", desc: "Expert coaching for IELTS, PTE, TOEFL, and Spoken English improvement.", img: "/images/training_new.png" },
          { title: "Visa Interview Coaching", desc: "Mock interviews and confidence-building sessions for successful visa outcomes.", img: "/images/coaching_new.png" },
          { title: "Student Success Community", desc: "A supportive environment where students share experiences and achievements.", img: "/images/community_new.png" },
          { title: "Global Study Pathways", desc: "Guiding students toward internationally recognized qualifications and career growth.", img: "/images/pathways_new.png" }
        ].map((item) => (
          <div class="rounded-2xl overflow-hidden border border-slate-200 bg-white shadow-sm hover:-translate-y-1 transition-all duration-300 group text-left">
            <div class="aspect-[16/10] relative overflow-hidden bg-slate-50">
              <img 
                src={item.img} 
                alt={item.title} 
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-550 select-none"
              />
              <div class="absolute inset-0 bg-accent-blue/0 group-hover:bg-accent-blue/5 transition-colors duration-300"></div>
            </div>
            <div class="p-5 border-t border-slate-100">
              <h3 class="text-base font-bold text-slate-800 font-display leading-snug">{item.title}</h3>
              <p class="text-xs text-slate-500 font-sans font-normal mt-1.5 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

  </section>

  <AICounsellor client:load />
</Layout>
