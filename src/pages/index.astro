        ))}
      </div>

    </div>
  </section>
  )}

  {/* ==================== SECTION 6: FAQS (LIGHT BACKGROUND) ==================== */}
  <section class="py-24 bg-slate-50/40 relative text-left font-sans">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      
      <div class="text-center mb-16 space-y-3">
        <span class="text-[14px] font-medium font-sans tracking-widest text-slate-800 bg-accent-blue/10 px-3 py-1 rounded-full border border-accent-blue/20 inline-block">
          FAQ
        </span>
        <h2 class="text-[28px] sm:text-[34px] lg:text-[38px] xl:text-[44px] font-extrabold font-display text-support-white leading-tight">
          Frequently Asked Questions?
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">
        
        {/* Left Column: Campus architecture photo */}
        <div class="lg:col-span-5 rounded-2xl border border-slate-200 overflow-hidden bg-white shadow-sm p-3">
          <img 
            src="/images/red_brick.png" 
            alt="Classic red brick university hall" 
            class="w-full h-full min-h-[300px] object-cover rounded-xl" 
          />
        </div>

        {/* Right Column: Accordions list (FAQ answers: Plus Jakarta Sans 400) */}
        <div class="lg:col-span-7 flex flex-col justify-center space-y-4 font-sans">
          {[
            { q: "What services does TESCA Visa Consultancy provide?", a: "We provide comprehensive end-to-end guidance including profile evaluation, university admissions assistance, SOP editing, student visa filing, financial proof audits, and pre-departure briefings." },
            { q: "Which global study destinations do you specialize in?", a: "We assist students in securing admissions and visas for major global destinations including the USA, UK, Canada, Australia, New Zealand, Ireland, Germany, Dubai, and key European countries." },
            { q: "How does TESCA help with the student visa application?", a: "Our certified consultants audit all financial and academic documents to ensure compliance with immigration policies, compile the visa files, and help schedule appointments for biometric registration." },
            { q: "Can you help me identify and apply for scholarships?", a: "Yes! During your initial profile evaluation, our team matches your academic records with eligible institutional waivers, grants, and regional study abroad scholarships to offset costs." },
            { q: "Is the initial consultation free?", a: "Absolutely. Your first profile evaluation and career counseling session are completely free. We then offer premium packages for IELTS coaching, SOP editing, and visa file auditing." }
          ].map((faq, idx) => {
            const tints = [
              "bg-gradient-to-br from-blue-50 to-sky-50/60 border-blue-100",
              "bg-gradient-to-br from-emerald-50 to-green-50/60 border-emerald-100",
              "bg-gradient-to-br from-amber-50 to-yellow-50/60 border-amber-100",
              "bg-gradient-to-br from-purple-50 to-pink-50/60 border-purple-100",
              "bg-gradient-to-br from-indigo-50 to-violet-50/60 border-indigo-100"
            ];
            return (
            <div key={idx} class={`p-4 rounded-xl border ${tints[idx]} space-y-2 shadow-xs`}>
              <button 
                class="w-full flex justify-between items-center text-[16px] font-bold text-slate-800 text-left outline-none font-display leading-snug cursor-pointer"
                onclick={`
                  const ans = document.getElementById('faq-ans-${idx}');
                  const isOpen = ans.classList.contains('grid-rows-[1fr]');
                  
                  document.querySelectorAll('[id^="faq-ans-"]').forEach(el => {
                    el.classList.remove('grid-rows-[1fr]');
                    el.classList.add('grid-rows-[0fr]');
                  });
                  document.querySelectorAll('[id^="faq-chevron-"]').forEach(el => el.classList.remove('rotate-180'));
                  
                  if (!isOpen) {
                    ans.classList.remove('grid-rows-[0fr]');
                    ans.classList.add('grid-rows-[1fr]');
                    document.getElementById('faq-chevron-${idx}')?.classList.add('rotate-180');
                  }
                `}
              >
                <span>{faq.q}</span>
                <ChevronDown id={`faq-chevron-${idx}`} class="w-4 h-4 text-slate-400 shrink-0 transition-transform duration-200" />
              </button>
              <div id={`faq-ans-${idx}`} class="grid grid-rows-[0fr] transition-all duration-300 ease-in-out overflow-hidden">
                <p class="min-h-0 text-[16px] text-slate-600 leading-relaxed pt-1 font-sans font-normal">
