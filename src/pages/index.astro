      </div>

    </div>
  </section>

  {/* ==================== SECTION 5: BULLETINS / ARTICLES (GREEN BACKGROUND) ==================== */}
  {visaUpdates.length > 0 && (
  <section class="py-24 bg-accent-blue text-white relative text-left font-sans">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      
      {/* Blog Title: General Sans 700, Headings 48-64px */}
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
        <div class="space-y-3">
