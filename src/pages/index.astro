            quote: "Their team helped me prepare every document perfectly. I received my visa without any complications.",
            user: "Vidhi Gujrati"
          }
        ].map((t, idx) => {
          const tints = [
            "bg-gradient-to-br from-purple-50 to-pink-50/60 border-purple-100",
            "bg-gradient-to-br from-cyan-50 to-blue-50/60 border-cyan-100"
          ];
          return (
          <div key={idx} class={`p-6 rounded-2xl border ${tints[idx]} flex flex-col justify-between space-y-4 shadow-sm`}>
            <div class="space-y-3">
