      </div>

      {/* Row list of bulletins: Blog Title: General Sans 700 */}
      <div class="border-t border-white/10 font-sans">
        {visaUpdates.map((item, idx) => (
          <div class="py-5 border-b border-white/10 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:bg-white/5 transition-colors px-4 rounded-lg">
