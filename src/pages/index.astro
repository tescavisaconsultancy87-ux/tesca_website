              <a href={item.link} class="text-[16px] lg:text-[18px] font-bold font-display hover:text-accent-cyan transition-colors text-left no-underline text-white truncate min-w-0">
                {item.title}
              </a>
            </div>
            <a href={item.link} class="p-1.5 rounded-full bg-white/10 hover:bg-white/20 text-white shrink-0 self-end sm:self-auto">
              <ArrowRight class="w-4 h-4" />
