---
import { env } from "cloudflare:workers";
import Layout from "../layouts/Layout.astro";
import CountrySelector from "../components/CountrySelector";
import StudentCarousel from "../components/StudentCarousel";
import FintechCalculators from "../components/FintechCalculators";
import AICounsellor from "../components/AICounsellor";
import { 
  Landmark, Calendar, ShieldCheck, Compass, Briefcase, GraduationCap, 
  CheckCircle, ArrowUpRight, ArrowRight, ChevronDown 
} from "lucide-react";

let stories = [];
let visaUpdates = [];
const db = env?.tesca_db || env?.DB;

try {
  if (db) {
    const { results } = await db.prepare("SELECT * FROM success_stories ORDER BY id ASC").all();
    stories = results.map(s => ({
      ...s,
      timeline: JSON.parse(s.timeline)
    })) || [];
  }
} catch (err) {
  console.error("Failed to fetch success stories from D1:", err);
}

try {
  if (db) {
    const { results } = await db.prepare("SELECT * FROM visa_updates ORDER BY id DESC").all();
    visaUpdates = results.map(u => ({
      ...u,
      tagBg: u.tag_bg
    })) || [];
  }
} catch (err) {
  console.error("Failed to fetch visa updates from D1:", err);
}


---

<Layout 
