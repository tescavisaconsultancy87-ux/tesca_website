---
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Info: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
  HelpCircle: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>`,
  ShieldAlert: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>`
};
---

<Layout 
  title="Privacy Policy | TESCA Study Abroad Consultancy"
  description="Understand how TESCA collects, uses, protects, and handles your personal information, cookies, and data retention policies."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-12 text-left">
    
    <!-- Go Back Link -->
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <!-- Premium Header Banner -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          Legal Operations
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Privacy Policy
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed">
          At TESCA, we value your trust. This Privacy Policy details how we process your personal data in compliance with international privacy acts.
        </p>
      </div>
    </div>

    <!-- Editorial Layout Policy Content -->
    <div class="space-y-10 max-w-4xl font-sans text-slate-700 leading-relaxed text-sm md:text-base">
      
      <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 flex gap-4 items-start mb-6">
        <span set:html={SVG.Info} class="w-5 h-5 text-accent-blue shrink-0 mt-0.5 flex items-center justify-center" />
        <p class="text-xs text-support-gray leading-relaxed">
          <strong>Last Updated: June 11, 2026.</strong> This privacy statement describes data collection parameters for the website and consultation channels operated by TESCA Verified Student Advisory systems.
        </p>
      </div>

      <div class="space-y-3">
        <h2 class="text-xl md:text-2xl font-bold font-display text-slate-800 flex items-center gap-2">
          <span set:html={SVG.HelpCircle} class="w-5 h-5 text-accent-blue flex items-center justify-center" /> 1. Data Collected Through Our Inquiry Systems
        </h2>
        <p>
          We collect personal data when you voluntarily submit inquiry forms, subscribe to our newsletters, or utilize our speaking simulators. This details:
        </p>
        <ul class="list-disc pl-6 space-y-2 text-sm text-slate-600">
          <li><strong>Personal details</strong>: Name, email address, and verified 10-digit mobile number.</li>
          <li><strong>Academic information</strong>: GPA scores, IELTS bands, exam history, and current degrees.</li>
          <li><strong>Destination preferences</strong>: Preferred target countries, courses, and tuition cost sliders.</li>
        </ul>
      </div>

      <div class="space-y-3">
        <h2 class="text-xl md:text-2xl font-bold font-display text-slate-800 flex items-center gap-2">
          <span set:html={SVG.ShieldAlert} class="w-5 h-5 text-accent-blue flex items-center justify-center" /> 2. Third-Party Sharing Protocols
        </h2>
        <p>
          TESCA does NOT sell or trade your data with external advertisers. Data sharing is limited exclusively to:
        </p>
        <ul class="list-disc pl-6 space-y-2 text-sm text-slate-600">
          <li><strong>University Partners</strong>: Exclusively to verify matching admission criteria and pre-screen applicants.</li>
          <li><strong>Banking Partners</strong>: Only for pre-approved loan evaluations or Blocked Account setups authorized directly by you.</li>
          <li><strong>Consulates & Embassies</strong>: For submitting formal visa files through secure governmental portals.</li>
        </ul>
      </div>

      <div class="space-y-3">
        <h2 class="text-xl md:text-2xl font-bold font-display text-slate-800 flex items-center gap-2">
          <span set:html={SVG.Info} class="w-5 h-5 text-accent-blue flex items-center justify-center" /> 3. Cookie Policy & Web Analytics
        </h2>
        <p>
          Our web portal uses essential session cookies to retain calculations, slider states, and destination preferences during your visit. We also employ web tracking models to inspect page performance speed and optimize image load states. You can control cookies through browser configurations at any time.
        </p>
      </div>

      <div class="space-y-3 border-t border-slate-100 pt-8">
        <h2 class="text-xl md:text-2xl font-bold font-display text-slate-800">4. Your Data Rights</h2>
        <p>
          Under global regulations (GDPR, CCPA), you hold full rights to request access to your stored files, request corrections of your information, or request a complete wipe of your document portfolios from our active servers. Contact our compliance desk at <strong>privacy@tesca.com</strong> for assistance.
        </p>
      </div>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
