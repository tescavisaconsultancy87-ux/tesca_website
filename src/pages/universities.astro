---
import { env } from "cloudflare:workers";
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
import UniversityFilter from "../components/UniversityFilter";
import { GraduationCap } from "lucide-react";

let universities = [];
try {
  const db = env?.tesca_db || env?.DB;
  if (db) {
    const { results } = await db.prepare("SELECT * FROM universities ORDER BY name ASC").all();
    universities = results || [];
  } else {
    console.error("D1 database binding not found in env.");
  }
} catch (err) {
  console.error("Failed to fetch universities from D1:", err);
}
---

<Layout
  title="Explore Top Universities | TESCA Study Destinations"
  description="Browse and filter top-ranked universities across USA, UK, Canada, Australia, Germany, and more. Find your perfect study destination with TESCA."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12">
    <!-- Header Banner -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-gradient-to-br from-slate-50 to-blue-50/30 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-8 items-center p-6 sm:p-8 md:p-12 relative mb-10 sm:mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      <div class="md:col-span-7 space-y-6 relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          WORLD-CLASS UNIVERSITIES
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
         Find the University That Fits Your Future
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
Explore leading universities, compare programs, and discover the right academic pathway to achieve your global career goals.        </p>
      </div>
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-center">
        <div class="relative w-full max-w-[320px] md:max-w-[400px] flex items-center aspect-[4/3] rounded-2xl overflow-hidden shadow-md border border-accent-blue/15">
          <img 
            src="/images/universities_hero.png" 
            alt="Explore Universities" 
            class="object-cover w-full h-full select-none"
          />
        </div>
      </div>
    </div>

    <!-- Country Filter + University Grid (client-side) -->
    <UniversityFilter client:load universities={universities} />
  </section>

  <AICounsellor client:load />
</Layout>
