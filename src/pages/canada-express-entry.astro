---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-600"><polyline points="20 6 9 17 4 12"/></svg>`
};
---

<Layout 
  title="Canada Express Entry & CRS Score Calculator Guide | TESCA"
  description="Master Canada's Express Entry. Point scoring systems, CRS calculation factors, category-based draws, and positive provincial PNP boosts."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left font-sans">
    
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          Canada Immigration
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Canada Express Entry Guide
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          The ultimate guide to Express Entry. Learn how to optimize your Comprehensive Ranking System (CRS) score, target category-based draws, and leverage provincial nominations.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      
      <div class="lg:col-span-2 space-y-12">
        
        <!-- Highlights -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">CRS Scoring</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Understand point distributions for age, qualifications, work history, and foreign language skills.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Category-Based Selection</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Targeting specific job-class draws (STEM, Healthcare, Trades) that require lower overall CRS cutoffs.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">PNP Integration</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Filing in provincial portals (e.g. OINP, SINP) to unlock a 600-point boost that guarantees an ITA.</p>
          </div>
        </div>

        <!-- Requirements -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Express Entry Core Pillars</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              "Federal Skilled Worker (FSW) qualification requirements",
              "Canadian Experience Class (CEC) - for those with Canadian work history",
              "Educational Credential Assessment (ECA) to prove degree value",
              "Language Benchmark (CLB) requirements - IELTS or CELPIP",
              "NOC / TEER classification system check",
              "Proof of Funds validation criteria"
            ].map(doc => (
              <div class="flex items-center gap-3 p-4 rounded-xl border border-slate-100 bg-white shadow-sm">
                <div class="p-1 rounded-full bg-emerald-50 text-emerald-600">
                  <span set:html={SVG.Check} />
                </div>
                <span class="text-xs font-semibold text-slate-700">{doc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Application Steps -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold font-display text-slate-850 tracking-tight">Filing Checklist Timeline</h2>
          <div class="relative pl-6 border-l-2 border-slate-200 space-y-8">
            {[
              "Calculate your estimated points and assess NOC classifications",
              "Fulfill ECA evaluations and clear language testing with CLB 9+ target",
              "Submit Express Entry profile into the IRCC federal pool",
              "Leverage provincial nominee streams to boost CRS by 600 points",
              "Receive Invitation to Apply (ITA) and submit full PR documentation e-APR"
            ].map((step, idx) => (
              <div class="relative">
                <div class="absolute -left-[31px] top-0 w-4 h-4 rounded-full bg-accent-blue border-4 border-white shadow-sm"></div>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Step {idx + 1}</span>
                <p class="text-sm font-semibold text-slate-700 mt-1">{step}</p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="space-y-6 sticky top-28 font-sans">
        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-1">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Want to check your CRS Score?</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-normal">
              Simulate your Comprehensive Ranking System (CRS) score for Canada PR. Max score: <strong>1,200 points</strong>.
            </p>
          </div>

          <form id="crs-form" class="space-y-4 text-xs text-slate-700">
            <!-- Age Bracket -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Age Bracket</label>
              <select id="crs-age" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="110" selected>20 to 29 years (+110 pts)</option>
                <option value="95">30 years (+95 pts)</option>
                <option value="75">31 to 35 years (+75 pts)</option>
                <option value="50">36 to 39 years (+50 pts)</option>
                <option value="15">40 to 44 years (+15 pts)</option>
                <option value="0">45 years and over (+0 pts)</option>
              </select>
            </div>

            <!-- Education Level -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Education Level</label>
              <select id="crs-education" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="150">Doctorate / PhD (+150 pts)</option>
                <option value="135" selected>Master's or Professional Degree (+135 pts)</option>
                <option value="128">Two or more Post-Secondary Credentials (+128 pts)</option>
                <option value="120">Bachelor's Degree (3+ years) (+120 pts)</option>
                <option value="90">Post-Secondary Diploma (1-2 years) (+90 pts)</option>
                <option value="30">Secondary School / High school (+30 pts)</option>
              </select>
            </div>

            <!-- Language Proficiency -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Language Level (IELTS CLB)</label>
              <select id="crs-language" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="136" selected>CLB 9+ (IELTS Listening 8.0, others 7.0+) (+136 pts)</option>
                <option value="120">CLB 8 (IELTS Listening 7.5, others 6.5) (+120 pts)</option>
                <option value="68">CLB 7 (IELTS 6.0 in all bands) (+68 pts)</option>
                <option value="0">CLB 6 or lower / No Test (+0 pts)</option>
              </select>
            </div>

            <!-- Skilled Experience -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Foreign Work Experience</label>
              <select id="crs-experience" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="50" selected>3 or more years (+50 pts)</option>
                <option value="25">1 to 2 years (+25 pts)</option>
                <option value="0">None (+0 pts)</option>
              </select>
            </div>

            <!-- Provincial Nomination -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Provincial Nomination (PNP)</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="crs-pnp" value="600" class="w-3.5 h-3.5 text-accent-blue" />
                  <span>Yes (+600 pts)</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="crs-pnp" value="0" checked class="w-3.5 h-3.5 text-accent-blue" />
                  <span>No (+0 pts)</span>
                </label>
              </div>
            </div>

            <!-- Result Box -->
            <div class="p-4 rounded-xl bg-slate-50 border border-slate-150/80 flex items-center justify-between">
              <div>
                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest block">Estimated CRS Score</span>
                <span id="crs-score-display" class="text-2xl font-extrabold font-display text-accent-blue">431</span>
              </div>
              <div class="text-right">
                <span id="crs-status-display" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-amber-100 border border-amber-200 text-amber-800">
                  Target PNP
                </span>
              </div>
            </div>

            <button 
              type="button" 
              onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
              class="w-full py-2.5 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-xs rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer tracking-wide block"
            >
              Calculate CRS & Consult
            </button>
          </form>
        </div>
      </div>

      <!-- Script for Canada CRS Calculator -->
      <script is:inline>
        function calculateCrsScore() {
          const age = Number(document.getElementById('crs-age').value) || 0;
          const education = Number(document.getElementById('crs-education').value) || 0;
          const language = Number(document.getElementById('crs-language').value) || 0;
          const experience = Number(document.getElementById('crs-experience').value) || 0;
          
          const pnpRadio = document.querySelector('input[name="crs-pnp"]:checked');
          const pnp = pnpRadio ? Number(pnpRadio.value) : 0;

          const total = age + education + language + experience + pnp;

          const scoreEl = document.getElementById('crs-score-display');
          const statusEl = document.getElementById('crs-status-display');

          if (scoreEl) scoreEl.textContent = total;

          if (statusEl) {
            if (total >= 1000) {
              statusEl.textContent = "Guaranteed ITA";
              statusEl.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-100 border border-emerald-200 text-emerald-800";
            } else if (total >= 480) {
              statusEl.textContent = "High Draw Chance";
              statusEl.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-100 border border-emerald-200 text-emerald-800";
            } else if (total >= 430) {
              statusEl.textContent = "Target PNP Stream";
              statusEl.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-amber-100 border border-amber-200 text-amber-800";
            } else {
              statusEl.textContent = "Optimize Profile";
              statusEl.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-red-100 border border-red-200 text-red-800";
            }
          }
        }

        function initCrsCalculator() {
          const form = document.getElementById('crs-form');
          if (form) {
            form.addEventListener('change', calculateCrsScore);
            calculateCrsScore();
          }
        }

        document.addEventListener('DOMContentLoaded', initCrsCalculator);
        document.addEventListener('astro:page-load', initCrsCalculator);
      </script>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
