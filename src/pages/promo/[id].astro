---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { getSupabaseAdmin } from "../../utils/supabase";

const { id } = Astro.params;
const supabase = getSupabaseAdmin();

const { data: popup, error } = await supabase
  .from('popup_settings')
  .select('*')
  .eq('id', id)
  .single();

if (error || !popup) {
  return Astro.redirect("/");
}

const reqFields = Array.isArray(popup.required_fields) ? popup.required_fields : ["name", "phone"];
const isNameReq = reqFields.includes("name");
const isPhoneReq = reqFields.includes("phone");
const isEmailReq = reqFields.includes("email");
---

<Layout
  title={`${popup.title} | TESCA`}
  description={popup.subtitle || "Register to receive details."}
>
  <main class="min-h-screen bg-slate-50 py-12 md:py-20 px-4 flex items-center justify-center">
    <div class="w-full max-w-5xl bg-white rounded-[2rem] shadow-xl overflow-hidden border border-slate-100 flex flex-col md:flex-row min-h-[500px]">
      
      <!-- Left side: Flyer Image -->
      <div class="w-full md:w-1/2 relative bg-slate-900 overflow-hidden flex items-center justify-center min-h-[300px] md:min-h-auto">
        <img src={popup.image_url} alt="" class="absolute inset-0 w-full h-full object-cover blur-xl opacity-40 scale-110 pointer-events-none select-none" />
        <img src={popup.image_url} alt={popup.title} class="absolute inset-0 m-auto max-w-full max-h-full object-contain p-4 md:p-8 pointer-events-none select-none" />
      </div>

      <!-- Right side: Lead capture form -->
      <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-center bg-white relative">
        
        <div id="form-container" class="space-y-6">
          <div>
            <span class="inline-block text-[9px] font-extrabold uppercase tracking-widest text-indigo-600 bg-indigo-50 border border-indigo-100 px-2.5 py-0.5 rounded-full mb-3">Featured Update</span>
            <h1 class="text-xl md:text-2xl font-extrabold tracking-tight text-slate-800 leading-tight">
              {popup.title}
            </h1>
            {popup.subtitle && (
              <p class="text-slate-500 text-xs mt-3 leading-relaxed font-sans font-normal">
                {popup.subtitle}
              </p>
            )}
          </div>

          <form id="promo-landing-lead-form" class="space-y-4 text-xs font-semibold text-slate-600" autocomplete="off">
            <input type="hidden" name="popupId" value={popup.id} />
            <input type="hidden" name="popupTitle" value={popup.title} />

            <div class="space-y-1.5">
              <label for="name" class="text-[10px] text-slate-500 uppercase tracking-wide">
                Full Name {isNameReq ? "*" : "(Optional)"}
              </label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required={isNameReq}
                class="w-full px-3.5 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-850 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans font-normal" 
                placeholder="e.g. John Doe" 
              />
            </div>

            <div class="space-y-1.5">
              <label for="phone" class="text-[10px] text-slate-500 uppercase tracking-wide">
                Mobile Number {isPhoneReq ? "*" : "(Optional)"}
              </label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                required={isPhoneReq}
                class="w-full px-3.5 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-855 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans font-normal" 
                placeholder="e.g. +91 99999 99999" 
              />
            </div>

            <div class="space-y-1.5">
              <label for="email" class="text-[10px] text-slate-500 uppercase tracking-wide">
                Email Address {isEmailReq ? "*" : "(Optional)"}
              </label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required={isEmailReq}
                class="w-full px-3.5 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-860 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans font-normal" 
                placeholder="e.g. johndoe@gmail.com" 
              />
            </div>

            <div class="pt-3">
              <button 
                type="submit" 
                id="submit-btn" 
                class="w-full py-3.5 bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-700 hover:to-violet-700 text-white font-bold text-xs rounded-xl shadow-lg cursor-pointer hover:scale-[1.01] transition-all flex items-center justify-center gap-2"
              >
                Submit Registration
              </button>
            </div>
          </form>
        </div>

        <!-- Success State Container -->
        <div id="success-container" class="hidden absolute inset-0 bg-white p-8 md:p-12 flex flex-col items-center justify-center text-center">
          <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mb-5 border border-emerald-100">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <h2 class="text-lg md:text-xl font-extrabold text-slate-800">Registration Successful!</h2>
          <p class="text-slate-500 text-xs mt-2.5 leading-relaxed max-w-sm font-sans font-normal">
            Thank you for registering. Our student coordinator will contact you shortly to review your profile.
          </p>
          <a 
            href="/" 
            class="mt-6 px-6 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-xs rounded-xl transition-all"
          >
            Go Back to Homepage
          </a>
        </div>

      </div>

    </div>
  </main>
</Layout>

<script>
  function setupPromoForm() {
    const form = document.getElementById("promo-landing-lead-form") as HTMLFormElement;
    const formContainer = document.getElementById("form-container");
    const successContainer = document.getElementById("success-container");
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const originalBtnContent = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>Submitting...</span>
      `;

      const formData = new FormData(form);
      const payload = {
        name: formData.get("name")?.toString() || null,
        phone: formData.get("phone")?.toString() || null,
        email: formData.get("email")?.toString() || null,
        popupId: formData.get("popupId")?.toString(),
        popupTitle: formData.get("popupTitle")?.toString()
      };

      try {
        const res = await fetch("/api/popup-lead", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || "Submission failed. Please try again.");
        }

        // Show success state
        if (formContainer && successContainer) {
          formContainer.classList.add("hidden");
          successContainer.classList.remove("hidden");
        }

      } catch (err: any) {
        alert(err.message || "An error occurred. Please try again.");
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnContent;
      }
    });
  }

  document.addEventListener("astro:page-load", setupPromoForm);
  setupPromoForm();
</script>
