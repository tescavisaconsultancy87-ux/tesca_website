---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import AICounsellor from "../../components/AICounsellor";

export async function getStaticPaths() {
  return [
    { params: { country: 'canada' } },
    { params: { country: 'uk' } },
    { params: { country: 'australia' } },
    { params: { country: 'germany' } },
    { params: { country: 'usa' } },
    { params: { country: 'new-zealand' } },
    { params: { country: 'ireland' } },
    { params: { country: 'europe' } },
    { params: { country: 'singapore' } },
    { params: { country: 'dubai' } },
    { params: { country: 'malaysia' } },
    { params: { country: 'switzerland' } },
  ];
}

const { country } = Astro.params;

interface CountryContent {
  name: string;
  title: string;
  description: string;
  heroTitle: string;
  flag: string;
  intro: string;
  tuitionFees: string;
  livingCosts: string;
  intakes: { name: string; detail: string }[];
  timeline: string[];
  requirements: { name: string; value: string }[];
  faqs: { q: string; a: string }[];
}

const countryData: Record<string, CountryContent> = {
