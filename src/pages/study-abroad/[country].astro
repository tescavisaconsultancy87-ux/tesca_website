const data = countryData[country || "canada"];

// FAQ Schema JSON-LD
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": data.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-600"><polyline points="20 6 9 17 4 12"/></svg>`
};
---

<Layout 
  title={data.title}
  description={data.description}
>
  <!-- Inject Structured Schema for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left">
    
    <!-- Go Back Link -->
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <!-- Hero Section Banner -->
    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-flex items-center gap-2 text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          <img
            src={`https://flagcdn.com/w20/${data.flag}.png`}
            alt={`${data.name} Flag`}
            class="w-4.5 h-3 rounded-sm object-cover"
          />
          Study Abroad
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          {data.heroTitle}
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          {data.intro} Get end-to-end guidance from university shortlisting to visa success with our senior counsellors.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start mb-16">
      
      <!-- Left Column: Core Guide details (2 cols width) -->
      <div class="lg:col-span-2 space-y-12">
        
        <!-- Costs Table -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Tuition Fees & Cost of Living</h2>
          <div class="overflow-hidden border border-slate-200 rounded-2xl shadow-sm">
            <table class="min-w-full divide-y divide-slate-200 font-sans text-sm">
              <thead class="bg-slate-50">
                <tr>
                  <th scope="col" class="px-6 py-3.5 text-left font-bold text-slate-700">Expense Category</th>
                  <th scope="col" class="px-6 py-3.5 text-left font-bold text-slate-700">Estimated Average Costs</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-slate-200 text-slate-600">
                <tr>
                  <td class="px-6 py-4 font-semibold text-slate-800">Average Tuition Fees</td>
                  <td class="px-6 py-4">{data.tuitionFees}</td>
                </tr>
                <tr>
                  <td class="px-6 py-4 font-semibold text-slate-800">Estimated Cost of Living</td>
                  <td class="px-6 py-4">{data.livingCosts}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Academic & Entry requirements -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Academic & Language Requirements</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {data.requirements.map(req => (
              <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/60 shadow-sm space-y-2">
                <span class="text-[10px] font-bold text-accent-blue uppercase tracking-wider block font-sans">{req.name}</span>
                <p class="text-sm font-semibold text-slate-800 font-sans leading-snug">{req.value}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Student Intakes -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Academic Intakes & Deadlines</h2>
          <div class="space-y-3">
            {data.intakes.map(intake => (
              <div class="flex items-start gap-3 p-4 rounded-xl border border-slate-100 bg-white shadow-sm font-sans">
                <div class="p-1 rounded-full bg-emerald-50 text-emerald-600 mt-0.5">
                  <span set:html={SVG.Check} />
                </div>
                <div>
                  <h4 class="font-bold text-slate-800 text-sm">{intake.name}</h4>
                  <p class="text-xs text-slate-500 mt-0.5">{intake.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Step-by-Step Visa Timeline -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Student Visa Step-by-Step Timeline</h2>
          <div class="relative pl-6 border-l-2 border-slate-200 space-y-8 font-sans">
            {data.timeline.map((step, idx) => (
              <div class="relative">
                <div class="absolute -left-[31px] top-0 w-4 h-4 rounded-full bg-accent-blue border-4 border-white shadow-sm flex items-center justify-center"></div>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Step {idx + 1}</span>
                <p class="text-sm font-semibold text-slate-700 mt-1 leading-relaxed">{step}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- FAQ Section -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {data.faqs.map(faq => (
              <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/60 shadow-sm font-sans">
                <h4 class="font-bold text-slate-800 text-sm flex items-start gap-2 leading-relaxed">
                  <span class="text-accent-blue font-extrabold font-display">Q:</span>
                  <span>{faq.q}</span>
                </h4>
                <p class="text-xs text-slate-500 mt-2 leading-relaxed pl-5 flex items-start gap-2">
                  <span class="text-emerald-600 font-extrabold font-display">A:</span>
                  <span>{faq.a}</span>
                </p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Right Column: Interactive Consultation Card (1 col width) -->
      <div class="space-y-6 sticky top-28">
        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Consult with our Experts</h3>
            <p class="text-xs text-slate-500 font-sans leading-relaxed">
              Book a session with a senior counselor to audit your qualifications and prepare your application plan.
            </p>
          </div>
          
          <button 
            type="button" 
            onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
            class="w-full py-3 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer font-sans tracking-wide block"
          >
            Book Free Counselling Session
          </button>
        </div>
      </div>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
