---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { supabase } from "../../utils/supabase";

// Inline SVG helpers — no lucide-react in .astro (SSR hook errors)
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Users: _s('<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>'),
  GraduationCap: _s('<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>'),
  MessageSquare: _s('<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>'),
  AlertCircle: _s('<circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>'),
  FileText: _s('<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>'),
  ArrowRight: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`,
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

let totalLeads = 0;
let totalPartners = 0;
let totalUniversities = 0;
let totalStories = 0;
let totalAnnouncements = 0;
let totalUpdates = 0;
let totalGalleryImages = 0;
let totalSocialCauses = 0;
let totalBlogPosts = 0;

try {
  const { count: leadsCount } = await supabase.from('leads').select('*', { count: 'exact', head: true }).neq('lead_type', 'partner');
  totalLeads = leadsCount || 0;

  const { count: partnersCount } = await supabase.from('leads').select('*', { count: 'exact', head: true }).eq('lead_type', 'partner');
  totalPartners = partnersCount || 0;

  const { count: uniCount } = await supabase.from('universities').select('*', { count: 'exact', head: true });
  totalUniversities = uniCount || 0;

  const { count: storiesCount } = await supabase.from('success_stories').select('*', { count: 'exact', head: true });
  totalStories = storiesCount || 0;

  const { count: annCount } = await supabase.from('announcements').select('*', { count: 'exact', head: true });
  totalAnnouncements = annCount || 0;

  const { count: updatesCount } = await supabase.from('visa_updates').select('*', { count: 'exact', head: true });
  totalUpdates = updatesCount || 0;

  // Query gallery images count (catch errors if table not created yet)
  const { count: galleryCount } = await supabase.from('gallery_images').select('*', { count: 'exact', head: true });
  totalGalleryImages = galleryCount || 0;

  // Query social causes count
  const { count: socialCount } = await supabase.from('social_causes').select('*', { count: 'exact', head: true });
  totalSocialCauses = socialCount || 0;

  // Query blog posts count
  const { count: blogCount } = await supabase.from('blog_posts').select('*', { count: 'exact', head: true });
  totalBlogPosts = blogCount || 0;
} catch (err) {
  console.error("Dashboard overview query failed:", err);
}

const cards = [
  {
    id: "leads",
    title: "Student Leads",
    desc: "View and manage submissions from assessment forms & counselor requests.",
    count: totalLeads,
    color: "from-blue-50 to-indigo-50 hover:border-indigo-300",
    iconSvg: SVG.Users,
    iconColor: "text-indigo-600 bg-indigo-50",
    href: "/admin/leads"
  },
  {
    id: "partners",
    title: "Partnerships",
    desc: "View and manage B2B partnership applications and franchise inquiries.",
    count: totalPartners,
    color: "from-blue-50 to-cyan-50 hover:border-cyan-300",
    iconSvg: _s('<rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>'),
    iconColor: "text-cyan-600 bg-cyan-50",
    href: "/admin/partners"
  },
  {
    id: "universities",
    title: "Universities Database",
    desc: "Add new universities and adjust scores/tuition criteria for matching.",
    count: totalUniversities,
    color: "from-emerald-50 to-teal-50 hover:border-teal-300",
    iconSvg: SVG.GraduationCap,
    iconColor: "text-teal-600 bg-teal-50",
    href: "/admin/universities"
  },
  {
    id: "stories",
    title: "Success Stories",
    desc: "Manage testimonials, student admissions, and flags shown on main page.",
    count: totalStories,
    color: "from-amber-50 to-orange-50 hover:border-orange-300",
    iconSvg: SVG.MessageSquare,
    iconColor: "text-orange-600 bg-orange-50",
    href: "/admin/success-stories"
  },
  {
    id: "gallery",
    title: "Gallery Manager",
    desc: "Upload and organize student activity photos and institute events.",
    count: totalGalleryImages,
    color: "from-sky-50 to-blue-50 hover:border-blue-300",
    iconSvg: _s('<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>'),
    iconColor: "text-blue-600 bg-blue-50",
    href: "/admin/gallery"
  },
  {
    id: "our-social",
    title: "Our Social",
    desc: "Manage YouTube, Instagram, and Facebook posts featured on the home page.",
    count: totalSocialCauses,
    color: "from-pink-50 to-rose-50 hover:border-rose-300",
    iconSvg: _s('<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>'),
    iconColor: "text-rose-600 bg-rose-50",
    href: "/admin/our-social"
  },
  {
    id: "announcements",
    title: "Alert Banner",
    desc: "Add or delete global alert text rotating at the very top of your site.",
    count: totalAnnouncements,
    color: "from-purple-50 to-fuchsia-50 hover:border-fuchsia-300",
    iconSvg: SVG.AlertCircle,
    iconColor: "text-fuchsia-600 bg-fuchsia-50",
    href: "/admin/announcements"
  },
  {
    id: "updates",
    title: "Visa Bulletins",
    desc: "Publish study abroad news and link them directly to blogs.",
    count: totalUpdates,
    color: "from-rose-50 to-red-50 hover:border-red-300",
    iconSvg: SVG.FileText,
    iconColor: "text-red-600 bg-red-50",
    href: "/admin/visa-updates"
  },
  {
    id: "blogs",
    title: "Blog Posts",
    desc: "Create and manage blog articles displayed on the public resource center.",
    count: totalBlogPosts,
    color: "from-violet-50 to-purple-50 hover:border-purple-300",
    iconSvg: _s('<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>'),
    iconColor: "text-purple-600 bg-purple-50",
    href: "/admin/blogs"
  }
];
---

<Layout 
  title="Admin Console Dashboard | TESCA"
  description="Secure access configuration for TESCA web portals."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="dashboard" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Overview Control Panel
        </h1>
        <p class="text-slate-500 text-xs mt-1">Quick summary statistics and page management portals.</p>
      </div>

      {/* Grid of Control Cards */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {cards.map((card) => (
          <a 
            href={card.href}
            class={`group block p-6 rounded-3xl border border-slate-200 bg-gradient-to-br ${card.color} shadow-sm transition-all duration-300 hover:scale-[1.01]`}
          >
            <div class="flex items-start justify-between mb-4">
              <div class={`w-10 h-10 rounded-xl flex items-center justify-center ${card.iconColor}`}>
                <span set:html={card.iconSvg} />
              </div>
              <div class="text-2xl font-extrabold font-mono text-slate-700 group-hover:text-indigo-600 transition-colors">
                {card.count}
              </div>
            </div>
            
            <h2 class="text-lg font-bold font-display text-slate-800 group-hover:text-indigo-600 transition-colors">
              {card.title}
            </h2>
            <p class="text-xs text-slate-500 mt-1.5 leading-relaxed">
              {card.desc}
            </p>

            <div class="mt-6 flex items-center gap-1.5 text-xs font-bold text-slate-500 group-hover:text-indigo-600 transition-colors">
              Open Portal <span set:html={SVG.ArrowRight} class="transition-transform group-hover:translate-x-1" />
            </div>
          </a>
        ))}
      </div>
    </main>
  </div>
</Layout>
