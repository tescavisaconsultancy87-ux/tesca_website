---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { supabase } from "../../utils/supabase";


// Inline SVG helpers — no lucide-react in .astro
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Trash2: _s('<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>'),
  Plus: _s('<path d="M12 5v14"/><path d="M5 12h14"/>'),
  ShieldAlert: _s('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>'),
  User: _s('<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'),
  Key: _s('<path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 1.5 1.5M15.5 7.5 14 6"/>'),
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

// Get logged-in admin email
let currentAdminEmail = "";
const accessToken = Astro.cookies.get("sb-access-token")?.value;
if (accessToken) {
  const { data: { user } } = await supabase.auth.getUser(accessToken);
  if (user) {
    currentAdminEmail = user.email || "";
  }
}

let adminsList = [];
let successMessage = "";
let errorMessage = "";

// Handle Actions (Add/Remove Admin)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "add-admin") {
      const email = formData.get("email")?.toString().trim();
      const password = formData.get("password")?.toString().trim();

      if (email && password) {
        // 1. Try to register user in Supabase Auth first
        const { data: authData, error: authError } = await supabase.auth.signUp({
          email,
          password,
        });

        if (authError) {
          throw new Error(`Supabase Auth registration failed: ${authError.message}`);
        }

        // 2. Add email to the public.admins table
        const { error: dbError } = await supabase
          .from('admins')
          .insert({ email });

        if (dbError) {
          throw dbError;
        }

        successMessage = `Admin user '${email}' created and allowlisted successfully.`;
      } else {
        errorMessage = "Please enter both email and password.";
      }
    } else if (action === "delete-admin") {
      const emailToDelete = formData.get("email")?.toString().trim();

      if (emailToDelete) {
        if (emailToDelete === currentAdminEmail) {
          throw new Error("You cannot revoke your own administrator access while logged in.");
        }

        // Remove from public.admins table
        const { error: dbError } = await supabase
          .from('admins')
          .delete()
          .eq('email', emailToDelete);

        if (dbError) {
          throw dbError;
        }

        successMessage = `Revoked administrative privileges for '${emailToDelete}'.`;
      }
    }
  } catch (err: any) {
    console.error("Action error on manage-admins page:", err);
    errorMessage = err.message || "An unexpected error occurred.";
  }
}

// Fetch allowlisted admins
try {
  const { data, error } = await supabase
    .from('admins')
    .select('*')
    .order('created_at', { ascending: true });

  if (error) {
    throw error;
  }
  adminsList = data || [];
} catch (err: any) {
  console.error("Failed to query admins table:", err);
  errorMessage = "Failed to load allowlisted admin records.";
}
---

<Layout 
  title="Manage System Administrators | TESCA Admin"
  description="Grant and revoke administrator privileges for systems management."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="admins" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Header title */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Manage System Admins
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure credentials and grant secure allowlist access for other administrative users.</p>
      </div>

      {/* Warnings & Messages */}

      {errorMessage && (
        <div class="admin-alert-banner p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <span set:html={SVG.ShieldAlert} class="shrink-0 text-rose-500" />
          <span>{errorMessage}</span>
        </div>
      )}

      {successMessage && (
        <div class="admin-alert-banner p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        {/* Form: Add Admin */}
        <div class="lg:col-span-5 bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
          <h2 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2">
            <span set:html={SVG.Plus} class="text-[#0A7880]" /> Add New Admin
          </h2>
          
          <form method="POST" class="space-y-4 text-xs font-semibold text-slate-600">
            <input type="hidden" name="action" value="add-admin" />
            
            <div class="space-y-1.5">
              <label for="admin-email" class="text-[10px] text-slate-500 uppercase tracking-wide">Email Address *</label>
              <input 
                type="email" 
                id="admin-email" 
                name="email" 
                required 
                disabled={false}
                class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-[#0A7880] disabled:opacity-50" 
                placeholder="e.g. admin@tescavisaconsultancy.com" 
              />
            </div>

            <div class="space-y-1.5">
              <label for="admin-password" class="text-[10px] text-slate-500 uppercase tracking-wide">Login Password *</label>
              <input 
                type="password" 
                id="admin-password" 
                name="password" 
                required 
                disabled={false}
                minlength="6"
                class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-[#0A7880] disabled:opacity-50" 
                placeholder="Minimum 6 characters" 
              />
            </div>

            <button 
              type="submit" 
              disabled={false}
              class="w-full py-3 bg-[#0A7880] hover:bg-[#075E64] text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-2 disabled:opacity-50 disabled:scale-100 disabled:cursor-not-allowed"
            >
              Register & Allowlist Admin
            </button>
          </form>
        </div>

        {/* List: Authorized Admins */}
        <div class="lg:col-span-7 space-y-4">
          <h2 class="text-base font-bold text-slate-800">
            Authorized Allowlist ({adminsList.length})
          </h2>

          {adminsList.length === 0 ? (
            <div class="bg-white border border-slate-200 rounded-3xl p-10 text-center">
              <p class="text-xs text-slate-500">No registered admins found in database.</p>
            </div>
          ) : (
            <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm max-h-[70vh] overflow-y-auto">
              <div class="overflow-x-auto w-full">
                <table class="w-full min-w-[500px] text-left border-collapse text-xs">
                  <thead>
                    <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                      <th class="px-6 py-4">Administrator Email</th>
                      <th class="px-6 py-4 w-[180px]">Status</th>
                      <th class="px-6 py-4 text-right w-[100px]">Actions</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100 font-sans text-xs">
                    {adminsList.map((admin) => {
                      const isSelf = admin.email === currentAdminEmail;
                      return (
                        <tr class="hover:bg-slate-50 transition-colors">
                          <td class="px-6 py-4 font-semibold text-slate-700">{admin.email}</td>
                          <td class="px-6 py-4">
                            {isSelf ? (
                              <span class="text-[9px] bg-[#0A7880]/15 text-[#0A7880] font-extrabold uppercase tracking-wider px-2 py-0.5 rounded border border-[#0A7880]/15">
                                Current Active User
                              </span>
                            ) : (
                              <span class="text-[9px] bg-slate-100 text-slate-600 font-extrabold uppercase tracking-wider px-2 py-0.5 rounded border border-slate-200">
                                Authorized
                              </span>
                            )}
                          </td>
                          <td class="px-6 py-4 text-right">
                            {!isSelf && (
                              <form method="POST" class="inline delete-admin-form">
                                <input type="hidden" name="action" value="delete-admin" />
                                <input type="hidden" name="email" value={admin.email} />
                                <button
                                  type="submit"
                                  class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                                  aria-label="Revoke admin access"
                                >
                                  <span set:html={SVG.Trash2} />
                                </button>
                              </form>
                            )}
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          )}
        </div>

      </div>

    </main>
  </div>
</Layout>

<script>
  function setupAdminManagement() {
    const deleteForms = document.querySelectorAll(".delete-admin-form");
    deleteForms.forEach(form => {
      if ((form as any)._ajaxBound) return;
      (form as any)._ajaxBound = true;

      form.addEventListener("submit", (e) => {
        const email = (form as HTMLFormElement).querySelector('input[name="email"]')?.getAttribute("value") || "";
        if (!confirm(`Are you sure you want to revoke administrative access for '${email}'? This user will no longer be able to log in.`)) {
          e.preventDefault();
        }
      });
    });
  }

  setupAdminManagement();
  document.addEventListener("astro:page-load", setupAdminManagement);
</script>
