---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { supabase } from "../../utils/supabase";
// Inline SVG helpers — no lucide-react in .astro (SSR hook errors)
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Trash2: _s('<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>'),
  Plus: _s('<path d="M12 5v14"/><path d="M5 12h14"/>'),
  ShieldAlert: _s('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>'),
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

let announcements = [];
let successMessage = "";
let errorMessage = "";

// Handle server actions (Add / Delete)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-announcement") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const { error } = await supabase
        .from('announcements')
        .delete()
        .eq('id', id);

      if (error) throw error;
      successMessage = "Announcement alert text deleted successfully.";
    } else if (action === "add-announcement") {
      const text = formData.get("text")?.toString().trim();
      if (text) {
        const { error } = await supabase
          .from('announcements')
          .insert({ text });

        if (error) throw error;
        successMessage = "New announcement alert bar message posted.";
      } else {
        errorMessage = "Announcement text cannot be empty.";
      }
    }
  } catch (err: any) {
    console.error("Action error on announcements page:", err);
    errorMessage = `Action failed: ${err.message || "Unknown error"}`;
  }
}

// Fetch announcements
try {
  const { data, error } = await supabase
    .from('announcements')
    .select('*')
    .order('id', { ascending: false });

  if (error) throw error;
  announcements = data || [];
} catch (err) {
  console.error("Failed to load announcements:", err);
  errorMessage = "Failed to load database records.";
}
---

<Layout 
  title="Manage Announcement Bar Alerts | TESCA Admin"
  description="Administrative portal to configure announcement banner alert strings."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="announcements" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Announcement Alert Bar
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure alerts rotating dynamically in the header strip at the top of the website.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="admin-alert-banner p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <span set:html={SVG.ShieldAlert} />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="admin-alert-banner p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        {/* Form panel (5 cols) */}
        <div class="lg:col-span-5 bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
          <h2 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2">
            <span set:html={SVG.Plus} /> Post New Announcement
          </h2>
          
          <form method="POST" autocomplete="off" class="space-y-4 text-xs font-semibold text-slate-600">
            <input type="hidden" name="action" value="add-announcement" />
            
            <div class="space-y-1.5">
              <label for="announcement-text" class="text-[10px] text-slate-500 uppercase tracking-wide">Announcement Alert Message *</label>
              <textarea 
                id="announcement-text" 
                name="text" 
                required 
                rows="4" 
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500 text-xs leading-relaxed" 
                placeholder="e.g. September 2026 priority intakes are now open — only 10 consultation slots remaining this week!"
              ></textarea>
            </div>

            <button type="submit" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-2">
              Publish Announcement
            </button>
          </form>
        </div>

        {/* List panel (7 cols) */}
        <div class="lg:col-span-7 space-y-4">
          <h2 class="text-base font-bold text-slate-800">
            Active Rotations ({announcements.length})
          </h2>

          {announcements.length === 0 ? (
            <div class="bg-white border border-slate-200 rounded-3xl p-10 text-center">
              <p class="text-xs text-slate-500">No announcements found in database. The website will display fallback defaults.</p>
            </div>
          ) : (
            <div class="space-y-3">
              {announcements.map((a) => (
                <div class="flex items-center justify-between gap-4 p-4 rounded-2xl border border-slate-200 bg-white shadow-sm">
                  <p class="text-xs text-slate-700 font-sans font-semibold leading-relaxed">{a.text}</p>
                  <form method="POST" class="shrink-0 delete-announcement-form">
                    <input type="hidden" name="action" value="delete-announcement" />
                    <input type="hidden" name="id" value={a.id} />
                    <button
                      type="submit"
                      class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                      aria-label="Delete announcement"
                    >
                      <span set:html={SVG.Trash2} />
                    </button>
                  </form>
                </div>
              ))}
            </div>
          )}
        </div>

      </div>

    </main>
  </div>
</Layout>

<script>
  async function handleResponse(res: Response, successMsg: string) {
    if (res.ok) {
      const htmlText = await res.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(htmlText, "text/html");
      const errorBanner = doc.querySelector(".bg-rose-50");
      if (errorBanner) {
        alert("Error: " + errorBanner.textContent.trim());
        return false;
      }
      sessionStorage.setItem("admin_alert", JSON.stringify({
        type: "success",
        message: successMsg
      }));
      window.location.href = window.location.href;
      return true;
    }
    alert("Request failed. Please try again.");
    return false;
  }

  function setupAnnouncements() {
    // Handle the add form
    const addForm = document.querySelector('form:not(.delete-announcement-form)') as HTMLFormElement;
    if (addForm && !(addForm as any)._ajaxBound) {
      (addForm as any)._ajaxBound = true;
      addForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const submitBtn = addForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        (window as any).showBtnLoader?.(submitBtn, "Saving...");

        const formData = new FormData(addForm);
        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            body: formData
          });
          addForm.reset();
          await handleResponse(res, "New announcement alert bar message posted.");
        } catch (err) {
          console.error("AJAX error:", err);
          alert("An error occurred. Please try again.");
        } finally {
          if (submitBtn) {
            (window as any).hideBtnLoader?.(submitBtn);
          }
        }
      });
    }

    // Handle delete forms
    const deleteForms = document.querySelectorAll("form.delete-announcement-form");
    deleteForms.forEach(form => {
      if ((form as any)._ajaxBound) return;
      (form as any)._ajaxBound = true;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const confirmed = await (window as any).showConfirmDialog({
          title: "Are you absolutely sure?",
          description: "This action cannot be undone. This will permanently delete this announcement and remove it from the home page.",
          actionText: "Delete",
          cancelText: "Cancel",
          variant: "destructive",
          from: "bottom"
        });
        if (!confirmed) return;

        const btn = form.querySelector('button[type="submit"]') as HTMLElement;
        (window as any).showBtnLoader?.(btn);

        const params = new URLSearchParams();
        form.querySelectorAll("input[name]").forEach((el) => {
          const input = el as HTMLInputElement;
          params.append(input.name, input.value);
        });

        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: params
          });
          await handleResponse(res, "Announcement alert text deleted successfully.");
        } catch (err) {
          console.error("AJAX error:", err);
          alert("An error occurred. Please try again.");
        } finally {
          if (btn) {
            (window as any).hideBtnLoader?.(btn);
          }
        }
      });
    });
  }

  setupAnnouncements();
  document.addEventListener("astro:page-load", setupAnnouncements);
</script>
