---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { getSupabase } from "../../utils/supabase";
// Inline SVG helpers — no lucide-react in .astro (SSR hook errors)
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Trash2: _s('<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>'),
  ShieldAlert: _s('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>'),
  Plus: _s('<path d="M12 5v14"/><path d="M5 12h14"/>'),
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

let stories = [];
let successMessage = "";
let errorMessage = "";

// Helper to upload file to Supabase Storage
const uploadImageToSupabase = async (photoFile: File): Promise<string> => {
  const sb = getSupabase();
  const ext = (photoFile.name.split('.').pop() || 'jpg').toLowerCase();
  const key = `stories/${crypto.randomUUID()}.${ext}`;
  const buffer = await photoFile.arrayBuffer();

  const { error } = await sb.storage
    .from('tesca-assets')
    .upload(key, buffer, {
      contentType: photoFile.type,
      upsert: false,
    });

  if (error) throw new Error(`Storage upload failed: ${error.message}`);

  const { data } = sb.storage.from('tesca-assets').getPublicUrl(key);
  return data.publicUrl;
};

// Handle server actions (Add / Update / Delete)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-story") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const { error } = await getSupabase()
        .from('success_stories')
        .delete()
        .eq('id', id);

      if (error) throw error;
      successMessage = "Success story profile deleted successfully.";
    } else if (action === "add-story") {
      const name = formData.get("name")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;
      const type = formData.get("type")?.toString().trim();
      const score = formData.get("score")?.toString().trim() || null;
      const country = formData.get("country")?.toString().trim() || null;

      let photo = "";
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 1024 * 1024) {
          errorMessage = "Image size must be less than 1MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, JPG, and PNG images are allowed.";
        } else {
          photo = await uploadImageToSupabase(photoFile);
        }
      } else {
        errorMessage = "Student photo is required.";
      }

      if (!errorMessage && name && photo && type) {
        const { error } = await getSupabase()
          .from('success_stories')
          .insert({
            name,
            photo,
            type,
            score,
            country
          });

        if (error) throw error;
        successMessage = `Successfully added success story for ${name}.`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields (Name, Photo, and Type).";
      }
    } else if (action === "update-story") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const name = formData.get("name")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;
      const photoExisting = formData.get("photo_existing")?.toString().trim() || "";
      const type = formData.get("type")?.toString().trim();
      const score = formData.get("score")?.toString().trim() || null;
      const country = formData.get("country")?.toString().trim() || null;

      let photo = photoExisting;
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 1024 * 1024) {
          errorMessage = "Image size must be less than 1MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, JPG, and PNG images are allowed.";
        } else {
          photo = await uploadImageToSupabase(photoFile);
        }
      }

      if (!errorMessage && id && name && photo && type) {
        const { error } = await getSupabase()
          .from('success_stories')
          .update({
            name,
            photo,
            type,
            score,
            country
          })
          .eq('id', id);

        if (error) throw error;
        successMessage = `Successfully updated ${name}.`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields.";
      }
    }
  } catch (err: any) {
    console.error("Action error on success-stories page:", err);
    errorMessage = `Action failed: ${err.message || "Unknown error"}`;
  }
}

// Fetch success stories
try {
  const { data, error } = await getSupabase()
    .from('success_stories')
    .select('*')
    .order('id', { ascending: false });

  if (error) throw error;
  stories = data || [];
} catch (err) {
  console.error("Failed to load success stories:", err);
  errorMessage = "Failed to load database records.";
}
---

<Layout 
  title="Manage Success Stories | TESCA Admin"
  description="Administrative portal to manage success stories on the home page."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="stories" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Manage Success Stories
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure student success stories that are featured in the landing carousel.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <span set:html={SVG.ShieldAlert} class="w-4 h-4 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      {/* Add New Button */}
      <button id="show-add-form-btn" class="mb-6 flex items-center gap-2 px-5 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs rounded-xl transition-all cursor-pointer shadow-sm">
        <span set:html={SVG.Plus} /> Add New Success Story
      </button>

      {/* Add/Edit Form Panel */}
      <div id="story-form-panel" class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm mb-8 hidden">
        <h2 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2" id="story-form-heading">
          <span set:html={SVG.Plus} class="text-indigo-600" /> Add Success Story
        </h2>
        <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-semibold text-slate-600">
          <input type="hidden" name="action" id="story-form-action" value="add-story" />
          <input type="hidden" name="id" id="story-edit-id" value="" />
          
          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Student Name *</label>
            <input type="text" name="name" id="s-name" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Aarav Patel" />
          </div>
          
          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide" id="photo-label">Upload Photo *</label>
            <input type="file" name="photo_file" id="s-photo-file" accept=".jpg,.jpeg,.png" class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans text-xs" />
            <input type="hidden" name="photo_existing" id="s-photo-existing" />
            <div id="photo-preview-container" class="mt-2 hidden">
              <span class="text-[9px] text-slate-400 block mb-1">Current / Selected Image:</span>
              <img id="photo-preview" src="" class="w-12 h-12 rounded-full object-cover border border-slate-200" />
            </div>
            <span class="text-[9px] text-slate-400 block mt-1 font-normal">Max size: 1MB. Allowed types: JPG, JPEG, PNG.</span>
          </div>

          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Category *</label>
            <select id="s-category" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500">
              <option value="Visa">Visa</option>
              <option value="English Test">English Test</option>
            </select>
          </div>

          <input type="hidden" name="type" id="s-type" value="Visa Success" />

          <div class="space-y-1.5 hidden" id="test-type-container">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Test Type *</label>
            <select id="s-test-type" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500">
              <option value="IELTS">IELTS</option>
              <option value="PTE">PTE</option>
            </select>
          </div>

          <div class="space-y-1.5 hidden" id="score-container">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Overall Score *</label>
            <input type="text" name="score" id="s-score" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. 8.0 or 79" />
          </div>

          <div class="space-y-1.5 hidden" id="country-container">
            <label for="s-country" class="text-[10px] text-slate-500 uppercase tracking-wide">Visa Country *</label>
            <select 
              name="country" 
              id="s-country" 
              class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 text-xs font-sans font-semibold cursor-pointer"
            >
              <option value="">Select Country</option>
              <option value="USA">USA</option>
              <option value="United Kingdom">United Kingdom</option>
              <option value="Canada">Canada</option>
              <option value="Australia">Australia</option>
              <option value="Germany">Germany</option>
              <option value="New Zealand">New Zealand</option>
              <option value="Ireland">Ireland</option>
              <option value="Singapore">Singapore</option>
              <option value="Switzerland">Switzerland</option>
              <option value="Malaysia">Malaysia</option>
              <option value="Dubai">Dubai</option>
              <option value="Europe">Europe</option>
            </select>
          </div>

          <div class="md:col-span-2 flex gap-3 mt-2">
            <button type="submit" id="story-submit-btn" class="flex-1 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01]">
              Add Story
            </button>
            <button type="button" id="cancel-story-edit" class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-xl transition-all cursor-pointer border border-slate-200">
              Cancel
            </button>
          </div>
        </form>
      </div>

      {/* List Stories */}
      {stories.length === 0 ? (
        <div class="bg-white border border-slate-200 rounded-3xl p-12 text-center">
          <p class="text-sm text-slate-500">No success stories found in the database.</p>
        </div>
      ) : (
        <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
          <div class="overflow-x-auto w-full">
            <table class="w-full min-w-[750px] text-left border-collapse text-xs">
              <thead>
                <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                  <th class="px-6 py-4 w-[100px]">Photo</th>
                  <th class="px-6 py-4 w-[200px]">Student Name</th>
                  <th class="px-6 py-4 w-[150px]">Type</th>
                  <th class="px-6 py-4 w-[180px]">Details</th>
                  <th class="px-6 py-4 text-right w-[120px]">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 font-sans text-xs">
                {stories.map((s) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4">
                      <img src={s.photo} alt={s.name} class="w-10 h-10 rounded-full object-cover border border-slate-200" />
                    </td>
                    <td class="px-6 py-4 font-bold text-slate-800 whitespace-nowrap">{s.name}</td>
                    <td class="px-6 py-4 text-slate-600 whitespace-nowrap">{s.type}</td>
                    <td class="px-6 py-4 text-slate-600 whitespace-nowrap">
                      {s.type === "Visa Success" ? `Visa: ${s.country || "N/A"}` : `Score: ${s.score || "N/A"}`}
                    </td>
                    <td class="px-6 py-4 text-right whitespace-nowrap">
                      <div class="flex items-center justify-end gap-1">
                        <button
                          type="button"
                          class="edit-story-btn p-2 text-indigo-500 hover:bg-indigo-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-indigo-200"
                          data-id={s.id}
                          data-name={s.name}
                          data-photo={s.photo}
                          data-type={s.type}
                          data-score={s.score || ""}
                          data-country={s.country || ""}
                          aria-label={`Edit ${s.name}`}
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                        </button>
                        <form method="POST" class="inline delete-story-form">
                          <input type="hidden" name="action" value="delete-story" />
                          <input type="hidden" name="id" value={s.id} />
                          <button 
                            type="submit" 
                            class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                            aria-label={`Delete ${s.name}`}
                          >
                            <span set:html={SVG.Trash2} />
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

    </main>
  </div>
</Layout>

<script>
  import { openCropModal } from "../../scripts/image-cropper";

  function showAddForm() {
    const panel = document.getElementById("story-form-panel");
    if (panel) {
      cancelStoryForm();
      panel.classList.remove("hidden");
      document.getElementById("show-add-form-btn")?.classList.add("hidden");
      
      const formAction = document.getElementById("story-form-action") as HTMLInputElement;
      if (formAction) formAction.value = "add-story";
      
      const formHeading = document.getElementById("story-form-heading");
      if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M12 5v14"/><path d="M5 12h14"/></svg> Add Success Story';
      
      const submitBtn = document.getElementById("story-submit-btn");
      if (submitBtn) submitBtn.textContent = "Add Story";

      const photoLabel = document.getElementById("photo-label");
      if (photoLabel) photoLabel.textContent = "Upload Photo *";
      
      const fileInput = document.getElementById("s-photo-file") as HTMLInputElement;
      if (fileInput) fileInput.setAttribute("required", "required");

      panel.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function setupStoryEdit() {
    // Buttons setup - use clean binding checks to avoid cloning
    const addBtn = document.getElementById("show-add-form-btn");
    if (addBtn && !(addBtn as any)._bound) {
      (addBtn as any)._bound = true;
      addBtn.addEventListener("click", showAddForm);
    }

    const cancelBtn = document.getElementById("cancel-story-edit");
    if (cancelBtn && !(cancelBtn as any)._bound) {
      (cancelBtn as any)._bound = true;
      cancelBtn.addEventListener("click", cancelStoryForm);
    }

    // Category Select Listener
    const categorySelect = document.getElementById("s-category") as HTMLSelectElement;
    if (categorySelect && !(categorySelect as any)._bound) {
      (categorySelect as any)._bound = true;
      categorySelect.addEventListener("change", toggleFields);
    }

    // Test Type Listener
    const testTypeSelect = document.getElementById("s-test-type") as HTMLSelectElement;
    if (testTypeSelect && !(testTypeSelect as any)._bound) {
      (testTypeSelect as any)._bound = true;
      testTypeSelect.addEventListener("change", () => {
        const typeInput = document.getElementById("s-type") as HTMLInputElement;
        if (typeInput) typeInput.value = testTypeSelect.value;
      });
    }

    // Form submit AJAX
    const form = document.querySelector("#story-form-panel form") as HTMLFormElement;
    if (form && !(form as any)._ajaxBound) {
      (form as any)._ajaxBound = true;
      form.addEventListener("submit", async (e) => {
        const categoryVal = (document.getElementById("s-category") as HTMLSelectElement).value;
        if (categoryVal === "Visa") {
          const countryVal = (document.getElementById("s-country") as HTMLSelectElement).value;
          if (!countryVal) {
            alert("Please select a visa country.");
            e.preventDefault();
            return;
          }
        }

        e.preventDefault();
        const submitBtn = document.getElementById("story-submit-btn") as HTMLButtonElement;
        (window as any).showBtnLoader?.(submitBtn, "Saving...");

        const formData = new FormData(form);
        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            body: formData
          });
          if (res.ok) {
            const htmlText = await res.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(htmlText, "text/html");

            const oldMain = document.querySelector("main");
            const newMain = doc.querySelector("main");
            if (oldMain && newMain) {
              oldMain.innerHTML = newMain.innerHTML;
            }

            cancelStoryForm();
            setupStoryEdit();
          }
        } catch (err) {
          console.error("Failed to submit story:", err);
          alert("An error occurred while saving the story.");
        } finally {
          if (submitBtn) {
            (window as any).hideBtnLoader?.(submitBtn);
          }
        }
      });
    }

    // Client-side file validation + crop modal
    const fileInput = document.getElementById("s-photo-file") as HTMLInputElement;
    if (fileInput && !(fileInput as any)._bound) {
      (fileInput as any)._bound = true;
      fileInput.addEventListener("change", async () => {
        const file = fileInput.files?.[0];
        if (!file) return;

        if (file.size > 1024 * 1024) {
          alert("Warning: Image size must be less than 1MB. Please compress or select another photo.");
          fileInput.value = "";
          return;
        }
        if (!["image/jpeg", "image/png", "image/jpg"].includes(file.type)) {
          alert("Warning: Only JPEG, JPG, and PNG images are allowed.");
          fileInput.value = "";
          return;
        }

        try {
          const croppedBlob = await openCropModal({ aspectRatio: 1, file });
          const croppedFile = new File([croppedBlob], file.name.replace(/\.[^.]+$/, ".jpg"), { type: "image/jpeg" });
          const dt = new DataTransfer();
          dt.items.add(croppedFile);
          fileInput.files = dt.files;

          const reader = new FileReader();
          reader.onload = (e) => {
            const previewContainer = document.getElementById("photo-preview-container");
            const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
            if (previewContainer && previewImg && e.target?.result) {
              previewContainer.classList.remove("hidden");
              previewImg.src = e.target.result as string;
            }
          };
          reader.readAsDataURL(croppedFile);
        } catch {
          fileInput.value = "";
        }
      });
    }

    // Edit buttons handler
    const editBtns = document.querySelectorAll(".edit-story-btn");
    editBtns.forEach(btn => {
      if ((btn as any)._bound) return;
      (btn as any)._bound = true;
      btn.addEventListener("click", () => {
        const panel = document.getElementById("story-form-panel");
        if (panel) {
          panel.classList.remove("hidden");
          document.getElementById("show-add-form-btn")?.classList.add("hidden");

          const formAction = document.getElementById("story-form-action") as HTMLInputElement;
          if (formAction) formAction.value = "update-story";
          
          const formHeading = document.getElementById("story-form-heading");
          if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg> Edit Success Story';
          
          const submitBtn = document.getElementById("story-submit-btn");
          if (submitBtn) submitBtn.textContent = "Update Story";

          const photoLabel = document.getElementById("photo-label");
          if (photoLabel) photoLabel.textContent = "Upload New Photo (Optional)";

          const fileInput = document.getElementById("s-photo-file") as HTMLInputElement;
          if (fileInput) fileInput.removeAttribute("required");

          const ds = (btn as HTMLElement).dataset;
          const editIdInput = document.getElementById("story-edit-id") as HTMLInputElement;
          if (editIdInput) editIdInput.value = ds.id || "";
          
          const nameInput = document.getElementById("s-name") as HTMLInputElement;
          if (nameInput) nameInput.value = ds.name || "";
          
          const photoExistingInput = document.getElementById("s-photo-existing") as HTMLInputElement;
          if (photoExistingInput) photoExistingInput.value = ds.photo || "";

          const previewContainer = document.getElementById("photo-preview-container");
          const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
          if (previewContainer && previewImg && ds.photo) {
            previewContainer.classList.remove("hidden");
            previewImg.src = ds.photo;
          }
          
          const typeVal = ds.type || "Visa Success";
          const scoreInput = document.getElementById("s-score") as HTMLInputElement;
          const countryVal = ds.country || "";
          const typeInput = document.getElementById("s-type") as HTMLInputElement;
          const categorySelect = document.getElementById("s-category") as HTMLSelectElement;
          const testTypeSelect = document.getElementById("s-test-type") as HTMLSelectElement;
          const countrySelect = document.getElementById("s-country") as HTMLSelectElement;

          if (typeInput) typeInput.value = typeVal;

          if (typeVal === "Visa Success") {
            if (categorySelect) categorySelect.value = "Visa";
            if (countrySelect) countrySelect.value = countryVal;
            if (scoreInput) scoreInput.value = "";
          } else {
            if (categorySelect) categorySelect.value = "English Test";
            if (testTypeSelect) testTypeSelect.value = typeVal;
            if (scoreInput) scoreInput.value = ds.score || "";
            if (countrySelect) countrySelect.value = "";
          }

          toggleFields();
          panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });

    // Intercept delete forms
    const deleteForms = document.querySelectorAll("form.delete-story-form");
    deleteForms.forEach(df => {
      if ((df as any)._ajaxBound) return;
      (df as any)._ajaxBound = true;
      df.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!confirm("Are you sure you want to remove this success story?")) return;

        const btn = df.querySelector('button[type="submit"]') as HTMLElement;
        (window as any).showBtnLoader?.(btn);
        
        const formData = new FormData(df);
        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            body: formData
          });
          if (res.ok) {
            const htmlText = await res.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(htmlText, "text/html");

            const oldMain = document.querySelector("main");
            const newMain = doc.querySelector("main");
            if (oldMain && newMain) {
              oldMain.innerHTML = newMain.innerHTML;
            }
            setupStoryEdit();
          }
        } catch (err) {
          console.error("Failed to delete story:", err);
        }
      });
    });
  }

  function toggleFields() {
    const categorySelect = document.getElementById("s-category") as HTMLSelectElement;
    const testTypeSelect = document.getElementById("s-test-type") as HTMLSelectElement;
    const testTypeContainer = document.getElementById("test-type-container");
    const scoreContainer = document.getElementById("score-container");
    const countryContainer = document.getElementById("country-container");
    
    const scoreInput = document.getElementById("s-score") as HTMLInputElement;
    const typeInput = document.getElementById("s-type") as HTMLInputElement;

    if (categorySelect && scoreContainer && countryContainer && testTypeContainer) {
      if (categorySelect.value === "Visa") {
        testTypeContainer.classList.add("hidden");
        scoreContainer.classList.add("hidden");
        if (scoreInput) scoreInput.removeAttribute("required");
        
        countryContainer.classList.remove("hidden");
        if (typeInput) typeInput.value = "Visa Success";
      } else {
        testTypeContainer.classList.remove("hidden");
        scoreContainer.classList.remove("hidden");
        if (scoreInput) scoreInput.setAttribute("required", "required");
        
        countryContainer.classList.add("hidden");
        if (typeInput && testTypeSelect) typeInput.value = testTypeSelect.value;
      }
    }
  }

  function cancelStoryForm() {
    document.getElementById("story-form-panel")?.classList.add("hidden");
    document.getElementById("show-add-form-btn")?.classList.remove("hidden");
    
    const editId = document.getElementById("story-edit-id") as HTMLInputElement;
    if (editId) editId.value = "";
    
    const actionInput = document.getElementById("story-form-action") as HTMLInputElement;
    if (actionInput) actionInput.value = "add-story";

    const previewContainer = document.getElementById("photo-preview-container");
    if (previewContainer) previewContainer.classList.add("hidden");
    const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
    if (previewImg) previewImg.src = "";

    const photoExistingInput = document.getElementById("s-photo-existing") as HTMLInputElement;
    if (photoExistingInput) photoExistingInput.value = "";

    const countrySelect = document.getElementById("s-country") as HTMLSelectElement;
    if (countrySelect) countrySelect.value = "";

    const form = document.querySelector("#story-form-panel form");
    if (form) {
      form.querySelectorAll("input, select").forEach(el => {
        const input = el as HTMLInputElement;
        if (input.type !== "hidden" && input.id !== "s-category" && input.id !== "s-test-type") {
          input.value = "";
        }
      });
      const categorySelect = document.getElementById("s-category") as HTMLSelectElement;
      if (categorySelect) categorySelect.value = "Visa";
      const testTypeSelect = document.getElementById("s-test-type") as HTMLSelectElement;
      if (testTypeSelect) testTypeSelect.value = "IELTS";
      const typeInput = document.getElementById("s-type") as HTMLInputElement;
      if (typeInput) typeInput.value = "Visa Success";
      toggleFields();
    }
  }

  setupStoryEdit();
  document.addEventListener("astro:page-load", setupStoryEdit);
</script>
