---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { env } from "cloudflare:workers";
import { Trash2, Plus, Landmark, ShieldAlert } from "lucide-react";

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

const db = env?.tesca_db || env?.DB;

let universities = [];
let successMessage = "";
let errorMessage = "";

// Handle server actions (Add / Update / Delete)
if (Astro.request.method === "POST" && db) {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-university") {
      const id = formData.get("id");
      await db.prepare("DELETE FROM universities WHERE id = ?").bind(id).run();
      successMessage = "University deleted successfully.";
    } else if (action === "add-university") {
      const name = formData.get("name")?.toString().trim();
      const country = formData.get("country")?.toString().trim();
      const code = formData.get("code")?.toString().trim();
      const tuitionFees = formData.get("tuition_fees")?.toString().trim();
      const intake = formData.get("intake")?.toString().trim();
      const ieltsPteReq = formData.get("ielts_pte_req")?.toString().trim() || null;
      const moiAccepted = formData.get("moi_accepted")?.toString().trim();
      const minCgpaPercent = formData.get("min_cgpa_percent")?.toString().trim();
      const courses = formData.get("courses")?.toString().trim();

      if (name && country && code && tuitionFees && intake && moiAccepted && minCgpaPercent && courses) {
        await db.prepare(
          `INSERT INTO universities 
          (name, country, code, tuition_fees, intake, ielts_pte_req, moi_accepted, min_cgpa_percent, courses) 
          VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)`
        ).bind(
          name, country, code, tuitionFees, intake, ieltsPteReq, moiAccepted, minCgpaPercent, courses
        ).run();

        successMessage = `Successfully added ${name} to database.`;
      } else {
        errorMessage = "Please fill in all required fields (Name, Country, Tuition Fees, Intake, MOI Accepted, Min CGPA/Percentage, Courses).";
      }
    } else if (action === "update-university") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const name = formData.get("name")?.toString().trim();
      const country = formData.get("country")?.toString().trim();
      const code = formData.get("code")?.toString().trim();
      const tuitionFees = formData.get("tuition_fees")?.toString().trim();
      const intake = formData.get("intake")?.toString().trim();
      const ieltsPteReq = formData.get("ielts_pte_req")?.toString().trim() || null;
      const moiAccepted = formData.get("moi_accepted")?.toString().trim();
      const minCgpaPercent = formData.get("min_cgpa_percent")?.toString().trim();
      const courses = formData.get("courses")?.toString().trim();

      if (id && name && country && code && tuitionFees && intake && moiAccepted && minCgpaPercent && courses) {
        await db.prepare(
          `UPDATE universities SET name=?, country=?, code=?, tuition_fees=?, intake=?, ielts_pte_req=?, moi_accepted=?, min_cgpa_percent=?, courses=? WHERE id=?`
        ).bind(
          name, country, code, tuitionFees, intake, ieltsPteReq, moiAccepted, minCgpaPercent, courses, id
        ).run();

        successMessage = `Successfully updated ${name}.`;
      } else {
        errorMessage = "Please fill in all required fields.";
      }
    }
  } catch (err: any) {
    console.error("Action error on universities page:", err);
    errorMessage = `Action failed: ${err.message || "Unknown error"}`;
  }
}

// Fetch universities
if (db) {
  try {
    const res = await db.prepare("SELECT * FROM universities ORDER BY name ASC").all();
    universities = res.results || [];
  } catch (err) {
    console.error("Failed to load universities:", err);
    errorMessage = "Failed to load database records.";
  }
}
---

<Layout 
  title="Manage Universities Database | TESCA Admin"
  description="Administrative portal to configure university options and admission criteria."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex">
    <AdminHeader activeTab="universities" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Universities Settings
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure intake options, fees, and requirements for target universities.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <ShieldAlert class="w-4 h-4 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        {/* Form panel (5 cols) */}
        <div class="lg:col-span-5 bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
          <h2 id="form-heading" class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2">
            <Plus class="w-4 h-4 text-indigo-600" /> Add New University
          </h2>
          
          <form method="POST" class="space-y-4 text-xs font-semibold text-slate-600">
            <input type="hidden" id="form-action" name="action" value="add-university" />
            <input type="hidden" id="edit-id" name="id" value="" />
            
            <div class="space-y-1.5">
              <label for="uni-name" class="text-[10px] text-slate-500 uppercase tracking-wide">University Name *</label>
              <input type="text" id="uni-name" name="name" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Coventry University" />
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="space-y-1.5">
                <label for="uni-country" class="text-[10px] text-slate-500 uppercase tracking-wide">Country *</label>
                <select id="uni-country" name="country" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                  <option value="">Select Country</option>
                  <option value="USA">USA</option>
                  <option value="United Kingdom">United Kingdom</option>
                  <option value="Canada">Canada</option>
                  <option value="Australia">Australia</option>
                  <option value="Germany">Germany</option>
                  <option value="New Zealand">New Zealand</option>
                  <option value="Ireland">Ireland</option>
                  <option value="Singapore">Singapore</option>
                  <option value="Switzerland">Switzerland</option>
                  <option value="Malaysia">Malaysia</option>
                  <option value="Dubai">Dubai</option>
                  <option value="Europe">Europe</option>
                </select>
              </div>
              <div class="space-y-1.5">
                <label for="uni-code-display" class="text-[10px] text-slate-500 uppercase tracking-wide">Auto-assigned Code</label>
                <input type="text" id="uni-code-display" disabled class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-100 text-slate-500 focus:outline-none cursor-not-allowed" placeholder="e.g. uk, ca" />
                <input type="hidden" id="uni-code" name="code" required />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="space-y-1.5">
                <label for="uni-tuition" class="text-[10px] text-slate-500 uppercase tracking-wide">Tuition Fees *</label>
                <input type="text" id="uni-tuition" name="tuition_fees" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. £15,000 - £20,000 / year" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-intake" class="text-[10px] text-slate-500 uppercase tracking-wide">Intakes *</label>
                <input type="text" id="uni-intake" name="intake" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Sept, Jan, May" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="space-y-1.5">
                <label for="uni-ielts-pte" class="text-[10px] text-slate-500 uppercase tracking-wide">IELTS/PTE Requirement (Optional)</label>
                <input type="text" id="uni-ielts-pte" name="ielts_pte_req" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. 6.0 overall / PTE 50" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-moi" class="text-[10px] text-slate-500 uppercase tracking-wide">MOI Accepted *</label>
                <select id="uni-moi" name="moi_accepted" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                  <option value="Yes">Yes</option>
                  <option value="No">No</option>
                </select>
              </div>
            </div>

            <div class="space-y-1.5">
              <label for="uni-cgpa" class="text-[10px] text-slate-500 uppercase tracking-wide">Min CGPA / Percentage *</label>
              <input type="text" id="uni-cgpa" name="min_cgpa_percent" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. 55% or 6.0 CGPA" />
            </div>

            <div class="space-y-1.5">
              <label for="uni-courses" class="text-[10px] text-slate-500 uppercase tracking-wide">Courses Offered *</label>
              <textarea id="uni-courses" name="courses" required rows="3" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. MBA, MSc Data Science, CS, BBA (comma separated)"></textarea>
            </div>

            <button type="submit" id="submit-btn" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-2">
              Save University
            </button>
            <button type="button" id="cancel-edit-btn" class="w-full py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-xl transition-all cursor-pointer border border-slate-200 hidden mt-2">
              Cancel Edit
            </button>
          </form>
        </div>

        {/* List panel (7 cols) */}
        <div class="lg:col-span-7 space-y-4">
          <h2 class="text-base font-bold text-slate-800 flex items-center gap-2">
            <Landmark class="w-4 h-4 text-emerald-600" /> Active Universities Database ({universities.length})
          </h2>

          {universities.length === 0 ? (
            <p class="text-xs text-slate-500 py-6 text-center">No universities found in database.</p>
          ) : (
            <div class="bg-white border border-slate-200 rounded-3xl shadow-sm max-h-[70vh] overflow-y-scroll overscroll-contain">
              <table class="w-full text-left border-collapse text-xs">
                <thead>
                  <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                    <th class="px-6 py-4">University</th>
                    <th class="px-6 py-4">Details</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {universities.map((u) => (
                    <tr class="hover:bg-slate-50 transition-colors">
                      <td class="px-6 py-4">
                        <div class="font-bold text-slate-800 text-xs">{u.name}</div>
                        <div class="text-[10px] text-slate-500 mt-1 font-mono">Courses: {u.courses}</div>
                      </td>
                      <td class="px-6 py-4 space-y-1">
                        <div>Country: <span class="font-bold text-slate-700">{u.country} ({u.code.toUpperCase()})</span></div>
                        <div>Fees: <span class="font-bold text-slate-700">{u.tuition_fees}</span></div>
                        <div>Intake: <span class="font-bold text-slate-700">{u.intake}</span></div>
                        <div>IELTS/PTE: <span class="font-bold text-slate-700">{u.ielts_pte_req || "N/A"}</span></div>
                        <div>MOI Accepted: <span class="font-bold text-slate-700">{u.moi_accepted}</span></div>
                        <div>Min CGPA/Score: <span class="font-bold text-slate-700">{u.min_cgpa_percent}</span></div>
                      </td>
                      <td class="px-6 py-4 text-right whitespace-nowrap">
                        <div class="flex items-center justify-end gap-1">
                          <button
                            type="button"
                            class="edit-uni-btn p-2 text-indigo-500 hover:bg-indigo-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-indigo-200"
                            data-id={u.id}
                            data-name={u.name}
                            data-country={u.country}
                            data-code={u.code}
                            data-tuition-fees={u.tuition_fees}
                            data-intake={u.intake}
                            data-ielts-pte-req={u.ielts_pte_req || ""}
                            data-moi-accepted={u.moi_accepted}
                            data-min-cgpa-percent={u.min_cgpa_percent}
                            data-courses={u.courses}
                            aria-label={`Edit ${u.name}`}
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                          </button>
                          <form method="POST" onsubmit="return confirm('Are you sure you want to remove this university?');" class="inline">
                            <input type="hidden" name="action" value="delete-university" />
                            <input type="hidden" name="id" value={u.id} />
                            <button
                              type="submit"
                              class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                              aria-label={`Delete ${u.name}`}
                            >
                              <Trash2 class="w-3.5 h-3.5" />
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>

      </div>

    </main>
  </div>
</Layout>

<script>
  const countryToCode: Record<string, string> = {
    "USA": "us",
    "United Kingdom": "uk",
    "Canada": "ca",
    "Australia": "au",
    "Germany": "de",
    "New Zealand": "nz",
    "Ireland": "ie",
    "Singapore": "sg",
    "Switzerland": "ch",
    "Malaysia": "my",
    "Dubai": "ae",
    "Europe": "eu"
  };

  function setupUniEdit() {
    const editBtns = document.querySelectorAll(".edit-uni-btn");
    editBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        const editId = document.getElementById("edit-id") as HTMLInputElement;
        const formAction = document.getElementById("form-action") as HTMLInputElement;
        const formHeading = document.getElementById("form-heading");
        const submitBtn = document.getElementById("submit-btn");
        const cancelBtn = document.getElementById("cancel-edit-btn");

        if (editId) editId.value = (btn as HTMLElement).dataset.id || "";
        if (formAction) formAction.value = "update-university";
        if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg> Edit University';
        if (submitBtn) submitBtn.textContent = "Update University";
        if (cancelBtn) cancelBtn.classList.remove("hidden");

        const getValue = (val: string | undefined) => val || "";

        const nameInput = document.querySelector('[name="name"]') as HTMLInputElement;
        const countrySelect = document.querySelector('[name="country"]') as HTMLSelectElement;
        const codeInput = document.getElementById("uni-code") as HTMLInputElement;
        const codeDisplay = document.getElementById("uni-code-display") as HTMLInputElement;
        const tuitionFeesInput = document.querySelector('[name="tuition_fees"]') as HTMLInputElement;
        const intakeInput = document.querySelector('[name="intake"]') as HTMLInputElement;
        const ieltsPteReqInput = document.querySelector('[name="ielts_pte_req"]') as HTMLInputElement;
        const moiAcceptedSelect = document.querySelector('[name="moi_accepted"]') as HTMLSelectElement;
        const minCgpaPercentInput = document.querySelector('[name="min_cgpa_percent"]') as HTMLInputElement;
        const coursesInput = document.querySelector('[name="courses"]') as HTMLTextAreaElement;

        const ds = (btn as HTMLElement).dataset;
        if (nameInput) nameInput.value = getValue(ds.name);
        if (countrySelect) countrySelect.value = getValue(ds.country);
        if (codeInput) codeInput.value = getValue(ds.code);
        if (codeDisplay) codeDisplay.value = getValue(ds.code).toUpperCase();
        if (tuitionFeesInput) tuitionFeesInput.value = getValue(ds.tuitionFees);
        if (intakeInput) intakeInput.value = getValue(ds.intake);
        if (ieltsPteReqInput) ieltsPteReqInput.value = getValue(ds.ieltsPteReq);
        if (moiAcceptedSelect) moiAcceptedSelect.value = getValue(ds.moiAccepted);
        if (minCgpaPercentInput) minCgpaPercentInput.value = getValue(ds.minCgpaPercent);
        if (coursesInput) coursesInput.value = getValue(ds.courses);

        document.querySelector("form")?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    const cancelBtn = document.getElementById("cancel-edit-btn");
    if (cancelBtn) {
      cancelBtn.replaceWith(cancelBtn.cloneNode(true));
      const newCancelBtn = document.getElementById("cancel-edit-btn");
      newCancelBtn?.addEventListener("click", cancelEdit);
    }

    // Country select change listener to sync code input
    const countrySelect = document.getElementById("uni-country") as HTMLSelectElement;
    const codeInput = document.getElementById("uni-code") as HTMLInputElement;
    const codeDisplay = document.getElementById("uni-code-display") as HTMLInputElement;

    if (countrySelect && codeInput && codeDisplay) {
      // Clear listener if already added by replacing element
      countrySelect.replaceWith(countrySelect.cloneNode(true));
      const newCountrySelect = document.getElementById("uni-country") as HTMLSelectElement;
      newCountrySelect.addEventListener("change", () => {
        const code = countryToCode[newCountrySelect.value] || "";
        codeInput.value = code;
        codeDisplay.value = code.toUpperCase();
      });
    }
  }

  function cancelEdit() {
    const editId = document.getElementById("edit-id") as HTMLInputElement;
    const formAction = document.getElementById("form-action") as HTMLInputElement;
    const formHeading = document.getElementById("form-heading");
    const submitBtn = document.getElementById("submit-btn");
    const cancelBtn = document.getElementById("cancel-edit-btn");

    if (editId) editId.value = "";
    if (formAction) formAction.value = "add-university";
    if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M12 5v14"/><path d="M5 12h14"/></svg> Add New University';
    if (submitBtn) submitBtn.textContent = "Save University";
    if (cancelBtn) cancelBtn.classList.add("hidden");

    const form = document.querySelector("form");
    if (form) {
      form.querySelectorAll("input, textarea, select").forEach(el => {
        const input = el as HTMLInputElement;
        if (input.type !== "hidden" && input.name !== "moi_accepted") {
          input.value = "";
        }
      });
      const codeDisplay = document.getElementById("uni-code-display") as HTMLInputElement;
      if (codeDisplay) codeDisplay.value = "";
    }
  }

  setupUniEdit();
  document.addEventListener("astro:page-load", setupUniEdit);
</script>
