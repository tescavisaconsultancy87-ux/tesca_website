---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { supabase } from "../../utils/supabase";
// Inline SVG helpers — no lucide-react in .astro (SSR hook errors)
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Trash2: _s('<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>'),
  Plus: _s('<path d="M12 5v14"/><path d="M5 12h14"/>'),
  Landmark: _s('<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="22"/><line x1="10" x2="10" y1="18" y2="22"/><line x1="14" x2="14" y1="18" y2="22"/><line x1="18" x2="18" y1="18" y2="22"/><polygon points="12 2 20 7 4 7"/>'),
  ShieldAlert: _s('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>'),
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

const IMAGE_MAGIC_BYTES: Record<string, { magic: number[]; mime: string }> = {
  jpeg: { magic: [0xFF, 0xD8, 0xFF], mime: 'image/jpeg' },
  png: { magic: [0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A], mime: 'image/png' },
  webp: { magic: [0x52, 0x49, 0x46, 0x46], mime: 'image/webp' },
};

const detectImageType = (buffer: ArrayBuffer): string | null => {
  const bytes = new Uint8Array(buffer);
  for (const [ext, sig] of Object.entries(IMAGE_MAGIC_BYTES)) {
    if (sig.magic.every((b, i) => bytes[i] === b)) {
      return ext;
    }
  }
  return null;
};

const uploadImageToSupabase = async (photoFile: File): Promise<string> => {
  const sb = supabase;
  const buffer = await photoFile.arrayBuffer();

  const detectedExt = detectImageType(buffer);
  if (!detectedExt) {
    throw new Error("Invalid image file. Only JPEG, PNG, and WEBP formats are accepted.");
  }

  const mime = IMAGE_MAGIC_BYTES[detectedExt].mime;
  const key = `universities/${crypto.randomUUID()}.${detectedExt}`;

  const { error } = await sb.storage
    .from('tesca-assets')
    .upload(key, buffer, {
      contentType: mime,
      upsert: false,
    });

  if (error) {
    console.error("Storage upload failed:", error.message);
    throw new Error("Failed to upload image. Please try again.");
  }

  const { data } = sb.storage.from('tesca-assets').getPublicUrl(key);
  return data.publicUrl;
};

let universities = [];
let successMessage = "";
let errorMessage = "";

// Handle server actions (Add / Update / Delete)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-university") {
      const id = formData.get("id");
      const { error } = await supabase
        .from('universities')
        .delete()
        .eq('id', id);

      if (error) throw error;
      successMessage = "University deleted successfully.";
    } else if (action === "add-university") {
      const name = formData.get("name")?.toString().trim();
      const country = formData.get("country")?.toString().trim();
      const code = formData.get("code")?.toString().trim();
      
      const ugTuitionFees = formData.get("ug_tuition_fees")?.toString().trim();
      const pgTuitionFees = formData.get("pg_tuition_fees")?.toString().trim();
      const ugIelts = formData.get("ug_ielts_pte")?.toString().trim() || null;
      const pgIelts = formData.get("pg_ielts_pte")?.toString().trim() || null;
      const ugMoi = formData.get("ug_moi")?.toString().trim();
      const pgMoi = formData.get("pg_moi")?.toString().trim();
      const ugIntakes = formData.get("ug_intakes")?.toString().trim();
      const pgIntakes = formData.get("pg_intakes")?.toString().trim();
      const ugCourses = formData.get("ug_courses")?.toString().trim();
      const pgCourses = formData.get("pg_courses")?.toString().trim();
      
      const minCgpaPercent = formData.get("min_cgpa_percent")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;

      let imageUrl = "";
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 1024 * 1024) {
          errorMessage = "Image size must be less than 1MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, PNG, and WEBP images are allowed.";
        } else {
          imageUrl = await uploadImageToSupabase(photoFile);
        }
      }

      if (!errorMessage && name && country && code && ugTuitionFees && pgTuitionFees && ugIntakes && pgIntakes && ugMoi && pgMoi && minCgpaPercent && ugCourses && pgCourses) {
        const { error } = await supabase
          .from('universities')
          .insert({
            name, country, code, min_cgpa_percent: minCgpaPercent,
            tuition_fees: ugTuitionFees, intake: ugIntakes, ielts_pte_req: ugIelts, moi_accepted: ugMoi, courses: ugCourses, photo: imageUrl,
            ug_fees: ugTuitionFees, pg_fees: pgTuitionFees, ug_ielts_pte_req: ugIelts, pg_ielts_pte_req: pgIelts, ug_moi_accepted: ugMoi, pg_moi_accepted: pgMoi, ug_intake: ugIntakes, pg_intake: pgIntakes, ug_courses: ugCourses, pg_courses: pgCourses,
            image_url: imageUrl, ug_tuition_fees: ugTuitionFees, ug_intakes: ugIntakes, ug_ielts_pte: ugIelts, ug_moi: ugMoi, pg_tuition_fees: pgTuitionFees, pg_intakes: pgIntakes, pg_ielts_pte: pgIelts, pg_moi: pgMoi
          });

        if (error) throw error;
        successMessage = `Successfully added ${name} to database.`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields (Name, Country, fees, intakes, MOI and courses for both UG/PG).";
      }
    } else if (action === "update-university") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const name = formData.get("name")?.toString().trim();
      const country = formData.get("country")?.toString().trim();
      const code = formData.get("code")?.toString().trim();
      
      const ugTuitionFees = formData.get("ug_tuition_fees")?.toString().trim();
      const pgTuitionFees = formData.get("pg_tuition_fees")?.toString().trim();
      const ugIelts = formData.get("ug_ielts_pte")?.toString().trim() || null;
      const pgIelts = formData.get("pg_ielts_pte")?.toString().trim() || null;
      const ugMoi = formData.get("ug_moi")?.toString().trim();
      const pgMoi = formData.get("pg_moi")?.toString().trim();
      const ugIntakes = formData.get("ug_intakes")?.toString().trim();
      const pgIntakes = formData.get("pg_intakes")?.toString().trim();
      const ugCourses = formData.get("ug_courses")?.toString().trim();
      const pgCourses = formData.get("pg_courses")?.toString().trim();
      
      const minCgpaPercent = formData.get("min_cgpa_percent")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;
      const imageUrlExisting = formData.get("image_url_existing")?.toString().trim() || "";

      let imageUrl = imageUrlExisting;
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 1024 * 1024) {
          errorMessage = "Image size must be less than 1MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, PNG, and WEBP images are allowed.";
        } else {
          imageUrl = await uploadImageToSupabase(photoFile);
        }
      }

      if (!errorMessage && id && name && country && code && ugTuitionFees && pgTuitionFees && ugIntakes && pgIntakes && ugMoi && pgMoi && minCgpaPercent && ugCourses && pgCourses) {
        const { error } = await supabase
          .from('universities')
          .update({
            name, country, code, min_cgpa_percent: minCgpaPercent,
            tuition_fees: ugTuitionFees, intake: ugIntakes, ielts_pte_req: ugIelts, moi_accepted: ugMoi, courses: ugCourses, photo: imageUrl,
            ug_fees: ugTuitionFees, pg_fees: pgTuitionFees, ug_ielts_pte_req: ugIelts, pg_ielts_pte_req: pgIelts, ug_moi_accepted: ugMoi, pg_moi_accepted: pgMoi, ug_intake: ugIntakes, pg_intake: pgIntakes, ug_courses: ugCourses, pg_courses: pgCourses,
            image_url: imageUrl, ug_tuition_fees: ugTuitionFees, ug_intakes: ugIntakes, ug_ielts_pte: ugIelts, ug_moi: ugMoi, pg_tuition_fees: pgTuitionFees, pg_intakes: pgIntakes, pg_ielts_pte: pgIelts, pg_moi: pgMoi
          })
          .eq('id', id);

        if (error) throw error;
        successMessage = `Successfully updated ${name}.`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields.";
      }
    }
  } catch (err: any) {
    console.error("Action error on universities page:", err);
    errorMessage = "Action failed. Please try again.";
  }
}

// Fetch universities
try {
  const { data, error } = await supabase
    .from('universities')
    .select('*')
    .order('name', { ascending: true });

  if (error) throw error;
  universities = data || [];
} catch (err) {
  console.error("Failed to load universities:", err);
  errorMessage = "Failed to load database records.";
}
---

<Layout 
  title="Manage Universities Database | TESCA Admin"
  description="Administrative portal to configure university options and admission criteria."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="universities" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Universities Settings
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure intake options, fees, and requirements for target universities.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="admin-alert-banner p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <span set:html={SVG.ShieldAlert} class="w-4 h-4 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="admin-alert-banner p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        {/* Form panel (5 cols) */}
        <div class="lg:col-span-5 bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
          <h2 id="form-heading" class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2">
            <span set:html={SVG.Plus} class="w-4 h-4 text-indigo-600 inline-block" /> Add New University
          </h2>
          
          <form method="POST" enctype="multipart/form-data" class="space-y-4 text-xs font-semibold text-slate-600">
            <input type="hidden" id="form-action" name="action" value="add-university" />
            <input type="hidden" id="edit-id" name="id" value="" />
            <input type="hidden" id="image-url-existing" name="image_url_existing" value="" />
            
            <div class="space-y-1.5">
              <label for="uni-name" class="text-[10px] text-slate-500 uppercase tracking-wide">University Name *</label>
              <input type="text" id="uni-name" name="name" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Coventry University" />
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="space-y-1.5">
                <label for="uni-country" class="text-[10px] text-slate-500 uppercase tracking-wide">Country *</label>
                <select id="uni-country" name="country" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                  <option value="">Select Country</option>
                  <option value="USA">USA</option>
                  <option value="United Kingdom">United Kingdom</option>
                  <option value="Canada">Canada</option>
                  <option value="Australia">Australia</option>
                  <option value="Germany">Germany</option>
                  <option value="New Zealand">New Zealand</option>
                  <option value="Ireland">Ireland</option>
                  <option value="Singapore">Singapore</option>
                  <option value="Switzerland">Switzerland</option>
                  <option value="Malaysia">Malaysia</option>
                  <option value="Dubai">Dubai</option>
                  <option value="Europe">Europe</option>
                </select>
              </div>
              <div class="space-y-1.5">
                <label for="uni-code-display" class="text-[10px] text-slate-500 uppercase tracking-wide">Auto-assigned Code</label>
                <input type="text" id="uni-code-display" disabled class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-100 text-slate-500 focus:outline-none cursor-not-allowed" placeholder="e.g. uk, ca" />
                <input type="hidden" id="uni-code" name="code" required />
              </div>
            </div>

            <div class="space-y-1.5">
              <label for="uni-cgpa" class="text-[10px] text-slate-500 uppercase tracking-wide">Min CGPA / Percentage *</label>
              <input type="text" id="uni-cgpa" name="min_cgpa_percent" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. 55% or 6.0 CGPA" />
            </div>

            <div class="space-y-1.5">
              <label for="uni-photo" class="text-[10px] text-slate-500 uppercase tracking-wide">University Logo/Photo (Max 1MB)</label>
              <input type="file" id="uni-photo" name="photo_file" accept="image/png, image/jpeg, image/jpg, image/webp" class="w-full text-slate-500 border border-slate-200 bg-slate-50 rounded-lg file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
              <div id="photo-preview-container" class="mt-2 hidden flex items-center gap-3">
                <img id="photo-preview" class="w-16 h-16 object-cover rounded-lg border border-slate-200" src="" />
                <button type="button" id="remove-photo-btn" class="text-rose-500 hover:text-rose-700 text-[10px] font-bold uppercase tracking-wider cursor-pointer">Remove Photo</button>
              </div>
            </div>

            {/* TAB toggles */}
            <div class="flex border-b border-slate-200 mb-2 mt-4">
              <button type="button" id="tab-ug" class="flex-1 pb-2 text-center border-b-2 border-indigo-600 font-bold text-indigo-600 focus:outline-none cursor-pointer">UG Level</button>
              <button type="button" id="tab-pg" class="flex-1 pb-2 text-center border-b-2 border-transparent text-slate-400 hover:text-slate-600 font-bold focus:outline-none cursor-pointer">PG Level</button>
            </div>

            {/* UG Fields Container */}
            <div id="ug-fields" class="space-y-4">
              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1.5">
                  <label for="ug-fees" class="text-[10px] text-slate-500 uppercase tracking-wide">UG Tuition Fees *</label>
                  <input type="text" id="ug-fees" name="ug_tuition_fees" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. £15,000 / year" />
                </div>
                <div class="space-y-1.5">
                  <label for="ug-intake" class="text-[10px] text-slate-500 uppercase tracking-wide">UG Intakes *</label>
                  <input type="text" id="ug-intake" name="ug_intakes" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Sept, Jan" />
                </div>
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1.5">
                  <label for="ug-ielts" class="text-[10px] text-slate-500 uppercase tracking-wide">UG IELTS/PTE (Optional)</label>
                  <input type="text" id="ug-ielts" name="ug_ielts_pte" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. 6.0 overall" />
                </div>
                <div class="space-y-1.5">
                  <label for="ug-moi" class="text-[10px] text-slate-500 uppercase tracking-wide">UG MOI Accepted *</label>
                  <select id="ug-moi" name="ug_moi" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                    <option value="Yes">Yes</option>
                    <option value="No">No</option>
                  </select>
                </div>
              </div>

              <div class="space-y-1.5">
                <label for="ug-courses" class="text-[10px] text-slate-500 uppercase tracking-wide">UG Courses Offered *</label>
                <textarea id="ug-courses" name="ug_courses" rows="2" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. BSc CS, BBA, BEng (comma separated)"></textarea>
              </div>
            </div>

            {/* PG Fields Container */}
            <div id="pg-fields" class="space-y-4 hidden">
              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1.5">
                  <label for="pg-fees" class="text-[10px] text-slate-500 uppercase tracking-wide">PG Tuition Fees *</label>
                  <input type="text" id="pg-fees" name="pg_tuition_fees" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. £17,000 / year" />
                </div>
                <div class="space-y-1.5">
                  <label for="pg-intake" class="text-[10px] text-slate-500 uppercase tracking-wide">PG Intakes *</label>
                  <input type="text" id="pg-intake" name="pg_intakes" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Sept, Jan, May" />
                </div>
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1.5">
                  <label for="pg-ielts" class="text-[10px] text-slate-500 uppercase tracking-wide">PG IELTS/PTE (Optional)</label>
                  <input type="text" id="pg-ielts" name="pg_ielts_pte" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. 6.5 overall" />
                </div>
                <div class="space-y-1.5">
                  <label for="pg-moi" class="text-[10px] text-slate-500 uppercase tracking-wide">PG MOI Accepted *</label>
                  <select id="pg-moi" name="pg_moi" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                    <option value="Yes">Yes</option>
                    <option value="No">No</option>
                  </select>
                </div>
              </div>

              <div class="space-y-1.5">
                <label for="pg-courses" class="text-[10px] text-slate-500 uppercase tracking-wide">PG Courses Offered *</label>
                <textarea id="pg-courses" name="pg_courses" rows="2" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. MBA, MSc Data Science, CS (comma separated)"></textarea>
              </div>
            </div>

            <button type="submit" id="submit-btn" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-2">
              Save University
            </button>
            <button type="button" id="cancel-edit-btn" class="w-full py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-xl transition-all cursor-pointer border border-slate-200 hidden mt-2">
              Cancel Edit
            </button>
          </form>
        </div>

        {/* List panel (7 cols) */}
        <div class="lg:col-span-7 space-y-4">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 bg-white p-4 rounded-2xl border border-slate-200 shadow-xs">
            <h2 class="text-base font-bold text-slate-800 flex items-center gap-2">
              <span set:html={SVG.Landmark} class="text-emerald-600" /> Universities (<span id="visible-uni-count">{universities.length}</span>/<span id="total-uni-count">{universities.length}</span>)
            </h2>

            <div class="flex flex-wrap items-center gap-2">
              <select
                id="filter-country"
                class="px-3 py-1.5 rounded-xl border border-slate-200 bg-slate-50 text-xs font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all cursor-pointer"
              >
                <option value="all">All Countries</option>
                <option value="us">USA 🇺🇸</option>
                <option value="uk">United Kingdom 🇬🇧</option>
                <option value="ca">Canada 🇨🇦</option>
                <option value="au">Australia 🇦🇺</option>
                <option value="de">Germany 🇩🇪</option>
                <option value="nz">New Zealand 🇳🇿</option>
                <option value="ie">Ireland 🇮🇪</option>
                <option value="sg">Singapore 🇸🇬</option>
                <option value="ch">Switzerland 🇨🇭</option>
                <option value="my">Malaysia 🇲🇾</option>
                <option value="ae">Dubai 🇦🇪</option>
                <option value="eu">Europe 🇪🇺</option>
              </select>

              <input
                type="text"
                id="search-university"
                placeholder="Search name..."
                class="px-3 py-1.5 rounded-xl border border-slate-200 bg-slate-50 text-xs text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all w-28 sm:w-36"
              />
            </div>
          </div>

          {universities.length === 0 ? (
            <p class="text-xs text-slate-500 py-6 text-center">No universities found in database.</p>
          ) : (
            <div class="bg-white border border-slate-200 rounded-3xl shadow-sm max-h-[85vh] overflow-y-auto overflow-x-auto overscroll-contain" data-lenis-prevent>
              <table class="w-full text-left border-collapse text-xs min-w-[700px]">
                <thead>
                  <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                    <th class="px-4 py-4">University</th>
                    <th class="px-4 py-4">UG Program</th>
                    <th class="px-4 py-4">PG Program</th>
                    <th class="px-4 py-4 text-right">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {universities.map((u) => (
                    <tr 
                      class="uni-row hover:bg-slate-50 transition-colors"
                      data-code={u.code.toLowerCase()}
                      data-country={u.country.toLowerCase()}
                      data-name={u.name.toLowerCase()}
                    >
                      <td class="px-4 py-4 align-top">
                        <div class="flex items-start gap-3">
                          {u.image_url || u.photo ? (
                            <img src={u.image_url || u.photo} alt={u.name} class="w-12 h-12 rounded-lg object-cover border border-slate-200 bg-slate-50 shrink-0" />
                          ) : (
                            <div class="w-12 h-12 rounded-lg bg-slate-100 flex items-center justify-center text-slate-400 border border-slate-200 shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            </div>
                          )}
                          <div class="min-w-0">
                            <div class="font-bold text-slate-800 text-xs leading-tight">{u.name}</div>
                            <div class="flex items-center gap-1 mt-1">
                              <img
                                src={`https://flagcdn.com/w20/${u.code === "uk" ? "gb" : u.code}.png`}
                                alt={`${u.country} flag`}
                                class="w-3.5 h-2.5 rounded-sm object-cover"
                              />
                              <span class="text-[10px] text-slate-500 font-medium">{u.country} ({u.code.toUpperCase()})</span>
                            </div>
                            <div class="text-[9px] text-slate-400 mt-1">Min CGPA: <span class="font-bold text-slate-600">{u.min_cgpa_percent}</span></div>
                          </div>
                        </div>
                      </td>
                      <td class="px-4 py-4 align-top space-y-0.5 text-[11px]">
                        <div><span class="text-slate-400">Fees:</span> <span class="font-bold text-slate-700">{u.ug_tuition_fees || u.ug_fees || u.tuition_fees || "N/A"}</span></div>
                        <div><span class="text-slate-400">Intake:</span> <span class="font-semibold text-slate-700">{u.ug_intakes || u.ug_intake || u.intake || "N/A"}</span></div>
                        <div><span class="text-slate-400">IELTS:</span> <span class="font-semibold text-slate-700">{u.ug_ielts_pte || u.ug_ielts_pte_req || u.ielts_pte_req || "N/A"}</span></div>
                        <div><span class="text-slate-400">MOI:</span> <span class="font-semibold text-slate-700">{u.ug_moi || u.ug_moi_accepted || u.moi_accepted || "N/A"}</span></div>
                        <div class="text-[9px] text-slate-500 font-mono line-clamp-2 mt-0.5">Courses: {u.ug_courses || u.courses || "N/A"}</div>
                      </td>
                      <td class="px-4 py-4 align-top space-y-0.5 text-[11px]">
                        <div><span class="text-slate-400">Fees:</span> <span class="font-bold text-slate-700">{u.pg_tuition_fees || u.pg_fees || "N/A"}</span></div>
                        <div><span class="text-slate-400">Intake:</span> <span class="font-semibold text-slate-700">{u.pg_intakes || u.pg_intake || "N/A"}</span></div>
                        <div><span class="text-slate-400">IELTS:</span> <span class="font-semibold text-slate-700">{u.pg_ielts_pte || u.pg_ielts_pte_req || "N/A"}</span></div>
                        <div><span class="text-slate-400">MOI:</span> <span class="font-semibold text-slate-700">{u.pg_moi || u.pg_moi_accepted || "N/A"}</span></div>
                        <div class="text-[9px] text-slate-500 font-mono line-clamp-2 mt-0.5">Courses: {u.pg_courses || "N/A"}</div>
                      </td>
                      <td class="px-4 py-4 align-top text-right whitespace-nowrap">
                        <div class="flex items-center justify-end gap-1">
                          <button
                            type="button"
                            class="edit-uni-btn p-2 text-indigo-500 hover:bg-indigo-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-indigo-200"
                            data-id={u.id}
                            data-name={u.name}
                            data-country={u.country}
                            data-code={u.code}
                            data-min-cgpa-percent={u.min_cgpa_percent}
                            data-image-url={u.image_url || u.photo || ""}
                            data-ug-tuition-fees={u.ug_tuition_fees || u.ug_fees || u.tuition_fees || ""}
                            data-ug-intakes={u.ug_intakes || u.ug_intake || u.intake || ""}
                            data-ug-ielts-pte={u.ug_ielts_pte || u.ug_ielts_pte_req || u.ielts_pte_req || ""}
                            data-ug-moi={u.ug_moi || u.ug_moi_accepted || u.moi_accepted || "Yes"}
                            data-ug-courses={u.ug_courses || u.courses || ""}
                            data-pg-tuition-fees={u.pg_tuition_fees || u.pg_fees || ""}
                            data-pg-intakes={u.pg_intakes || u.pg_intake || ""}
                            data-pg-ielts-pte={u.pg_ielts_pte || u.pg_ielts_pte_req || ""}
                            data-pg-moi={u.pg_moi || u.pg_moi_accepted || "Yes"}
                            data-pg-courses={u.pg_courses || ""}
                            aria-label={`Edit ${u.name}`}
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                          </button>
                          <form method="POST" class="inline delete-university-form" data-no-loader>
                            <input type="hidden" name="action" value="delete-university" />
                            <input type="hidden" name="id" value={u.id} />
                            <button
                              type="submit"
                              class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                              aria-label={`Delete ${u.name}`}
                            >
                              <span set:html={SVG.Trash2} />
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))}
                  <tr id="no-filter-matches" class="hidden">
                    <td colspan="4" class="px-4 py-8 text-center text-slate-400 text-xs font-medium">
                      No universities match your filter criteria.
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
          )}
        </div>

      </div>

    </main>
  </div>
</Layout>

<script>
  const countryToCode: Record<string, string> = {
    "USA": "us",
    "United Kingdom": "uk",
    "Canada": "ca",
    "Australia": "au",
    "Germany": "de",
    "New Zealand": "nz",
    "Ireland": "ie",
    "Singapore": "sg",
    "Switzerland": "ch",
    "Malaysia": "my",
    "Dubai": "ae",
    "Europe": "eu"
  };

  function setupUniEdit() {
    // Tabs functionality
    const tabUg = document.getElementById("tab-ug");
    const tabPg = document.getElementById("tab-pg");
    const ugFields = document.getElementById("ug-fields");
    const pgFields = document.getElementById("pg-fields");

    if (tabUg && tabPg && ugFields && pgFields) {
      tabUg.replaceWith(tabUg.cloneNode(true));
      tabPg.replaceWith(tabPg.cloneNode(true));
      
      const newTabUg = document.getElementById("tab-ug")!;
      const newTabPg = document.getElementById("tab-pg")!;
      const newUgFields = document.getElementById("ug-fields")!;
      const newPgFields = document.getElementById("pg-fields")!;

      newTabUg.addEventListener("click", () => {
        newUgFields.classList.remove("hidden");
        newPgFields.classList.add("hidden");
        newTabUg.className = "flex-1 pb-2 text-center border-b-2 border-indigo-600 font-bold text-indigo-600 focus:outline-none cursor-pointer";
        newTabPg.className = "flex-1 pb-2 text-center border-b-2 border-transparent text-slate-400 hover:text-slate-600 font-bold focus:outline-none cursor-pointer";
      });

      newTabPg.addEventListener("click", () => {
        newPgFields.classList.remove("hidden");
        newUgFields.classList.add("hidden");
        newTabPg.className = "flex-1 pb-2 text-center border-b-2 border-indigo-600 font-bold text-indigo-600 focus:outline-none cursor-pointer";
        newTabUg.className = "flex-1 pb-2 text-center border-b-2 border-transparent text-slate-400 hover:text-slate-600 font-bold focus:outline-none cursor-pointer";
      });
    }

    // Photo preview functionality
    const photoInput = document.getElementById("uni-photo") as HTMLInputElement;
    const photoPreviewContainer = document.getElementById("photo-preview-container");
    const photoPreview = document.getElementById("photo-preview") as HTMLImageElement;
    const removePhotoBtn = document.getElementById("remove-photo-btn");
    const photoExistingInput = document.getElementById("image-url-existing") as HTMLInputElement;

    if (photoInput && photoPreviewContainer && photoPreview && removePhotoBtn && photoExistingInput) {
      photoInput.replaceWith(photoInput.cloneNode(true));
      removePhotoBtn.replaceWith(removePhotoBtn.cloneNode(true));

      const newPhotoInput = document.getElementById("uni-photo") as HTMLInputElement;
      const newRemovePhotoBtn = document.getElementById("remove-photo-btn")!;

      newPhotoInput.addEventListener("change", () => {
        const file = newPhotoInput.files?.[0];
        if (file) {
          if (file.size > 1024 * 1024) {
            alert("Image size must be less than 1MB.");
            newPhotoInput.value = "";
            return;
          }
          const reader = new FileReader();
          reader.onload = (e) => {
            photoPreview.src = e.target?.result as string;
            photoPreviewContainer.classList.remove("hidden");
          };
          reader.readAsDataURL(file);
        }
      });

      newRemovePhotoBtn.addEventListener("click", () => {
        newPhotoInput.value = "";
        photoExistingInput.value = "";
        photoPreview.src = "";
        photoPreviewContainer.classList.add("hidden");
      });
    }

    const editBtns = document.querySelectorAll(".edit-uni-btn");
    editBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        const editId = document.getElementById("edit-id") as HTMLInputElement;
        const formAction = document.getElementById("form-action") as HTMLInputElement;
        const formHeading = document.getElementById("form-heading");
        const submitBtn = document.getElementById("submit-btn");
        const cancelBtn = document.getElementById("cancel-edit-btn");

        if (editId) editId.value = (btn as HTMLElement).dataset.id || "";
        if (formAction) formAction.value = "update-university";
        if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg> Edit University';
        if (submitBtn) submitBtn.textContent = "Update University";
        if (cancelBtn) cancelBtn.classList.remove("hidden");

        const getValue = (val: string | undefined) => val || "";

        const nameInput = document.querySelector('[name="name"]') as HTMLInputElement;
        const countrySelect = document.querySelector('[name="country"]') as HTMLSelectElement;
        const codeInput = document.getElementById("uni-code") as HTMLInputElement;
        const codeDisplay = document.getElementById("uni-code-display") as HTMLInputElement;
        const minCgpaPercentInput = document.querySelector('[name="min_cgpa_percent"]') as HTMLInputElement;
        
        const ugFeesInput = document.querySelector('[name="ug_tuition_fees"]') as HTMLInputElement;
        const ugIntakeInput = document.querySelector('[name="ug_intakes"]') as HTMLInputElement;
        const ugIeltsInput = document.querySelector('[name="ug_ielts_pte"]') as HTMLInputElement;
        const ugMoiSelect = document.querySelector('[name="ug_moi"]') as HTMLSelectElement;
        const ugCoursesInput = document.querySelector('[name="ug_courses"]') as HTMLTextAreaElement;

        const pgFeesInput = document.querySelector('[name="pg_tuition_fees"]') as HTMLInputElement;
        const pgIntakeInput = document.querySelector('[name="pg_intakes"]') as HTMLInputElement;
        const pgIeltsInput = document.querySelector('[name="pg_ielts_pte"]') as HTMLInputElement;
        const pgMoiSelect = document.querySelector('[name="pg_moi"]') as HTMLSelectElement;
        const pgCoursesInput = document.querySelector('[name="pg_courses"]') as HTMLTextAreaElement;

        const ds = (btn as HTMLElement).dataset;
        if (nameInput) nameInput.value = getValue(ds.name);
        if (countrySelect) countrySelect.value = getValue(ds.country);
        if (codeInput) codeInput.value = getValue(ds.code);
        if (codeDisplay) codeDisplay.value = getValue(ds.code).toUpperCase();
        if (minCgpaPercentInput) minCgpaPercentInput.value = getValue(ds.minCgpaPercent);
        
        if (ugFeesInput) ugFeesInput.value = getValue(ds.ugTuitionFees);
        if (ugIntakeInput) ugIntakeInput.value = getValue(ds.ugIntakes);
        if (ugIeltsInput) ugIeltsInput.value = getValue(ds.ugIeltsPte);
        if (ugMoiSelect) ugMoiSelect.value = getValue(ds.ugMoi);
        if (ugCoursesInput) ugCoursesInput.value = getValue(ds.ugCourses);

        if (pgFeesInput) pgFeesInput.value = getValue(ds.pgTuitionFees);
        if (pgIntakeInput) pgIntakeInput.value = getValue(ds.pgIntakes);
        if (pgIeltsInput) pgIeltsInput.value = getValue(ds.pgIeltsPte);
        if (pgMoiSelect) pgMoiSelect.value = getValue(ds.pgMoi);
        if (pgCoursesInput) pgCoursesInput.value = getValue(ds.pgCourses);

        if (photoExistingInput && photoPreview && photoPreviewContainer) {
          const photoVal = getValue(ds.imageUrl);
          photoExistingInput.value = photoVal;
          if (photoVal) {
            photoPreview.src = photoVal;
            photoPreviewContainer.classList.remove("hidden");
          } else {
            photoPreview.src = "";
            photoPreviewContainer.classList.add("hidden");
          }
        }

        document.querySelector("form")?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    const cancelBtn = document.getElementById("cancel-edit-btn");
    if (cancelBtn) {
      cancelBtn.replaceWith(cancelBtn.cloneNode(true));
      const newCancelBtn = document.getElementById("cancel-edit-btn");
      newCancelBtn?.addEventListener("click", cancelEdit);
    }

    // Country select change listener to sync code input
    const countrySelect = document.getElementById("uni-country") as HTMLSelectElement;
    const codeInput = document.getElementById("uni-code") as HTMLInputElement;
    const codeDisplay = document.getElementById("uni-code-display") as HTMLInputElement;

    if (countrySelect && codeInput && codeDisplay) {
      countrySelect.replaceWith(countrySelect.cloneNode(true));
      const newCountrySelect = document.getElementById("uni-country") as HTMLSelectElement;
      newCountrySelect.addEventListener("change", () => {
        const code = countryToCode[newCountrySelect.value] || "";
        codeInput.value = code;
        codeDisplay.value = code.toUpperCase();
      });
    }

    // Form client-side validation for required tab-fields
    const form = document.querySelector("form");
    if (form) {
      form.replaceWith(form.cloneNode(true));
      const newForm = document.querySelector("form")!;
      newForm.addEventListener("submit", (e) => {
        const name = (document.getElementById("uni-name") as HTMLInputElement).value.trim();
        const country = (document.getElementById("uni-country") as HTMLSelectElement).value;
        const cgpa = (document.getElementById("uni-cgpa") as HTMLInputElement).value.trim();
        
        const ugFees = (document.getElementById("ug-fees") as HTMLInputElement).value.trim();
        const ugIntake = (document.getElementById("ug-intake") as HTMLInputElement).value.trim();
        const ugCourses = (document.getElementById("ug-courses") as HTMLTextAreaElement).value.trim();
        
        const pgFees = (document.getElementById("pg-fees") as HTMLInputElement).value.trim();
        const pgIntake = (document.getElementById("pg-intake") as HTMLInputElement).value.trim();
        const pgCourses = (document.getElementById("pg-courses") as HTMLTextAreaElement).value.trim();

        if (!name || !country || !cgpa) {
          alert("Please fill in all general fields.");
          e.preventDefault();
          return;
        }

        if (!ugFees || !ugIntake || !ugCourses) {
          alert("Please fill in all Undergraduate (UG) details.");
          document.getElementById("tab-ug")?.click();
          e.preventDefault();
          return;
        }

        if (!pgFees || !pgIntake || !pgCourses) {
          alert("Please fill in all Postgraduate (PG) details.");
          document.getElementById("tab-pg")?.click();
          e.preventDefault();
          return;
        }
      });
    }
  }

  function cancelEdit() {
    const editId = document.getElementById("edit-id") as HTMLInputElement;
    const formAction = document.getElementById("form-action") as HTMLInputElement;
    const formHeading = document.getElementById("form-heading");
    const submitBtn = document.getElementById("submit-btn");
    const cancelBtn = document.getElementById("cancel-edit-btn");
    const photoExistingInput = document.getElementById("image-url-existing") as HTMLInputElement;
    const photoPreview = document.getElementById("photo-preview") as HTMLImageElement;
    const photoPreviewContainer = document.getElementById("photo-preview-container");
    const photoInput = document.getElementById("uni-photo") as HTMLInputElement;

    if (editId) editId.value = "";
    if (formAction) formAction.value = "add-university";
    if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M12 5v14"/><path d="M5 12h14"/></svg> Add New University';
    if (submitBtn) submitBtn.textContent = "Save University";
    if (cancelBtn) cancelBtn.classList.add("hidden");

    if (photoExistingInput) photoExistingInput.value = "";
    if (photoPreview) photoPreview.src = "";
    if (photoPreviewContainer) photoPreviewContainer.classList.add("hidden");
    if (photoInput) photoInput.value = "";

    const form = document.querySelector("form");
    if (form) {
      form.querySelectorAll("input, textarea, select").forEach(el => {
        const input = el as HTMLInputElement;
        if (input.type !== "hidden" && input.name !== "ug_moi_accepted" && input.name !== "pg_moi_accepted" && input.type !== "file") {
          input.value = "";
        }
      });
      const codeDisplay = document.getElementById("uni-code-display") as HTMLInputElement;
      if (codeDisplay) codeDisplay.value = "";
    }
  }

  function setupFilter() {
    const filterSelect = document.getElementById("filter-country") as HTMLSelectElement;
    const searchInput = document.getElementById("search-university") as HTMLInputElement;
    const uniRows = document.querySelectorAll(".uni-row");
    const visibleCountSpan = document.getElementById("visible-uni-count");
    const noMatchMsg = document.getElementById("no-filter-matches");

    if (!filterSelect && !searchInput) return;

    const filterUnis = () => {
      const selectedCountryCode = filterSelect?.value.toLowerCase() || "all";
      const searchQuery = searchInput?.value.trim().toLowerCase() || "";
      let visibleCount = 0;

      uniRows.forEach(row => {
        const el = row as HTMLElement;
        const code = (el.dataset.code || "").toLowerCase();
        const country = (el.dataset.country || "").toLowerCase();
        const name = (el.dataset.name || "").toLowerCase();

        const matchesCountry = selectedCountryCode === "all" || code === selectedCountryCode || country.includes(selectedCountryCode);
        const matchesSearch = !searchQuery || name.includes(searchQuery) || country.includes(searchQuery);

        if (matchesCountry && matchesSearch) {
          el.classList.remove("hidden");
          visibleCount++;
        } else {
          el.classList.add("hidden");
        }
      });

      if (visibleCountSpan) visibleCountSpan.textContent = visibleCount.toString();
      if (noMatchMsg) {
        if (visibleCount === 0 && uniRows.length > 0) {
          noMatchMsg.classList.remove("hidden");
        } else {
          noMatchMsg.classList.add("hidden");
        }
      }
    };

    filterSelect?.addEventListener("change", filterUnis);
    searchInput?.addEventListener("input", filterUnis);
  }

  setupUniEdit();
  setupFilter();

  // Add loader to submit button on form submit
  const uniForm = document.querySelector("form");
  if (uniForm && !(uniForm as any)._loaderBound) {
    (uniForm as any)._loaderBound = true;
    uniForm.addEventListener("submit", () => {
      const btn = document.getElementById("submit-btn");
      if (btn) (window as any).showBtnLoader?.(btn, "Saving...");
    });
  }

  // Handle delete university confirmation
  function bindDeleteConfirm() {
    const deleteForms = document.querySelectorAll("form.delete-university-form");
    deleteForms.forEach(form => {
      if ((form as any)._bound) return;
      (form as any)._bound = true;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const confirmed = await (window as any).showConfirmDialog({
          title: "Are you absolutely sure?",
          description: "This action cannot be undone. This will permanently remove this university record.",
          actionText: "Delete",
          cancelText: "Cancel",
          variant: "destructive",
          from: "bottom"
        });
        if (confirmed) {
          (form as HTMLFormElement).submit();
        }
      });
    });
  }
  bindDeleteConfirm();
  document.addEventListener("astro:page-load", () => {
    setupUniEdit();
    setupFilter();
    bindDeleteConfirm();
  });
</script>
