---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { env } from "cloudflare:workers";
import { Trash2, Plus, Landmark, Award, ShieldAlert } from "lucide-react";

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

const db = env?.tesca_db || env?.DB;

let universities = [];
let successMessage = "";
let errorMessage = "";

// Handle server actions (Add / Delete)
if (Astro.request.method === "POST" && db) {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-university") {
      const id = formData.get("id");
      await db.prepare("DELETE FROM universities WHERE id = ?").bind(id).run();
      successMessage = "University deleted successfully.";
    } else if (action === "add-university") {
      const name = formData.get("name")?.toString().trim();
      const country = formData.get("country")?.toString().trim();
      const code = formData.get("code")?.toString().trim();
      const rank = parseInt(formData.get("rank")?.toString() || "999");
      const domain = formData.get("domain")?.toString().trim() || "General";
      const city = formData.get("city")?.toString().trim();
      const established = parseInt(formData.get("established")?.toString() || "2000");
      const students = formData.get("students")?.toString().trim() || "10,000+";
      const tuitionMin = parseFloat(formData.get("tuition_min")?.toString() || "0");
      const tuitionMax = parseFloat(formData.get("tuition_max")?.toString() || "0");
      const minGpa = parseFloat(formData.get("min_gpa")?.toString() || "0");
      const minIelts = parseFloat(formData.get("min_ielts")?.toString() || "0");
      const minToefl = parseInt(formData.get("min_toefl")?.toString() || "0");
      const highlights = formData.get("highlights")?.toString().trim();

      if (name && country && code && city && highlights) {
        await db.prepare(
          `INSERT INTO universities 
          (name, country, code, rank, domain, city, established, students, tuition_fee_min, tuition_fee_max, min_gpa_percent, min_ielts, min_toefl, highlights) 
          VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`
        ).bind(
          name, country, code, rank, domain, city, established, students, tuitionMin, tuitionMax, minGpa, minIelts, minToefl, highlights
        ).run();

        successMessage = `Successfully added ${name} to database.`;
      } else {
        errorMessage = "Please fill in all required fields (Name, Country, Code, City, Highlights).";
      }
    }
  } catch (err: any) {
    console.error("Action error on universities page:", err);
    errorMessage = `Action failed: ${err.message || "Unknown error"}`;
  }
}

// Fetch universities
if (db) {
  try {
    const res = await db.prepare("SELECT * FROM universities ORDER BY rank ASC").all();
    universities = res.results || [];
  } catch (err) {
    console.error("Failed to load universities:", err);
    errorMessage = "Failed to load database records.";
  }
}
---

<Layout 
  title="Manage Universities Database | TESCA Admin"
  description="Administrative portal to configure university options and admission criteria."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col">
    <AdminHeader activeTab="universities" />

    <main class="max-w-7xl mx-auto w-full px-4 md:px-8 py-10 flex-grow text-left">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Universities Settings
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure admission matching guidelines, IELTS cutoff values, and tuition constraints.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <ShieldAlert class="w-4 h-4 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        {/* Form panel (5 cols) */}
        <div class="lg:col-span-5 bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
          <h2 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2">
            <Plus class="w-4 h-4 text-indigo-600" /> Add New University
          </h2>
          
          <form method="POST" class="space-y-4 text-xs font-semibold text-slate-600">
            <input type="hidden" name="action" value="add-university" />
            
            <div class="space-y-1.5">
              <label for="uni-name" class="text-[10px] text-slate-500 uppercase tracking-wide">University Name *</label>
              <input type="text" id="uni-name" name="name" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Harvard University" />
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="space-y-1.5">
                <label for="uni-country" class="text-[10px] text-slate-500 uppercase tracking-wide">Country *</label>
                <input type="text" id="uni-country" name="country" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. United States" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-code" class="text-[10px] text-slate-500 uppercase tracking-wide">Code (lowercase) *</label>
                <input type="text" id="uni-code" name="code" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. us, gb, ca, de" />
              </div>
            </div>

            <div class="grid grid-cols-3 gap-3">
              <div class="space-y-1.5">
                <label for="uni-rank" class="text-[10px] text-slate-500 uppercase tracking-wide">World Rank</label>
                <input type="number" id="uni-rank" name="rank" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. 15" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-city" class="text-[10px] text-slate-500 uppercase tracking-wide">City *</label>
                <input type="text" id="uni-city" name="city" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. Boston" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-est" class="text-[10px] text-slate-500 uppercase tracking-wide">Est. Year</label>
                <input type="number" id="uni-est" name="established" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. 1636" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="space-y-1.5">
                <label for="uni-domain" class="text-[10px] text-slate-500 uppercase tracking-wide">Domain Course</label>
                <input type="text" id="uni-domain" name="domain" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. CS, MBA (optional)" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-students" class="text-[10px] text-slate-500 uppercase tracking-wide">Total Students</label>
                <input type="text" id="uni-students" name="students" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. 21,000+" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="space-y-1.5">
                <label for="uni-fee-min" class="text-[10px] text-slate-500 uppercase tracking-wide">Tuition Min (USD/yr)</label>
                <input type="number" step="any" id="uni-fee-min" name="tuition_min" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. 25000" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-fee-max" class="text-[10px] text-slate-500 uppercase tracking-wide">Tuition Max (USD/yr)</label>
                <input type="number" step="any" id="uni-fee-max" name="tuition_max" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. 45000" />
              </div>
            </div>

            <div class="grid grid-cols-3 gap-3">
              <div class="space-y-1.5">
                <label for="uni-gpa" class="text-[10px] text-slate-500 uppercase tracking-wide">Min GPA (%)</label>
                <input type="number" step="any" id="uni-gpa" name="min_gpa" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. 65" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-ielts" class="text-[10px] text-slate-500 uppercase tracking-wide">Min IELTS</label>
                <input type="number" step="any" id="uni-ielts" name="min_ielts" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. 6.5" />
              </div>
              <div class="space-y-1.5">
                <label for="uni-toefl" class="text-[10px] text-slate-500 uppercase tracking-wide">Min TOEFL</label>
                <input type="number" id="uni-toefl" name="min_toefl" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none" placeholder="e.g. 90" />
              </div>
            </div>

            <div class="space-y-1.5">
              <label for="uni-highlights" class="text-[10px] text-slate-500 uppercase tracking-wide">Highlights / Intakes *</label>
              <textarea id="uni-highlights" name="highlights" required rows="3" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Intakes: Sept, Jan. Leading courses in AI & Data Science. Offers $10k scholarship."></textarea>
            </div>

            <button type="submit" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-2">
              Save University
            </button>
          </form>
        </div>

        {/* List panel (7 cols) */}
        <div class="lg:col-span-7 space-y-4">
          <h2 class="text-base font-bold text-slate-800 flex items-center gap-2">
            <Landmark class="w-4 h-4 text-emerald-600" /> Active Universities Database ({universities.length})
          </h2>

          {universities.length === 0 ? (
            <p class="text-xs text-slate-500 py-6 text-center">No universities found in database.</p>
          ) : (
            <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm max-h-[70vh] overflow-y-auto">
              <table class="w-full text-left border-collapse text-xs">
                <thead>
                  <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                    <th class="px-6 py-4">Rank / Name</th>
                    <th class="px-6 py-4">Location</th>
                    <th class="px-6 py-4">Requirements</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {universities.map((u) => (
                    <tr class="hover:bg-slate-50 transition-colors">
                      <td class="px-6 py-4">
                        <div class="font-bold text-indigo-600">#{u.rank}</div>
                        <div class="font-bold text-slate-800 text-xs mt-0.5">{u.name}</div>
                        <div class="text-[10px] text-slate-500 mt-0.5 font-mono">Est: {u.established} | {u.students} students</div>
                      </td>
                      <td class="px-6 py-4">
                        <div class="font-semibold text-slate-700">{u.city}</div>
                        <div class="text-slate-500 mt-0.5">{u.country} ({u.code.toUpperCase()})</div>
                      </td>
                      <td class="px-6 py-4 space-y-1">
                        <div>GPA: <span class="font-bold text-slate-700">{u.min_gpa_percent}%</span></div>
                        <div>IELTS: <span class="font-bold text-slate-700">{u.min_ielts || "N/A"}</span></div>
                        <div>Fee: <span class="font-bold text-slate-700">${u.tuition_fee_min?.toLocaleString()} - ${u.tuition_fee_max?.toLocaleString()}</span></div>
                      </td>
                      <td class="px-6 py-4 text-right whitespace-nowrap">
                        <form method="POST" onsubmit="return confirm('Are you sure you want to remove this university?');" class="inline">
                          <input type="hidden" name="action" value="delete-university" />
                          <input type="hidden" name="id" value={u.id} />
                          <button
                            type="submit"
                            class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                            aria-label={`Delete ${u.name}`}
                          >
                            <Trash2 class="w-3.5 h-3.5" />
                          </button>
                        </form>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>

      </div>

    </main>
  </div>
</Layout>
