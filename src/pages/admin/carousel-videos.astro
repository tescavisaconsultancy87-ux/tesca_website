---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { getSupabase } from "../../utils/supabase";

const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Trash2: _s('<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>'),
  ShieldAlert: _s('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>'),
  Plus: _s('<path d="M12 5v14"/><path d="M5 12h14"/>'),
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

let carouselVideos = [];
let successMessage = "";
let errorMessage = "";

// Helper to upload file to Supabase Storage
const uploadImageToSupabase = async (photoFile: File): Promise<string> => {
  const sb = getSupabase();
  const ext = (photoFile.name.split('.').pop() || 'jpg').toLowerCase();
  const key = `carousel/${crypto.randomUUID()}.${ext}`;
  const buffer = await photoFile.arrayBuffer();

  const { error } = await sb.storage
    .from('tesca-assets')
    .upload(key, buffer, {
      contentType: photoFile.type,
      upsert: false,
    });

  if (error) throw new Error(`Storage upload failed: ${error.message}`);

  const { data } = sb.storage.from('tesca-assets').getPublicUrl(key);
  return data.publicUrl;
};

// Handle server actions (Add / Update / Delete)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-video") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const { error } = await getSupabase()
        .from('carousel_videos')
        .delete()
        .eq('id', id);

      if (error) throw error;
      successMessage = "Carousel video deleted successfully.";
    } else if (action === "add-video") {
      const title = formData.get("title")?.toString().trim();
      const videoUrl = formData.get("video_url")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;

      let thumbnailUrl = "";
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 2 * 1024 * 1024) {
          errorMessage = "Thumbnail size must be less than 2MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, JPG, WEBP and PNG images are allowed.";
        } else {
          thumbnailUrl = await uploadImageToSupabase(photoFile);
        }
      } else {
        errorMessage = "Video thumbnail image is required.";
      }

      if (!errorMessage && title && videoUrl && thumbnailUrl) {
        const { error } = await getSupabase()
          .from('carousel_videos')
          .insert({
            title,
            video_url: videoUrl,
            thumbnail_url: thumbnailUrl
          });

        if (error) throw error;
        successMessage = `Successfully added video "${title}" to carousel.`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields (Title, Video Link, and Thumbnail).";
      }
    } else if (action === "update-video") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const title = formData.get("title")?.toString().trim();
      const videoUrl = formData.get("video_url")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;
      const photoExisting = formData.get("photo_existing")?.toString().trim() || "";

      let thumbnailUrl = photoExisting;
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 2 * 1024 * 1024) {
          errorMessage = "Thumbnail size must be less than 2MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, JPG, WEBP and PNG images are allowed.";
        } else {
          thumbnailUrl = await uploadImageToSupabase(photoFile);
        }
      }

      if (!errorMessage && id && title && videoUrl && thumbnailUrl) {
        const { error } = await getSupabase()
          .from('carousel_videos')
          .update({
            title,
            video_url: videoUrl,
            thumbnail_url: thumbnailUrl
          })
          .eq('id', id);

        if (error) throw error;
        successMessage = `Successfully updated "${title}".`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields.";
      }
    }
  } catch (err: any) {
    console.error("Action error on carousel-videos page:", err);
    errorMessage = `Action failed: ${err.message || "Unknown error"}`;
  }
}

// Fetch carousel videos
try {
  const { data, error } = await getSupabase()
    .from('carousel_videos')
    .select('*')
    .order('id', { ascending: false });

  if (error) throw error;
  carouselVideos = data || [];
} catch (err) {
  console.error("Failed to load carousel videos:", err);
  errorMessage = "Failed to load database records.";
}
---

<Layout 
  title="Manage Carousel Videos | TESCA Admin"
  description="Administrative portal to manage carousel videos with redirect links on the home page."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="carousel-videos" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Manage Carousel Videos
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure success story videos with redirection links featured in the landing page carousel.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <span set:html={SVG.ShieldAlert} class="w-4 h-4 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      {/* Add New Button */}
      <button id="show-add-form-btn" class="mb-6 flex items-center gap-2 px-5 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs rounded-xl transition-all cursor-pointer shadow-sm">
        <span set:html={SVG.Plus} /> Add New Video
      </button>

      {/* Add/Edit Form Panel */}
      <div id="video-form-panel" class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm mb-8 hidden">
        <h2 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2" id="video-form-heading">
          <span set:html={SVG.Plus} class="text-indigo-600" /> Add Carousel Video
        </h2>
        <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-semibold text-slate-600">
          <input type="hidden" name="action" id="video-form-action" value="add-video" />
          <input type="hidden" name="id" id="video-edit-id" value="" />
          
          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Video Title *</label>
            <input type="text" name="title" id="v-title" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. PTE Achievement Review Video" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Video / Redirection Link *</label>
            <input type="url" name="video_url" id="v-video-url" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. https://www.youtube.com/watch?v=..." />
          </div>

          <div class="space-y-1.5 md:col-span-2">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide" id="photo-label">Thumbnail Image *</label>
            <input type="file" name="photo_file" id="v-photo-file" accept=".jpg,.jpeg,.png,.webp" class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans text-xs" />
            <input type="hidden" name="photo_existing" id="v-photo-existing" />
            <div id="photo-preview-container" class="mt-3 hidden">
              <span class="text-[9px] text-slate-400 block mb-1">Thumbnail Preview:</span>
              <img id="photo-preview" src="" class="w-32 h-20 rounded-xl object-cover border border-slate-200" />
            </div>
            <span class="text-[9px] text-slate-400 block mt-1 font-normal">Max size: 2MB. Allowed types: JPG, JPEG, PNG, WEBP.</span>
          </div>

          <div class="md:col-span-2 flex gap-3 mt-2">
            <button type="submit" id="video-submit-btn" class="flex-1 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01]">
              Add Video
            </button>
            <button type="button" id="cancel-video-edit" class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-xl transition-all cursor-pointer border border-slate-200">
              Cancel
            </button>
          </div>
        </form>
      </div>

      {/* List Videos */}
      {carouselVideos.length === 0 ? (
        <div class="bg-white border border-slate-200 rounded-3xl p-12 text-center shadow-sm">
          <p class="text-sm text-slate-500">No carousel videos found in the database. Add videos to display them in the landing page carousel alongside stories.</p>
        </div>
      ) : (
        <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
          <div class="overflow-x-auto w-full">
            <table class="w-full min-w-[750px] text-left border-collapse text-xs">
              <thead>
                <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                  <th class="px-6 py-4 w-[140px]">Thumbnail</th>
                  <th class="px-6 py-4 w-[240px]">Title</th>
                  <th class="px-6 py-4 w-[280px]">Redirection Link</th>
                  <th class="px-6 py-4 text-right w-[110px]">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 font-sans text-xs">
                {carouselVideos.map((v) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4">
                      <img src={v.thumbnail_url} alt={v.title} class="w-24 h-16 rounded-lg object-cover border border-slate-200 shadow-xs" />
                    </td>
                    <td class="px-6 py-4 font-bold text-slate-800 whitespace-nowrap">{v.title}</td>
                    <td class="px-6 py-4 text-indigo-600 font-medium truncate max-w-[280px]">
                      <a href={v.video_url} target="_blank" rel="noopener noreferrer" class="hover:underline">{v.video_url}</a>
                    </td>
                    <td class="px-6 py-4 text-right whitespace-nowrap">
                      <div class="flex items-center justify-end gap-1">
                        <button
                          type="button"
                          class="edit-video-btn p-2 text-indigo-500 hover:bg-indigo-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-indigo-200"
                          data-id={v.id}
                          data-title={v.title}
                          data-videourl={v.video_url}
                          data-photo={v.thumbnail_url}
                          aria-label={`Edit ${v.title}`}
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                        </button>
                        <form method="POST" class="inline delete-video-form">
                          <input type="hidden" name="action" value="delete-video" />
                          <input type="hidden" name="id" value={v.id} />
                          <button 
                            type="submit" 
                            class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                            aria-label={`Delete ${v.title}`}
                          >
                            <span set:html={SVG.Trash2} />
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

    </main>
  </div>
</Layout>

<script>
  function showAddForm() {
    const panel = document.getElementById("video-form-panel");
    if (panel) {
      cancelVideoForm();
      panel.classList.remove("hidden");
      document.getElementById("show-add-form-btn")?.classList.add("hidden");
      
      const formAction = document.getElementById("video-form-action") as HTMLInputElement;
      if (formAction) formAction.value = "add-video";
      
      const formHeading = document.getElementById("video-form-heading");
      if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M12 5v14"/><path d="M5 12h14"/></svg> Add Carousel Video';
      
      const submitBtn = document.getElementById("video-submit-btn");
      if (submitBtn) submitBtn.textContent = "Add Video";

      const photoLabel = document.getElementById("photo-label");
      if (photoLabel) photoLabel.textContent = "Thumbnail Image *";
      
      const fileInput = document.getElementById("v-photo-file") as HTMLInputElement;
      if (fileInput) fileInput.setAttribute("required", "required");

      panel.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function setupVideoEdit() {
    const addBtn = document.getElementById("show-add-form-btn");
    if (addBtn && !(addBtn as any)._bound) {
      (addBtn as any)._bound = true;
      addBtn.addEventListener("click", showAddForm);
    }

    const cancelBtn = document.getElementById("cancel-video-edit");
    if (cancelBtn && !(cancelBtn as any)._bound) {
      (cancelBtn as any)._bound = true;
      cancelBtn.addEventListener("click", cancelVideoForm);
    }

    // Form submit AJAX
    const form = document.querySelector("#video-form-panel form") as HTMLFormElement;
    if (form && !(form as any)._ajaxBound) {
      (form as any)._ajaxBound = true;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const submitBtn = document.getElementById("video-submit-btn") as HTMLButtonElement;
        (window as any).showBtnLoader?.(submitBtn, "Saving...");

        const formData = new FormData(form);
        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            body: formData
          });
          if (res.ok) {
            const htmlText = await res.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(htmlText, "text/html");

            const oldMain = document.querySelector("main");
            const newMain = doc.querySelector("main");
            if (oldMain && newMain) {
              oldMain.innerHTML = newMain.innerHTML;
            }

            cancelVideoForm();
            setupVideoEdit();
          }
        } catch (err) {
          console.error("Failed to submit video:", err);
          alert("An error occurred while saving the video.");
        } finally {
          if (submitBtn) {
            (window as any).hideBtnLoader?.(submitBtn);
          }
        }
      });
    }

    // Client-side file preview & validation
    const fileInput = document.getElementById("v-photo-file") as HTMLInputElement;
    if (fileInput && !(fileInput as any)._bound) {
      (fileInput as any)._bound = true;
      fileInput.addEventListener("change", () => {
        const file = fileInput.files?.[0];
        if (file) {
          if (file.size > 2 * 1024 * 1024) {
            alert("Warning: Image size must be less than 2MB.");
            fileInput.value = "";
            return;
          }
          if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(file.type)) {
            alert("Warning: Only JPEG, JPG, PNG and WEBP images are allowed.");
            fileInput.value = "";
            return;
          }
          
          const reader = new FileReader();
          reader.onload = (e) => {
            const previewContainer = document.getElementById("photo-preview-container");
            const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
            if (previewContainer && previewImg && e.target?.result) {
              previewContainer.classList.remove("hidden");
              previewImg.src = e.target.result as string;
            }
          };
          reader.readAsDataURL(file);
        }
      });
    }

    // Edit buttons handler
    const editBtns = document.querySelectorAll(".edit-video-btn");
    editBtns.forEach(btn => {
      if ((btn as any)._bound) return;
      (btn as any)._bound = true;
      btn.addEventListener("click", () => {
        const panel = document.getElementById("video-form-panel");
        if (panel) {
          panel.classList.remove("hidden");
          document.getElementById("show-add-form-btn")?.classList.add("hidden");

          const formAction = document.getElementById("video-form-action") as HTMLInputElement;
          if (formAction) formAction.value = "update-video";
          
          const formHeading = document.getElementById("video-form-heading");
          if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg> Edit Carousel Video';
          
          const submitBtn = document.getElementById("video-submit-btn");
          if (submitBtn) submitBtn.textContent = "Update Video";

          const photoLabel = document.getElementById("photo-label");
          if (photoLabel) photoLabel.textContent = "Select New Thumbnail File (Optional)";

          const fileInput = document.getElementById("v-photo-file") as HTMLInputElement;
          if (fileInput) fileInput.removeAttribute("required");

          const ds = (btn as HTMLElement).dataset;
          const editIdInput = document.getElementById("video-edit-id") as HTMLInputElement;
          if (editIdInput) editIdInput.value = ds.id || "";
          
          const titleInput = document.getElementById("v-title") as HTMLInputElement;
          if (titleInput) titleInput.value = ds.title || "";
          
          const videoUrlInput = document.getElementById("v-video-url") as HTMLInputElement;
          if (videoUrlInput) videoUrlInput.value = ds.videourl || "";
          
          const photoExistingInput = document.getElementById("v-photo-existing") as HTMLInputElement;
          if (photoExistingInput) photoExistingInput.value = ds.photo || "";

          const previewContainer = document.getElementById("photo-preview-container");
          const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
          if (previewContainer && previewImg && ds.photo) {
            previewContainer.classList.remove("hidden");
            previewImg.src = ds.photo;
          }

          panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });

    // Intercept delete forms
    const deleteForms = document.querySelectorAll("form.delete-video-form");
    deleteForms.forEach(df => {
      if ((df as any)._ajaxBound) return;
      (df as any)._ajaxBound = true;
      df.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!confirm("Are you sure you want to remove this carousel video?")) return;

        const btn = df.querySelector('button[type="submit"]') as HTMLElement;
        (window as any).showBtnLoader?.(btn);
        
        const formData = new FormData(df);
        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            body: formData
          });
          if (res.ok) {
            const htmlText = await res.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(htmlText, "text/html");

            const oldMain = document.querySelector("main");
            const newMain = doc.querySelector("main");
            if (oldMain && newMain) {
              oldMain.innerHTML = newMain.innerHTML;
            }
            setupVideoEdit();
          }
        } catch (err) {
          console.error("Failed to delete video:", err);
        }
      });
    });
  }

  function cancelVideoForm() {
    document.getElementById("video-form-panel")?.classList.add("hidden");
    document.getElementById("show-add-form-btn")?.classList.remove("hidden");
    
    const editId = document.getElementById("video-edit-id") as HTMLInputElement;
    if (editId) editId.value = "";
    
    const actionInput = document.getElementById("video-form-action") as HTMLInputElement;
    if (actionInput) actionInput.value = "add-video";

    const previewContainer = document.getElementById("photo-preview-container");
    if (previewContainer) previewContainer.classList.add("hidden");
    const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
    if (previewImg) previewImg.src = "";

    const photoExistingInput = document.getElementById("v-photo-existing") as HTMLInputElement;
    if (photoExistingInput) photoExistingInput.value = "";

    const form = document.querySelector("#video-form-panel form");
    if (form) {
      form.querySelectorAll("input").forEach(el => {
        const input = el as HTMLInputElement;
        if (input.type !== "hidden") {
          input.value = "";
        }
      });
    }
  }

  setupVideoEdit();
  document.addEventListener("astro:page-load", setupVideoEdit);
</script>
