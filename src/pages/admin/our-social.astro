---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { supabase } from "../../utils/supabase";

const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Trash2: _s('<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>'),
  ShieldAlert: _s('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>'),
  Plus: _s('<path d="M12 5v14"/><path d="M5 12h14"/>'),
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

let socialCauses = [];
let successMessage = "";
let errorMessage = "";

// Helper to upload file to Supabase Storage
const IMAGE_MAGIC_BYTES: Record<string, { magic: number[]; mime: string }> = {
  jpeg: { magic: [0xFF, 0xD8, 0xFF], mime: 'image/jpeg' },
  png: { magic: [0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A], mime: 'image/png' },
  webp: { magic: [0x52, 0x49, 0x46, 0x46], mime: 'image/webp' },
};

const detectImageType = (buffer: ArrayBuffer): string | null => {
  const bytes = new Uint8Array(buffer);
  for (const [ext, sig] of Object.entries(IMAGE_MAGIC_BYTES)) {
    if (sig.magic.every((b, i) => bytes[i] === b)) {
      return ext;
    }
  }
  return null;
};

const uploadImageToSupabase = async (photoFile: File): Promise<string> => {
  const sb = supabase;
  const buffer = await photoFile.arrayBuffer();

  const detectedExt = detectImageType(buffer);
  if (!detectedExt) {
    throw new Error("Invalid image file. Only JPEG, PNG, and WEBP formats are accepted.");
  }

  const mime = IMAGE_MAGIC_BYTES[detectedExt].mime;
  const key = `social-causes/${crypto.randomUUID()}.${detectedExt}`;

  const { error } = await sb.storage
    .from('tesca-assets')
    .upload(key, buffer, {
      contentType: mime,
      upsert: false,
    });

  if (error) {
    console.error("Storage upload failed:", error.message);
    throw new Error("Failed to upload image. Please try again.");
  }

  const { data } = sb.storage.from('tesca-assets').getPublicUrl(key);
  return data.publicUrl;
};

// Handle server actions (Add / Update / Delete)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-cause") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const { error } = await supabase
        .from('social_causes')
        .delete()
        .eq('id', id);

      if (error) throw error;
      successMessage = "Social cause link deleted successfully.";
    } else if (action === "add-cause") {
      const title = formData.get("title")?.toString().trim();
      const linkUrl = formData.get("link_url")?.toString().trim();
      const platform = formData.get("platform")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;

      let thumbnailUrl = "";
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 2 * 1024 * 1024) {
          errorMessage = "Thumbnail size must be less than 2MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, JPG, WEBP and PNG images are allowed.";
        } else {
          thumbnailUrl = await uploadImageToSupabase(photoFile);
        }
      } else {
        errorMessage = "Thumbnail image is required.";
      }

      if (!errorMessage && title && linkUrl && platform && thumbnailUrl) {
        const { error } = await supabase
          .from('social_causes')
          .insert({
            title,
            link_url: linkUrl,
            platform,
            thumbnail_url: thumbnailUrl
          });

        if (error) throw error;
        successMessage = `Successfully added "${title}" to Our Social.`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields.";
      }
    } else if (action === "update-cause") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const title = formData.get("title")?.toString().trim();
      const linkUrl = formData.get("link_url")?.toString().trim();
      const platform = formData.get("platform")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;
      const photoExisting = formData.get("photo_existing")?.toString().trim() || "";

      let thumbnailUrl = photoExisting;
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 2 * 1024 * 1024) {
          errorMessage = "Thumbnail size must be less than 2MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, JPG, WEBP and PNG images are allowed.";
        } else {
          thumbnailUrl = await uploadImageToSupabase(photoFile);
        }
      }

      if (!errorMessage && id && title && linkUrl && platform && thumbnailUrl) {
        const { error } = await supabase
          .from('social_causes')
          .update({
            title,
            link_url: linkUrl,
            platform,
            thumbnail_url: thumbnailUrl
          })
          .eq('id', id);

        if (error) throw error;
        successMessage = `Successfully updated "${title}".`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields.";
      }
    }
  } catch (err: any) {
    console.error("Action error on social-causes page:", err);
    errorMessage = "Action failed. Please try again.";
  }
}

// Fetch social causes
try {
  const { data, error } = await supabase
    .from('social_causes')
    .select('*')
    .order('id', { ascending: false });

  if (error) throw error;
  socialCauses = data || [];
} catch (err) {
  console.error("Failed to load social causes:", err);
  errorMessage = "Failed to load database records.";
}
---

<Layout 
  title="Manage Our Social | TESCA Admin"
  description="Administrative portal to manage Our Social media links on the home page."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="our-social" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Manage Our Social
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure YouTube, Instagram, and Facebook links featured under "Our Social" on the landing page.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="admin-alert-banner p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <span set:html={SVG.ShieldAlert} class="w-4 h-4 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="admin-alert-banner p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      {/* Add New Button */}
      <button id="show-add-form-btn" class="mb-6 flex items-center gap-2 px-5 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs rounded-xl transition-all cursor-pointer shadow-sm">
        <span set:html={SVG.Plus} /> Add New Social Link
      </button>

      {/* Add/Edit Form Panel */}
      <div id="cause-form-panel" class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm mb-8 hidden">
        <h2 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2" id="cause-form-heading">
          <span set:html={SVG.Plus} class="text-indigo-600" /> Add Social Link
        </h2>
        <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-semibold text-slate-600">
          <input type="hidden" name="action" id="cause-form-action" value="add-cause" />
          <input type="hidden" name="id" id="cause-edit-id" value="" />
          
          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Title *</label>
            <input type="text" name="title" id="c-title" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. Celebrating Visa Success in Vancouver" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Platform *</label>
            <select name="platform" id="c-platform" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500">
              <option value="youtube">YouTube</option>
              <option value="instagram">Instagram</option>
              <option value="facebook">Facebook</option>
            </select>
          </div>

          <div class="space-y-1.5 md:col-span-2">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">URL / Link *</label>
            <input type="url" name="link_url" id="c-link-url" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. https://www.instagram.com/p/..." />
          </div>

          <div class="space-y-1.5 md:col-span-2">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide" id="photo-label">Thumbnail Image *</label>
            <input type="file" name="photo_file" id="c-photo-file" accept=".jpg,.jpeg,.png,.webp" class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans text-xs" />
            <input type="hidden" name="photo_existing" id="c-photo-existing" />
            <div id="photo-preview-container" class="mt-2 hidden">
              <span class="text-[9px] text-slate-400 block mb-1">Current / Selected Image:</span>
              <img id="photo-preview" src="" class="w-12 h-12 rounded-full object-cover border border-slate-200" />
            </div>
            <span class="text-[9px] text-slate-400 block mt-1 font-normal">Max size: 2MB. Allowed types: JPG, JPEG, PNG, WEBP.</span>
          </div>

          <div class="md:col-span-2 flex gap-3 mt-2">
            <button type="submit" id="cause-submit-btn" class="flex-1 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01]">
              Add Link
            </button>
            <button type="button" id="cancel-cause-edit" class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-xl transition-all cursor-pointer border border-slate-200">
              Cancel
            </button>
          </div>
        </form>
      </div>

      {/* List Social Causes */}
      {socialCauses.length === 0 ? (
        <div class="bg-white border border-slate-200 rounded-3xl p-12 text-center shadow-sm">
          <p class="text-sm text-slate-500">No social media links found in the database. Add links to display them in the Our Social section on the homepage.</p>
        </div>
      ) : (
        <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
          <div class="overflow-x-auto w-full">
            <table class="w-full min-w-[750px] text-left border-collapse text-xs">
              <thead>
                <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                  <th class="px-6 py-4 w-[100px]">Photo</th>
                  <th class="px-6 py-4 w-[200px]">Title</th>
                  <th class="px-6 py-4 w-[120px]">Platform</th>
                  <th class="px-6 py-4 w-[280px]">Link URL</th>
                  <th class="px-6 py-4 text-right w-[110px]">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 font-sans text-xs">
                {socialCauses.map((c) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4">
                      <img src={c.thumbnail_url} alt={c.title} class="w-10 h-10 rounded-full object-cover border border-slate-200" />
                    </td>
                    <td class="px-6 py-4 font-bold text-slate-800 whitespace-nowrap">{c.title}</td>
                    <td class="px-6 py-4">
                      <span class={`px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide ${
                        c.platform === "youtube" ? "bg-red-100 text-red-700" :
                        c.platform === "instagram" ? "bg-pink-100 text-pink-700" :
                        "bg-blue-100 text-blue-700"
                      }`}>
                        {c.platform}
                      </span>
                    </td>
                    <td class="px-6 py-4 text-indigo-600 font-medium truncate max-w-[280px]">
                      <a href={c.link_url} target="_blank" rel="noopener noreferrer" class="hover:underline">{c.link_url}</a>
                    </td>
                    <td class="px-6 py-4 text-right whitespace-nowrap">
                      <div class="flex items-center justify-end gap-1">
                        <button
                          type="button"
                          class="edit-cause-btn p-2 text-indigo-500 hover:bg-indigo-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-indigo-200"
                          data-id={c.id}
                          data-title={c.title}
                          data-linkurl={c.link_url}
                          data-platform={c.platform}
                          data-photo={c.thumbnail_url}
                          aria-label={`Edit ${c.title}`}
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                        </button>
                        <form method="POST" class="inline delete-cause-form">
                          <input type="hidden" name="action" value="delete-cause" />
                          <input type="hidden" name="id" value={c.id} />
                          <button 
                            type="submit" 
                            class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                            aria-label={`Delete ${c.title}`}
                          >
                            <span set:html={SVG.Trash2} />
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

    </main>
  </div>
</Layout>

<script>
  import { openCropModal } from "../../scripts/image-cropper";

  function showAddForm() {
    const panel = document.getElementById("cause-form-panel");
    if (panel) {
      cancelCauseForm();
      panel.classList.remove("hidden");
      document.getElementById("show-add-form-btn")?.classList.add("hidden");
      
      const formAction = document.getElementById("cause-form-action") as HTMLInputElement;
      if (formAction) formAction.value = "add-cause";
      
      const formHeading = document.getElementById("cause-form-heading");
      if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M12 5v14"/><path d="M5 12h14"/></svg> Add Social Link';
      
      const submitBtn = document.getElementById("cause-submit-btn");
      if (submitBtn) submitBtn.textContent = "Add Link";

      const photoLabel = document.getElementById("photo-label");
      if (photoLabel) photoLabel.textContent = "Thumbnail Image *";
      
      const fileInput = document.getElementById("c-photo-file") as HTMLInputElement;
      if (fileInput) fileInput.setAttribute("required", "required");

      panel.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function initAlertDismissal() {
    const alerts = document.querySelectorAll(".bg-emerald-50, .bg-rose-50");
    alerts.forEach((alert) => {
      if ((alert as any)._timeoutId) clearTimeout((alert as any)._timeoutId);
      (alert as any)._timeoutId = setTimeout(() => {
        (alert as HTMLElement).style.transition = "opacity 0.6s ease, transform 0.6s ease";
        (alert as HTMLElement).style.opacity = "0";
        (alert as HTMLElement).style.transform = "translateY(-10px)";
        setTimeout(() => {
          alert.remove();
        }, 600);
      }, 3000);
    });
  }

  async function handleResponse(res: Response, successMsg: string) {
    if (res.ok) {
      const htmlText = await res.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(htmlText, "text/html");
      const errorBanner = doc.querySelector(".admin-alert-banner.bg-rose-50");
      if (errorBanner) {
        alert("Error: " + errorBanner.textContent.trim());
        return false;
      }
      sessionStorage.setItem("admin_alert", JSON.stringify({
        type: "success",
        message: successMsg
      }));
      window.location.href = window.location.href;
      return true;
    }
    alert("Request failed. Please try again.");
    return false;
  }

  function setupCauseEdit() {
    initAlertDismissal();
    const addBtn = document.getElementById("show-add-form-btn");
    if (addBtn && !(addBtn as any)._bound) {
      (addBtn as any)._bound = true;
      addBtn.addEventListener("click", showAddForm);
    }

    const cancelBtn = document.getElementById("cancel-cause-edit");
    if (cancelBtn && !(cancelBtn as any)._bound) {
      (cancelBtn as any)._bound = true;
      cancelBtn.addEventListener("click", cancelCauseForm);
    }

    // Form submit AJAX
    const form = document.querySelector("#cause-form-panel form") as HTMLFormElement;
    if (form && !(form as any)._ajaxBound) {
      (form as any)._ajaxBound = true;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const submitBtn = document.getElementById("cause-submit-btn") as HTMLButtonElement;
        (window as any).showBtnLoader?.(submitBtn, "Saving...");

        const formData = new FormData(form);
        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            body: formData
          });
          const action = (document.getElementById("cause-form-action") as HTMLInputElement)?.value;
          const msg = action === "update-cause" ? "Social link updated successfully." : "New social link added successfully.";
          await handleResponse(res, msg);
        } catch (err) {
          console.error("Failed to submit cause:", err);
          alert("An error occurred while saving the social link.");
        } finally {
          if (submitBtn) {
            (window as any).hideBtnLoader?.(submitBtn);
          }
        }
      });
    }

    // Client-side file validation + crop modal
    const fileInput = document.getElementById("c-photo-file") as HTMLInputElement;
    if (fileInput && !(fileInput as any)._bound) {
      (fileInput as any)._bound = true;
      fileInput.addEventListener("change", async () => {
        const file = fileInput.files?.[0];
        if (!file) return;

        if (file.size > 2 * 1024 * 1024) {
          alert("Warning: Image size must be less than 2MB.");
          fileInput.value = "";
          return;
        }
        if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(file.type)) {
          alert("Warning: Only JPEG, JPG, PNG and WEBP images are allowed.");
          fileInput.value = "";
          return;
        }

        try {
          const croppedBlob = await openCropModal({ aspectRatio: 1, file });
          const croppedFile = new File([croppedBlob], file.name.replace(/\.[^.]+$/, ".jpg"), { type: "image/jpeg" });
          const dt = new DataTransfer();
          dt.items.add(croppedFile);
          fileInput.files = dt.files;

          const reader = new FileReader();
          reader.onload = (e) => {
            const previewContainer = document.getElementById("photo-preview-container");
            const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
            if (previewContainer && previewImg && e.target?.result) {
              previewContainer.classList.remove("hidden");
              previewImg.src = e.target.result as string;
            }
          };
          reader.readAsDataURL(croppedFile);
        } catch {
          fileInput.value = "";
        }
      });
    }

    // Edit buttons handler
    const editBtns = document.querySelectorAll(".edit-cause-btn");
    editBtns.forEach(btn => {
      if ((btn as any)._bound) return;
      (btn as any)._bound = true;
      btn.addEventListener("click", () => {
        const panel = document.getElementById("cause-form-panel");
        if (panel) {
          panel.classList.remove("hidden");
          document.getElementById("show-add-form-btn")?.classList.add("hidden");

          const formAction = document.getElementById("cause-form-action") as HTMLInputElement;
          if (formAction) formAction.value = "update-cause";
          
          const formHeading = document.getElementById("cause-form-heading");
          if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg> Edit Social Link';
          
          const submitBtn = document.getElementById("cause-submit-btn");
          if (submitBtn) submitBtn.textContent = "Update Link";

          const photoLabel = document.getElementById("photo-label");
          if (photoLabel) photoLabel.textContent = "Select New Thumbnail File (Optional)";

          const fileInput = document.getElementById("c-photo-file") as HTMLInputElement;
          if (fileInput) fileInput.removeAttribute("required");

          const ds = (btn as HTMLElement).dataset;
          const editIdInput = document.getElementById("cause-edit-id") as HTMLInputElement;
          if (editIdInput) editIdInput.value = ds.id || "";
          
          const titleInput = document.getElementById("c-title") as HTMLInputElement;
          if (titleInput) titleInput.value = ds.title || "";
          
          const linkUrlInput = document.getElementById("c-link-url") as HTMLInputElement;
          if (linkUrlInput) linkUrlInput.value = ds.linkurl || "";

          const platformSelect = document.getElementById("c-platform") as HTMLSelectElement;
          if (platformSelect) platformSelect.value = ds.platform || "youtube";
          
          const photoExistingInput = document.getElementById("c-photo-existing") as HTMLInputElement;
          if (photoExistingInput) photoExistingInput.value = ds.photo || "";

          const previewContainer = document.getElementById("photo-preview-container");
          const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
          if (previewContainer && previewImg && ds.photo) {
            previewContainer.classList.remove("hidden");
            previewImg.src = ds.photo;
          }

          panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });

    // Intercept delete forms
    const deleteForms = document.querySelectorAll("form.delete-cause-form");
    deleteForms.forEach(df => {
      if ((df as any)._ajaxBound) return;
      (df as any)._ajaxBound = true;
      df.addEventListener("submit", async (e) => {
        e.preventDefault();
        const confirmed = await (window as any).showConfirmDialog({
          title: "Are you absolutely sure?",
          description: "This action cannot be undone. This will permanently remove this social cause link.",
          actionText: "Delete",
          cancelText: "Cancel",
          variant: "destructive",
          from: "bottom"
        });
        if (!confirmed) return;

        const btn = df.querySelector('button[type="submit"]') as HTMLElement;
        (window as any).showBtnLoader?.(btn);

        const params = new URLSearchParams();
        df.querySelectorAll("input[name]").forEach((el) => {
          const input = el as HTMLInputElement;
          params.append(input.name, input.value);
        });

        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: params
          });
          await handleResponse(res, "Social link deleted successfully.");
        } catch (err) {
          console.error("Failed to delete cause:", err);
        }
      });
    });
  }

  function cancelCauseForm() {
    document.getElementById("cause-form-panel")?.classList.add("hidden");
    document.getElementById("show-add-form-btn")?.classList.remove("hidden");
    
    const editId = document.getElementById("cause-edit-id") as HTMLInputElement;
    if (editId) editId.value = "";
    
    const actionInput = document.getElementById("cause-form-action") as HTMLInputElement;
    if (actionInput) actionInput.value = "add-cause";

    const previewContainer = document.getElementById("photo-preview-container");
    if (previewContainer) previewContainer.classList.add("hidden");
    const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
    if (previewImg) previewImg.src = "";

    const photoExistingInput = document.getElementById("c-photo-existing") as HTMLInputElement;
    if (photoExistingInput) photoExistingInput.value = "";

    const form = document.querySelector("#cause-form-panel form");
    if (form) {
      form.querySelectorAll("input, select").forEach(el => {
        const input = el as HTMLInputElement;
        if (input.type !== "hidden") {
          input.value = "";
        }
      });
      const platformSelect = document.getElementById("c-platform") as HTMLSelectElement;
      if (platformSelect) platformSelect.value = "youtube";
    }
  }

  setupCauseEdit();
  document.addEventListener("astro:page-load", setupCauseEdit);
</script>
