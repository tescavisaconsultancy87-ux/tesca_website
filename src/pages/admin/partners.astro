---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { supabase } from "../../utils/supabase";

// Inline SVG helpers — no lucide-react in .astro (SSR hook errors)
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Trash2: _s('<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>'),
  Eye: _s('<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>'),
  Calendar: _s('<rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>'),
  User: _s('<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'),
  Phone: _s('<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4a2 2 0 0 1 2-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>'),
  Mail: _s('<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>'),
  X: _s('<path d="M18 6 6 18"/><path d="m6 6 12 12"/>'),
  MapPin: _s('<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>'),
  Award: _s('<circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>'),
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

let inquiries = [];
let successMessage = "";
let errorMessage = "";

// Handle server actions
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-inquiry") {
      const id = formData.get("id")?.toString() || "";
      const { error } = await supabase
        .from('leads')
        .delete()
        .eq('id', id);

      if (error) throw error;
      successMessage = "Partnership inquiry removed successfully.";
    } else if (action === "update-status") {
      const id = formData.get("id")?.toString() || "";
      const status = formData.get("status")?.toString().trim();
      
      const { error } = await supabase
        .from('leads')
        .update({ status })
        .eq('id', id);

      if (error) throw error;
      successMessage = "Inquiry status updated successfully.";
    }
  } catch (err: any) {
    console.error("Failed to process partner inquiry action:", err);
    errorMessage = `Failed to complete action: ${err.message || "Unknown error"}`;
  }
}

// Fetch partner inquiries
try {
  const { data, error } = await supabase
    .from('leads')
    .select('*')
    .eq('lead_type', 'partner')
    .order('created_at', { ascending: false });

  if (error) throw error;
  inquiries = data || [];
} catch (err) {
  console.error("Failed to load partner inquiries from Supabase:", err);
  errorMessage = "Failed to load database records.";
}
---

<Layout 
  title="Partnership Inquiries | TESCA Admin"
  description="Administrative dashboard to view business partnership and franchise applications."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="partners" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Title & Info */}
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
          <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
            Partnership Inquiries
          </h1>
          <p class="text-slate-500 text-xs mt-1">Review B2B Franchise applications, sub-agent submissions, and proposals.</p>
        </div>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="admin-alert-banner p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6">
          {errorMessage}
        </div>
      )}
      {successMessage && (
        <div class="admin-alert-banner p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      {/* Table */}
      {inquiries.length === 0 ? (
        <div class="bg-white border border-slate-200 rounded-3xl p-12 text-center">
          <p class="text-sm text-slate-500">No partnership inquiries found in the database.</p>
        </div>
      ) : (
        <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm">
          <div class="overflow-x-auto w-full">
            <table class="w-full min-w-[900px] text-left border-collapse text-xs">
              <thead>
                <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                  <th class="px-6 py-4 w-[160px]">Submitted At</th>
                  <th class="px-6 py-4 w-[180px]">Partnership Model</th>
                  <th class="px-6 py-4 w-[160px]">Applicant Name</th>
                  <th class="px-6 py-4 w-[180px]">Contact Info</th>
                  <th class="px-6 py-4 w-[140px]">City / Location</th>
                  <th class="px-6 py-4 w-[120px]">Status</th>
                  <th class="px-6 py-4 text-right w-[140px]">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {inquiries.map((inquiry) => {
                  let details: any = {};
                  try {
                    details = JSON.parse(inquiry.details || "{}");
                  } catch (e) {}

                  const model = details.partnershipModel || "Franchise Partner";
                  const city = details.city || "Not specified";

                  let modelBg = "bg-sky-50 text-sky-700 border-sky-200";
                  if (model.toLowerCase().includes("sub-agent")) {
                    modelBg = "bg-violet-50 text-violet-700 border-violet-200";
                  }

                  const formattedDate = new Date(inquiry.created_at || Date.now()).toLocaleString("en-IN", {
                    timeZone: "Asia/Kolkata",
                    dateStyle: "medium",
                    timeStyle: "short"
                  });

                  return (
                    <tr class="hover:bg-slate-50 transition-colors">
                      <td class="px-6 py-4 text-slate-600 whitespace-nowrap">
                        <span class="flex items-center gap-1.5">
                          <span class="text-slate-400" set:html={SVG.Calendar} />
                          {formattedDate}
                        </span>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <span class={`px-2.5 py-1 rounded-full border text-[10px] font-bold tracking-wide ${modelBg}`}>
                          {model}
                        </span>
                      </td>
                      <td class="px-6 py-4 font-bold text-slate-800 whitespace-nowrap">
                        <span class="flex items-center gap-1.5">
                          <span class="text-slate-400" set:html={SVG.User} />
                          {inquiry.name}
                        </span>
                      </td>
                      <td class="px-6 py-4 space-y-1">
                        <div class="flex items-center gap-1.5 text-slate-600">
                          <span class="text-slate-400" set:html={SVG.Phone} />
                          <span>{inquiry.phone}</span>
                        </div>
                        {inquiry.email && (
                          <div class="flex items-center gap-1.5 text-slate-500">
                            <span class="text-slate-400" set:html={SVG.Mail} />
                            <span>{inquiry.email}</span>
                          </div>
                        )}
                      </td>
                      <td class="px-6 py-4 text-slate-600 whitespace-nowrap">
                        <span class="flex items-center gap-1.5">
                          <span class="text-slate-400" set:html={SVG.MapPin} />
                          {city}
                        </span>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <form method="POST" class="inline-block relative status-update-form">
                          <input type="hidden" name="action" value="update-status" />
                          <input type="hidden" name="id" value={inquiry.id} />
                          <input type="hidden" name="status" value={inquiry.status || "pending"} />
                          
                          <div class="relative inline-block text-left custom-dropdown">
                            <button
                              type="button"
                              class={`status-dropdown-trigger flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-bold tracking-wide focus:outline-none transition-all duration-200 hover:brightness-95 cursor-pointer ` +
                                (inquiry.status === 'completed' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' :
                                 inquiry.status === 'not_available' ? 'bg-slate-100 text-slate-600 border-slate-200' :
                                 inquiry.status === 'follow up' ? 'bg-violet-50 text-violet-700 border-violet-200' :
                                 'bg-amber-50 text-amber-700 border-amber-200')}
                              aria-haspopup="true"
                              aria-expanded="false"
                            >
                              <span>
                                {inquiry.status === 'completed' ? 'Completed' :
                                 inquiry.status === 'not_available' ? 'Not Available' :
                                 inquiry.status === 'follow up' ? 'Follow Up' :
                                 'Pending'}
                              </span>
                              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 dropdown-arrow"><path d="m6 9 6 6 6-6"/></svg>
                            </button>

                            <div 
                              class="dropdown-menu-content absolute left-0 mt-1.5 w-36 rounded-xl border border-slate-200 bg-white shadow-lg p-1 focus:outline-none opacity-0 scale-95 translate-y-[-4px] pointer-events-none transition-all duration-200 ease-out z-30"
                              role="menu"
                            >
                              <div class="text-[8px] font-bold text-slate-400 px-2 py-0.5 uppercase tracking-wider">Change Status</div>
                              <div class="space-y-0.5">
                                <button 
                                  type="button" 
                                  role="menuitem"
                                  data-value="pending"
                                  class={`flex w-full items-center justify-between rounded-lg px-2 py-1 text-[10px] font-bold text-left transition-colors cursor-pointer ` + 
                                    (inquiry.status === 'pending' || !inquiry.status ? 'bg-amber-50 text-amber-700' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900')}
                                >
                                  Pending
                                  {(inquiry.status === 'pending' || !inquiry.status) && <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>}
                                </button>

                                <button 
                                  type="button" 
                                  role="menuitem"
                                  data-value="not_available"
                                  class={`flex w-full items-center justify-between rounded-lg px-2 py-1 text-[10px] font-bold text-left transition-colors cursor-pointer ` + 
                                    (inquiry.status === 'not_available' ? 'bg-slate-100 text-slate-700' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900')}
                                >
                                  Not Available
                                  {inquiry.status === 'not_available' && <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>}
                                </button>

                                <button 
                                  type="button" 
                                  role="menuitem"
                                  data-value="follow up"
                                  class={`flex w-full items-center justify-between rounded-lg px-2 py-1 text-[10px] font-bold text-left transition-colors cursor-pointer ` + 
                                    (inquiry.status === 'follow up' ? 'bg-violet-50 text-violet-700' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900')}
                                >
                                  Follow Up
                                  {inquiry.status === 'follow up' && <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>}
                                </button>

                                <button 
                                  type="button" 
                                  role="menuitem"
                                  data-value="completed"
                                  class={`flex w-full items-center justify-between rounded-lg px-2 py-1 text-[10px] font-bold text-left transition-colors cursor-pointer ` + 
                                    (inquiry.status === 'completed' ? 'bg-emerald-50 text-emerald-700' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900')}
                                >
                                  Completed
                                  {inquiry.status === 'completed' && <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>}
                                </button>
                              </div>
                            </div>
                          </div>
                        </form>
                      </td>
                      <td class="px-6 py-4 text-right whitespace-nowrap space-x-1.5">
                        <button
                          type="button"
                          class="view-details-btn px-3 py-1.5 bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-800 rounded-lg transition-all cursor-pointer font-bold inline-flex items-center gap-1 border border-slate-200"
                          data-details={inquiry.details}
                          data-name={inquiry.name}
                          data-type={model}
                          data-status={inquiry.status || "pending"}
                        >
                          <span set:html={SVG.Eye} /> View Details
                        </button>
                        <form method="POST" class="inline delete-inquiry-form">
                          <input type="hidden" name="action" value="delete-inquiry" />
                          <input type="hidden" name="id" value={inquiry.id} />
                          <button
                            type="submit"
                            class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                            aria-label="Delete inquiry"
                          >
                            <span set:html={SVG.Trash2} />
                          </button>
                        </form>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}

    </main>

    {/* Details Modal Overlay */}
    <div id="details-modal" class="hidden fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm flex items-center justify-center p-4">
      <div class="bg-white border border-slate-200 w-full max-w-2xl rounded-3xl shadow-xl overflow-hidden flex flex-col max-h-[85vh] text-left">
        <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 bg-slate-50">
          <div>
            <h3 class="text-base font-extrabold text-slate-800" id="modal-title">Partnership details</h3>
            <p class="text-[10px] text-indigo-600 font-bold uppercase tracking-wider mt-0.5" id="modal-subtitle">Model</p>
          </div>
          <button id="close-modal-btn" class="p-1.5 hover:bg-slate-100 text-slate-400 hover:text-slate-600 rounded-xl transition-colors cursor-pointer">
            <span set:html={SVG.X} />
          </button>
        </div>

        <div class="p-6 overflow-y-auto space-y-4 text-sm" id="modal-content-list">
          {/* Populated via client-side JavaScript */}
        </div>

        <div class="px-6 py-4 border-t border-slate-200 bg-slate-50/60 text-right">
          <button id="close-modal-footer-btn" class="px-5 py-2.5 bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-800 rounded-xl transition-all cursor-pointer text-xs font-bold border border-slate-200">
            Close Details
          </button>
        </div>
      </div>
    </div>

  </div>
</Layout>

<script>
  function setupModal() {
    const viewButtons = document.querySelectorAll(".view-details-btn");
    const modal = document.getElementById("details-modal");
    const modalTitle = document.getElementById("modal-title");
    const modalSubtitle = document.getElementById("modal-subtitle");
    const modalContent = document.getElementById("modal-content-list");
    const closeBtn = document.getElementById("close-modal-btn");
    const closeFooterBtn = document.getElementById("close-modal-footer-btn");

    const openModal = (btn: Element) => {
      const name = btn.getAttribute("data-name") || "Partner Details";
      const type = btn.getAttribute("data-type") || "Partnership Model";
      const status = btn.getAttribute("data-status") || "pending";
      const detailsRaw = btn.getAttribute("data-details") || "{}";

      const escapeHTML = (str: string) => {
        const div = document.createElement("div");
        div.textContent = str;
        return div.innerHTML;
      };

      if (modalTitle) modalTitle.innerText = name;
      if (modalSubtitle) modalSubtitle.innerText = type;

      if (modalContent) {
        modalContent.innerHTML = "";
        try {
          const details = JSON.parse(detailsRaw);
          
          // Map properties to a premium list key/value pair
          const listContainer = document.createElement("div");
          listContainer.className = "grid grid-cols-1 sm:grid-cols-2 gap-4";

          // Status Item
          const statusItem = document.createElement("div");
          statusItem.className = "bg-slate-50 border border-slate-200 p-3.5 rounded-2xl space-y-1 col-span-1 sm:col-span-2";
          statusItem.innerHTML = `
            <span class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">Inquiry Status</span>
            <span class="inline-block px-2.5 py-1 rounded-full border text-[10px] font-bold tracking-wide ${
              status === 'completed' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' :
              status === 'not_available' ? 'bg-slate-100 text-slate-600 border-slate-200' :
              status === 'follow up' ? 'bg-violet-50 text-violet-700 border-violet-200' :
              'bg-amber-50 text-amber-700 border-amber-200'
            }">${escapeHTML(status === 'not_available' ? 'Not Available' : status.charAt(0).toUpperCase() + status.slice(1))}</span>
          `;
          listContainer.appendChild(statusItem);

          Object.entries(details).forEach(([key, val]) => {
            // Format keys beautifully
            const formattedKey = key
              .replace(/([A-Z])/g, " $1")
              .replace(/_/g, " ")
              .replace(/^\w/, c => c.toUpperCase());

            let formattedVal = "";
            if (Array.isArray(val)) {
              formattedVal = val.join(", ");
            } else if (typeof val === "object" && val !== null) {
              formattedVal = JSON.stringify(val);
            } else {
              formattedVal = String(val);
            }

            if (!formattedVal.trim() || formattedVal === "null" || formattedVal === "undefined") {
              formattedVal = "Not provided";
            }

            const item = document.createElement("div");
            item.className = "bg-slate-50 border border-slate-200 p-3.5 rounded-2xl space-y-1";
            item.innerHTML = `
              <span class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider">${escapeHTML(formattedKey)}</span>
              <span class="block text-xs font-semibold text-slate-700 leading-normal">${escapeHTML(formattedVal)}</span>
            `;
            listContainer.appendChild(item);
          });

          modalContent.appendChild(listContainer);
        } catch (e) {
          modalContent.innerText = "Error parsing partnership details.";
        }
      }

      modal?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
      modal?.classList.add("hidden");
      document.body.style.overflow = "";
    };

    viewButtons.forEach(btn => {
      btn.addEventListener("click", () => openModal(btn));
    });

    closeBtn?.addEventListener("click", closeModal);
    closeFooterBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });
  }

  async function handleResponse(res: Response, successMsg: string) {
    if (res.ok) {
      const htmlText = await res.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(htmlText, "text/html");
      const errorBanner = doc.querySelector(".bg-rose-50");
      if (errorBanner) {
        alert("Error: " + errorBanner.textContent.trim());
        return false;
      }
      sessionStorage.setItem("admin_alert", JSON.stringify({
        type: "success",
        message: successMsg
      }));
      window.location.href = window.location.href;
      return true;
    }
    alert("Request failed. Please try again.");
    return false;
  }

  function setupPartnersPage() {
    setupModal();

    const forms = document.querySelectorAll("form");
    forms.forEach(form => {
      if ((form as any)._ajaxBound) return;
      (form as any)._ajaxBound = true;



      // Bind custom dropdown menu interactions
      const dropdown = form.querySelector('.custom-dropdown');
      if (dropdown) {
        const trigger = dropdown.querySelector(".status-dropdown-trigger") as HTMLButtonElement;
        const statusInput = form.querySelector('input[name="status"]') as HTMLInputElement;

        trigger?.addEventListener("click", (e) => {
          e.stopPropagation();
          // Close other dropdowns
          document.querySelectorAll(".custom-dropdown").forEach(other => {
            if (other !== dropdown) other.classList.remove("open");
          });
          dropdown.classList.toggle("open");
        });

        const items = dropdown.querySelectorAll("[role='menuitem']");
        items.forEach(item => {
          item.addEventListener("click", async (e) => {
            e.stopPropagation();
            const val = item.getAttribute("data-value") || "pending";
            const prevVal = statusInput.value || "pending";

            if (val === prevVal) {
              dropdown.classList.remove("open");
              return;
            }

            // Update UI trigger text and colors
            const spanText = trigger.querySelector("span");
            if (spanText) {
              spanText.textContent = item.textContent?.trim() || "";
            }
            trigger.className = `status-dropdown-trigger flex items-center gap-1.5 px-2.5 py-1 rounded-full border text-[10px] font-bold tracking-wide focus:outline-none transition-all duration-200 hover:brightness-95 cursor-pointer ` +
              (val === 'completed' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' :
               val === 'not_available' ? 'bg-slate-100 text-slate-600 border-slate-200' :
               val === 'follow up' ? 'bg-violet-50 text-violet-700 border-violet-200' :
               'bg-amber-50 text-amber-700 border-amber-200');

            // Apply selected background to items
            items.forEach(btn => {
              const bVal = btn.getAttribute("data-value");
              btn.className = `flex w-full items-center justify-between rounded-lg px-2 py-1 text-[10px] font-bold text-left transition-colors cursor-pointer `;
              if (bVal === val) {
                btn.classList.add(
                  val === 'completed' ? 'bg-emerald-50' :
                  val === 'not_available' ? 'bg-slate-100' :
                  val === 'follow up' ? 'bg-violet-50' :
                  'bg-amber-50'
                );
                btn.classList.add(
                  val === 'completed' ? 'text-emerald-700' :
                  val === 'not_available' ? 'text-slate-700' :
                  val === 'follow up' ? 'text-violet-700' :
                  'text-amber-700'
                );
                // Ensure checkmark SVG is there
                if (!btn.querySelector("svg")) {
                  const checkSvg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
                  checkSvg.setAttribute("width", "10");
                  checkSvg.setAttribute("height", "10");
                  checkSvg.setAttribute("viewBox", "0 0 24 24");
                  checkSvg.setAttribute("fill", "none");
                  checkSvg.setAttribute("stroke", "currentColor");
                  checkSvg.setAttribute("stroke-width", "3");
                  checkSvg.setAttribute("stroke-linecap", "round");
                  checkSvg.setAttribute("stroke-linejoin", "round");
                  checkSvg.innerHTML = '<path d="M20 6 9 17l-5-5"/>';
                  btn.appendChild(checkSvg);
                }
              } else {
                btn.classList.add('text-slate-600', 'hover:bg-slate-50', 'hover:text-slate-900');
                const existingCheck = btn.querySelector("svg");
                if (existingCheck) btn.removeChild(existingCheck);
              }
            });

            statusInput.value = val;
            dropdown.classList.remove("open");

            const formData = new FormData(form);
            try {
              const res = await fetch(window.location.href, {
                method: "POST",
                body: formData
              });
              await handleResponse(res, "Inquiry status updated successfully.");
            } catch (err) {
              console.error("AJAX status update error:", err);
            }
          });
        });
      }

      // Intercept delete submit
      if (form.classList.contains("delete-inquiry-form")) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const confirmed = await (window as any).showConfirmDialog({
            title: "Are you absolutely sure?",
            description: "This action cannot be undone. This will permanently delete this partnership inquiry.",
            actionText: "Delete",
            cancelText: "Cancel",
            variant: "destructive",
            from: "bottom"
          });
          if (!confirmed) return;

          const btn = form.querySelector('button[type="submit"]') as HTMLElement;
          (window as any).showBtnLoader?.(btn);

          const formData = new FormData(form);
          try {
            const res = await fetch(window.location.href, {
              method: "POST",
              body: formData
            });
            await handleResponse(res, "Inquiry removed successfully.");
          } catch (err) {
            console.error("AJAX delete inquiry error:", err);
          }
        });
      }
    });
    // Close dropdowns on clicking outside
    document.addEventListener("click", () => {
      document.querySelectorAll(".custom-dropdown").forEach(dropdown => {
        dropdown.classList.remove("open");
      });
    });
  }

  // Bind handlers
  setupPartnersPage();
  document.addEventListener("astro:page-load", setupPartnersPage);
</script>

<style is:global>
  /* Custom animated dropdown styling */
  .custom-dropdown .dropdown-menu-content {
    opacity: 0;
    transform: scale(0.95) translateY(-4px);
    pointer-events: none;
    transition: opacity 0.2s cubic-bezier(0.16, 1, 0.3, 1), transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: top left;
  }
  .custom-dropdown.open .dropdown-menu-content {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }
  .custom-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
  }
</style>
