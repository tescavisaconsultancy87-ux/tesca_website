---
import Layout from "../../layouts/Layout.astro";
import AdminHeader from "../../components/AdminHeader.astro";
import { checkAdminAuth } from "../../utils/adminAuth";
import { supabase } from "../../utils/supabase";

const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  Trash2: _s('<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>'),
  ShieldAlert: _s('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>'),
  Plus: _s('<path d="M12 5v14"/><path d="M5 12h14"/>'),
};

// Check session
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (!isAuthenticated) {
  return Astro.redirect("/admin");
}

let galleryImages = [];
let successMessage = "";
let errorMessage = "";
let classroomCount = 0;
let campusCount = 0;

// Fallback images used by the public gallery when DB is empty
const fallbackClassroom = [
  { title: "Personal Career Counselling", desc: "One-on-one guidance to help students choose the right country, university, and career pathway.", img: "/images/consultation_gallery.webp" },
  { title: "Student Departure Support", desc: "Comprehensive assistance for travel planning, documentation checks, and departure readiness.", img: "/images/student_abroad_new.webp" },
  { title: "Pre-Visa Preparation", desc: "Expert guidance on visa requirements, documentation, and interview preparation.", img: "/images/services_hero_gallery.webp" },
  { title: "Academic Profile Evaluation", desc: "Detailed assessment of academic records and eligibility for study abroad opportunities.", img: "/images/consultation_new.webp" },
  { title: "IELTS Practice & Assessment", desc: "Real exam-style mock tests designed to improve language proficiency and exam readiness.", img: "/images/testprep_hero_new.webp" },
  { title: "University Admission Support", desc: "Professional assistance with university selection, applications, and admission processes.", img: "/images/university_support.webp" },
  { title: "Visa Documentation Support", desc: "Step-by-step help with SOPs, financial documents, and visa application requirements.", img: "/images/visa_support.webp" },
  { title: "Scholarship Guidance Services", desc: "Helping students identify and apply for scholarships to reduce study costs.", img: "/images/scholarship_new.webp" },
  { title: "Study Abroad Workshops", desc: "Informative seminars covering admissions, visas, scholarships, and student life abroad.", img: "/images/workshop_new.webp" },
  { title: "Career Planning Sessions", desc: "Personalized advice to align education choices with long-term career goals.", img: "/images/consultation.webp" }
];

const fallbackCampus = [
  { title: "Successful Student Placements", desc: "Celebrating students who achieved admissions and visa approvals for their dream destinations.", img: "/images/graduating_students_new.webp" },
  { title: "Global Education Opportunities", desc: "Exploring international study destinations and future career possibilities worldwide.", img: "/images/global_new.webp" },
  { title: "Pre-Departure Orientation", desc: "Preparing students for life abroad through practical guidance and support sessions.", img: "/images/pre_new.webp" },
  { title: "Admission Success Milestones", desc: "Supporting students from application submission to receiving university offer letters.", img: "/images/milestone_new.webp" },
  { title: "International Student Network", desc: "Connecting aspiring students with alumni and current international students for guidance.", img: "/images/mock_new.webp" },
  { title: "Application Review Support", desc: "Ensuring applications are complete, accurate, and ready for university submission.", img: "/images/support_new.webp" },
  { title: "English Language Training", desc: "Expert coaching for IELTS, PTE, TOEFL, and Spoken English improvement.", img: "/images/training_new.webp" },
  { title: "Visa Interview Coaching", desc: "Mock interviews and confidence-building sessions for successful visa outcomes.", img: "/images/coaching_new.webp" },
  { title: "Student Success Community", desc: "A supportive environment where students share experiences and achievements.", img: "/images/community_new.webp" },
  { title: "Global Study Pathways", desc: "Guiding students toward internationally recognized qualifications and career growth.", img: "/images/pathways_new.webp" }
];

// Helper to upload file to Supabase Storage
const uploadImageToSupabase = async (photoFile: File): Promise<string> => {
  const sb = supabase;
  const ext = (photoFile.name.split('.').pop() || 'jpg').toLowerCase();
  const key = `gallery/${crypto.randomUUID()}.${ext}`;
  const buffer = await photoFile.arrayBuffer();

  const { error } = await sb.storage
    .from('tesca-assets')
    .upload(key, buffer, {
      contentType: photoFile.type,
      upsert: false,
    });

  if (error) throw new Error(`Storage upload failed: ${error.message}`);

  const { data } = sb.storage.from('tesca-assets').getPublicUrl(key);
  return data.publicUrl;
};

// Handle server actions (Add / Update / Delete)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "delete-image") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const { error } = await supabase
        .from('gallery_images')
        .delete()
        .eq('id', id);

      if (error) throw error;
      successMessage = "Gallery image deleted successfully.";
    } else if (action === "add-image") {
      const title = formData.get("title")?.toString().trim();
      const description = formData.get("description")?.toString().trim() || "";
      const category = formData.get("category")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;

      let imageUrl = "";
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 2 * 1024 * 1024) {
          errorMessage = "Image size must be less than 2MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, JPG, WEBP and PNG images are allowed.";
        } else {
          imageUrl = await uploadImageToSupabase(photoFile);
        }
      } else {
        errorMessage = "Image file is required.";
      }

      if (!errorMessage && title && imageUrl && category) {
        const { error } = await supabase
          .from('gallery_images')
          .insert({
            title,
            description,
            image_url: imageUrl,
            category
          });

        if (error) throw error;
        successMessage = `Successfully added "${title}" to gallery.`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields (Title, Category, and Image).";
      }
    } else if (action === "import-fallbacks") {
      const category = formData.get("category")?.toString();
      const images = category === "campus" ? fallbackCampus : fallbackClassroom;
      let imported = 0;
      for (const img of images) {
        const { error } = await supabase
          .from('gallery_images')
          .insert({
            title: img.title,
            description: img.desc,
            image_url: img.img,
            category: category || "classroom"
          });
        if (!error) imported++;
      }
      if (imported > 0) {
        successMessage = `Successfully imported ${imported} ${category === "campus" ? "campus" : "classroom"} images to the database.`;
      } else {
        errorMessage = "Failed to import images. They may already exist.";
      }
    } else if (action === "update-image") {
      const id = parseInt(formData.get("id")?.toString() || "0");
      const title = formData.get("title")?.toString().trim();
      const description = formData.get("description")?.toString().trim() || "";
      const category = formData.get("category")?.toString().trim();
      const photoFile = formData.get("photo_file") as File;
      const photoExisting = formData.get("photo_existing")?.toString().trim() || "";

      let imageUrl = photoExisting;
      if (photoFile && photoFile.size > 0) {
        if (photoFile.size > 2 * 1024 * 1024) {
          errorMessage = "Image size must be less than 2MB.";
        } else if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(photoFile.type)) {
          errorMessage = "Only JPEG, JPG, WEBP and PNG images are allowed.";
        } else {
          imageUrl = await uploadImageToSupabase(photoFile);
        }
      }

      if (!errorMessage && id && title && imageUrl && category) {
        const { error } = await supabase
          .from('gallery_images')
          .update({
            title,
            description,
            image_url: imageUrl,
            category
          })
          .eq('id', id);

        if (error) throw error;
        successMessage = `Successfully updated "${title}".`;
      } else if (!errorMessage) {
        errorMessage = "Please fill in all required fields.";
      }
    }
  } catch (err: any) {
    console.error("Action error on gallery page:", err);
    errorMessage = `Action failed: ${err.message || "Unknown error"}`;
  }
}

// Fetch gallery images
try {
  const { data, error } = await supabase
    .from('gallery_images')
    .select('*')
    .order('id', { ascending: false });

  if (error) throw error;
  galleryImages = data || [];
  classroomCount = galleryImages.filter(i => i.category === 'classroom').length;
  campusCount = galleryImages.filter(i => i.category === 'campus').length;
} catch (err) {
  console.error("Failed to load gallery images:", err);
  errorMessage = "Failed to load database records.";
}
---

<Layout 
  title="Manage Gallery | TESCA Admin"
  description="Administrative portal to manage photo gallery images on classroom moments and campus success."
  showNavFooter={false}
>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col lg:flex-row">
    <AdminHeader activeTab="gallery" />

    <main class="flex-1 px-4 md:px-8 py-10 overflow-y-auto text-left lg:ml-64">
      
      {/* Title block */}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800">
          Manage Gallery Images
        </h1>
        <p class="text-slate-500 text-xs mt-1">Configure classroom training sessions and campus placement photos featured on the gallery page.</p>
      </div>

      {/* Messages */}
      {errorMessage && (
        <div class="admin-alert-banner p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-xs font-semibold mb-6 flex items-center gap-2">
          <span set:html={SVG.ShieldAlert} class="w-4 h-4 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}
      {successMessage && (
        <div class="admin-alert-banner p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-600 text-xs font-semibold mb-6">
          {successMessage}
        </div>
      )}

      {/* Add New Button */}
      <button id="show-add-form-btn" class="mb-6 flex items-center gap-2 px-5 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs rounded-xl transition-all cursor-pointer shadow-sm">
        <span set:html={SVG.Plus} /> Add New Gallery Image
      </button>

      {/* Add/Edit Form Panel */}
      <div id="gallery-form-panel" class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm mb-8 hidden">
        <h2 class="text-base font-bold text-slate-800 mb-4 flex items-center gap-2" id="gallery-form-heading">
          <span set:html={SVG.Plus} class="text-indigo-600" /> Add Gallery Image
        </h2>
        <form method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-semibold text-slate-600">
          <input type="hidden" name="action" id="gallery-form-action" value="add-image" />
          <input type="hidden" name="id" id="gallery-edit-id" value="" />
          
          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Image Title *</label>
            <input type="text" name="title" id="g-title" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="e.g. IELTS Coaching Session" />
          </div>

          <div class="space-y-1.5">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Category *</label>
            <select name="category" id="g-category" required class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 cursor-pointer">
              <option value="classroom">Classroom Moments</option>
              <option value="campus">Global Placements & Campus Success</option>
            </select>
          </div>
          
          <div class="space-y-1.5 md:col-span-2">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide">Short Description (Optional)</label>
            <textarea name="description" id="g-description" rows="2" class="w-full px-3 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans" placeholder="Brief details about this picture..."></textarea>
          </div>

          <div class="space-y-1.5 md:col-span-2">
            <label class="text-[10px] text-slate-500 uppercase tracking-wide" id="photo-label">Select Image File *</label>
            <input type="file" name="photo_file" id="g-photo-file" accept=".jpg,.jpeg,.png,.webp" class="w-full px-3 py-2 rounded-lg border border-slate-200 bg-slate-50 text-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500 font-sans text-xs" />
            <input type="hidden" name="photo_existing" id="g-photo-existing" />
            <div id="photo-preview-container" class="mt-3 hidden">
              <span class="text-[9px] text-slate-400 block mb-1">Image Preview:</span>
              <img id="photo-preview" src="" class="w-32 h-20 rounded-xl object-cover border border-slate-200" />
            </div>
            <span class="text-[9px] text-slate-400 block mt-1 font-normal">Max size: 2MB. Allowed types: JPG, JPEG, PNG, WEBP.</span>
          </div>

          <div class="md:col-span-2 flex gap-3 mt-2">
            <button type="submit" id="gallery-submit-btn" class="flex-1 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01]">
              Add Image
            </button>
            <button type="button" id="cancel-gallery-edit" class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-xl transition-all cursor-pointer border border-slate-200">
              Cancel
            </button>
          </div>
        </form>
      </div>

      {/* List Images */}
      {galleryImages.length > 0 && (
        <div class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm mb-8">
          <div class="overflow-x-auto w-full">
            <table class="w-full min-w-[750px] text-left border-collapse text-xs">
              <thead>
                <tr class="bg-slate-50 text-slate-500 border-b border-slate-200 font-bold uppercase tracking-wider">
                  <th class="px-6 py-4 w-[140px]">Preview</th>
                  <th class="px-6 py-4 w-[220px]">Title</th>
                  <th class="px-6 py-4 w-[160px]">Category</th>
                  <th class="px-6 py-4 w-[220px]">Description</th>
                  <th class="px-6 py-4 text-right w-[110px]">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 font-sans text-xs">
                {galleryImages.map((g) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4">
                      <img src={g.image_url} alt={g.title} class="w-24 h-16 rounded-lg object-cover border border-slate-200 shadow-xs" />
                    </td>
                    <td class="px-6 py-4 font-bold text-slate-800 whitespace-nowrap">{g.title}</td>
                    <td class="px-6 py-4 text-slate-600 whitespace-nowrap capitalize">
                      {g.category === "classroom" ? "Classroom Moments" : "Campus Success"}
                    </td>
                    <td class="px-6 py-4 text-slate-500 line-clamp-2 max-w-[220px] py-6 leading-relaxed">
                      {g.description || <span class="italic text-slate-350">No description</span>}
                    </td>
                    <td class="px-6 py-4 text-right whitespace-nowrap">
                      <div class="flex items-center justify-end gap-1">
                        <button
                          type="button"
                          class="edit-image-btn p-2 text-indigo-500 hover:bg-indigo-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-indigo-200"
                          data-id={g.id}
                          data-title={g.title}
                          data-description={g.description || ""}
                          data-category={g.category}
                          data-photo={g.image_url}
                          aria-label={`Edit ${g.title}`}
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                        </button>
                        <form method="POST" class="inline delete-image-form">
                          <input type="hidden" name="action" value="delete-image" />
                          <input type="hidden" name="id" value={g.id} />
                          <button 
                            type="submit" 
                            class="p-2 text-rose-500 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer border border-transparent hover:border-rose-200"
                            aria-label={`Delete ${g.title}`}
                          >
                            <span set:html={SVG.Trash2} />
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* Import fallback sections - shown per category when that category has 0 images */}
      <div class="space-y-8">
        {classroomCount === 0 && (
          <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
            <div class="flex items-center justify-between mb-2">
              <h2 class="text-base font-bold text-slate-800">Classroom Moments (Static Fallbacks)</h2>
              <button type="button" class="import-fallbacks-btn px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-[11px] rounded-xl transition-all cursor-pointer shadow-sm" data-category="classroom">
                Import All to Database
              </button>
            </div>
            <p class="text-xs text-slate-500 mb-6">Import these images to enable editing, deleting, and dashboard counting.</p>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
              {fallbackClassroom.map((item) => (
                <div class="rounded-xl overflow-hidden border border-slate-200 bg-slate-50 text-left">
                  <img src={item.img} alt={item.title} class="w-full h-24 object-cover" />
                  <div class="p-3">
                    <p class="text-[11px] font-bold text-slate-700 leading-tight">{item.title}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
        {campusCount === 0 && (
          <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
            <div class="flex items-center justify-between mb-2">
              <h2 class="text-base font-bold text-slate-800">Global Placements & Campus Success (Static Fallbacks)</h2>
              <button type="button" class="import-fallbacks-btn px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-[11px] rounded-xl transition-all cursor-pointer shadow-sm" data-category="campus">
                Import All to Database
              </button>
            </div>
            <p class="text-xs text-slate-500 mb-6">Import these images to enable editing, deleting, and dashboard counting.</p>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
              {fallbackCampus.map((item) => (
                <div class="rounded-xl overflow-hidden border border-slate-200 bg-slate-50 text-left">
                  <img src={item.img} alt={item.title} class="w-full h-24 object-cover" />
                  <div class="p-3">
                    <p class="text-[11px] font-bold text-slate-700 leading-tight">{item.title}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

    </main>
  </div>
</Layout>

<script>
  import { openCropModal } from "../../scripts/image-cropper";

  function showAddForm() {
    const panel = document.getElementById("gallery-form-panel");
    if (panel) {
      cancelGalleryForm();
      panel.classList.remove("hidden");
      document.getElementById("show-add-form-btn")?.classList.add("hidden");
      
      const formAction = document.getElementById("gallery-form-action") as HTMLInputElement;
      if (formAction) formAction.value = "add-image";
      
      const formHeading = document.getElementById("gallery-form-heading");
      if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M12 5v14"/><path d="M5 12h14"/></svg> Add Gallery Image';
      
      const submitBtn = document.getElementById("gallery-submit-btn");
      if (submitBtn) submitBtn.textContent = "Add Image";

      const photoLabel = document.getElementById("photo-label");
      if (photoLabel) photoLabel.textContent = "Select Image File *";
      
      const fileInput = document.getElementById("g-photo-file") as HTMLInputElement;
      if (fileInput) fileInput.setAttribute("required", "required");

      panel.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  async function handleResponse(res: Response, successMsg: string) {
    if (res.ok) {
      const htmlText = await res.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(htmlText, "text/html");
      const errorBanner = doc.querySelector(".bg-rose-50");
      if (errorBanner) {
        alert("Error: " + errorBanner.textContent.trim());
        return false;
      }
      sessionStorage.setItem("admin_alert", JSON.stringify({
        type: "success",
        message: successMsg
      }));
      window.location.href = window.location.href;
      return true;
    }
    alert("Request failed. Please try again.");
    return false;
  }

  function setupGalleryEdit() {
    const addBtn = document.getElementById("show-add-form-btn");
    if (addBtn && !(addBtn as any)._bound) {
      (addBtn as any)._bound = true;
      addBtn.addEventListener("click", showAddForm);
    }

    const cancelBtn = document.getElementById("cancel-gallery-edit");
    if (cancelBtn && !(cancelBtn as any)._bound) {
      (cancelBtn as any)._bound = true;
      cancelBtn.addEventListener("click", cancelGalleryForm);
    }

    // Form submit AJAX
    const form = document.querySelector("#gallery-form-panel form") as HTMLFormElement;
    if (form && !(form as any)._ajaxBound) {
      (form as any)._ajaxBound = true;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const submitBtn = document.getElementById("gallery-submit-btn") as HTMLButtonElement;
        (window as any).showBtnLoader?.(submitBtn, "Saving...");

        const formData = new FormData(form);
        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            body: formData
          });
          const action = (document.getElementById("gallery-form-action") as HTMLInputElement)?.value;
          const msg = action === "update-image" ? "Gallery image updated successfully." : "New gallery image added successfully.";
          await handleResponse(res, msg);
        } catch (err) {
          console.error("Failed to submit image:", err);
          alert("An error occurred while saving the gallery image.");
        } finally {
          if (submitBtn) {
            (window as any).hideBtnLoader?.(submitBtn);
          }
        }
      });
    }

    // Client-side file validation + crop modal
    const fileInput = document.getElementById("g-photo-file") as HTMLInputElement;
    if (fileInput && !(fileInput as any)._bound) {
      (fileInput as any)._bound = true;
      fileInput.addEventListener("change", async () => {
        const file = fileInput.files?.[0];
        if (!file) return;

        if (file.size > 2 * 1024 * 1024) {
          alert("Warning: Image size must be less than 2MB.");
          fileInput.value = "";
          return;
        }
        if (!["image/jpeg", "image/png", "image/jpg", "image/webp"].includes(file.type)) {
          alert("Warning: Only JPEG, JPG, PNG and WEBP images are allowed.");
          fileInput.value = "";
          return;
        }

        const category = (document.getElementById("g-category") as HTMLSelectElement)?.value || "classroom";
        const aspectRatio = category === "campus" ? 16 / 10 : 4 / 3;

        try {
          const croppedBlob = await openCropModal({ aspectRatio, file });
          const croppedFile = new File([croppedBlob], file.name.replace(/\.[^.]+$/, ".jpg"), { type: "image/jpeg" });
          const dt = new DataTransfer();
          dt.items.add(croppedFile);
          fileInput.files = dt.files;

          const reader = new FileReader();
          reader.onload = (e) => {
            const previewContainer = document.getElementById("photo-preview-container");
            const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
            if (previewContainer && previewImg && e.target?.result) {
              previewContainer.classList.remove("hidden");
              previewImg.src = e.target.result as string;
            }
          };
          reader.readAsDataURL(croppedFile);
        } catch {
          fileInput.value = "";
        }
      });
    }

    // Edit buttons handler
    const editBtns = document.querySelectorAll(".edit-image-btn");
    editBtns.forEach(btn => {
      if ((btn as any)._bound) return;
      (btn as any)._bound = true;
      btn.addEventListener("click", () => {
        const panel = document.getElementById("gallery-form-panel");
        if (panel) {
          panel.classList.remove("hidden");
          document.getElementById("show-add-form-btn")?.classList.add("hidden");

          const formAction = document.getElementById("gallery-form-action") as HTMLInputElement;
          if (formAction) formAction.value = "update-image";
          
          const formHeading = document.getElementById("gallery-form-heading");
          if (formHeading) formHeading.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-indigo-600"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg> Edit Gallery Image';
          
          const submitBtn = document.getElementById("gallery-submit-btn");
          if (submitBtn) submitBtn.textContent = "Update Image";

          const photoLabel = document.getElementById("photo-label");
          if (photoLabel) photoLabel.textContent = "Select New Image File (Optional)";

          const fileInput = document.getElementById("g-photo-file") as HTMLInputElement;
          if (fileInput) fileInput.removeAttribute("required");

          const ds = (btn as HTMLElement).dataset;
          const editIdInput = document.getElementById("gallery-edit-id") as HTMLInputElement;
          if (editIdInput) editIdInput.value = ds.id || "";
          
          const titleInput = document.getElementById("g-title") as HTMLInputElement;
          if (titleInput) titleInput.value = ds.title || "";
          
          const descInput = document.getElementById("g-description") as HTMLTextAreaElement;
          if (descInput) descInput.value = ds.description || "";
          
          const categorySelect = document.getElementById("g-category") as HTMLSelectElement;
          if (categorySelect) categorySelect.value = ds.category || "classroom";
          
          const photoExistingInput = document.getElementById("g-photo-existing") as HTMLInputElement;
          if (photoExistingInput) photoExistingInput.value = ds.photo || "";

          const previewContainer = document.getElementById("photo-preview-container");
          const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
          if (previewContainer && previewImg && ds.photo) {
            previewContainer.classList.remove("hidden");
            previewImg.src = ds.photo;
          }

          panel.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });

    // Import fallbacks buttons
    const importBtns = document.querySelectorAll(".import-fallbacks-btn");
    importBtns.forEach(btn => {
      if ((btn as any)._bound) return;
      (btn as any)._bound = true;
      btn.addEventListener("click", async () => {
        const category = (btn as HTMLElement).dataset.category || "classroom";
        if (!confirm(`Import all ${category} images to the database?`)) return;

        (btn as HTMLButtonElement).disabled = true;
        btn.textContent = "Importing...";

        const params = new URLSearchParams();
        params.append("action", "import-fallbacks");
        params.append("category", category);

        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: params
          });
          await handleResponse(res, `Successfully imported ${category} images to the database.`);
        } catch (err) {
          console.error("Failed to import images:", err);
          alert("Import failed. Please try again.");
        }
      });
    });

    // Intercept delete forms
    const deleteForms = document.querySelectorAll("form.delete-image-form");
    deleteForms.forEach(df => {
      if ((df as any)._ajaxBound) return;
      (df as any)._ajaxBound = true;
      df.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!confirm("Are you sure you want to remove this gallery image?")) return;

        const btn = df.querySelector('button[type="submit"]') as HTMLElement;
        (window as any).showBtnLoader?.(btn);

        const params = new URLSearchParams();
        df.querySelectorAll("input[name]").forEach((el) => {
          const input = el as HTMLInputElement;
          params.append(input.name, input.value);
        });

        try {
          const res = await fetch(window.location.href, {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: params
          });
          await handleResponse(res, "Gallery image deleted successfully.");
        } catch (err) {
          console.error("Failed to delete image:", err);
        }
      });
    });
  }

  function cancelGalleryForm() {
    document.getElementById("gallery-form-panel")?.classList.add("hidden");
    document.getElementById("show-add-form-btn")?.classList.remove("hidden");
    
    const editId = document.getElementById("gallery-edit-id") as HTMLInputElement;
    if (editId) editId.value = "";
    
    const actionInput = document.getElementById("gallery-form-action") as HTMLInputElement;
    if (actionInput) actionInput.value = "add-image";

    const previewContainer = document.getElementById("photo-preview-container");
    if (previewContainer) previewContainer.classList.add("hidden");
    const previewImg = document.getElementById("photo-preview") as HTMLImageElement;
    if (previewImg) previewImg.src = "";

    const photoExistingInput = document.getElementById("g-photo-existing") as HTMLInputElement;
    if (photoExistingInput) photoExistingInput.value = "";

    const form = document.querySelector("#gallery-form-panel form");
    if (form) {
      form.querySelectorAll("input, textarea, select").forEach(el => {
        const input = el as HTMLInputElement;
        if (input.type !== "hidden" && input.id !== "g-category") {
          input.value = "";
        }
      });
      const categorySelect = document.getElementById("g-category") as HTMLSelectElement;
      if (categorySelect) categorySelect.value = "classroom";
    }
  }

  setupGalleryEdit();
  document.addEventListener("astro:page-load", setupGalleryEdit);
</script>
