---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import EligibilityForm from "../components/EligibilityForm";
import AICounsellor from "../components/AICounsellor";
---

<Layout
  title="University Eligibility Finder | TESCA Study Destinations"
  description="Input your academic profile and tuition budget to see eligible universities and scholarship opportunities across USA, UK, Canada, Australia, Germany, and more."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12">
    <!-- Header Banner -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-gradient-to-br from-slate-50 to-blue-50/30 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-8 items-center p-6 sm:p-8 md:p-12 relative mb-10 sm:mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      <div class="md:col-span-7 space-y-6 relative z-10">
        <span class="inline-block text-xs font-bold tracking-wider text-accent-indigo bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          Admissions Eligibility Finder
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Check Your University Match in 2 Minutes
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          Enter your academic scores, test results, and budget details to instantly discover which world-class partner universities you qualify for.
        </p>
      </div>
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-center">
        <div class="relative w-full max-w-[320px] md:max-w-[400px] flex items-center aspect-[4/3] rounded-2xl overflow-hidden shadow-md border border-accent-blue/15">
          <img 
            src="/images/universities_hero.png" 
            alt="Check Eligibility" 
            class="object-cover w-full h-full select-none"
          />
        </div>
      </div>
    </div>

    <!-- Interactive Finder Form (client-side React) -->
    <EligibilityForm client:only="react" />
  </section>

  <AICounsellor client:only="react" />
</Layout>
