---
import Layout from "../../layouts/Layout.astro";
import AICounsellor from "../../components/AICounsellor";
import { SERVICES, getServiceBySlug } from "../../data/services";
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8">${d}</svg>`;
const iconMap: Record<string, string> = {
  User: _s('<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'),
  GraduationCap: _s('<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>'),
  FileText: _s('<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>'),
  Award: _s('<circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>'),
  BookOpen: _s('<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>'),
  Briefcase: _s('<path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/>'),
  Heart: _s('<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>'),
  Landmark: _s('<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="22"/><line x1="10" x2="10" y1="18" y2="22"/><line x1="14" x2="14" y1="18" y2="22"/><line x1="18" x2="18" y1="18" y2="22"/><polygon points="12 2 20 7 4 7"/>'),
  Home: _s('<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>'),
  Plane: _s('<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3.5c-.5-.5-2.5 0-4 1.5L13.5 8.5 5.3 6.7c-.7-.2-1.5.1-1.8.8-.4.9 0 2 .7 2.4l7.1 3.7-2.8 2.8-3.7-.7c-.5-.1-1.1.2-1.2.7-.2.6 0 1.3.5 1.7l3.2 2 2 3.2c.4.5 1 .6 1.7.5.5-.1.8-.7.7-1.2l-.7-3.7 2.8-2.8 3.7 7.1c.4.7 1.5 1 2.4.7.6-.3.9-1.1.8-1.8Z"/>'),
};
const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  ChevronRight: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-accent-blue shrink-0 mt-0.5"><path d="m9 18 6-6-6-6"/></svg>`,
};

export const prerender = true;

export function getStaticPaths() {
  return SERVICES.map(s => ({
    params: { slug: s.id },
    props: { service: s }
  }));
}

const { service } = Astro.props;

if (!service) {
  return Astro.redirect("/404");
}

const ServiceIcon = iconMap[service.icon] || iconMap.User;
---

<Layout
  title={`${service.title} | TESCA Visa Consultancy`}
  description={service.desc}
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-12 text-left">
    <!-- Back Link -->
    <a href="/services" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Services
    </a>

    <!-- Service Header -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>

      <div class="relative z-10 flex items-start gap-6 flex-col sm:flex-row">
        <div class={`p-4 rounded-2xl ${service.color} shrink-0`}>
          <span set:html={ServiceIcon} />
        </div>
        <div class="space-y-3">
          <h1 class="text-[32px] sm:text-[42px] font-extrabold font-display text-support-white tracking-tight leading-none">
            {service.title}
          </h1>
          <p class="text-base md:text-lg text-support-gray font-sans font-normal leading-relaxed max-w-2xl">
            {service.desc}
          </p>
        </div>
      </div>
    </div>

    <!-- Detailed Content -->
    <div class="rounded-3xl p-8 md:p-12 bg-white border border-slate-200/80 shadow-sm mb-12">
      <h2 class="text-xl font-bold text-slate-800 font-display mb-6">What's Included</h2>
      <div class="space-y-4">
        {service.detailedContent.map((item) => (
          <div class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 border border-slate-100">
            <span set:html={SVG.ChevronRight} />
            <p class="text-sm md:text-base text-slate-700 font-sans font-normal leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Need Assistance CTA -->
    <div class="rounded-3xl p-8 md:p-12 bg-gradient-to-br from-accent-blue/5 to-accent-indigo/5 border border-accent-blue/20 shadow-sm text-center">
      <div class="max-w-lg mx-auto space-y-4">
        <h2 class="text-2xl md:text-3xl font-bold font-display text-support-white tracking-tight">Need Assistance?</h2>
        <p class="text-sm md:text-base text-support-gray font-sans font-normal leading-relaxed">
          Our expert counselors are here to guide you through every step of your study abroad journey.
          Book a free consultation today.
        </p>
        <div class="pt-2">
          <button
            type="button"
            onclick="window.openCounsellorForm?.()"
            class="px-8 py-3.5 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-full shadow-md hover:scale-[1.02] transition-all cursor-pointer font-sans inline-flex items-center gap-2"
          >
            Book a Consultation
          </button>
        </div>
      </div>
    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
