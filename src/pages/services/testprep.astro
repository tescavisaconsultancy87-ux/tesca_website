---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import AICounsellor from "../../components/AICounsellor";
import IELTSBandCalculator from "../../components/IELTSBandCalculator";
const SVG = {
  BookOpen: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  Mic: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>`,
  Languages: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>`,
  Globe: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  Calculator: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>`,
  Download: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`
};
---

<Layout
  title="IELTS & PTE Coaching Academy | Study Abroad Prep | TESCA"
  description="Master IELTS, PTE, and Spoken English. Practice with overall band calculators, simulated mock test papers, and audio speaking modules."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 py-12">
    <!-- Premium Header Banner Card -->
    <div
      class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-8 items-center p-8 md:p-12 relative mb-16"
    >
      {/* Subtle Background Auroras */}
      <div
        class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"
      >
      </div>

      {/* Left Column: Text Content */}
      <div class="md:col-span-7 space-y-6 text-left relative z-10">
        <span
          class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase"
        >
          Interactive Test Prep
        </span>
        <h1
          class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none"
        >
          TESCA Test Prep Academy
        </h1>
        <p
          class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl"
        >
          Train using predictive scoring engines. Average student scores
          increase from 6.0 to 7.5 within 24 study cycles.
        </p>
      </div>

      {/* Right Column: Hero Image cutout */}
      <div
        class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-center"
      >
        <div
          class="relative w-full max-w-[320px] md:max-w-[400px] flex items-center aspect-[4/3] rounded-2xl overflow-hidden shadow-md border border-accent-blue/15"
        >
          <img
            src="/images/testprep_hero.webp"
            alt="Study abroad test preparation"
            class="object-cover w-full h-full select-none"
          />
        </div>
      </div>
    </div>

    {/* Test Cards Grid */}
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16 items-start"
      id="ielts"
    >
      {
        [
          {
            name: "IELTS",
            id: "ielts",
            desc: "International English Language Testing System — Academic & General Training.",
            color: "from-accent-blue to-accent-indigo",
            bg: "bg-accent-blue/5",
            text: "text-accent-blue",
            icon: SVG.BookOpen,
            detailedContent: [
              "Covers both IELTS Academic and IELTS General Training modules.",
              "Comprehensive coverage of Listening, Reading, Writing, and Speaking sections.",
              "Includes 20+ full-length computerized mock tests and detailed band scoring feedback.",
              "Interactive speaking simulators with personalized assessment and pronunciation reviews."
            ]
          },
          {
            name: "PTE",
            id: "pte",
            desc: "Pearson Test of English — Fast, computer-based, accepted globally.",
            color: "from-blue-500 to-blue-600",
            bg: "bg-blue-50",
            text: "text-blue-600",
            icon: SVG.Mic,
            detailedContent: [
              "Fully computer-based with automated AI scoring mapping university standards.",
              "Dedicated practice on Speaking & Writing, Reading, and Listening modules.",
              "Real-time PTE AI scoring engine access to benchmark performance instantly.",
              "Fast-track results preparation (average score release in less than 48 hours)."
            ]
          },

          {
            name: "Spoken English",
            id: "spoken-english",
            desc: "Fluency & pronunciation coaching for interviews and daily communication.",
            color: "from-purple-500 to-purple-600",
            bg: "bg-purple-50",
            text: "text-purple-600",
            icon: SVG.Globe,
            detailedContent: [
              "Fluency building exercises, vocabulary enrichment, and accent training.",
              "Simulated corporate job interviews, group discussions, and public speaking coaching.",
              "Personalized feedback on vocabulary usage, sentence structures, and body language.",
              "Confidence booster drills to remove speaking hesitation and communication barriers."
            ]
          },
          {
            name: "French",
            id: "french",
            desc: "DELF/DALF preparation — Open doors to French-speaking institutions.",
            color: "from-indigo-500 to-indigo-600",
            bg: "bg-indigo-50",
            text: "text-indigo-600",
            icon: SVG.Languages,
            detailedContent: [
              "DELF/DALF certification preparation across levels A1 to C2.",
              "Structured practice modules for writing, reading, listening, and conversational skills.",
              "Native-level aligned curriculum and official practice resources.",
              "Preparation for bilingual university admissions and PR immigration interviews."
            ]
          },
        ].map((test) => {
          const Icon = test.icon;
          return (
            <div
              id={`test-${test.id}`}
              class={`rounded-3xl p-8 transition-all duration-500 flex flex-col justify-between items-start border border-slate-200/80 shadow-sm relative overflow-hidden group ${test.bg}`}
            >
              <div class="w-full">
                <div class="space-y-4">
                  <div
                    class={`p-3.5 rounded-xl ${test.bg} ${test.text} inline-block`}
                  >
                    <span set:html={test.icon} />
                  </div>
                  <h3 class="text-[20px] lg:text-[24px] font-bold text-slate-800 font-display leading-snug">
                    {test.name}
                  </h3>
                  <p class="text-[15px] text-slate-600 leading-relaxed font-sans font-normal">
                    {test.desc}
                  </p>
                </div>
                
                <div class="test-details max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
                  <div class="pt-6 border-t border-slate-200/40 mt-4 space-y-4 text-left">
                    <h4 class="text-xs font-bold font-sans uppercase tracking-wider text-slate-800 mb-2">Preparation Breakdown:</h4>
                    <ul class="space-y-2.5">
                      {test.detailedContent.map((item) => (
                        <li class="flex items-start gap-2 text-sm text-slate-600 font-sans font-normal leading-relaxed">
                          <span class={`w-1.5 h-1.5 rounded-full shrink-0 mt-2 bg-current ${test.text}`}></span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                    <div class="pt-4 flex items-center justify-between gap-4 border-t border-slate-100/50 mt-4">
                      <span class="text-xs font-semibold text-slate-500 font-sans">Ready to score?</span>
                      <button
                        type="button"
                        onclick="window.openCounsellorForm?.()"
                        class={`px-4 py-2 text-white font-semibold text-xs rounded-full shadow-sm hover:scale-[1.02] transition-all cursor-pointer font-sans ${test.id === 'ielts' ? 'bg-accent-blue hover:bg-accent-indigo' : test.id === 'pte' ? 'bg-blue-600 hover:bg-blue-700' : test.id === 'german' ? 'bg-amber-600 hover:bg-amber-700' : test.id === 'spoken-english' ? 'bg-purple-600 hover:bg-purple-700' : 'bg-indigo-600 hover:bg-indigo-700'}`}
                      >
                        Start Prep
                      </button>
                    </div>
                  </div>
                </div>
              </div>
              
              <button 
                type="button"
                data-target={`test-${test.id}`}
                class={`test-toggle-btn text-[15px] font-semibold font-sans tracking-wide ${test.text} hover:text-slate-800 inline-flex items-center gap-1 pt-4 cursor-pointer focus:outline-none`}
              >
                <span class="btn-text">Learn More</span> <span class="arrow-icon transition-transform duration-300">→</span>
              </button>
            </div>
          );
        })
      }
    </div>

    {/* IELTS Band Calculator Section */}
    <div id="ielts-engine" class="scroll-mt-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch mb-16">
        {/* Band Calculator Widget */}
        <div
          class="lg:col-span-7 rounded-3xl p-6 md:p-8 flex flex-col justify-between space-y-6 text-left bg-gradient-to-br from-[#F5FAFA] to-white border border-[#E6F2F3]"
        >
          <div class="flex items-center gap-2.5">
            <div class="p-2 rounded-lg bg-accent-blue/10 text-accent-blue flex items-center justify-center">
              <span set:html={SVG.Calculator} />
            </div>
            <div>
              <h3
                class="text-xl lg:text-[24px] font-bold text-slate-800 font-display tracking-tight"
              >
                IELTS Band Calculator
              </h3>
              <p class="text-xs text-slate-500 font-sans font-normal">
                Evaluate overall band score indices
              </p>
            </div>
          </div>

          <IELTSBandCalculator client:load />
        </div>

        {/* Connect with Counsellor */}
        <div
          class="lg:col-span-5 rounded-3xl p-6 md:p-8 flex flex-col justify-between space-y-6 text-left bg-white border border-slate-200 shadow-sm"
        >
          <div class="flex items-center gap-3">
            <div class="p-3 rounded-xl bg-accent-blue/10 text-accent-indigo">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-6 h-6"
                ><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
                ></path><circle cx="12" cy="7" r="4"></circle></svg
              >
            </div>
            <div>
              <h3
                class="text-xl lg:text-[24px] font-bold text-slate-800 font-display tracking-tight"
              >
                Connect with Counsellor
              </h3>
              <p class="text-xs text-slate-500 font-sans font-normal">
                Get personalised test prep guidance
              </p>
            </div>
          </div>

          <p
            class="text-sm text-slate-600 font-sans font-normal leading-relaxed"
          >
            Talk to our expert counsellors to build a customised test
            preparation plan tailored to your target score and university
            requirements.
          </p>

          <div class="space-y-3 pt-2">
            <div
              class="flex items-center gap-3 p-3 rounded-xl bg-slate-50 border border-slate-100"
            >
              <div class="p-2 rounded-lg bg-accent-blue/10 text-accent-indigo">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-4 h-4"
                  ><path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                  ></path></svg
                >
              </div>
              <div>
                <span
                  class="block text-sm font-semibold text-slate-800 font-display"
                  >9824152731</span
                >
                <span class="text-xs text-slate-500 font-sans font-normal"
                  >Call us for free counselling</span
                >
              </div>
            </div>
            <button
              onclick="window.openCounsellorForm?.()"
              class="flex items-center justify-center gap-2 w-full py-3 bg-accent-blue text-white font-semibold text-sm rounded-xl shadow-sm hover:scale-[1.01] transition-transform duration-200 cursor-pointer"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-4 h-4"
                ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
              >
              Book a Free Consultation
            </button>
          </div>
        </div>
      </div>
    </div>

    {/* Practice Resources Portal */}
    <div
      class="rounded-3xl p-8 md:p-12 space-y-8 relative overflow-hidden text-left bg-gradient-to-br from-slate-50 to-slate-100 border border-slate-200"
    >
      <div
        class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pb-6 border-b border-slate-200"
      >
        <div class="space-y-1">
          <span
            class="text-sm font-semibold text-accent-blue uppercase tracking-wider font-sans"
            >Syllabus & Downloads</span
          >
          <h3
            class="text-[24px] lg:text-[28px] font-bold font-display text-slate-800 tracking-tight"
          >
            Practice Resources
          </h3>
        </div>
        <p
          class="text-sm text-slate-500 font-sans font-normal max-w-sm leading-relaxed"
        >
          High-end prep books, authentic mock materials, and sample audio
          archives updated for 2026 guidelines.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          [
            {
              title: "IELTS Speaking Cue Cards",
              desc: "Comprehensive speaking cue cards with model answers, structures, and vocabulary for IELTS speaking tasks.",
              size: "1.4 MB PDF",
              downloads: "Free Download",
              file: "/material/IELTS-Speaking-Cue-Cards.pdf",
            },
            {
              title: "IELTS Vocabulary Cheat Sheet (Top 100)",
              desc: "Highly curated list of top 100 IELTS vocabulary words with definitions, synonyms, and practical sentence examples.",
              size: "2.9 MB PDF",
              downloads: "Free Download",
              file: "/material/IELTS-Vocabulary-Cheat-Sheet-Top-100-Words.pdf",
            },
            {
              title: "IELTS Writing Task 2 Templates",
              desc: "Premium high-scoring structural templates and vocabulary frameworks for IELTS Writing Task 2 essays.",
              size: "1.3 MB PDF",
              downloads: "Free Download",
              file: "/material/task_2 template.pdf",
            },
          ].map((doc) => (
            <div class="p-6 rounded-2xl border border-slate-200 bg-white flex flex-col justify-between space-y-4 hover:border-accent-blue/30 transition-all duration-300 shadow-sm">
              <div class="space-y-2">
                <h4 class="text-base lg:text-lg font-bold text-slate-800 font-display leading-snug">
                  {doc.title}
                </h4>
                <p class="text-sm text-slate-600 leading-relaxed font-sans font-normal">
                  {doc.desc}
                </p>
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-slate-100">
                <div>
                  <span class="block text-xs text-slate-500 font-sans font-medium">
                    {doc.size}
                  </span>
                  <span class="block text-xs text-accent-blue font-sans font-semibold">
                    {doc.downloads}
                  </span>
                </div>
                <a
                  href={doc.file}
                  download
                  class="p-2.5 rounded-lg bg-accent-blue/10 hover:bg-accent-blue hover:text-white text-accent-blue transition-colors cursor-pointer flex items-center justify-center"
                  aria-label={`Download ${doc.title}`}
                >
                  <span set:html={SVG.Download} class="w-4 h-4 flex items-center justify-center" />
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <AICounsellor client:only="react" />
</Layout>

<script>
  function setupTestToggles() {
    const toggleButtons = document.querySelectorAll('.test-toggle-btn');
    toggleButtons.forEach(btn => {
      // Avoid duplicate event listeners by replacing with clone
      const newBtn = btn.cloneNode(true);
      btn.parentNode?.replaceChild(newBtn, btn);
    });

    const newToggleButtons = document.querySelectorAll('.test-toggle-btn');
    newToggleButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const cardId = btn.getAttribute('data-target');
        if (!cardId) return;
        const card = document.getElementById(cardId);
        if (!card) return;

        const details = card.querySelector('.test-details') as HTMLElement;
        const btnText = btn.querySelector('.btn-text') as HTMLElement;
        const arrow = btn.querySelector('.arrow-icon') as HTMLElement;

        if (details && btnText && arrow) {
          const isExpanded = details.style.maxHeight && details.style.maxHeight !== '0px';

          if (!isExpanded) {
            // Collapse all other expanded test cards
            const allCards = document.querySelectorAll('[id^="test-"]');
            allCards.forEach(otherCard => {
              if (otherCard.id !== cardId) {
                const otherDetails = otherCard.querySelector('.test-details') as HTMLElement;
                const otherBtn = otherCard.querySelector('.test-toggle-btn');
                if (otherDetails && otherDetails.style.maxHeight && otherDetails.style.maxHeight !== '0px') {
                  otherDetails.style.maxHeight = '0px';
                  if (otherBtn) {
                    const otherBtnText = otherBtn.querySelector('.btn-text');
                    const otherArrow = otherBtn.querySelector('.arrow-icon') as HTMLElement;
                    if (otherBtnText) otherBtnText.textContent = 'Learn More';
                    if (otherArrow) otherArrow.style.transform = 'rotate(0deg)';
                  }
                  otherCard.classList.remove('border-accent-blue/30', 'shadow-md', 'scale-[1.01]', 'bg-white/95');
                }
              }
            });
          }

          if (isExpanded) {
            // Collapse
            details.style.maxHeight = '0px';
            btnText.textContent = 'Learn More';
            arrow.style.transform = 'rotate(0deg)';
            card.classList.remove('border-accent-blue/30', 'shadow-md', 'scale-[1.01]', 'bg-white/95');
          } else {
            // Expand
            details.style.maxHeight = details.scrollHeight + 'px';
            btnText.textContent = 'Show Less';
            arrow.style.transform = 'rotate(90deg)';
            card.classList.add('border-accent-blue/30', 'shadow-md', 'scale-[1.01]', 'bg-white/95');
          }
        }
      });
    });
  }

  // Initial setup
  setupTestToggles();
  // Listen for view transitions if enabled
  document.addEventListener('astro:page-load', setupTestToggles);
  document.addEventListener('astro:after-swap', setupTestToggles);
</script>
