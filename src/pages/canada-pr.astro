---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-600"><polyline points="20 6 9 17 4 12"/></svg>`
};
---

<Layout 
  title="Canada Permanent Residency (PR) Services | TESCA Visa Consultancy"
  description="Navigate Express Entry and Provincial Nominee Programs (PNP) with professional immigration consultancies. CRS score audits and ECA assistance."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left">
    
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          PR & Immigration
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Canada Permanent Residency
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          Unlock your pathway to Canada. We provide comprehensive points calculation, coordinate Educational Credential Assessments (ECA via WES), and guide your Express Entry profile filing.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      
      <div class="lg:col-span-2 space-y-12 font-sans">
        
        <!-- Highlights -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Express Entry</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Optimizing CRS scores across Federal Skilled Worker (FSW) and Canadian Experience Class (CEC) programs.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Provincial Nominee (PNP)</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Targeting express-entry linked provincial pathways (Ontario, BC, Alberta, Saskatchewan) to secure a +600 CRS point boost.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">ECA & IELTS Audit</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Managing your WES profile verification and planning strategies to hit CLB 9+ targets in IELTS.</p>
          </div>
        </div>

        <!-- Requirements checklist -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Immigration Checklist</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              "ECA Evaluation Certificate (WES, CES, or IQAS)",
              "IELTS General Training test results (target CLB 9+)",
              "Minimum 1 year of continuous skilled work experience",
              "Reference Letters matching NOC TEER classifications",
              "Proof of Funds (as per federal family size thresholds)",
              "Clean Medicals and Police Clearance Certificates (PCC)"
            ].map(doc => (
              <div class="flex items-center gap-3 p-4 rounded-xl border border-slate-100 bg-white shadow-sm">
                <div class="p-1 rounded-full bg-emerald-50 text-emerald-600">
                  <span set:html={SVG.Check} />
                </div>
                <span class="text-xs font-semibold text-slate-700">{doc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Process Timeline -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Express Entry Filing Timeline</h2>
          <div class="relative pl-6 border-l-2 border-slate-200 space-y-8">
            {[
              "Complete ECA credential assessment and language examinations",
              "Calculate estimated CRS score and submit online Express Entry Profile",
              "Apply for PNP nominations (optional, for score enhancement)",
              "Receive Invitation to Apply (ITA) in the federal draw",
              "Submit full electronic PR Application (e-APR) within 60 days of ITA"
            ].map((step, idx) => (
              <div class="relative">
                <div class="absolute -left-[31px] top-0 w-4 h-4 rounded-full bg-accent-blue border-4 border-white shadow-sm"></div>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Phase {idx + 1}</span>
                <p class="text-sm font-semibold text-slate-700 mt-1">{step}</p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="space-y-6 sticky top-28 font-sans">
        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-1">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Evaluate Canada PR Eligibility</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-normal">
              Check if you score the minimum <strong>67 points</strong> required for the Federal Skilled Worker (FSW) pool.
            </p>
          </div>

          <form id="fsw-form" class="space-y-4 text-xs text-slate-700">
            <!-- Language Level -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Language Level (CLB/IELTS)</label>
              <select id="fsw-lang" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="24" selected>CLB 9+ (IELTS L:8, others 7.0) (+24 pts)</option>
                <option value="20">CLB 8 (IELTS L:7.5, others 6.5) (+20 pts)</option>
                <option value="16">CLB 7 (IELTS 6.0 in all bands) (+16 pts)</option>
                <option value="0">CLB 6 or lower (Not Eligible)</option>
              </select>
            </div>

            <!-- Education -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Education</label>
              <select id="fsw-edu" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="25">Doctorate / PhD (+25 pts)</option>
                <option value="23" selected>Master's or Professional Degree (+23 pts)</option>
                <option value="21">Bachelor's Degree (3+ years) (+21 pts)</option>
                <option value="19">Post-Secondary Diploma (2 years) (+19 pts)</option>
                <option value="5">Secondary / High School (+5 pts)</option>
              </select>
            </div>

            <!-- Experience -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Skilled Work Experience</label>
              <select id="fsw-exp" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="15" selected>6 or more years (+15 pts)</option>
                <option value="13">4 to 5 years (+13 pts)</option>
                <option value="11">2 to 3 years (+11 pts)</option>
                <option value="9">1 year (+9 pts)</option>
                <option value="0">None (+0 pts)</option>
              </select>
            </div>

            <!-- Age -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Age Bracket</label>
              <select id="fsw-age" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="12" selected>18 to 35 years (+12 pts)</option>
                <option value="11">36 years (+11 pts)</option>
                <option value="10">37 years (+10 pts)</option>
                <option value="9">38 years (+9 pts)</option>
                <option value="8">39 years (+8 pts)</option>
                <option value="7">40 years (+7 pts)</option>
                <option value="6">41 years (+6 pts)</option>
                <option value="4">42 to 46 years (+4 pts)</option>
                <option value="0">47 years and over (+0 pts)</option>
              </select>
            </div>

            <!-- Adaptability / Job Offer -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Adaptability & Offer</label>
              <select id="fsw-adapt" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="0" selected>None (+0 pts)</option>
                <option value="10">Arranged employment in Canada (+10 pts)</option>
                <option value="5">Relative in Canada or partner language (+5 pts)</option>
                <option value="10">Prior Canada work/study (+10 pts)</option>
              </select>
            </div>

            <!-- Result Box -->
            <div class="p-4 rounded-xl bg-slate-50 border border-slate-150/80 flex items-center justify-between">
              <div>
                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest block">Total FSW Points</span>
                <span id="fsw-score-display" class="text-2xl font-extrabold font-display text-accent-blue">74</span>
              </div>
              <div class="text-right">
                <span id="fsw-status-display" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-100 border border-emerald-200 text-emerald-800">
                  Eligible (67+)
                </span>
              </div>
            </div>

            <button 
              type="button" 
              onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
              class="w-full py-2.5 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-xs rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer tracking-wide block"
            >
              Start PR Profile Evaluation
            </button>
          </form>
        </div>
      </div>

      <!-- Script for Canada FSW Calculator -->
      <script is:inline>
        function calculateFswPoints() {
          const lang = Number(document.getElementById('fsw-lang').value) || 0;
          const edu = Number(document.getElementById('fsw-edu').value) || 0;
          const exp = Number(document.getElementById('fsw-exp').value) || 0;
          const age = Number(document.getElementById('fsw-age').value) || 0;
          const adapt = Number(document.getElementById('fsw-adapt').value) || 0;

          const total = lang + edu + exp + age + adapt;

          const scoreEl = document.getElementById('fsw-score-display');
          const statusEl = document.getElementById('fsw-status-display');

          if (scoreEl) scoreEl.textContent = total;

          if (statusEl) {
            if (total >= 67) {
              statusEl.textContent = "Eligible (67+)";
              statusEl.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-100 border border-emerald-200 text-emerald-800";
            } else {
              statusEl.textContent = "Not Eligible (<67)";
              statusEl.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-red-100 border border-red-200 text-red-800";
            }
          }
        }

        function initFswCalculator() {
          const form = document.getElementById('fsw-form');
          if (form) {
            form.addEventListener('change', calculateFswPoints);
            calculateFswPoints();
          }
        }

        document.addEventListener('DOMContentLoaded', initFswCalculator);
        document.addEventListener('astro:page-load', initFswCalculator);
      </script>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
