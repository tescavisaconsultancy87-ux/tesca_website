---
import Layout from "../layouts/Layout.astro";
import { ArrowLeft, Home } from "lucide-react";
---

<Layout
  title="404 - Page Not Found | TESCA Visa Consultancy"
  description="The page you are looking for does not exist or has been moved."
>
  <section class="relative min-h-[70vh] flex items-center justify-center px-6 py-24 bg-white overflow-hidden">
    <div class="aurora-bg w-[500px] h-[500px] bg-accent-cyan/5 -top-48 left-1/4 animate-aurora"></div>
    <div class="aurora-bg w-[400px] h-[400px] bg-accent-blue/5 -bottom-48 right-1/4 animate-aurora"></div>

    <div class="max-w-2xl mx-auto text-center relative z-10 space-y-8">
      <div class="space-y-2">
        <span class="text-[160px] sm:text-[200px] font-black font-display text-gradient-highlight leading-none">404</span>
        <h1 class="text-[28px] sm:text-[34px] font-extrabold font-display text-support-white leading-tight -mt-6">
          Page Not Found
        </h1>
        <p class="text-[16px] text-support-gray font-sans max-w-md mx-auto leading-relaxed">
          The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
        </p>
      </div>

      <div class="flex items-center justify-center gap-4 font-sans font-semibold text-[16px] tracking-wide">
        <a
          href="/"
          class="px-7 py-3 rounded-full text-white bg-accent-blue shadow-md hover:scale-[1.02] transition-transform duration-300 inline-flex items-center gap-2"
        >
          <Home class="w-4 h-4" />
          Go Home
        </a>
        <button
          onclick="history.back()"
          class="px-7 py-3 rounded-full text-support-slate border border-slate-200 hover:bg-slate-50 transition-all duration-300 inline-flex items-center gap-2 cursor-pointer"
        >
          <ArrowLeft class="w-4 h-4" />
          Go Back
        </button>
      </div>

      <div class="pt-8 border-t border-slate-100 max-w-sm mx-auto">
        <p class="text-xs text-support-gray/60 font-sans">
          Need help? <a href="/" class="text-accent-blue hover:underline font-medium">Contact our support team</a>
        </p>
      </div>
    </div>
  </section>
</Layout>
