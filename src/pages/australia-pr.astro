---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-600"><polyline points="20 6 9 17 4 12"/></svg>`
};
---

<Layout 
  title="Australia Skilled Migration PR Services | TESCA Visa Consultancy"
  description="Expert guidance on General Skilled Migration (GSM) to Australia. Fulfill point tests, skill assessment, and state nominations for subclass 189, 190, and 491."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left">
    
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          PR & Immigration
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Australia Skilled Migration
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          Plan your PR pathway to Australia. We specialize in skill assessment coordinates, points optimization checklists, Expression of Interest (EOI) filings, and state nomination programs.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      
      <div class="lg:col-span-2 space-y-12 font-sans">
        
        <!-- Highlights -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Subclass 189 & 190</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Filing independent and state-nominated visas that grant permanent residency upon landing.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Skills Assessment</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Liaising with assessment authorities (ACS, Engineers Australia, VETASSESS) to secure positive occupational outcomes.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Subclass 491</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Targeting regional point-tested pathways that convert to PR after 3 years of living/working in regional areas.</p>
          </div>
        </div>

        <!-- Requirements checklist -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Australia PR Document Checklist</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              "Positive Skill Assessment outcome letter",
              "IELTS (Academic or General) or PTE Test results",
              "Academic Degree certificates and transcript evaluations",
              "Detailed Reference Letters detailing work tasks",
              "Partner Skills credentials (for extra points)",
              "State Sponsorship nomination approval (Subclass 190/491)"
            ].map(doc => (
              <div class="flex items-center gap-3 p-4 rounded-xl border border-slate-100 bg-white shadow-sm">
                <div class="p-1 rounded-full bg-emerald-50 text-emerald-600">
                  <span set:html={SVG.Check} />
                </div>
                <span class="text-xs font-semibold text-slate-700">{doc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Timeline -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Immigration Milestones</h2>
          <div class="relative pl-6 border-l-2 border-slate-200 space-y-8">
            {[
              "Confirm relevant occupation list listing (MLTSSL or STSOL)",
              "Prepare documents and submit to skills assessment authority",
              "Take PTE/IELTS exams to hit Superior/Proficient English targets",
              "File Expression of Interest (EOI) in Australia's SkillSelect portal",
              "Apply for state sponsorship (for 190/491) and receive ITA from Department of Home Affairs"
            ].map((step, idx) => (
              <div class="relative">
                <div class="absolute -left-[31px] top-0 w-4 h-4 rounded-full bg-accent-blue border-4 border-white shadow-sm"></div>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Step {idx + 1}</span>
                <p class="text-sm font-semibold text-slate-700 mt-1">{step}</p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="space-y-6 sticky top-28 font-sans">
        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-1">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Evaluate your Australia Points</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-normal">
              Calculate your points for GSM Subclass 189/190/491. Minimum required: <strong>65 points</strong>.
            </p>
          </div>

          <form id="aus-points-form" class="space-y-4 text-xs text-slate-700">
            <!-- Age Group -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Age group</label>
              <select id="aus-age" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="25">18 to 24 years (+25 pts)</option>
                <option value="30" selected>25 to 32 years (+30 pts)</option>
                <option value="25">33 to 39 years (+25 pts)</option>
                <option value="15">40 to 44 years (+15 pts)</option>
                <option value="0">45 years and over (Not Eligible)</option>
              </select>
            </div>

            <!-- English Language -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">English Ability (IELTS/PTE)</label>
              <select id="aus-english" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="20">Superior English: IELTS 8 / PTE 79 (+20 pts)</option>
                <option value="10" selected>Proficient English: IELTS 7 / PTE 65 (+10 pts)</option>
                <option value="0">Competent English: IELTS 6 / PTE 50 (+0 pts)</option>
              </select>
            </div>

            <!-- Skilled Employment (Outside Australia) -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Skilled Experience (Overseas)</label>
              <select id="aus-experience" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="15">8+ years experience (+15 pts)</option>
                <option value="10">5 to 7 years experience (+10 pts)</option>
                <option value="5" selected>3 to 4 years experience (+5 pts)</option>
                <option value="0">Less than 3 years experience (+0 pts)</option>
              </select>
            </div>

            <!-- Educational Qualifications -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Qualifications</label>
              <select id="aus-education" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="20">Doctorate / PhD (+20 pts)</option>
                <option value="15" selected>Bachelor or Master Degree (+15 pts)</option>
                <option value="10">Diploma or Trade Qualification (+10 pts)</option>
                <option value="0">Other / Secondary (+0 pts)</option>
              </select>
            </div>

            <!-- Partner Skills / Single Status -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Partner & Single Status</label>
              <select id="aus-partner" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="10" selected>Single or Partner is Citizen/PR (+10 pts)</option>
                <option value="10">Skilled Partner: Competent English + Assessment (+10 pts)</option>
                <option value="5">Partner has Competent English only (+5 pts)</option>
                <option value="0">Unskilled partner / No language score (+0 pts)</option>
              </select>
            </div>

            <!-- Result Box -->
            <div class="p-4 rounded-xl bg-slate-50 border border-slate-150/80 flex items-center justify-between">
              <div>
                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest block">Total GSM Points</span>
                <span id="aus-score-display" class="text-2xl font-extrabold font-display text-accent-blue">70</span>
              </div>
              <div class="text-right">
                <span id="aus-status-display" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-100 border border-emerald-200 text-emerald-800">
                  Eligible (65+)
                </span>
              </div>
            </div>

            <button 
              type="button" 
              onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
              class="w-full py-2.5 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-xs rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer tracking-wide block"
            >
              Start Points Filing
            </button>
          </form>
        </div>
      </div>

      <!-- Script for Australia Points Calculator -->
      <script is:inline>
        function calculateAusPoints() {
          const age = Number(document.getElementById('aus-age').value) || 0;
          const english = Number(document.getElementById('aus-english').value) || 0;
          const experience = Number(document.getElementById('aus-experience').value) || 0;
          const education = Number(document.getElementById('aus-education').value) || 0;
          const partner = Number(document.getElementById('aus-partner').value) || 0;

          const total = age + english + experience + education + partner;

          const scoreEl = document.getElementById('aus-score-display');
          const statusEl = document.getElementById('aus-status-display');

          if (scoreEl) scoreEl.textContent = total;

          if (statusEl) {
            if (total >= 65) {
              statusEl.textContent = "Eligible (65+)";
              statusEl.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-100 border border-emerald-200 text-emerald-800";
            } else {
              statusEl.textContent = "Needs Boost (<65)";
              statusEl.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-red-100 border border-red-200 text-red-800";
            }
          }
        }

        function initAusCalculator() {
          const form = document.getElementById('aus-points-form');
          if (form) {
            form.addEventListener('change', calculateAusPoints);
            calculateAusPoints();
          }
        }

        document.addEventListener('DOMContentLoaded', initAusCalculator);
        document.addEventListener('astro:page-load', initAusCalculator);
      </script>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
