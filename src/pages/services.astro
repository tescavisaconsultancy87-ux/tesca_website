---
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
import { 
  User, GraduationCap, FileText, Award, BookOpen, Briefcase, 
  Heart, Shield, Landmark, Home, Plane, Download
} from "lucide-react";
---

<Layout 
  title="Study Abroad & Visa Consulting Services | TESCA"
  description="Explore our premium study abroad services: university admissions consulting, test preparation, visa documentation audits, blocked accounts, education loans, and housing support."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-12">
    <!-- Premium Header Banner Card -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-8 items-center p-8 md:p-12 relative mb-16">
      
      {/* Subtle Background Auroras */}
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>

      {/* Left Column: Text Content */}
      <div class="md:col-span-7 space-y-6 text-left relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          Global Success Portfolio
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Our Premium Services
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          From university admissions profiling to automated visa compliance checks, TESCA combines algorithmic precision with premium human consultancy.
        </p>
      </div>

      {/* Right Column: Student Hero Image cutout */}
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-end">
        <div class="relative w-full max-w-[320px] md:max-w-none md:absolute md:-bottom-12 md:top-[-48px] flex items-end">
          <img 
            src="/images/services_hero.png" 
            alt="TESCA student services" 
            class="object-contain w-full h-full max-h-[380px] md:max-h-none select-none filter drop-shadow-[0_10px_20px_rgba(0,0,0,0.06)]"
          />
        </div>
      </div>

    </div>

    {/* 10 Services Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20 text-left">
      {[
        {
          id: "counselling",
          title: "Expert Counselling",
          desc: "Personalized profiling session matching you with elite institutions based on GPA, GRE scores, and aspirations.",
          icon: User,
          color: "text-slate-800 bg-accent-blue/5"
        },
        {
          id: "admission",
          title: "University Admission Process",
          desc: "Algorithmic screening of DLI/SEVIS lists, managing direct application filings, and coordinating school offers.",
          icon: GraduationCap,
          color: "text-accent-indigo bg-accent-indigo/5"
        },
        {
          id: "sop",
          title: "SOP & Documentation",
          desc: "Expert structural auditing of your Statement of Purpose (SOP), Letters of Recommendation (LORs), and CVs.",
          icon: FileText,
          color: "text-highlight-purple bg-highlight-purple/5"
        },
        {
          id: "scholarships",
          title: "Scholarship Guidance",
          desc: "Automated analysis of merit grants, assistantships, and tuition waivers, yielding maximum funding support.",
          icon: Award,
          color: "text-accent-cyan bg-accent-cyan/5"
        },
        {
          id: "testprep",
          title: "Test Prep & Coaching",
          desc: "Coaching modules for IELTS, TOEFL, and GRE exams using diagnostic tools to score above standard thresholds.",
          icon: BookOpen,
          color: "text-slate-800 bg-accent-blue/5"
        },
        {
          id: "visa",
          title: "Expert Visa Assistance",
          desc: "Complete documentation audits, biometrics scheduling, and predictive checkup tools checking visa success SLA.",
          icon: Briefcase,
          color: "text-accent-indigo bg-accent-indigo/5"
        },
        {
          id: "insurance",
          title: "Health Insurance",
          desc: "Compliance checks for regional health coverages like OSHC (Australia) and provincial plans (Canada/Germany).",
          icon: Heart,
          color: "text-highlight-purple bg-highlight-purple/5"
        },
        {
          id: "financial",
          title: "Financial Guidance & Loans",
          desc: "Integration with banking partners to verify blocked accounts and structure pre-approved educational loans.",
          icon: Landmark,
          color: "text-accent-cyan bg-accent-cyan/5"
        },
        {
          id: "accommodation",
          title: "Accommodation Assistance",
          desc: "Coordination of on-campus residence bookings and regional housing partners close to target university campuses.",
          icon: Home,
          color: "text-slate-800 bg-accent-blue/5"
        },
        {
          id: "departure",
          title: "Pre & Post Departure Services",
          desc: "Pre-departure briefings, biometrics support, flight options matching, and airport landing assistance.",
          icon: Plane,
          color: "text-accent-indigo bg-accent-indigo/5"
        }
      ].map((srv, idx) => {
        const gradients = [
          "bg-gradient-to-br from-blue-50 to-indigo-50/70",
          "bg-gradient-to-br from-emerald-50 to-teal-50/70",
          "bg-gradient-to-br from-amber-50 to-orange-50/70",
          "bg-gradient-to-br from-purple-50 to-pink-50/70",
          "bg-gradient-to-br from-teal-50 to-cyan-50/70",
          "bg-gradient-to-br from-cyan-50 to-blue-50/70",
          "bg-gradient-to-br from-pink-50 to-rose-50/70",
          "bg-gradient-to-br from-orange-50 to-amber-50/70",
          "bg-gradient-to-br from-indigo-50 to-purple-50/70",
          "bg-gradient-to-br from-teal-50 to-cyan-50/70"
        ];
        return (
        <div id={srv.id} class={`rounded-3xl p-8 space-y-6 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between border border-slate-200/60 shadow-sm ${gradients[idx]}`}>
          <div class="space-y-4">
            <div class={`p-3.5 rounded-2xl ${srv.color} inline-block`}>
              <srv.icon class="w-6 h-6" />
            </div>
            <h3 class="text-xl lg:text-2xl font-bold text-slate-800 font-display tracking-tight">{srv.title}</h3>
            <p class="text-sm md:text-base text-slate-600 font-sans font-normal leading-relaxed">{srv.desc}</p>
          </div>
          
          <a href="/TestPrep" class="text-sm font-semibold font-sans text-accent-blue hover:underline inline-flex items-center gap-1 mt-4">
            Learn More →
          </a>
        </div>
        );
      })}
    </div>

    {/* Section: Diagnostic downloads and coaching track */}
    <div class="rounded-3xl p-8 md:p-12 space-y-8 relative overflow-hidden text-left bg-gradient-to-br from-slate-50 to-blue-50/50 border border-slate-200">
      
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pb-6 border-b border-slate-200">
        <div class="space-y-1">
          <span class="text-sm font-semibold text-accent-blue uppercase tracking-wider font-sans">Syllabus & Downloads</span>
          <h3 class="text-[28px] lg:text-[36px] font-bold font-display text-support-white tracking-tight">Practice Resources Portal</h3>
        </div>
        <p class="text-sm text-support-gray/60 font-sans font-normal max-w-sm leading-relaxed">
          High-end prep books, authentic mock materials, and sample audio archives updated for 2026 guidelines.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: "IELTS Diagnostic Prep Packet 2026",
            desc: "Full academic diagnostic module including Listening scripts, Reading papers, and sample templates.",
            size: "12.4 MB PDF",
            downloads: "4.8K Downloads"
          },
          {
            title: "AI Grade Task 2 Essay Templates",
            desc: "High-scoring structures for opinion essays, comparative writing, and descriptive academic graphs.",
            size: "8.1 MB PDF",
            downloads: "3.2K Downloads"
          },
          {
            title: "Speaking Module Audio Clips",
            desc: "Authentic examiner audio questions with transcripts for Band 8.0 model replies.",
            size: "45.0 MB ZIP",
            downloads: "2.1K Downloads"
          }
        ].map(doc => (
          <div class="p-6 rounded-2xl border border-slate-200/80 bg-white flex flex-col justify-between space-y-4 hover:border-accent-blue/30 transition-all duration-300 shadow-sm">
            <div class="space-y-2">
              <h4 class="text-base lg:text-lg font-bold text-support-white font-display leading-snug">{doc.title}</h4>
              <p class="text-sm text-support-gray leading-relaxed font-sans font-normal">{doc.desc}</p>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-slate-100">
              <div>
                <span class="block text-xs text-support-gray/55 font-sans font-medium">{doc.size}</span>
                <span class="block text-xs text-accent-blue font-sans font-semibold">{doc.downloads}</span>
              </div>
              <button 
                onclick={`alert('Starting download for ${doc.title}...');`}
                class="p-2.5 rounded-lg bg-accent-blue/10 hover:bg-accent-blue hover:text-white text-accent-indigo transition-colors cursor-pointer"
                aria-label={`Download ${doc.title}`}
              >
                <Download class="w-4 h-4" />
              </button>
            </div>
          </div>
        ))}
      </div>

    </div>

  </section>

  {/* Client floating chatbot */}
  <AICounsellor client:load />
</Layout>
