---
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
import { 
  User, GraduationCap, FileText, Award, BookOpen, Briefcase, 
  Heart, Shield, Landmark, Home, Plane, Download
} from "lucide-react";
---

<Layout 
  title="Study Abroad & Visa Consulting Services | TESCA"
  description="Explore our premium study abroad services: university admissions consulting, test preparation, visa documentation audits, blocked accounts, education loans, and housing support."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-12">
    <!-- Premium Header Banner Card -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-8 items-center p-8 md:p-12 relative mb-16">
      
      {/* Subtle Background Auroras */}
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>

      {/* Left Column: Text Content */}
      <div class="md:col-span-7 space-y-6 text-left relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          Global Success Portfolio
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Our Premium Services
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          From university admissions profiling to automated visa compliance checks, TESCA combines algorithmic precision with premium human consultancy.
        </p>
      </div>

      {/* Right Column: Student Hero Image cutout */}
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-end">
        <div class="relative w-full max-w-[320px] md:max-w-none md:absolute md:-bottom-12 md:top-[-48px] flex items-end">
          <img 
            src="/images/services_hero.png" 
            alt="TESCA student services" 
            class="object-contain w-full h-full max-h-[380px] md:max-h-none select-none filter drop-shadow-[0_10px_20px_rgba(0,0,0,0.06)]"
          />
        </div>
      </div>

    </div>

    {/* 10 Services Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20 text-left items-start">
      {[
        {
          id: "counselling",
          title: "Expert Counselling",
          desc: "Personalized profiling session matching you with elite institutions based on GPA, GRE scores, and aspirations.",
          icon: User,
          color: "text-slate-800 bg-accent-blue/5",
          detailedContent: [
            "1-on-1 profiling session with senior study abroad consultants.",
            "Detailed analysis of GPA, academic history, test scores, and research publications.",
            "Personalized country, course, and university shortlisting targeting Reach, Match, and Safe options.",
            "Career path mapping and guidance on post-graduation work opportunities."
          ]
        },
        {
          id: "admission",
          title: "University Admission Process",
          desc: "Algorithmic screening of DLI/SEVIS lists, managing direct application filings, and coordinating school offers.",
          icon: GraduationCap,
          color: "text-accent-indigo bg-accent-indigo/5",
          detailedContent: [
            "End-to-end management of university application portals and fee waivers.",
            "Rigorous verification of application packets, including transcripts and credentials.",
            "Direct liaison with university admission offices to expedite application processing.",
            "Dedicated support for responding to and accepting offer letters (CAS/i-20 request processing)."
          ]
        },
        {
          id: "sop",
          title: "SOP & Documentation",
          desc: "Expert structural auditing of your Statement of Purpose (SOP), Letters of Recommendation (LORs), and CVs.",
          icon: FileText,
          color: "text-highlight-purple bg-highlight-purple/5",
          detailedContent: [
            "Comprehensive review and structural auditing of Statements of Purpose (SOPs).",
            "Guidance and templates for drafting professional Letters of Recommendation (LORs).",
            "Resume and CV optimization to highlight academic achievements, projects, and internships.",
            "Strict alignment check with country-specific student visa statement requirements."
          ]
        },
        {
          id: "scholarships",
          title: "Scholarship Guidance",
          desc: "Automated analysis of merit grants, assistantships, and tuition waivers, yielding maximum funding support.",
          icon: Award,
          color: "text-accent-cyan bg-accent-cyan/5",
          detailedContent: [
            "Access to an updated database of institutional, governmental, and external scholarships.",
            "Assistance with application documentation for merit-based and need-based financial aid.",
            "Coaching on scholarship essay writing to maximize your chances of winning funding.",
            "Strategies to secure Graduate Assistantships (TA/RA) and tuition fee waivers."
          ]
        },
        {
          id: "testprep",
          title: "Test Prep & Coaching",
          desc: "Coaching modules for IELTS, TOEFL, and GRE exams using diagnostic tools to score above standard thresholds.",
          icon: BookOpen,
          color: "text-slate-800 bg-accent-blue/5",
          detailedContent: [
            "Highly structured prep classes led by certified, experienced educators.",
            "Diagnostic mock tests simulating actual exam conditions with detailed score analysis.",
            "Customized drills for Listening, Reading, Writing, Speaking, and Quantitative sections.",
            "Exclusive preparation material, grammar guides, and vocabulary building tools."
          ]
        },
        {
          id: "visa",
          title: "Expert Visa Assistance",
          desc: "Complete documentation audits, biometrics scheduling, and predictive checkup tools checking visa success SLA.",
          icon: Briefcase,
          color: "text-accent-indigo bg-accent-indigo/5",
          detailedContent: [
            "Step-by-step guidance on student visa filings (e.g., US F-1, UK Student Visa, Canada Study Permit).",
            "Comprehensive review of financial documents, sponsor affidavits, and fund source declarations.",
            "Interactive mock visa interview sessions to build confidence and refine responses.",
            "Pre-checking documentation against the latest immigration and visa compliance laws."
          ]
        },
        {
          id: "insurance",
          title: "Health Insurance",
          desc: "Compliance checks for regional health coverages like OSHC (Australia) and provincial plans (Canada/Germany).",
          icon: Heart,
          color: "text-highlight-purple bg-highlight-purple/5",
          detailedContent: [
            "Sourcing and comparison of mandatory student health covers (e.g., OSHC, German statutory insurance).",
            "Tailored plans balancing premium costs, deductible limits, and coverage scopes.",
            "Fast-tracked policy registration and digital insurance card issuance.",
            "Detailed briefings on claims filing, medical networks, and student health support."
          ]
        },
        {
          id: "financial",
          title: "Financial Guidance & Loans",
          desc: "Integration with banking partners to verify blocked accounts and structure pre-approved educational loans.",
          icon: Landmark,
          color: "text-accent-cyan bg-accent-cyan/5",
          detailedContent: [
            "Tie-ups with leading banks for collateral-free and collateral-based educational loans.",
            "Streamlined processing of blocked accounts required for Germany and Canada.",
            "Assistance in structuring financial declarations, sponsor letters, and liquid asset proofs.",
            "Preferential forex exchange rates for tuition fee transfers and international drafts."
          ]
        },
        {
          id: "accommodation",
          title: "Accommodation Assistance",
          desc: "Coordination of on-campus residence bookings and regional housing partners close to target university campuses.",
          icon: Home,
          color: "text-slate-800 bg-accent-blue/5",
          detailedContent: [
            "Guidance on securing on-campus dormitories and university residences.",
            "Access to verified off-campus student housing partners, studios, and shared apartments.",
            "Support in reviewing tenancy agreements, rental terms, and deposit payment structures.",
            "Connections with student community networks for roommate matching and local navigation."
          ]
        },
        {
          id: "departure",
          title: "Pre & Post Departure Services",
          desc: "Pre-departure briefings, biometrics support, flight options matching, and airport landing assistance.",
          icon: Plane,
          color: "text-accent-indigo bg-accent-indigo/5",
          detailedContent: [
            "Comprehensive pre-departure orientations detailing lifestyle, compliance, and academic norms.",
            "Guidelines on currency, international SIM cards, packing essentials, and customs regulations.",
            "Assistance with airport pick-up scheduling and booking temporary stays.",
            "Post-arrival setup support including local bank accounts, transport passes, and student IDs."
          ]
        }
      ].map((srv, idx) => {
        const gradients = [
          "bg-gradient-to-br from-blue-50 to-indigo-50/70 border-blue-100/60",
          "bg-gradient-to-br from-emerald-50 to-teal-50/70 border-emerald-100/60",
          "bg-gradient-to-br from-amber-50 to-orange-50/70 border-amber-100/60",
          "bg-gradient-to-br from-purple-50 to-pink-50/70 border-purple-100/60",
          "bg-gradient-to-br from-teal-50 to-cyan-50/70 border-teal-100/60",
          "bg-gradient-to-br from-cyan-50 to-blue-50/70 border-cyan-100/60",
          "bg-gradient-to-br from-pink-50 to-rose-50/70 border-pink-100/60",
          "bg-gradient-to-br from-orange-50 to-amber-50/70 border-orange-100/60",
          "bg-gradient-to-br from-indigo-50 to-purple-50/70 border-indigo-100/60",
          "bg-gradient-to-br from-teal-50 to-cyan-50/70 border-teal-100/60"
        ];
        return (
        <div id={srv.id} class={`rounded-3xl p-8 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between border shadow-sm relative overflow-hidden group ${gradients[idx]}`}>
          <div>
            <div class="space-y-4">
              <div class={`p-3.5 rounded-2xl ${srv.color} inline-block`}>
                <srv.icon class="w-6 h-6" />
              </div>
              <h3 class="text-xl lg:text-2xl font-bold text-slate-800 font-display tracking-tight">{srv.title}</h3>
              <p class="text-sm md:text-base text-slate-600 font-sans font-normal leading-relaxed">{srv.desc}</p>
            </div>
            
            <div class="service-details max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
              <div class="pt-6 border-t border-slate-200/40 mt-4 space-y-4 text-left">
                <h4 class="text-xs font-bold font-sans uppercase tracking-wider text-slate-800 mb-2">What's Included:</h4>
                <ul class="space-y-2.5">
                  {srv.detailedContent.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-slate-600 font-sans font-normal leading-relaxed">
                      <span class="w-1.5 h-1.5 bg-accent-blue rounded-full shrink-0 mt-2"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
                <div class="pt-4 flex items-center justify-between gap-4 border-t border-slate-100/50 mt-4">
                  <span class="text-xs font-semibold text-slate-500 font-sans">Need assistance?</span>
                  <button
                    type="button"
                    onclick="window.openCounsellorForm?.()"
                    class="px-4 py-2 bg-accent-blue hover:bg-accent-indigo text-white font-semibold text-xs rounded-full shadow-sm hover:scale-[1.02] transition-all cursor-pointer font-sans"
                  >
                    Book Consultation
                  </button>
                </div>
              </div>
            </div>
          </div>
          
          <button 
            type="button"
            data-target={srv.id}
            class="service-toggle-btn text-sm font-semibold font-sans text-accent-blue hover:text-accent-indigo inline-flex items-center gap-1 mt-4 cursor-pointer focus:outline-none self-start"
          >
            <span class="btn-text">Learn More</span> <span class="arrow-icon transition-transform duration-300">→</span>
          </button>
        </div>
        );
      })}
    </div>

    {/* Section: Diagnostic downloads and coaching track */}
    <div class="rounded-3xl p-8 md:p-12 space-y-8 relative overflow-hidden text-left bg-gradient-to-br from-slate-50 to-blue-50/50 border border-slate-200">
      
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pb-6 border-b border-slate-200">
        <div class="space-y-1">
          <span class="text-sm font-semibold text-accent-blue uppercase tracking-wider font-sans">Syllabus & Downloads</span>
          <h3 class="text-[28px] lg:text-[36px] font-bold font-display text-support-white tracking-tight">Practice Resources</h3>
        </div>
        <p class="text-sm text-support-gray/60 font-sans font-normal max-w-sm leading-relaxed">
          High-end prep books, authentic mock materials, and sample audio archives updated for 2026 guidelines.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: "IELTS Speaking Cue Cards",
            desc: "Comprehensive speaking cue cards with model answers, structures, and vocabulary for IELTS speaking tasks.",
            size: "1.4 MB PDF",
            downloads: "Free Download",
            file: "/material/IELTS-Speaking-Cue-Cards.pdf"
          },
          {
            title: "IELTS Vocabulary Cheat Sheet (Top 100)",
            desc: "Highly curated list of top 100 IELTS vocabulary words with definitions, synonyms, and practical sentence examples.",
            size: "2.9 MB PDF",
            downloads: "Free Download",
            file: "/material/IELTS-Vocabulary-Cheat-Sheet-Top-100-Words.pdf"
          },
          {
            title: "IELTS Writing Task 2 Templates",
            desc: "Premium high-scoring structural templates and vocabulary frameworks for IELTS Writing Task 2 essays.",
            size: "1.3 MB PDF",
            downloads: "Free Download",
            file: "/material/task_2 template.pdf"
          }
        ].map(doc => (
          <div class="p-6 rounded-2xl border border-slate-200/80 bg-white flex flex-col justify-between space-y-4 hover:border-accent-blue/30 transition-all duration-300 shadow-sm">
            <div class="space-y-2">
              <h4 class="text-base lg:text-lg font-bold text-support-white font-display leading-snug">{doc.title}</h4>
              <p class="text-sm text-support-gray leading-relaxed font-sans font-normal">{doc.desc}</p>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-slate-100">
              <div>
                <span class="block text-xs text-support-gray/55 font-sans font-medium">{doc.size}</span>
                <span class="block text-xs text-accent-blue font-sans font-semibold">{doc.downloads}</span>
              </div>
              <a 
                href={doc.file}
                download
                class="p-2.5 rounded-lg bg-accent-blue/10 hover:bg-accent-blue hover:text-white text-accent-indigo transition-colors cursor-pointer flex items-center justify-center"
                aria-label={`Download ${doc.title}`}
              >
                <Download class="w-4 h-4" />
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>

  </section>

  {/* Client floating chatbot */}
  <AICounsellor client:load />
</Layout>

<script>
  function setupServiceToggles() {
    const toggleButtons = document.querySelectorAll('.service-toggle-btn');
    toggleButtons.forEach(btn => {
      // Avoid duplicate event listeners by replacing with clone
      const newBtn = btn.cloneNode(true);
      btn.parentNode?.replaceChild(newBtn, btn);
    });

    const newToggleButtons = document.querySelectorAll('.service-toggle-btn');
    newToggleButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const cardId = btn.getAttribute('data-target');
        if (!cardId) return;
        const card = document.getElementById(cardId);
        if (!card) return;

        const details = card.querySelector('.service-details') as HTMLElement;
        const btnText = btn.querySelector('.btn-text') as HTMLElement;
        const arrow = btn.querySelector('.arrow-icon') as HTMLElement;

        if (details && btnText && arrow) {
          const isExpanded = details.style.maxHeight && details.style.maxHeight !== '0px';

          if (!isExpanded) {
            // Collapse all other expanded service cards
            const allCards = document.querySelectorAll('.grid > div');
            allCards.forEach(otherCard => {
              if (otherCard.id !== cardId) {
                const otherDetails = otherCard.querySelector('.service-details') as HTMLElement;
                const otherBtn = otherCard.querySelector('.service-toggle-btn');
                if (otherDetails && otherDetails.style.maxHeight && otherDetails.style.maxHeight !== '0px') {
                  otherDetails.style.maxHeight = '0px';
                  if (otherBtn) {
                    const otherBtnText = otherBtn.querySelector('.btn-text');
                    const otherArrow = otherBtn.querySelector('.arrow-icon') as HTMLElement;
                    if (otherBtnText) otherBtnText.textContent = 'Learn More';
                    if (otherArrow) otherArrow.style.transform = 'rotate(0deg)';
                  }
                  otherCard.classList.remove('border-accent-blue/30', 'shadow-md', 'scale-[1.01]', 'bg-white/95');
                }
              }
            });
          }

          if (isExpanded) {
            // Collapse
            details.style.maxHeight = '0px';
            btnText.textContent = 'Learn More';
            arrow.style.transform = 'rotate(0deg)';
            card.classList.remove('border-accent-blue/30', 'shadow-md', 'scale-[1.01]', 'bg-white/95');
          } else {
            // Expand
            details.style.maxHeight = details.scrollHeight + 'px';
            btnText.textContent = 'Show Less';
            arrow.style.transform = 'rotate(90deg)';
            card.classList.add('border-accent-blue/30', 'shadow-md', 'scale-[1.01]', 'bg-white/95');
          }
        }
      });
    });
  }

  // Initial setup
  setupServiceToggles();
  // Listen for view transitions if enabled
  document.addEventListener('astro:page-load', setupServiceToggles);
  document.addEventListener('astro:after-swap', setupServiceToggles);
</script>
