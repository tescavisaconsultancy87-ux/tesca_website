---
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
import { SERVICES } from "../data/services";
const _s = (d: string) => `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>${d}</svg>`;
const iconMap: Record<string, string> = {
  User: _s('<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'),
  GraduationCap: _s('<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>'),
  FileText: _s('<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>'),
  Award: _s('<circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>'),
  BookOpen: _s('<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>'),
  Briefcase: _s('<path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/>'),
  Heart: _s('<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>'),
  Landmark: _s('<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="22"/><line x1="10" x2="10" y1="18" y2="22"/><line x1="14" x2="14" y1="18" y2="22"/><line x1="18" x2="18" y1="18" y2="22"/><polygon points="12 2 20 7 4 7"/>'),
  Home: _s('<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>'),
  Plane: _s('<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3.5c-.5-.5-2.5 0-4 1.5L13.5 8.5 5.3 6.7c-.7-.2-1.5.1-1.8.8-.4.9 0 2 .7 2.4l7.1 3.7-2.8 2.8-3.7-.7c-.5-.1-1.1.2-1.2.7-.2.6 0 1.3.5 1.7l3.2 2 2 3.2c.4.5 1 .6 1.7.5.5-.1.8-.7.7-1.2l-.7-3.7 2.8-2.8 3.7 7.1c.4.7 1.5 1 2.4.7.6-.3.9-1.1.8-1.8Z"/>'),
};
const SVG = {
  ArrowRight: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>`,
  Download: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`,
};
---

<Layout 
  title="Study Abroad & Visa Consulting Services | TESCA"
  description="Explore our premium study abroad services: university admissions consulting, test preparation, visa documentation audits, blocked accounts, education loans, and housing support."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-12">
    <!-- Premium Header Banner Card -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-8 items-center p-8 md:p-12 relative mb-16">
      
      {/* Subtle Background Auroras */}
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>

      {/* Left Column: Text Content */}
      <div class="md:col-span-7 space-y-6 text-left relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          OUR SERVICES
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
         Everything You Need to Study Abroad
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          From career counselling and university admissions to visa approval and pre-departure support, we guide you at every step.        
        </p>
      </div>

      {/* Right Column: Student Hero Image cutout */}
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-end">
        <div class="relative w-full max-w-[320px] md:max-w-none md:absolute md:-bottom-12 md:top-[-48px] flex items-end">
          <img 
            src="/images/services_hero.webp" 
            alt="TESCA student services" 
            class="object-contain w-full h-full max-h-[380px] md:max-h-none select-none filter drop-shadow-[0_10px_20px_rgba(0,0,0,0.06)]"
          />
        </div>
      </div>

    </div>

    {/* 10 Services Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20 text-left">
      {SERVICES.map((srv, idx) => {
        const gradients = [
          "bg-gradient-to-br from-blue-50 to-indigo-50/70 border-blue-100/60",
          "bg-gradient-to-br from-emerald-50 to-teal-50/70 border-emerald-100/60",
          "bg-gradient-to-br from-amber-50 to-orange-50/70 border-amber-100/60",
          "bg-gradient-to-br from-purple-50 to-pink-50/70 border-purple-100/60",
          "bg-gradient-to-br from-teal-50 to-cyan-50/70 border-teal-100/60",
          "bg-gradient-to-br from-cyan-50 to-blue-50/70 border-cyan-100/60",
          "bg-gradient-to-br from-pink-50 to-rose-50/70 border-pink-100/60",
          "bg-gradient-to-br from-orange-50 to-amber-50/70 border-orange-100/60",
          "bg-gradient-to-br from-indigo-50 to-purple-50/70 border-indigo-100/60",
          "bg-gradient-to-br from-teal-50 to-cyan-50/70 border-teal-100/60",
          "bg-gradient-to-br from-blue-50 to-cyan-50/70 border-blue-100/60",
          "bg-gradient-to-br from-emerald-50 to-green-50/70 border-emerald-100/60"
        ];
        const ServiceIcon = iconMap[srv.icon] || iconMap.User;
        return (
        <a
          href={`/services/${srv.id}`}
          class={`h-[280px] rounded-3xl p-8 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between border shadow-sm relative overflow-hidden group cursor-pointer ${gradients[idx % gradients.length]}`}
        >
          <div class="space-y-4">
            <div class={`p-3.5 rounded-2xl ${srv.color} inline-flex items-center justify-center`}>
              <span set:html={ServiceIcon} />
            </div>
            <h3 class="text-xl lg:text-2xl font-bold text-slate-800 font-display tracking-tight">{srv.title}</h3>
            <p class="text-sm md:text-base text-slate-600 font-sans font-normal leading-relaxed">{srv.desc}</p>
          </div>
          <span class="text-sm font-semibold font-sans text-accent-blue inline-flex items-center gap-1 mt-4">
            Learn More <span set:html={SVG.ArrowRight} />
          </span>
        </a>
        );
      })}
    </div>

    {/* Banking & Loan Partners Carousel */}
    <div class="text-center mb-12">
      <span class="text-sm font-semibold text-accent-blue uppercase tracking-wider font-sans">Our Partners</span>
      <h3 class="text-[28px] lg:text-[36px] font-bold font-display text-support-white tracking-tight mt-1">Banking & Loan Partners</h3>
    </div>

    <div class="relative overflow-hidden w-full mb-16 py-6 border-t border-b border-slate-200/60">
      <div class="flex gap-20 items-center animate-marquee min-w-max px-6">
        {[
          { src: "/bank/sbi.png", alt: "State Bank of India" },
          { src: "/bank/hdfc.png", alt: "HDFC Bank" },
          { src: "/bank/icici.jpg", alt: "ICICI Bank" },
          { src: "/bank/axis.png", alt: "Axis Bank" },
          { src: "/bank/kotak.jpg", alt: "Kotak Mahindra Bank" },
          { src: "/bank/yes.png", alt: "Yes Bank" },
          { src: "/bank/bob.png", alt: "Bank of Baroda" },
          { src: "/bank/canara.jpg", alt: "Canara Bank" },
          { src: "/bank/bajaj.jpg", alt: "Bajaj Finserv" },
          { src: "/bank/avanse.png", alt: "Avanse" },
          { src: "/bank/credila.png", alt: "HDFC Credila" },
          { src: "/bank/auxilo.jpg", alt: "Auxilo" },
          { src: "/bank/incred.png", alt: "InCred" },
          { src: "/bank/propelld.png", alt: "Propelld" }
        ].map((partner) => (
          <div class="flex items-center shrink-0">
            <img src={partner.src} alt={partner.alt} class="h-12 w-auto object-contain" loading="lazy" />
          </div>
        ))}
        {[
          { src: "/bank/sbi.png", alt: "State Bank of India" },
          { src: "/bank/hdfc.png", alt: "HDFC Bank" },
          { src: "/bank/icici.png", alt: "ICICI Bank" },
          { src: "/bank/axis.png", alt: "Axis Bank" },
          { src: "/bank/kotak.png", alt: "Kotak Mahindra Bank" },
          { src: "/bank/yesbank.png", alt: "Yes Bank" },
          { src: "/bank/bob.png", alt: "Bank of Baroda" },
          { src: "/bank/canara.png", alt: "Canara Bank" },
          { src: "/bank/bajaj.png", alt: "Bajaj Finserv" },
          { src: "/bank/avanse.png", alt: "Avanse" },
          { src: "/bank/credila.png", alt: "HDFC Credila" },
          { src: "/bank/auxilo.png", alt: "Auxilo" },
          { src: "/bank/incred.png", alt: "InCred" },
          { src: "/bank/propelld.png", alt: "Propelld" }
        ].map((partner) => (
          <div class="flex items-center shrink-0">
            <img src={partner.src} alt={partner.alt} class="h-12 w-auto object-contain" loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <style>
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .animate-marquee {
        animation: marquee 50s linear infinite;
      }
      .animate-marquee:hover {
        animation-play-state: paused;
      }
    </style>

    {/* Section: Diagnostic downloads and coaching track */}
    <div class="rounded-3xl p-8 md:p-12 space-y-8 relative overflow-hidden text-left bg-gradient-to-br from-slate-50 to-blue-50/50 border border-slate-200">
      
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 pb-6 border-b border-slate-200">
        <div class="space-y-1">
          <span class="text-sm font-semibold text-accent-blue uppercase tracking-wider font-sans">Syllabus & Downloads</span>
          <h3 class="text-[28px] lg:text-[36px] font-bold font-display text-support-white tracking-tight">Practice Resources</h3>
        </div>
        <p class="text-sm text-support-gray/60 font-sans font-normal max-w-sm leading-relaxed">
          High-end prep books, authentic mock materials, and sample audio archives updated for 2026 guidelines.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: "IELTS Speaking Cue Cards",
            desc: "Comprehensive speaking cue cards with model answers, structures, and vocabulary for IELTS speaking tasks.",
            size: "1.4 MB PDF",
            downloads: "Free Download",
            file: "/material/IELTS-Speaking-Cue-Cards.pdf"
          },
          {
            title: "IELTS Vocabulary Cheat Sheet (Top 100)",
            desc: "Highly curated list of top 100 IELTS vocabulary words with definitions, synonyms, and practical sentence examples.",
            size: "2.9 MB PDF",
            downloads: "Free Download",
            file: "/material/IELTS-Vocabulary-Cheat-Sheet-Top-100-Words.pdf"
          },
          {
            title: "IELTS Writing Task 2 Templates",
            desc: "Premium high-scoring structural templates and vocabulary frameworks for IELTS Writing Task 2 essays.",
            size: "1.3 MB PDF",
            downloads: "Free Download",
            file: "/material/task_2 template.pdf"
          }
        ].map(doc => (
          <div class="p-6 rounded-2xl border border-slate-200/80 bg-white flex flex-col justify-between space-y-4 hover:border-accent-blue/30 transition-all duration-300 shadow-sm">
            <div class="space-y-2">
              <h4 class="text-base lg:text-lg font-bold text-support-white font-display leading-snug">{doc.title}</h4>
              <p class="text-sm text-support-gray leading-relaxed font-sans font-normal">{doc.desc}</p>
            </div>
            <div class="flex items-center justify-between pt-4 border-t border-slate-100">
              <div>
                <span class="block text-xs text-support-gray/55 font-sans font-medium">{doc.size}</span>
                <span class="block text-xs text-accent-blue font-sans font-semibold">{doc.downloads}</span>
              </div>
              <a 
                href={doc.file}
                download
                class="p-2.5 rounded-lg bg-accent-blue/10 hover:bg-accent-blue hover:text-white text-accent-indigo transition-colors cursor-pointer flex items-center justify-center"
                aria-label={`Download ${doc.title}`}
              >
                <span set:html={SVG.Download} class="w-4 h-4 flex items-center justify-center" />
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>

  </section>

  {/* Client floating chatbot */}
  <AICounsellor client:only="react" />
</Layout>