---
import { supabase } from "../utils/supabase";
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
const SVG = {
  Newspaper: (cls = "") => `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="${cls}"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>`,
  ArrowUpRight: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>`
};

let visaUpdates = [];
try {
  const { data, error } = await supabase
    .from('visa_updates')
    .select('*');

  if (error) throw error;
  
  const parseUpdateDate = (dateStr: string) => {
    const normalized = (dateStr || '').trim();
    if (/^\d{4}$/.test(normalized)) {
      return {
        timestamp: new Date(`${normalized}-01-01T00:00:00Z`).getTime(),
        year: normalized
      };
    }
    const parsed = Date.parse(normalized);
    if (!isNaN(parsed)) {
      const dateObj = new Date(parsed);
      return {
        timestamp: parsed,
        year: String(dateObj.getFullYear())
      };
    }
    const yearMatch = normalized.match(/\b(20\d{2})\b/);
    const year = yearMatch ? yearMatch[1] : "Unknown";
    return {
      timestamp: yearMatch ? new Date(`${year}-01-01T00:00:00Z`).getTime() : 0,
      year
    };
  };

  const mapped = (data || []).map(u => {
    const parsed = parseUpdateDate(u.date);
    return {
      ...u,
      tagBg: u.tag_bg,
      _timestamp: parsed.timestamp,
      _year: parsed.year
    };
  });

  visaUpdates = mapped.sort((a, b) => b._timestamp - a._timestamp);
} catch (err) {
  console.error("Failed to fetch visa updates from Supabase:", err);
}

const uniqueYears = Array.from(new Set(visaUpdates.map(u => u._year)))
  .filter(y => y !== "Unknown")
  .sort((a, b) => b.localeCompare(a));
---

<Layout
  title="Visa & Admission Updates | TESCA"
  description="Stay informed with the latest visa bulletins, admission news, and study abroad updates from TESCA."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12">
    <!-- Header -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-gradient-to-br from-slate-50 to-blue-50/30 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-8 items-center p-6 sm:p-8 md:p-12 relative mb-10 sm:mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      <div class="md:col-span-7 space-y-6 relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          INSIGHTS & UPDATES
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Visa & Admission Bulletins
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          Stay ahead with the latest visa policy changes, admission deadlines, scholarship opportunities, and study abroad news from around the world.
        </p>
      </div>
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-center">
        <div class="relative w-full max-w-[320px] md:max-w-[400px] flex items-center aspect-[4/3] rounded-2xl overflow-hidden shadow-md border border-slate-200 bg-white p-2">
          <img 
            src="/images/visa_updates_banner.png" 
            alt="Visa & Admission Bulletins" 
            class="w-full h-full object-cover rounded-xl"
            loading="eager"
            decoding="async"
            width="1920"
            height="1080"
          />
        </div>
      </div>
    </div>

    <!-- Beautiful Filter tabs -->
    {visaUpdates.length > 0 && uniqueYears.length > 0 && (
      <div class="flex flex-wrap gap-2.5 mb-8 pb-3 border-b border-slate-200/60">
        <button
          data-filter-year="all"
          class="update-filter-btn px-4.5 py-1.5 rounded-full text-[12px] sm:text-[13px] font-bold font-sans border transition-all duration-300 cursor-pointer shadow-sm hover:scale-[1.01] bg-indigo-600 text-white border-transparent shadow-md shadow-indigo-100"
        >
          All Bulletins
        </button>
        {uniqueYears.map(year => (
          <button
            data-filter-year={year}
            class="update-filter-btn px-4.5 py-1.5 rounded-full text-[12px] sm:text-[13px] font-semibold font-sans border transition-all duration-300 cursor-pointer shadow-sm hover:scale-[1.01] bg-slate-50 border-slate-200 text-slate-600 hover:bg-slate-100 hover:text-slate-800"
          >
            {year}
          </button>
        ))}
      </div>
    )}

    <!-- Updates Grid -->
    {visaUpdates.length === 0 ? (
      <div class="text-center py-20">
        <span set:html={SVG.Newspaper("w-16 h-16 mx-auto text-slate-300 mb-4 flex items-center justify-center")} />
        <h2 class="text-xl font-bold text-slate-500 font-display">No updates available</h2>
        <p class="text-sm text-slate-400 mt-2">Check back later for the latest visa and admission news.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {visaUpdates.map((item) => (
          <a
            href={item.link}
            target={item.link.startsWith("http") ? "_blank" : undefined}
            rel={item.link.startsWith("http") ? "noopener noreferrer" : undefined}
            data-year={item._year}
            class="update-card group block bg-white border border-slate-200 rounded-2xl p-6 hover:shadow-lg hover:border-accent-blue/30 transition-all duration-300 hover:-translate-y-1 no-underline"
            style="opacity: 1; transform: translateY(0); transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;"
          >
            <div class="flex items-center gap-3 mb-4">
              <span class="text-[13px] font-medium text-slate-400 font-sans whitespace-nowrap">{item.date}</span>
              <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded border whitespace-nowrap ${item.tagBg}`}>
                {item.tag}
              </span>
            </div>
            <h3 class="text-[15px] font-bold font-display text-slate-800 group-hover:text-accent-blue transition-colors leading-snug line-clamp-3">
              {item.title}
            </h3>
            <div class="mt-4 pt-4 border-t border-slate-100 flex items-center gap-1.5 text-[13px] font-semibold text-accent-blue group-hover:gap-2 transition-all">
              <span>Read more</span>
              <span set:html={SVG.ArrowUpRight} class="w-3.5 h-3.5 flex items-center justify-center" />
            </div>
          </a>
        ))}
      </div>
    )}

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const buttons = document.querySelectorAll('.update-filter-btn');
        const cards = document.querySelectorAll('.update-card') as NodeListOf<HTMLElement>;

        buttons.forEach(btn => {
          btn.addEventListener('click', () => {
            // Reset styling for all buttons
            buttons.forEach(b => {
              b.className = "update-filter-btn px-4.5 py-1.5 rounded-full text-[12px] sm:text-[13px] font-semibold font-sans border transition-all duration-300 cursor-pointer shadow-sm hover:scale-[1.01] bg-slate-50 border-slate-200 text-slate-600 hover:bg-slate-100 hover:text-slate-800";
            });

            // Apply active styling to the clicked button
            btn.className = "update-filter-btn px-4.5 py-1.5 rounded-full text-[12px] sm:text-[13px] font-bold font-sans border transition-all duration-300 cursor-pointer shadow-sm hover:scale-[1.01] bg-indigo-600 text-white border-transparent shadow-md shadow-indigo-100";

            const yearFilter = btn.getAttribute('data-filter-year');

            cards.forEach(card => {
              const cardYear = card.getAttribute('data-year');
              if (yearFilter === 'all' || cardYear === yearFilter) {
                card.style.display = 'block';
                // Trigger animation
                requestAnimationFrame(() => {
                  setTimeout(() => {
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                  }, 15);
                });
              } else {
                card.style.opacity = '0';
                card.style.transform = 'translateY(12px)';
                setTimeout(() => {
                  if (card.style.opacity === '0') {
                    card.style.display = 'none';
                  }
                }, 300);
              }
            });
          });
        });
      });
    </script>
  </section>

  <AICounsellor client:only="react" />
</Layout>
