---
import { env } from "cloudflare:workers";
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
import { ArrowUpRight, Calendar, Newspaper } from "lucide-react";

let visaUpdates = [];
try {
  const db = env?.tesca_db || env?.DB;
  if (db) {
    const { results } = await db.prepare("SELECT * FROM visa_updates ORDER BY id DESC").all();
    visaUpdates = results.map(u => ({
      ...u,
      tagBg: u.tag_bg
    })) || [];
  }
} catch (err) {
  console.error("Failed to fetch visa updates from D1:", err);
}
---

<Layout
  title="Visa & Admission Updates | TESCA"
  description="Stay informed with the latest visa bulletins, admission news, and study abroad updates from TESCA."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12">
    <!-- Header -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-gradient-to-br from-slate-50 to-blue-50/30 border border-slate-200/60 shadow-lg grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-8 items-center p-6 sm:p-8 md:p-12 relative mb-10 sm:mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      <div class="md:col-span-7 space-y-6 relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          INSIGHTS & UPDATES
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Visa & Admission Bulletins
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed max-w-xl">
          Stay ahead with the latest visa policy changes, admission deadlines, scholarship opportunities, and study abroad news from around the world.
        </p>
      </div>
      <div class="md:col-span-5 relative flex justify-center md:justify-end self-stretch items-center">
        <div class="relative w-full max-w-[320px] md:max-w-[400px] flex items-center aspect-[4/3] rounded-2xl overflow-hidden shadow-md border border-accent-blue/15 bg-accent-blue/5">
          <div class="w-full h-full flex items-center justify-center text-accent-blue/30">
            <Newspaper class="w-24 h-24" />
          </div>
        </div>
      </div>
    </div>

    <!-- Updates Grid -->
    {visaUpdates.length === 0 ? (
      <div class="text-center py-20">
        <Newspaper class="w-16 h-16 mx-auto text-slate-300 mb-4" />
        <h2 class="text-xl font-bold text-slate-500 font-display">No updates available</h2>
        <p class="text-sm text-slate-400 mt-2">Check back later for the latest visa and admission news.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {visaUpdates.map((item) => (
          <a
            href={item.link}
            target={item.link.startsWith("http") ? "_blank" : undefined}
            rel={item.link.startsWith("http") ? "noopener noreferrer" : undefined}
            class="group block bg-white border border-slate-200 rounded-2xl p-6 hover:shadow-lg hover:border-accent-blue/30 transition-all duration-300 hover:-translate-y-1 no-underline"
          >
            <div class="flex items-center gap-3 mb-4">
              <span class="text-[13px] font-medium text-slate-400 font-sans whitespace-nowrap">{item.date}</span>
              <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded border whitespace-nowrap ${item.tagBg}`}>
                {item.tag}
              </span>
            </div>
            <h3 class="text-[15px] font-bold font-display text-slate-800 group-hover:text-accent-blue transition-colors leading-snug line-clamp-3">
              {item.title}
            </h3>
            <div class="mt-4 pt-4 border-t border-slate-100 flex items-center gap-1.5 text-[13px] font-semibold text-accent-blue group-hover:gap-2 transition-all">
              <span>Read more</span>
              <ArrowUpRight class="w-3.5 h-3.5" />
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <AICounsellor client:load />
</Layout>
