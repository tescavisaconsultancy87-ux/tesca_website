---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  Check: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-emerald-600"><polyline points="20 6 9 17 4 12"/></svg>`
};
---

<Layout 
  title="Visa Refusal Analysis & Re-application Services | TESCA"
  description="Overcome visa refusals for Canada, USA, UK, and Australia. Get professional profile rehabilitation and CAIPS notes analysis."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-16 text-left">
    
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10 font-sans">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          Visa Services
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Visa Refusal Help & Re-filing
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          Has your visa been refused? Do not panic. We analyze embassy rejection reasons, retrieve CAIPS/GCMS notes, rebuild your SOP/cover letters, and prepare a bulletproof re-application.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      
      <div class="lg:col-span-2 space-y-12 font-sans">
        
        <!-- Highlights -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">Refusal Diagnosis</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Deconstructing embassy refusal letters to isolate documentation or financial credibility failures.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">CAIPS/GCMS Audits</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Retrieving direct visa officer notes from embassy systems to understand the exact concern.</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-50 border border-slate-200/50 shadow-sm space-y-2">
            <h4 class="font-bold text-slate-850">SOP Re-drafting</h4>
            <p class="text-xs text-slate-500 leading-relaxed">Re-writing Statement of Purpose (SOP) to directly address and resolve past objection flags.</p>
          </div>
        </div>

        <!-- Checklist -->
        <div class="space-y-4">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Refusal Case Elements</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {[
              "Copy of the official embassy Refusal Letter",
              "Previously submitted visa application form (imm5257/DS-160)",
              "Previously submitted SOP / personal statements",
              "ECA, IELTS, and academic transcripts overview",
              "Financial proof audit (bank statements & sponsor details)",
              "GCMS / CAIPS Notes details (for Canadian files)"
            ].map(doc => (
              <div class="flex items-center gap-3 p-4 rounded-xl border border-slate-100 bg-white shadow-sm">
                <div class="p-1 rounded-full bg-emerald-50 text-emerald-600">
                  <span set:html={SVG.Check} />
                </div>
                <span class="text-xs font-semibold text-slate-700">{doc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Application Timeline -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Re-filing Strategy</h2>
          <div class="relative pl-6 border-l-2 border-slate-200 space-y-8">
            {[
              "Analyze refusal letter reasons and compile previous application portal history",
              "Request and review GCMS / CAIPS officer notes (where applicable)",
              "Identify documentation gaps (financial proofs, home ties, study intent)",
              "Re-draft SOP and cover letters to address officer concerns point-by-point",
              "Submit a clean, fortified re-application file to the embassy"
            ].map((step, idx) => (
              <div class="relative">
                <div class="absolute -left-[31px] top-0 w-4 h-4 rounded-full bg-accent-blue border-4 border-white shadow-sm"></div>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Phase {idx + 1}</span>
                <p class="text-sm font-semibold text-slate-700 mt-1">{step}</p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div class="space-y-6 sticky top-28 font-sans">
        <div class="glass-card rounded-[2rem] p-6 bg-gradient-to-br from-indigo-50/50 to-white border border-indigo-100 shadow-md space-y-6">
          <div class="space-y-1">
            <h3 class="text-xl font-bold text-slate-800 font-display tracking-tight">Re-apply with Confidence</h3>
            <p class="text-xs text-slate-500 leading-relaxed font-normal">
              Analyze your refusal letter dynamically to estimate your re-application path viability.
            </p>
          </div>

          <form id="refusal-form" class="space-y-4 text-xs text-slate-700">
            <!-- Country of Refusal -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Refused Destination</label>
              <select id="ref-country" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="ca">Canada</option>
                <option value="usa">United States</option>
                <option value="uk">United Kingdom</option>
                <option value="au">Australia</option>
                <option value="schengen">Schengen</option>
                <option value="other">Other Country</option>
              </select>
            </div>

            <!-- Refusal Reason -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Primary Refusal Reason</label>
              <select id="ref-reason" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="ties" selected>Home Ties / Purpose of Visit (e.g. 214b / 216b)</option>
                <option value="funds">Inadequate Funds / Financial Credibility</option>
                <option value="study">Study Plan / Course Misalignment</option>
                <option value="docs">Missing / Incomplete Documentation</option>
                <option value="history">Immigration History / Overstay Concerns</option>
              </select>
            </div>

            <!-- GCMS Notes Status -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Do you have CAIPS/GCMS Notes?</label>
              <div class="flex gap-4">
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="ref-notes" value="yes" class="w-3.5 h-3.5 text-accent-blue" />
                  <span>Yes</span>
                </label>
                <label class="flex items-center gap-1.5 cursor-pointer">
                  <input type="radio" name="ref-notes" value="no" checked class="w-3.5 h-3.5 text-accent-blue" />
                  <span>No</span>
                </label>
              </div>
            </div>

            <!-- Prior Rejections -->
            <div class="space-y-1.5">
              <label class="block font-semibold text-slate-800">Prior Rejections</label>
              <select id="ref-count" class="w-full bg-white border border-slate-200 rounded-lg px-3 py-2 focus:outline-none focus:border-accent-blue cursor-pointer">
                <option value="1" selected>1 Refusal</option>
                <option value="2">2 Refusals</option>
                <option value="3">3 or more Refusals</option>
              </select>
            </div>

            <!-- Result Box -->
            <div class="p-4 rounded-xl bg-slate-50 border border-slate-150/80 space-y-3">
              <div>
                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest block">Re-filing Feasibility</span>
                <span id="ref-status-display" class="text-base font-bold text-slate-850 mt-1 block">Moderate Success probability</span>
              </div>
              
              <!-- Dynamic Actions -->
              <div id="ref-actions-box" class="text-[10px] bg-amber-50 border border-amber-100 text-amber-800 p-2.5 rounded-lg space-y-1">
                <strong class="block font-semibold">Recommended Remedy:</strong>
                <p id="ref-remedy-text" class="leading-relaxed font-normal">Order GCMS Notes first to understand specific concerns before re-filing.</p>
              </div>
            </div>

            <button 
              type="button" 
              onclick="window.dispatchEvent(new CustomEvent('open-counsellor-form'))"
              class="w-full py-2.5 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-xs rounded-xl shadow-md transition-all duration-200 text-center cursor-pointer tracking-wide block"
            >
              Start Refusal Consultation
            </button>
          </form>
        </div>
      </div>

      <!-- Script for Refusal Diagnostic -->
      <script is:inline>
        function runRefusalDiagnostic() {
          const country = document.getElementById('ref-country').value;
          const reason = document.getElementById('ref-reason').value;
          const count = document.getElementById('ref-count').value;
          
          const notesRadio = document.querySelector('input[name="ref-notes"]:checked');
          const hasNotes = notesRadio ? notesRadio.value === 'yes' : false;

          const statusEl = document.getElementById('ref-status-display');
          const remedyEl = document.getElementById('ref-remedy-text');
          const actionsBox = document.getElementById('ref-actions-box');

          let feasibility = "Moderate Success Probability";
          let remedy = "Detailed profile review needed. We suggest compiling previous files.";

          if (count === '3') {
            feasibility = "Complex Profile (Requires Audit)";
            remedy = "Multiple refusals require active profile rehabilitation and senior counselor case review before re-filing.";
          } else if (count === '2') {
            feasibility = "Moderate Risk (Needs Preparation)";
            remedy = "Requires restructuring SOP from scratch and gathering stronger ties or seasoned funds.";
          } else {
            // 1 refusal cases
            if (reason === 'ties') {
              feasibility = "Good Re-filing Viability (75%+)";
              remedy = "Requires a fortified statement of purpose (SOP) explaining home ties, career goals, and assets in India.";
            } else if (reason === 'funds') {
              feasibility = "Good Re-filing Viability (80%+)";
              remedy = "Requires seasoning funds for 3-6 months or securing an education loan sanction letter to prove credibility.";
            } else if (reason === 'study') {
              feasibility = "Moderate Viability (65%+)";
              remedy = "Requires course progression justification. An explanation letter should link the new course to past studies.";
            } else if (reason === 'docs') {
              feasibility = "High Success Probability (90%+)";
              remedy = "Simply re-file by compiling correct documents matching embassy checklist guidelines.";
            }
          }

          // Override for Canada/USA if no GCMS notes
          if ((country === 'ca' || country === 'usa') && !hasNotes && count !== '3') {
            feasibility = "Order Notes First";
            remedy = "For " + (country === 'ca' ? 'Canada' : 'USA') + " files, we recommend ordering GCMS/CAIPS notes first to see exact officer concerns.";
          }

          if (statusEl) statusEl.textContent = feasibility;
          if (remedyEl) remedyEl.textContent = remedy;

          if (actionsBox) {
            if (feasibility.includes("High") || feasibility.includes("Good")) {
              actionsBox.className = "text-[10px] bg-emerald-50 border border-emerald-100 text-emerald-800 p-2.5 rounded-lg space-y-1";
            } else if (feasibility.includes("Risky") || feasibility.includes("Complex") || feasibility.includes("Order")) {
              actionsBox.className = "text-[10px] bg-red-50 border border-red-100 text-red-800 p-2.5 rounded-lg space-y-1";
            } else {
              actionsBox.className = "text-[10px] bg-amber-50 border border-amber-100 text-amber-800 p-2.5 rounded-lg space-y-1";
            }
          }
        }

        function initRefusalDiagnostic() {
          const form = document.getElementById('refusal-form');
          if (form) {
            form.addEventListener('change', runRefusalDiagnostic);
            runRefusalDiagnostic();
          }
        }

        document.addEventListener('DOMContentLoaded', initRefusalDiagnostic);
        document.addEventListener('astro:page-load', initRefusalDiagnostic);
      </script>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
