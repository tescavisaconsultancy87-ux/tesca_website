---
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
---

<Layout
  title="AI Google Review Generator | TESCA Visa Consultancy"
  description="Generate a natural, genuine Google review for visa and study abroad consultancy services instantly."
  showNavFooter={false}
>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pt-2 pb-10 sm:pt-4 sm:pb-16">
    
    <div class="bg-white border border-slate-200 rounded-[2rem] p-5 sm:p-6 lg:p-8 shadow-xl relative text-left w-full max-h-[85vh] overflow-y-auto">
      <div class="space-y-4 sm:space-y-5">
        
        <div class="space-y-2">
          <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider">
            Target Country (Optional)
          </span>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3" id="country-grid">
            <button
              type="button"
              data-value=""
              class="country-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-indigo-50 border-indigo-500 text-indigo-700"
            >
              🌍 All Countries
            </button>
            <button
              type="button"
              data-value="USA"
              data-code="us"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/us.png" alt="USA flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              USA
            </button>
            <button
              type="button"
              data-value="United Kingdom"
              data-code="gb"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/gb.png" alt="UK flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              UK
            </button>
            <button
              type="button"
              data-value="Canada"
              data-code="ca"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/ca.png" alt="Canada flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Canada
            </button>
            <button
              type="button"
              data-value="Australia"
              data-code="au"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/au.png" alt="Australia flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Australia
            </button>
            <button
              type="button"
              data-value="Germany"
              data-code="de"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/de.png" alt="Germany flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Germany
            </button>
            <button
              type="button"
              data-value="Ireland"
              data-code="ie"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/ie.png" alt="Ireland flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Ireland
            </button>
            <button
              type="button"
              data-value="New Zealand"
              data-code="nz"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/nz.png" alt="New Zealand flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              New Zealand
            </button>
            <button
              type="button"
              data-value="Dubai"
              data-code="ae"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/ae.png" alt="Dubai flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Dubai
            </button>
            <button
              type="button"
              data-value="Singapore"
              data-code="sg"
              class="country-pill flex items-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              <img src="https://flagcdn.com/w20/sg.png" alt="Singapore flag" class="w-5 h-3.5 object-cover rounded-xs shadow-xs" />
              Singapore
            </button>
          </div>
        </div>

        <div class="space-y-2">
          <span class="block text-xs font-bold text-slate-700 uppercase tracking-wider">
            Visa Type (Optional)
          </span>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" id="visa-grid">
            <button
              type="button"
              data-value=""
              class="visa-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-indigo-50 border-indigo-500 text-indigo-700"
            >
              🌐 All Visas
            </button>
            <button
              type="button"
              data-value="Student Visa"
              class="visa-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              🎓 Student Visa
            </button>
            <button
              type="button"
              data-value="Visitor / Tourist Visa"
              class="visa-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              ✈️ Tourist Visa
            </button>
            <button
              type="button"
              data-value="Dependent Visa"
              class="visa-pill flex items-center justify-center gap-2 px-4 py-3 rounded-xl border text-xs font-bold transition-all hover:bg-slate-50 active:scale-95 cursor-pointer bg-white border-slate-200 text-slate-700"
            >
              👨‍👩‍👧‍👦 Dependent Visa
            </button>
          </div>
        </div>

        <div class="space-y-2 pt-4 border-t border-slate-100">
          <label for="review-output-textarea" class="block text-xs font-bold text-slate-700 uppercase tracking-wider">
            Your Generated Review (~30 words)
          </label>
          <textarea
            id="review-output-textarea"
            rows="3"
            readonly
            class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-sm text-slate-700 leading-relaxed focus:outline-none resize-none font-sans font-medium"
            placeholder="Generating review..."
          ></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <button
            type="button"
            id="submit-btn"
            class="w-full py-3 bg-[#F08A00] hover:bg-[#C06E00] text-white font-bold text-sm rounded-full shadow-md hover:scale-[1.01] transition-all flex items-center justify-center gap-2 cursor-pointer font-sans tracking-wide active:scale-95"
          >
            <span>Copy & Go to Google Reviews</span>
          </button>
          
          <button
            type="button"
            id="regenerate-btn"
            class="w-full py-3 bg-[#0A7880] hover:bg-[#075E64] text-white font-bold text-sm rounded-full shadow-md hover:scale-[1.01] transition-all flex items-center justify-center gap-2 cursor-pointer font-sans tracking-wide active:scale-95"
          >
            <span>Regenerate Variation</span>
          </button>
        </div>

      </div>
    </div>
  </section>

  <AICounsellor client:only="react" />
</Layout>

<script>
  function setupReviewGenerator() {
    let selectedCountry = "";
    let selectedVisaType = "";

    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const regenerateBtn = document.getElementById("regenerate-btn") as HTMLButtonElement;
    const reviewOutput = document.getElementById("review-output-textarea") as HTMLTextAreaElement;

    const countryPills = document.querySelectorAll(".country-pill");
    const visaPills = document.querySelectorAll(".visa-pill");

    if (!reviewOutput || !submitBtn || !regenerateBtn) return;

    const FRONTEND_FALLBACKS = [
      "Had an amazing experience with TESCA Visa Consultancy for my {visaPhrase}. The team is professional, supportive, and guided me through the entire process {countryPhrase}.",
      "Highly recommend TESCA for {visaPhrase} guidance. They provided clear assistance with all my documentation {countryPhrase}, and their communication was always prompt.",
      "Great service and professional approach. TESCA helped me secure my {visaPhrase} {countryPhrase} on time. The counselor was very supportive throughout.",
      "TESCA Visa Consultancy is highly reliable. Their expert team made my {visaPhrase} {countryPhrase} stress-free with their professional guidance and constant support.",
      "Very smooth and clear process. The team at TESCA was highly supportive, and their professional guidance helped me secure my {visaPhrase} {countryPhrase} without issues."
    ];

    function getLocalFallback() {
      const countryPhrase = selectedCountry ? `for ${selectedCountry}` : "abroad";
      const visaPhrase = selectedVisaType ? `${selectedVisaType} application` : "visa application";

      const template = FRONTEND_FALLBACKS[Math.floor(Math.random() * FRONTEND_FALLBACKS.length)];
      return template
        .replace("{visaPhrase}", visaPhrase)
        .replace("{countryPhrase}", countryPhrase);
    }

    // Helper to request API
    async function generateReview(loadingBtn: HTMLButtonElement) {
      if ((window as any).showBtnLoader) {
        (window as any).showBtnLoader(loadingBtn, "Generating...");
      } else {
        loadingBtn.disabled = true;
        loadingBtn.textContent = "Generating...";
      }
      reviewOutput.value = "Generating your review...";

      try {
        const res = await fetch("/api/generate-review", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            country: selectedCountry,
            visaType: selectedVisaType
          })
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || "Failed to generate review.");
        }

        const data = await res.json();
        reviewOutput.value = data.review || getLocalFallback();

      } catch (err: any) {
        console.warn("API failed, using local frontend backup review:", err);
        reviewOutput.value = getLocalFallback();
      } finally {
        if ((window as any).hideBtnLoader) {
          (window as any).hideBtnLoader(loadingBtn);
        } else {
          loadingBtn.disabled = false;
        }
        submitBtn.textContent = "Copy & Go to Google Reviews";
        regenerateBtn.textContent = "Regenerate Variation";
      }
    }

    // Set active styles helper
    function updateActivePills(pills: NodeListOf<Element>, activeValue: string, activeClasses: string[], inactiveClasses: string[]) {
      pills.forEach((pill) => {
        const value = pill.getAttribute("data-value") || "";
        if (value === activeValue) {
          pill.classList.remove(...inactiveClasses);
          pill.classList.add(...activeClasses);
        } else {
          pill.classList.remove(...activeClasses);
          pill.classList.add(...inactiveClasses);
        }
      });
    }

    const activeStyles = ["bg-indigo-50", "border-indigo-500", "text-indigo-700"];
    const inactiveStyles = ["bg-white", "border-slate-200", "text-slate-700"];

    // Country selection
    countryPills.forEach((pill) => {
      pill.addEventListener("click", () => {
        selectedCountry = pill.getAttribute("data-value") || "";
        updateActivePills(countryPills, selectedCountry, activeStyles, inactiveStyles);
        generateReview(regenerateBtn);
      });
    });

    // Visa selection
    visaPills.forEach((pill) => {
      pill.addEventListener("click", () => {
        selectedVisaType = pill.getAttribute("data-value") || "";
        updateActivePills(visaPills, selectedVisaType, activeStyles, inactiveStyles);
        generateReview(regenerateBtn);
      });
    });

    // Regenerate variation button click
    regenerateBtn.addEventListener("click", () => {
      generateReview(regenerateBtn);
    });

    // Copy to clipboard and redirect to Google Reviews
    submitBtn.addEventListener("click", () => {
      const text = reviewOutput.value || "";
      if (!text || text === "Generating your review..." || text.startsWith("Error:")) {
        alert("Please wait for the review to finish generating.");
        return;
      }

      // Try to copy to clipboard safely
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).catch((err) => {
          console.error("Failed to copy text:", err);
        });
      } else {
        // Fallback copy for webviews / in-app browsers on iOS
        try {
          const textarea = document.createElement("textarea");
          textarea.value = text;
          textarea.style.position = "fixed";
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();
          document.execCommand("copy");
          document.body.removeChild(textarea);
        } catch (err) {
          console.error("Fallback copy failed:", err);
        }
      }

      // Synchronous redirect is fully trusted and not blocked by iOS Safari
      window.location.href = "https://search.google.com/local/writereview?placeid=ChIJs1mzR4ZP4DsR_nxj9fVK9hE";
    });

    // Trigger initial load review
    generateReview(regenerateBtn);
  }

  // Bind handlers on swap/load
  setupReviewGenerator();
  document.addEventListener("astro:page-load", setupReviewGenerator);
</script>