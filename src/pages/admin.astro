---
import Layout from "../layouts/Layout.astro";
// Inline SVG helpers — no lucide-react in .astro (SSR hook errors)
const _s = (d: string, size = 20) => `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SVG = {
  ShieldAlert: _s('<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>', 24),
  AlertCircle: _s('<circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>', 20),
};
import { supabase } from "../utils/supabase";
import { checkAdminAuth } from "../utils/adminAuth";
import { getEnv } from "../utils/env";
import { getClientIP, checkRateLimit } from "../utils/security";

const serverSupabaseUrl = getEnv("PUBLIC_SUPABASE_URL") || import.meta.env.PUBLIC_SUPABASE_URL;
const serverSupabaseKey = getEnv("PUBLIC_SUPABASE_ANON_KEY") || import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

let errorMessage = "";

// Handle Login/Logout request
if (Astro.request.method === "POST") {
  try {
    const clientIP = getClientIP(Astro.request);
    if (await checkRateLimit(`admin-login:${clientIP}`, 10, 15 * 60 * 1000)) {
      errorMessage = "Too many attempts. Please wait a few minutes and try again.";
    } else {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "login") {
      const email = formData.get("email")?.toString();
      const password = formData.get("password")?.toString();

      if (email && password) {
        // 1. Try Supabase Auth
        const { data, error } = await supabase.auth.signInWithPassword({
          email,
          password
        });

        if (data?.session && data.user) {
          // Verify email is allowlisted as admin in database
          const { data: adminRecord, error: dbError } = await supabase
            .from('admins')
            .select('email')
            .eq('email', data.user.email)
            .maybeSingle();

          let isAllowed = false;
          if (!dbError && adminRecord) {
            isAllowed = true;
          }

          if (isAllowed) {
            Astro.cookies.set("sb-access-token", data.session.access_token, {
              path: "/",
              httpOnly: true,
              secure: true,
              sameSite: "strict",
              maxAge: data.session.expires_in,
            });
            Astro.cookies.set("sb-refresh-token", data.session.refresh_token, {
              path: "/",
              httpOnly: true,
              secure: true,
              sameSite: "strict",
              maxAge: data.session.expires_in,
            });
            Astro.cookies.delete("admin_session", { path: "/" });
            return Astro.redirect("/admin/dashboard");
          } else {
            await supabase.auth.signOut();
            errorMessage = "Access denied: Your email is not registered as an administrator.";
          }
        } else {
          const rawMsg = error?.message || "";
          if (rawMsg.includes("Invalid login credentials") || rawMsg.toLowerCase().includes("invalid_credentials")) {
            errorMessage = "Incorrect email or password. Please verify your credentials and try again.";
          } else {
            errorMessage = rawMsg || "Incorrect email or password. Please check your credentials.";
          }
        }
      } else {
        errorMessage = "Email and password are required.";
      }
    } else if (action === "logout") {
      try {
        await supabase.auth.signOut();
      } catch (e) {}
      Astro.cookies.delete("admin_session", { path: "/" });
      Astro.cookies.delete("sb-access-token", { path: "/" });
      Astro.cookies.delete("sb-refresh-token", { path: "/" });
      return Astro.redirect("/admin");
    }
    }
  } catch (err) {
    console.error("Login process error:", err);
    errorMessage = "An unexpected error occurred during login.";
  }
}

// Check session after handling POST requests (e.g. logout)
const isAuthenticated = await checkAdminAuth(Astro.cookies);
if (isAuthenticated) {
  return Astro.redirect("/admin/dashboard");
}
---

<Layout 
  title="Admin Authentication Portal | TESCA"
  description="Secure access configuration for TESCA web portals."
  showNavFooter={false}
>
  {/* Obfuscated configuration values passed from server to client to prevent build-time environment variable issues */}
  <div 
    id="sb-config-obf" 
    data-u={serverSupabaseUrl} 
    data-k={serverSupabaseKey} 
    class="hidden"
  ></div>

  <div class="min-h-screen bg-white flex items-center justify-center p-6 text-left font-sans">
    
    <div class="max-w-md w-full">
      {/* Brand logo or header */}
      <div class="text-center mb-8">
        <span class="inline-block text-xs font-bold bg-slate-100 text-slate-700 px-4 py-1.5 rounded-full border border-slate-200 uppercase tracking-widest font-sans">
          TESCA Control Center
        </span>
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-slate-800 mt-4">
          Administrative Sign In
        </h1>
        <p class="text-xs text-slate-500 font-sans mt-1">Enter your secure credentials to continue.</p>
      </div>

      {/* Errors */}
      {errorMessage && (
        <div class="flex items-center gap-3 p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-sm mb-6 font-medium animate-pulse">
          <span set:html={SVG.AlertCircle} class="text-rose-500 shrink-0" />
          <span>{errorMessage}</span>
        </div>
      )}

      {/* Client-side error container */}
      <div id="client-error-container" class="hidden flex items-center gap-3 p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-600 text-sm mb-6 font-medium">
        <span set:html={SVG.AlertCircle} class="text-rose-500 shrink-0" />
        <span id="client-error-message"></span>
      </div>

      {/* Card */}
      <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-lg">
        <div class="w-12 h-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center mx-auto mb-6 border border-indigo-100">
          <span set:html={SVG.ShieldAlert} />
        </div>
        
        {/* Login Form */}
        <form method="POST" class="space-y-5" id="login-form">
          <input type="hidden" name="action" value="login" />
          
          <div class="space-y-1.5">
            <label for="email" class="text-xs font-bold text-slate-600 uppercase tracking-wider">Email Address</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 font-sans text-sm transition-all"
              placeholder="admin@example.com"
            />
          </div>
          
          <div class="space-y-1.5">
            <label for="password" class="text-xs font-bold text-slate-600 uppercase tracking-wider">Security Password</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              required 
              class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 font-sans text-sm transition-all"
              placeholder="••••••••"
            />
          </div>
          
          <button 
            type="submit" 
            id="admin-login-btn"
            class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-4 flex items-center justify-center gap-2"
          >
            Authenticate Credentials
          </button>
        </form>

        {/* Forgot Password Form — hidden by default */}
        <div id="forgot-form-wrapper" class="hidden">
          <div class="text-center mb-5">
            <h2 class="text-lg font-extrabold text-slate-800 tracking-tight">Reset Password</h2>
            <p class="text-xs text-slate-500 mt-1">Enter your admin email and we'll send a secure reset link.</p>
          </div>

          <div class="space-y-5">
            <div class="space-y-1.5">
              <label for="reset-email" class="text-xs font-bold text-slate-600 uppercase tracking-wider">Admin Email Address</label>
              <input 
                type="email" 
                id="reset-email" 
                required 
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 font-sans text-sm transition-all"
                placeholder="admin@example.com"
              />
            </div>

            <button
              type="button"
              id="reset-btn"
              class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] flex items-center justify-center gap-2 disabled:opacity-50 disabled:scale-100 disabled:cursor-not-allowed"
            >
              <span id="reset-btn-text">Send Reset Link</span>
            </button>
          </div>

          {/* Status message area */}
          <div id="reset-status" class="mt-4 hidden"></div>
        </div>

        {/* Set New Password Form — hidden by default */}
        <div id="reset-password-form-wrapper" class="hidden">
          <div class="text-center mb-5">
            <h2 class="text-lg font-extrabold text-slate-800 tracking-tight">Set New Password</h2>
            <p class="text-xs text-slate-500 mt-1">Enter your new administrator security password.</p>
          </div>

          <div class="space-y-5">
            <div class="space-y-1.5">
              <label for="new-password" class="text-xs font-bold text-slate-600 uppercase tracking-wider">New Password</label>
              <input 
                type="password" 
                id="new-password" 
                required 
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 font-sans text-sm transition-all"
                placeholder="••••••••"
              />
            </div>

            <div class="space-y-1.5">
              <label for="confirm-password" class="text-xs font-bold text-slate-600 uppercase tracking-wider">Confirm New Password</label>
              <input 
                type="password" 
                id="confirm-password" 
                required 
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 font-sans text-sm transition-all"
                placeholder="••••••••"
              />
            </div>

            <button
              type="button"
              id="update-password-btn"
              class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-sm rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] flex items-center justify-center gap-2 disabled:opacity-50 disabled:scale-100 disabled:cursor-not-allowed"
            >
              <span id="update-password-btn-text">Update Password</span>
            </button>
          </div>

          {/* Status message area */}
          <div id="reset-password-status" class="mt-4 hidden"></div>
        </div>

        {/* Toggle link */}
        <div class="text-center mt-5">
          <button 
            type="button" 
            id="toggle-forgot" 
            class="text-xs font-semibold text-indigo-600 hover:text-indigo-500 transition-colors cursor-pointer bg-transparent border-none"
          >
            Forgot your password?
          </button>
        </div>
      </div>



      <div class="text-center mt-8">
        <a href="/" class="text-xs font-semibold text-slate-500 hover:text-slate-400 transition-colors">
          ← Return to Client Homepage
        </a>
      </div>
    </div>

  </div>
</Layout>

<script>
  import { validatePassword } from "../utils/validation";

  function setupForgotPassword() {
    const loginForm = document.getElementById('login-form') as HTMLFormElement;
    const forgotWrapper = document.getElementById('forgot-form-wrapper') as HTMLElement;
    const toggleBtn = document.getElementById('toggle-forgot') as HTMLButtonElement;
    const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
    const resetBtnText = document.getElementById('reset-btn-text') as HTMLSpanElement;
    const resetEmail = document.getElementById('reset-email') as HTMLInputElement;
    const resetStatus = document.getElementById('reset-status') as HTMLElement;

    if (!loginForm || !forgotWrapper || !toggleBtn || !resetBtn) return;

    // Guard to prevent binding multiple click listeners causing duplicate emails
    if (toggleBtn.dataset.initialized) return;
    toggleBtn.dataset.initialized = 'true';

    let showingForgot = false;
    let cooldownSeconds = 0;
    let cooldownInterval: ReturnType<typeof setInterval> | null = null;

    // Toggle between login and forgot password views
    toggleBtn.addEventListener('click', () => {
      showingForgot = !showingForgot;
      if (showingForgot) {
        loginForm.classList.add('hidden');
        forgotWrapper.classList.remove('hidden');
        toggleBtn.textContent = '← Back to Sign In';
        resetStatus.classList.add('hidden');
        resetEmail.value = '';
        resetEmail.focus();
      } else {
        loginForm.classList.remove('hidden');
        forgotWrapper.classList.add('hidden');
        toggleBtn.textContent = 'Forgot your password?';
      }
    });

    // Send reset request
    resetBtn.addEventListener('click', async () => {
      const email = resetEmail.value.trim().toLowerCase();

      // Client-side validation
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showStatus('Please enter a valid email address.', 'error');
        return;
      }

      // Disable button and show loading
      resetBtn.disabled = true;
      resetBtnText.textContent = 'Sending...';

      try {
        const res = await fetch('/api/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          showStatus(data.message, 'success');
          startCooldown(60); // 60-second cooldown before allowing another attempt
        } else {
          showStatus(data.message || 'Something went wrong. Please try again.', 'error');
        }
      } catch (err) {
        showStatus('Network error. Please check your connection and try again.', 'error');
      } finally {
        if (cooldownSeconds <= 0) {
          resetBtn.disabled = false;
          resetBtnText.textContent = 'Send Reset Link';
        }
      }
    });

    // Allow Enter key on the email input
    resetEmail.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        resetBtn.click();
      }
    });

    function showStatus(message: string, type: 'success' | 'error') {
      resetStatus.classList.remove('hidden');
      resetStatus.className = `mt-4 p-3.5 rounded-xl text-xs font-semibold flex items-center gap-2 ${
        type === 'success'
          ? 'bg-emerald-50 border border-emerald-200 text-emerald-700'
          : 'bg-rose-50 border border-rose-200 text-rose-600'
      }`;
      const icon = type === 'success'
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>';
      resetStatus.innerHTML = `<span class="shrink-0">${icon}</span><span>${message}</span>`;
    }

    function startCooldown(seconds: number) {
      cooldownSeconds = seconds;
      resetBtn.disabled = true;
      resetBtnText.textContent = `Retry in ${cooldownSeconds}s`;

      if (cooldownInterval) clearInterval(cooldownInterval);
      cooldownInterval = setInterval(() => {
        cooldownSeconds--;
        if (cooldownSeconds <= 0) {
          if (cooldownInterval) clearInterval(cooldownInterval);
          cooldownInterval = null;
          resetBtn.disabled = false;
          resetBtnText.textContent = 'Send Reset Link';
        } else {
          resetBtnText.textContent = `Retry in ${cooldownSeconds}s`;
        }
      }, 1000);
    }
  }

  function setupRecoveryFlow() {
    const hash = window.location.hash.substring(1);
    if (!hash) return;

    const params = new URLSearchParams(hash);
    const accessToken = params.get('access_token');
    const refreshToken = params.get('refresh_token');
    const type = params.get('type');
    const error = params.get('error');
    const errorDescription = params.get('error_description');

    const clientErrorContainer = document.getElementById('client-error-container');
    const clientErrorMessage = document.getElementById('client-error-message');

    if (error || errorDescription) {
      // Clear hash so page reload doesn't keep showing the error
      window.location.hash = '';
      
      if (clientErrorContainer && clientErrorMessage) {
        // Secure, generic error message (avoid leaking technical details to user)
        clientErrorMessage.textContent = 'The password reset link is invalid or has expired. Please request a new one.';
        clientErrorContainer.classList.remove('hidden');
      }
      return;
    }

    if (type === 'recovery' && accessToken && refreshToken) {
      const loginForm = document.getElementById('login-form');
      const forgotWrapper = document.getElementById('forgot-form-wrapper');
      const toggleForgotBtn = document.getElementById('toggle-forgot');
      const resetPasswordWrapper = document.getElementById('reset-password-form-wrapper');
      const updatePasswordBtn = document.getElementById('update-password-btn');
      const newPasswordInput = document.getElementById('new-password') as HTMLInputElement;
      const confirmPasswordInput = document.getElementById('confirm-password') as HTMLInputElement;
      const resetPasswordStatus = document.getElementById('reset-password-status');

      // Hide login and forgot forms
      if (loginForm) loginForm.classList.add('hidden');
      if (forgotWrapper) forgotWrapper.classList.add('hidden');
      if (toggleForgotBtn) toggleForgotBtn.classList.add('hidden');

      // Show reset password form
      if (resetPasswordWrapper) {
        resetPasswordWrapper.classList.remove('hidden');
      }

      // Handle updating the password
      if (updatePasswordBtn) {
        // Clone to remove existing listeners
        const newBtn = updatePasswordBtn.cloneNode(true) as HTMLButtonElement;
        updatePasswordBtn.parentNode?.replaceChild(newBtn, updatePasswordBtn);

        newBtn.addEventListener('click', async () => {
          const newPassword = newPasswordInput?.value;
          const confirmPassword = confirmPasswordInput?.value;

          const pwCheck = validatePassword(newPassword);
          if (!pwCheck.valid) {
            showResetStatus(pwCheck.message || 'Password does not meet the security requirements.', 'error');
            return;
          }

          if (newPassword !== confirmPassword) {
            showResetStatus('Passwords do not match.', 'error');
            return;
          }

          newBtn.disabled = true;
          const textSpan = newBtn.querySelector('#update-password-btn-text');
          if (textSpan) textSpan.textContent = 'Updating...';

          try {
            // Get config from DOM obfuscated attributes
            const configEl = document.getElementById('sb-config-obf');
            const url = configEl?.getAttribute('data-u');
            const key = configEl?.getAttribute('data-k');

            if (!url || !key) {
              throw new Error('Connection configuration not found. Please reload or request a new reset link.');
            }

            const { createClient } = await import('@supabase/supabase-js');
            const supabase = createClient(url, key);

            // Set the session first so we are authenticated
            const { error: sessionError } = await supabase.auth.setSession({
              access_token: accessToken,
              refresh_token: refreshToken,
            });

            if (sessionError) throw sessionError;

            // Update user password
            const { error: updateError } = await supabase.auth.updateUser({
              password: newPassword,
            });

            if (updateError) throw updateError;

            // Set cookies on the server so they are logged in on the SSR pages
            const setSessionRes = await fetch('/api/set-session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                access_token: accessToken,
                refresh_token: refreshToken,
                expires_in: 3600,
              }),
            });

            if (!setSessionRes.ok) {
              throw new Error('Failed to establish secure session cookies.');
            }

            showResetStatus('Password updated successfully! Redirecting...', 'success');
            
            // Clear hash
            window.location.hash = '';

            setTimeout(() => {
              window.location.href = '/admin/dashboard';
            }, 1500);

          } catch (err: any) {
            console.error('Password reset failure:', err);
            // Secure, generic error message (avoid leaking technical details/env var names to user)
            showResetStatus('Failed to update password. The link may have expired or is invalid.', 'error');
            newBtn.disabled = false;
            if (textSpan) textSpan.textContent = 'Update Password';
          }
        });
      }

      function showResetStatus(message: string, type: 'success' | 'error') {
        if (!resetPasswordStatus) return;
        resetPasswordStatus.classList.remove('hidden');
        resetPasswordStatus.className = `mt-4 p-3.5 rounded-xl text-xs font-semibold flex items-center gap-2 ${
          type === 'success'
            ? 'bg-emerald-50 border border-emerald-200 text-emerald-700'
            : 'bg-rose-50 border border-rose-200 text-rose-600'
        }`;
        const icon = type === 'success'
          ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
          : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>';
        resetPasswordStatus.innerHTML = `<span class="shrink-0">${icon}</span><span>${message}</span>`;
      }
    }
  }

  function setupLoginForm() {
    const loginForm = document.getElementById('login-form') as HTMLFormElement;
    const loginBtn = document.getElementById('admin-login-btn') as HTMLButtonElement;
    const clientErrorContainer = document.getElementById('client-error-container');
    const clientErrorMessage = document.getElementById('client-error-message');

    if (!loginForm || !loginBtn || !clientErrorContainer || !clientErrorMessage) return;
    if ((loginForm as any)._bound) return;
    (loginForm as any)._bound = true;

    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear any previous error messages
      clientErrorContainer.classList.add('hidden');
      clientErrorMessage.textContent = '';

      // Hide the server-side error element if it exists in the DOM to avoid showing duplicate errors
      const serverErrorEl = document.querySelector('.flex.items-center.gap-3.p-4.bg-rose-50.border-rose-200.text-rose-600');
      if (serverErrorEl) {
        (serverErrorEl as HTMLElement).style.display = 'none';
      }

      // Show loading state
      loginBtn.disabled = true;
      const originalText = loginBtn.textContent;
      loginBtn.textContent = 'Authenticating...';

      try {
        const formData = new FormData(loginForm);
        const res = await fetch(window.location.href, {
          method: 'POST',
          body: formData
        });

        if (res.redirected) {
          // Success: server redirected us to dashboard
          window.location.href = res.url;
          return;
        }

        // Failure: get the page content to find the error message
        const htmlText = await res.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(htmlText, 'text/html');

        // Look for the error message container inside the returned HTML
        const returnedErrorEl = doc.querySelector('.text-rose-600 span:not(.shrink-0), .bg-rose-50 span:not(.shrink-0)');
        let errorText = "";
        if (returnedErrorEl) {
          errorText = returnedErrorEl.textContent?.trim() || "";
        }

        // Clean up and translate technical terms for a friendly user experience
        let displayError = "Incorrect email or password. Please verify your credentials and try again.";
        if (errorText) {
          const lowerText = errorText.toLowerCase();
          if (lowerText.includes("invalid login credentials") || lowerText.includes("invalid_credentials")) {
            displayError = "Incorrect password or email address. Please check and try again.";
          } else if (lowerText.includes("not registered as an administrator")) {
            displayError = "This email is not registered as an administrator.";
          } else {
            displayError = errorText;
          }
        }

        clientErrorMessage.textContent = displayError;
        clientErrorContainer.classList.remove('hidden');

      } catch (err) {
        console.error("AJAX login error:", err);
        clientErrorMessage.textContent = "A connection error occurred. Please check your internet connection.";
        clientErrorContainer.classList.remove('hidden');
      } finally {
        loginBtn.disabled = false;
        loginBtn.textContent = originalText;
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    setupForgotPassword();
    setupRecoveryFlow();
    setupLoginForm();
  });
</script>

