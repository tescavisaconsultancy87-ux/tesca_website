---
import { env } from "cloudflare:workers";
import Layout from "../layouts/Layout.astro";
import { 
  ShieldAlert, LogOut, Trash2, Plus, 
  MessageSquare, AlertCircle, FileText, CheckCircle 
} from "lucide-react";

// Cryptographic hash token helper for edge compat
async function hashToken(password: string): Promise<string> {
  const encoder = new TextEncoder();
  const data = encoder.encode(password + "_tesca_admin_salt");
  const hashBuffer = await crypto.subtle.digest("SHA-256", data);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(b => b.toString(16).padStart(2, "0")).join("");
}

const db = env?.tesca_db || env?.DB;

// Fetch configurations
const expectedEmail = env?.ADMIN_EMAIL || import.meta.env.ADMIN_EMAIL || "admin@tesca.com";
const expectedPassword = env?.ADMIN_PASSWORD || import.meta.env.ADMIN_PASSWORD || "admin1234";

// Check session
const sessionCookie = Astro.cookies.get("admin_session")?.value;
const expectedHash = await hashToken(expectedPassword);
let isAuthenticated = sessionCookie === expectedHash;

let errorMessage = "";
let successMessage = "";

// Handle server actions
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action");

    if (action === "login") {
      const email = formData.get("email");
      const password = formData.get("password");

      if (email === expectedEmail && password === expectedPassword) {
        Astro.cookies.set("admin_session", expectedHash, {
          path: "/",
          httpOnly: true,
          secure: true,
          maxAge: 60 * 60 * 24, // 1 day
        });
        return Astro.redirect("/admin");
      } else {
        errorMessage = "Invalid email or password credentials.";
      }
    } else if (action === "logout") {
      Astro.cookies.delete("admin_session", { path: "/" });
      return Astro.redirect("/admin");
    }

    // Require authentication for data-modifying actions
    if (isAuthenticated && db) {
      if (action === "delete-story") {
        const id = formData.get("id");
        await db.prepare("DELETE FROM success_stories WHERE id = ?").bind(id).run();
        successMessage = "Success story deleted successfully.";
      } else if (action === "delete-announcement") {
        const id = formData.get("id");
        await db.prepare("DELETE FROM announcements WHERE id = ?").bind(id).run();
        successMessage = "Announcement text deleted successfully.";
      } else if (action === "add-announcement") {
        const text = formData.get("text")?.toString().trim();
        if (text) {
          await db.prepare("INSERT INTO announcements (text) VALUES (?)").bind(text).run();
          successMessage = "New announcement added successfully.";
        }
      } else if (action === "delete-update") {
        const id = formData.get("id");
        await db.prepare("DELETE FROM visa_updates WHERE id = ?").bind(id).run();
        successMessage = "Visa bulletin update deleted successfully.";
      } else if (action === "add-update") {
        const date = formData.get("date")?.toString().trim();
        const tag = formData.get("tag")?.toString().trim();
        const tagColor = formData.get("tag_color")?.toString().trim();
        const title = formData.get("title")?.toString().trim();
        const link = formData.get("link")?.toString().trim();

        if (date && tag && tagColor && title && link) {
          let tagBg = "bg-amber-400/20 text-amber-300 border-amber-400/30";
          if (tagColor === "emerald") tagBg = "bg-emerald-400/20 text-emerald-300 border-emerald-400/30";
          if (tagColor === "purple") tagBg = "bg-purple-400/20 text-purple-300 border-purple-400/30";
          if (tagColor === "cyan") tagBg = "bg-cyan-400/20 text-cyan-300 border-cyan-400/30";
          if (tagColor === "rose") tagBg = "bg-rose-400/20 text-rose-300 border-rose-400/30";

          await db.prepare("INSERT INTO visa_updates (date, tag, tag_bg, title, link) VALUES (?, ?, ?, ?, ?)")
            .bind(date, tag, tagBg, title, link)
            .run();
          successMessage = "Visa bulletin update posted successfully.";
        } else {
          errorMessage = "Please fill in all visa bulletin update fields.";
        }
      }
    }
  } catch (err) {
    console.error("Admin dashboard action failure:", err);
    errorMessage = "An unexpected error occurred processing your request.";
  }
}

// Fetch dashboard data if authenticated
let stories = [];
let announcements = [];
let visaUpdates = [];

if (isAuthenticated && db) {
  try {
    const resStories = await db.prepare("SELECT * FROM success_stories ORDER BY id ASC").all();
    stories = resStories.results || [];
    
    const resAnn = await db.prepare("SELECT * FROM announcements ORDER BY id ASC").all();
    announcements = resAnn.results || [];

    const resUpdates = await db.prepare("SELECT * FROM visa_updates ORDER BY id DESC").all();
    visaUpdates = resUpdates.results || [];
  } catch (err) {
    console.error("Failed to load dashboard data:", err);
    errorMessage = "Failed to load database records.";
  }
}
---

<Layout 
  title="Admin Dashboard Portal | TESCA"
  description="Secure access configuration for TESCA web portals."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 py-12 text-left font-sans min-h-[70vh]">
    
    {/* Page Header */}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-slate-200 pb-6 mb-8">
      <div>
        <span class="inline-block text-xs font-bold bg-slate-900/10 text-slate-800 px-3 py-1 rounded-full border border-slate-900/15 uppercase tracking-wider">
          Admin Portal
        </span>
        <h1 class="text-3xl font-extrabold font-display tracking-tight text-support-white mt-2">
          Dashboard Configuration
        </h1>
      </div>
      {isAuthenticated && (
        <form method="POST" class="shrink-0">
          <input type="hidden" name="action" value="logout" />
          <button 
            type="submit" 
            class="flex items-center gap-2 px-5 py-2.5 bg-rose-600 hover:bg-rose-700 text-white font-bold text-sm rounded-xl transition-all cursor-pointer shadow-sm hover:scale-[1.01]"
          >
            <LogOut class="w-4 h-4" /> Sign Out
          </button>
        </form>
      )}
    </div>

    {/* Messages */}
    {errorMessage && (
      <div class="flex items-center gap-3 p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-800 text-sm mb-6 font-medium">
        <AlertCircle class="w-5 h-5 text-rose-600 shrink-0" />
        <span>{errorMessage}</span>
      </div>
    )}
    {successMessage && (
      <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 rounded-2xl text-emerald-800 text-sm mb-6 font-medium">
        <CheckCircle class="w-5 h-5 text-emerald-600 shrink-0" />
        <span>{successMessage}</span>
      </div>
    )}

    {/* Login Wall */}
    {!isAuthenticated ? (
      <div class="max-w-md mx-auto py-12">
        <div class="glass-card bg-slate-50/80 border border-slate-200/80 rounded-3xl p-8 shadow-xl text-center">
          <div class="w-12 h-12 rounded-2xl bg-accent-blue/10 text-accent-indigo flex items-center justify-center mx-auto mb-4 border border-accent-blue/15">
            <ShieldAlert class="w-6 h-6" />
          </div>
          <h2 class="text-xl font-bold font-display text-slate-800 tracking-tight">Security Verification</h2>
          <p class="text-xs text-slate-500 font-sans mt-1 mb-6">Enter administrative credentials to gain access.</p>
          
          <form method="POST" class="space-y-4">
            <input type="hidden" name="action" value="login" />
            <div class="space-y-1.5 text-left">
              <label for="email" class="text-xs font-bold text-slate-700 uppercase tracking-wide">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-accent-blue font-sans text-sm"
                placeholder="admin@example.com"
              />
            </div>
            <div class="space-y-1.5 text-left">
              <label for="password" class="text-xs font-bold text-slate-700 uppercase tracking-wide">Security Password</label>
              <input 
                type="password" 
                id="password" 
                name="password" 
                required 
                class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-accent-blue font-sans text-sm"
                placeholder="••••••••"
              />
            </div>
            <button 
              type="submit" 
              class="w-full py-3.5 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-xl transition-all cursor-pointer shadow-md hover:scale-[1.01] mt-2"
            >
              Sign In
            </button>
          </form>
        </div>
      </div>
    ) : (
      /* Logged In Dashboard Control Room */
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        {/* Tab Selection Sidebar (3 cols) */}
        <div class="lg:col-span-3 flex flex-col gap-2 bg-slate-50/50 p-4 border border-slate-200 rounded-3xl shrink-0">
          <button 
            type="button"
            data-tab="stories"
            class="tab-btn active flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-sm font-semibold text-slate-700 text-left transition-colors cursor-pointer"
          >
            <MessageSquare class="w-4 h-4 shrink-0" /> Success Stories
          </button>
          <button 
            type="button"
            data-tab="announcements"
            class="tab-btn flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-sm font-semibold text-slate-700 text-left transition-colors cursor-pointer"
          >
            <AlertCircle class="w-4 h-4 shrink-0" /> Announcement Bar
          </button>
          <button 
            type="button"
            data-tab="updates"
            class="tab-btn flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-sm font-semibold text-slate-700 text-left transition-colors cursor-pointer"
          >
            <FileText class="w-4 h-4 shrink-0" /> Visa Bulletins
          </button>
        </div>

        {/* Tab View Panels (9 cols) */}
        <div class="lg:col-span-9 bg-white border border-slate-200 shadow-sm rounded-3xl p-6 md:p-8 flex-grow">
          
          {/* TAB 1: Success Stories */}
          <div id="tab-stories" class="tab-panel space-y-6">
            <div>
              <h3 class="text-xl font-bold font-display text-slate-800 tracking-tight">Manage Success Stories</h3>
              <p class="text-xs text-slate-500 font-sans mt-0.5">Remove student profiles listed on the homepage.</p>
            </div>

            {stories.length === 0 ? (
              <p class="text-sm text-slate-500 py-6 text-center">No success stories found in database.</p>
            ) : (
              <div class="border border-slate-200/60 rounded-2xl overflow-hidden shadow-xs">
                <table class="w-full text-left border-collapse font-sans text-sm">
                  <thead>
                    <tr class="bg-slate-50 text-slate-600 font-bold border-b border-slate-200/80">
                      <th class="px-6 py-4">Avatar</th>
                      <th class="px-6 py-4">Student Name</th>
                      <th class="px-6 py-4">Destination</th>
                      <th class="px-6 py-4">Admitted Uni</th>
                      <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {stories.map((s) => (
                      <tr class="border-b border-slate-100 hover:bg-slate-50/50">
                        <td class="px-6 py-4 text-lg">{s.avatar}</td>
                        <td class="px-6 py-4 font-semibold text-slate-800">{s.name}</td>
                        <td class="px-6 py-4 text-slate-600">{s.destination} {s.dest_flag}</td>
                        <td class="px-6 py-4 text-slate-600">{s.after_uni}</td>
                        <td class="px-6 py-4 text-right">
                          <form method="POST" onsubmit="return confirm('Are you sure you want to remove this success story?');" class="inline">
                            <input type="hidden" name="action" value="delete-story" />
                            <input type="hidden" name="id" value={s.id} />
                            <button 
                              type="submit" 
                              class="p-2 text-rose-600 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer"
                              aria-label={`Delete ${s.name}`}
                            >
                              <Trash2 class="w-4 h-4" />
                            </button>
                          </form>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>

          {/* TAB 2: Announcements */}
          <div id="tab-announcements" class="tab-panel hidden space-y-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
              <div>
                <h3 class="text-xl font-bold font-display text-slate-800 tracking-tight">Announcement Alert Bar</h3>
                <p class="text-xs text-slate-500 font-sans mt-0.5">Manage messages rotating in the top website banner.</p>
              </div>
            </div>

            {/* Add Announcement Form */}
            <form method="POST" class="bg-slate-50/60 border border-slate-200/80 rounded-2xl p-5 space-y-4">
              <input type="hidden" name="action" value="add-announcement" />
              <div class="space-y-1.5">
                <label for="announcement-text-input" class="text-xs font-bold text-slate-700 uppercase tracking-wide">Announcement Text</label>
                <textarea 
                  id="announcement-text-input" 
                  name="text" 
                  required 
                  rows="2"
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-accent-blue font-sans text-sm"
                  placeholder="e.g. September 2026 priority applications are now open — secure your consultation spot."
                ></textarea>
              </div>
              <button 
                type="submit" 
                class="flex items-center justify-center gap-2 px-5 py-2.5 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-xl transition-all cursor-pointer shadow-sm hover:scale-[1.01]"
              >
                <Plus class="w-4 h-4" /> Publish Announcement
              </button>
            </form>

            {/* List Announcements */}
            {announcements.length === 0 ? (
              <p class="text-sm text-slate-500 py-6 text-center">No announcements found in database.</p>
            ) : (
              <div class="space-y-3">
                <h4 class="text-xs font-bold text-slate-700 uppercase tracking-wider">Active Rotations</h4>
                {announcements.map((a) => (
                  <div class="flex items-center justify-between gap-4 p-4 rounded-xl border border-slate-100 bg-slate-50/20 hover:border-slate-200">
                    <p class="text-sm text-slate-700 font-sans font-medium">{a.text}</p>
                    <form method="POST" onsubmit="return confirm('Are you sure you want to delete this announcement?');" class="shrink-0">
                      <input type="hidden" name="action" value="delete-announcement" />
                      <input type="hidden" name="id" value={a.id} />
                      <button 
                        type="submit" 
                        class="p-2 text-rose-600 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer"
                        aria-label="Delete announcement"
                      >
                        <Trash2 class="w-4 h-4" />
                      </button>
                    </form>
                  </div>
                ))}
              </div>
            )}
          </div>

          {/* TAB 3: Visa Bulletins */}
          <div id="tab-updates" class="tab-panel hidden space-y-8">
            <div>
              <h3 class="text-xl font-bold font-display text-slate-800 tracking-tight">Visa & Admission Bulletins</h3>
              <p class="text-xs text-slate-500 font-sans mt-0.5">Post and remove insights linked to blog updates on the home page.</p>
            </div>

            {/* Add Bulletin Form */}
            <form method="POST" class="bg-slate-50/60 border border-slate-200/80 rounded-2xl p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
              <input type="hidden" name="action" value="add-update" />
              
              <div class="space-y-1.5">
                <label for="bulletin-date" class="text-xs font-bold text-slate-700 uppercase tracking-wide">Publish Date</label>
                <input 
                  type="text" 
                  id="bulletin-date" 
                  name="date" 
                  required 
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-accent-blue font-sans text-sm"
                  placeholder="e.g. Jan 15, 2026"
                />
              </div>

              <div class="space-y-1.5">
                <label for="bulletin-tag" class="text-xs font-bold text-slate-700 uppercase tracking-wide">Bulletin Tag</label>
                <input 
                  type="text" 
                  id="bulletin-tag" 
                  name="tag" 
                  required 
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-accent-blue font-sans text-sm"
                  placeholder="e.g. Visa Update, Admissions"
                />
              </div>

              <div class="space-y-1.5">
                <label for="bulletin-color" class="text-xs font-bold text-slate-700 uppercase tracking-wide">Tag Accent Theme</label>
                <select 
                  id="bulletin-color" 
                  name="tag_color" 
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-accent-blue font-sans text-sm"
                >
                  <option value="amber">Amber (Warning / Updates)</option>
                  <option value="emerald">Emerald (Success / Admissions)</option>
                  <option value="purple">Purple (Guides / Documentation)</option>
                  <option value="cyan">Cyan (Calculators / Finance)</option>
                  <option value="rose">Rose (Intake Alerts / Deadlines)</option>
                </select>
              </div>

              <div class="space-y-1.5">
                <label for="bulletin-link" class="text-xs font-bold text-slate-700 uppercase tracking-wide">Blog Link / URL Destination</label>
                <input 
                  type="text" 
                  id="bulletin-link" 
                  name="link" 
                  required 
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-accent-blue font-sans text-sm"
                  placeholder="e.g. /services#visa or https://example.com/blog"
                />
              </div>

              <div class="space-y-1.5 md:col-span-2">
                <label for="bulletin-title" class="text-xs font-bold text-slate-700 uppercase tracking-wide">Bulletin Title / Description</label>
                <input 
                  type="text" 
                  id="bulletin-title" 
                  name="title" 
                  required 
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-accent-blue font-sans text-sm"
                  placeholder="UK Student Visa Updates 2026: Working Hour Changes"
                />
              </div>

              <div class="md:col-span-2 pt-2">
                <button 
                  type="submit" 
                  class="flex items-center justify-center gap-2 px-6 py-3 bg-accent-blue hover:bg-accent-indigo text-white font-bold text-sm rounded-xl transition-all cursor-pointer shadow-sm hover:scale-[1.01]"
                >
                  <Plus class="w-4 h-4" /> Post Visa Bulletin
                </button>
              </div>
            </form>

            {/* List Visa Updates */}
            {visaUpdates.length === 0 ? (
              <p class="text-sm text-slate-500 py-6 text-center">No visa bulletins found in database.</p>
            ) : (
              <div class="border border-slate-200/60 rounded-2xl overflow-hidden shadow-xs">
                <table class="w-full text-left border-collapse font-sans text-sm">
                  <thead>
                    <tr class="bg-slate-50 text-slate-600 font-bold border-b border-slate-200/80">
                      <th class="px-6 py-4">Date</th>
                      <th class="px-6 py-4">Tag</th>
                      <th class="px-6 py-4">Title</th>
                      <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {visaUpdates.map((u) => (
                      <tr class="border-b border-slate-100 hover:bg-slate-50/50">
                        <td class="px-6 py-4 text-slate-500 whitespace-nowrap">{u.date}</td>
                        <td class="px-6 py-4">
                          <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ${u.tag_bg}`}>
                            {u.tag}
                          </span>
                        </td>
                        <td class="px-6 py-4 font-semibold text-slate-800 line-clamp-2 max-w-xs">{u.title}</td>
                        <td class="px-6 py-4 text-right">
                          <form method="POST" onsubmit="return confirm('Are you sure you want to delete this bulletin?');" class="inline">
                            <input type="hidden" name="action" value="delete-update" />
                            <input type="hidden" name="id" value={u.id} />
                            <button 
                              type="submit" 
                              class="p-2 text-rose-600 hover:bg-rose-50 rounded-lg hover:scale-105 transition-all cursor-pointer"
                              aria-label="Delete bulletin"
                            >
                              <Trash2 class="w-4 h-4" />
                            </button>
                          </form>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>

        </div>

      </div>
    )}

  </section>
</Layout>

<script>
  function setupTabs() {
    const tabButtons = document.querySelectorAll(".tab-btn");
    const tabPanels = document.querySelectorAll(".tab-panel");

    tabButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        // Deactivate all buttons
        tabButtons.forEach(b => {
          b.classList.remove("active", "bg-slate-100");
          b.classList.add("hover:bg-slate-100");
        });
        
        // Hide all panels
        tabPanels.forEach(p => p.classList.add("hidden"));

        // Activate clicked button
        btn.classList.add("active", "bg-slate-100");
        btn.classList.remove("hover:bg-slate-100");

        // Show matching panel
        const targetTab = btn.getAttribute("data-tab");
        const panel = document.getElementById(`tab-${targetTab}`);
        if (panel) panel.classList.remove("hidden");
      });
    });
  }

  // Bind event listeners
  setupTabs();
  document.addEventListener("astro:page-load", setupTabs);
</script>
