---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";
const SVG = {
  ArrowLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>`,
  ShieldCheck: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M20 13c0 5-8 7-8 7s-8-2-8-7V5l8-3 8 3v8Z"/><path d="m9 12 2 2 4-4"/></svg>`,
  Clock: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  Coins: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="8" cy="8" r="6"/><circle cx="18" cy="18" r="4"/><path d="M12 18a6 6 0 0 0-6-6"/><path d="M18 12a6 6 0 0 0-6-6"/></svg>`,
  Award: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>`,
  CheckCircle: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  TrendingUp: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`
};
---

<Layout 
  title="Visa Success SLA & Refund Guarantee | TESCA Visa Consultancy"
  description="Read about TESCA's 99% visa success rate guarantee, 45-day document processing timelines, compliance checks, and financial refund policy framework."
>
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-8 pb-12 text-left">
    
    <!-- Go Back Link -->
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-blue hover:underline mb-8 font-sans">
      <span set:html={SVG.ArrowLeft} /> Back to Home
    </a>

    <!-- Premium Header Banner -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-slate-50/80 border border-slate-200/60 shadow-lg p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-3xl space-y-6 relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 font-sans uppercase">
          Service Level Agreement
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Visa Success SLA & Refund Guarantee
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-sans font-normal leading-relaxed">
          TESCA operates with automated audit checks and certified compliance workflows, allowing us to back our advisory services with a premium success guarantee.
        </p>
      </div>
    </div>

    <!-- Core Metrics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      <div class="p-8 rounded-3xl bg-gradient-to-br from-blue-50 to-indigo-50/70 border border-blue-100 space-y-4 shadow-sm">
        <div class="p-3 rounded-2xl bg-white text-accent-blue inline-flex items-center justify-center shadow-sm">
          <span set:html={SVG.ShieldCheck} />
        </div>
        <h3 class="text-xl font-bold text-slate-800 font-display">99% Success SLA</h3>
        <p class="text-sm text-slate-600 font-sans leading-relaxed">
          Our automated verification scripts cross-check local embassy rules to eliminate administrative refilings and errors.
        </p>
      </div>

      <div class="p-8 rounded-3xl bg-gradient-to-br from-emerald-50 to-teal-50/70 border border-emerald-100 space-y-4 shadow-sm">
        <div class="p-3 rounded-2xl bg-white text-emerald-600 inline-flex items-center justify-center shadow-sm">
          <span set:html={SVG.Clock} />
        </div>
        <h3 class="text-xl font-bold text-slate-800 font-display">45-Day Processing</h3>
        <p class="text-sm text-slate-600 font-sans leading-relaxed">
          All documents are fully audited, cleared, and submitted to embassies within our strict 45-day cycle guarantee.
        </p>
      </div>

      <div class="p-8 rounded-3xl bg-gradient-to-br from-amber-50 to-orange-50/70 border border-amber-100 space-y-4 shadow-sm">
        <div class="p-3 rounded-2xl bg-white text-amber-600 inline-flex items-center justify-center shadow-sm">
          <span set:html={SVG.Coins} />
        </div>
        <h3 class="text-xl font-bold text-slate-800 font-display">Refund Framework</h3>
        <p class="text-sm text-slate-600 font-sans leading-relaxed">
          In the rare event of a visa refusal based on document structural failure, we guarantee a structured partial refund.
        </p>
      </div>
    </div>

    <!-- Detailed Policy Sections -->
    <div class="space-y-12 max-w-4xl">
      <div class="space-y-4">
        <h2 class="text-2xl lg:text-3xl font-bold text-slate-800 font-display tracking-tight flex items-center gap-2">
          <span set:html={SVG.Award} class="w-6 h-6 text-accent-blue flex items-center justify-center shrink-0" /> 1. Eligibility Criteria for Success Guarantee
        </h2>
        <p class="text-sm md:text-base text-slate-600 font-sans leading-relaxed">
          To qualify for the TESCA Visa Success SLA, applicants must complete our baseline verification audit. This includes submitting certified bank statements proving liquid funding thresholds, meeting regional language standards (IELTS Band 6.0+ or equivalent), and presenting valid, uncompromised academic credentials.
        </p>
      </div>

      <div class="space-y-4">
        <h2 class="text-2xl lg:text-3xl font-bold text-slate-800 font-display tracking-tight flex items-center gap-2">
          <span set:html={SVG.CheckCircle} class="w-6 h-6 text-accent-blue flex items-center justify-center shrink-0" /> 2. Refund Guidelines & Structural Integrity
        </h2>
        <p class="text-sm md:text-base text-slate-600 font-sans leading-relaxed font-normal">
          If an embassy refuses a visa due to formatting, documentation, or compliance failures in the filing compiled by TESCA, the candidate will be eligible for a refund of up to 50% of the advisory service fee. 
        </p>
        <p class="text-sm text-slate-500 font-sans leading-relaxed italic bg-slate-50 border border-slate-200/50 p-4 rounded-2xl">
          Note: Refusals resulting from biometric failures, medical issues, criminal history, or failure to attend scheduled interviews are outside the scope of this SLA.
        </p>
      </div>

      <div class="space-y-4">
        <h2 class="text-2xl lg:text-3xl font-bold text-slate-800 font-display tracking-tight flex items-center gap-2">
          <span set:html={SVG.TrendingUp} class="w-6 h-6 text-accent-blue flex items-center justify-center shrink-0" /> 3. Appeal & Re-filing Policy
        </h2>
        <p class="text-sm md:text-base text-slate-600 font-sans leading-relaxed">
          In case of a refusal, our senior compliance team conducts a diagnostic audit within 7 business days. If we determine that a refiling has a high success rating, TESCA will bear all refiling coordination costs, providing a free second attempt.
        </p>
      </div>
    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
