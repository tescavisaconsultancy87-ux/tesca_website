---
import { supabase } from "../utils/supabase";
import Layout from "../layouts/Layout.astro";
import AICounsellor from "../components/AICounsellor";

const SVG = {
  Newspaper: (cls = "") => `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="${cls}"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>`,
  ArrowUpRight: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>`
};

import { blogPosts as staticBlogPosts } from "../data/blog";

// Fetch blog posts from Supabase (with static fallback)
let blogPosts = staticBlogPosts;
let visaUpdates = [];

// 1. Initiate database fetches concurrently
const [blogRes, updatesRes] = await Promise.all([
  supabase.from('blog_posts').select('*').eq('is_published', true).order('id', { ascending: false }).then(res => res, err => ({ data: [], error: err })),
  supabase.from('visa_updates').select('*').then(res => res, err => ({ data: [], error: err }))
]);

// 2. Perform transformations and error handling
if (blogRes.error) {
  console.error("Failed to fetch blog posts from Supabase, using static fallback:", blogRes.error);
} else if (blogRes.data && blogRes.data.length > 0) {
  blogPosts = blogRes.data.map(p => ({
    slug: p.slug,
    title: p.title,
    desc: p.description,
    date: p.date,
    tag: p.tag,
    tagBg: p.tag_bg,
    link: `/blog/${p.slug}`,
    content: p.content,
    faq: p.faq || [],
  }));
}

if (updatesRes.error) {
  console.error("Failed to fetch visa updates in blog page:", updatesRes.error);
} else if (updatesRes.data) {
  const parseUpdateDate = (dateStr: string) => {
    const normalized = (dateStr || '').trim();
    if (/^\d{4}$/.test(normalized)) {
      return {
        timestamp: new Date(`${normalized}-01-01T00:00:00Z`).getTime(),
        year: normalized
      };
    }
    const parsed = Date.parse(normalized);
    if (!isNaN(parsed)) {
      const dateObj = new Date(parsed);
      return {
        timestamp: parsed,
        year: String(dateObj.getFullYear())
      };
    }
    const yearMatch = normalized.match(/\b(20\d{2})\b/);
    const year = yearMatch ? yearMatch[1] : "Unknown";
    return {
      timestamp: yearMatch ? new Date(`${year}-01-01T00:00:00Z`).getTime() : 0,
      year
    };
  };

  const mapped = updatesRes.data.map(u => {
    const parsed = parseUpdateDate(u.date);
    return {
      ...u,
      tagBg: u.tag_bg,
      _timestamp: parsed.timestamp
    };
  });

  visaUpdates = mapped
    .sort((a, b) => b._timestamp - a._timestamp)
    .slice(0, 3);
}
---

<Layout
  title="Resource & Blog Hub | TESCA Visa Consultancy"
  description="Stay updated with the latest visa news bulletins, study abroad guides, and university admission preparation guides."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 py-10 sm:py-12 text-left font-sans">
    
    <!-- Hero Banner -->
    <div class="glass-card rounded-[2rem] overflow-hidden bg-gradient-to-br from-slate-50 to-blue-50/30 border border-slate-200/60 shadow-lg p-6 sm:p-8 md:p-12 relative mb-12">
      <div class="aurora-bg w-[300px] h-[300px] bg-accent-blue/5 -top-12 -left-12 rounded-full blur-[80px]"></div>
      
      <div class="max-w-2xl space-y-6 relative z-10">
        <span class="inline-block text-xs font-semibold tracking-wider text-slate-800 bg-accent-blue/10 px-4 py-1.5 rounded-full border border-accent-blue/20 uppercase">
          Blog & Resources
        </span>
        <h1 class="text-[36px] sm:text-[48px] lg:text-[56px] font-extrabold font-display text-support-white tracking-tight leading-none">
          Resource Center
        </h1>
        <p class="text-base md:text-[18px] text-support-gray font-normal leading-relaxed">
          Your directory of study abroad guides, academic preparation tips, cost-of-living breakdowns, and real-time embassy visa updates.
        </p>
      </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Study Guides Grid (8 cols) -->
      <div class="lg:col-span-8 space-y-8">
        <div class="border-b border-slate-100 pb-3 flex justify-between items-center">
          <h2 class="text-2xl font-bold font-display text-slate-800 tracking-tight">Study Guides & Preparation</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {blogPosts.map(post => (
            <a 
              href={post.link}
              class="group bg-white border border-slate-200 rounded-2xl p-6 hover:shadow-lg hover:border-accent-blue/30 transition-all duration-300 hover:-translate-y-1 flex flex-col justify-between h-full no-underline cursor-pointer"
            >
              <div class="space-y-3">
                <div class="flex items-center gap-3">
                  <span class="text-xs text-slate-400 font-semibold">{post.date}</span>
                  <span class={`text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ${post.tagBg}`}>
                    {post.tag}
                  </span>
                </div>
                <h3 class="text-base font-bold font-display text-slate-800 group-hover:text-accent-blue transition-colors leading-snug line-clamp-2">
                  {post.title}
                </h3>
                <p class="text-xs text-slate-500 leading-relaxed line-clamp-3 font-normal">{post.desc}</p>
              </div>
              
              <div class="mt-6 pt-4 border-t border-slate-100 flex items-center gap-1.5 text-xs font-semibold text-accent-blue group-hover:gap-2 transition-all">
                <span>Read guide</span>
                <span set:html={SVG.ArrowUpRight} class="w-3.5 h-3.5 flex items-center justify-center" />
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Right Column: Live Bulletins Sidebar (4 cols) -->
      <div class="lg:col-span-4 space-y-8">
        <div class="border-b border-slate-100 pb-3 flex justify-between items-center">
          <h2 class="text-xl font-bold font-display text-slate-800 tracking-tight">Latest Visa Bulletins</h2>
          <a href="/updates" class="text-xs font-semibold text-accent-blue hover:underline">View all</a>
        </div>

        {visaUpdates.length === 0 ? (
          <div class="text-center py-10 bg-slate-50 rounded-2xl border border-slate-200/50">
            <span set:html={SVG.Newspaper("w-10 h-10 mx-auto text-slate-300 mb-2")} />
            <p class="text-xs text-slate-400">No updates listed recently.</p>
          </div>
        ) : (
          <div class="space-y-4">
            {visaUpdates.map(item => (
              <a 
                href={item.link}
                target={item.link.startsWith("http") ? "_blank" : undefined}
                rel={item.link.startsWith("http") ? "noopener noreferrer" : undefined}
                class="group block bg-white border border-slate-150 rounded-xl p-4 hover:shadow-md transition-all duration-350 no-underline cursor-pointer"
              >
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-[10px] font-semibold text-slate-400">{item.date}</span>
                  <span class={`text-[8px] font-bold uppercase tracking-wider px-1.5 py-0.2 rounded border ${item.tagBg}`}>
                    {item.tag}
                  </span>
                </div>
                <h4 class="text-xs font-bold text-slate-850 group-hover:text-accent-blue transition-colors leading-snug line-clamp-2">
                  {item.title}
                </h4>
              </a>
            ))}
          </div>
        )}
      </div>

    </div>

  </section>

  <AICounsellor client:only="react" />
</Layout>
