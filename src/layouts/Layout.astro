---
import "../styles/global.css";
import CounsellorForm from "../components/CounsellorForm";
import { supabase } from "../utils/supabase";
import { ClientRouter } from "astro:transitions";
// Inline SVG helpers — no lucide-react in .astro (SSR hook errors)
const _svg = (d: string, size = 16) => `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const NavIcons = {
	User: _svg('<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'),
	GraduationCap: _svg('<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>'),
	FileText: _svg('<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>'),
	Award: _svg('<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>'),
	BookOpen: _svg('<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>'),
	Briefcase: _svg('<rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>'),
	Heart: _svg('<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>'),
	Landmark: _svg('<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="22"/><line x1="10" x2="10" y1="18" y2="22"/><line x1="14" x2="14" y1="18" y2="22"/><line x1="18" x2="18" y1="18" y2="22"/><polygon points="12 2 20 7 4 7"/>'),
	Home: _svg('<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>'),
	Plane: _svg('<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21 4 19 4c-2 0-2.5 2.5-3.5 3.5L11 11 2.8 6.2l-.7.8 4 6L4 15l-2-1-.7.7 1.5 2.5L5.3 19l2.5 1.5.7-.7-1-2 1.8-2.1 6 4 .8-.7-4.8-8.2L18.6 8l2 4.8-2.8 6.4z"/>'),
	ArrowRight: _svg('<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>'),
	Phone: _svg('<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4a2 2 0 0 1 2-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>'),
};

interface Props {
	title?: string;
	description?: string;
	showNavFooter?: boolean;
}

const {
	title = "TESCA | Premium Study Abroad & Visa Consultancy",
	description = "Premium admissions evaluation, financial analysis tools, and visa compliance checking by TESCA Visa Consultancy.",
	showNavFooter = true,
} = Astro.props;

let announcements = [];

try {
	const { data, error } = await supabase
		.from('announcements')
		.select('text')
		.order('id', { ascending: true });

	if (error) throw error;
	if (data && data.length > 0) {
		announcements = data.map((r: any) => r.text);
	}
} catch (err) {
	console.error("Failed to fetch announcements from Supabase:", err);
}
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2HW0JXMF2Y"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-2HW0JXMF2Y');
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/images/Tesca_logo.png" />
		<link rel="shortcut icon" type="image/png" href="/images/Tesca_logo.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<ClientRouter />
		<style is:global>
			/* Custom Premium Toast Styles */
			#custom-toast-container {
				position: fixed;
				bottom: 24px;
				right: 24px;
				z-index: 99999;
				display: flex;
				flex-direction: column;
				gap: 12px;
				pointer-events: none;
			}
			.custom-toast-popup {
				pointer-events: auto;
				background: rgba(31, 41, 55, 0.95);
				color: #ffffff;
				border: 1px solid rgba(255, 255, 255, 0.1);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				padding: 14px 20px;
				border-radius: 16px;
				box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.2), 0 0 1px 1px rgba(255, 255, 255, 0.05);
				font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
				font-size: 13px;
				font-weight: 600;
				max-width: 350px;
				min-width: 280px;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.toast-icon-bg {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 28px;
				height: 28px;
				border-radius: 50%;
				background: rgba(10, 120, 128, 0.2);
				color: #F08A00;
				flex-shrink: 0;
			}
			.toast-message {
				line-height: 1.4;
				letter-spacing: 0.01em;
			}

			/* Animations for Toasts */
			@keyframes toastIn {
				from {
					opacity: 0;
					transform: translateY(20px) scale(0.95);
				}
				to {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}
			@keyframes toastOut {
				from {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
				to {
					opacity: 0;
					transform: translateY(10px) scale(0.95);
				}
			}
			.animate-toast-in {
				animation: toastIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}
			.animate-toast-out {
				animation: toastOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}

			/* Global Page Skeleton Loader Overlay */
			#global-page-skeleton {
				position: fixed;
				inset: 0;
				z-index: 999999;
				background-color: #FFFFFF;
				display: flex;
				flex-direction: column;
				padding: 24px;
				pointer-events: none;
				transition: opacity 0.5s ease-out;
			}
			@media (min-width: 768px) {
				#global-page-skeleton {
					padding: 48px;
				}
			}
			.shimmer {
				background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
				background-size: 200% 100%;
				animation: shimmerRun 1.5s infinite linear;
			}
			@keyframes shimmerRun {
				0% { background-position: 200% 0; }
				100% { background-position: -200% 0; }
			}

		</style>
	</head>
	<body
		class="bg-white text-support-slate min-h-screen flex flex-col antialiased selection:bg-accent-cyan/10 selection:text-accent-blue font-sans"
	>
		<!-- Global Page Skeleton Loader Overlay -->
		<div id="global-page-skeleton">
			<div class="max-w-7xl mx-auto w-full flex items-center justify-between animate-pulse mb-12">
				<div class="w-32 h-8 bg-slate-100 rounded-lg shimmer"></div>
				<div class="hidden md:flex gap-6">
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
				</div>
				<div class="w-32 h-10 bg-slate-100 rounded-full shimmer"></div>
			</div>
			<div class="max-w-7xl mx-auto w-full flex-grow space-y-12 animate-pulse">
				<div class="h-64 bg-slate-50 border border-slate-100 rounded-3xl w-full flex flex-col justify-center p-8 space-y-4">
					<div class="h-8 bg-slate-100 rounded-md w-1/3 shimmer"></div>
					<div class="h-4 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					<div class="h-4 bg-slate-100 rounded-md w-1/4 shimmer"></div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
				</div>
			</div>
		</div>
		<!-- Skip to Content Accessibility -->
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2.5 focus:bg-accent-blue focus:text-white focus:font-semibold focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-accent-cyan"
		>
			Skip to content
		</a>

		<!-- Floating Navigation Header -->
		{showNavFooter && (
		<header
			id="main-header"
			class="fixed top-0 left-0 right-0 z-40 transition-all duration-500 bg-white/80 backdrop-blur-md border-b border-slate-200/60 shadow-sm flex flex-col"
		>
			<!-- Rotating Announcement Bar -->
			{announcements.length > 0 && (
			<div
				id="announcement-bar"
				class="w-full bg-[#075E64] text-white py-2 px-4 transition-all duration-500 overflow-hidden relative z-50 text-center text-[11px] sm:text-xs font-semibold font-sans tracking-wide shrink-0"
				style="max-height: 56px; box-sizing: border-box;"
				data-announcements={JSON.stringify(announcements)}
			>
				<div class="flex items-center justify-center gap-2 max-w-7xl mx-auto">
					<span class="inline-flex h-2 w-2 rounded-full bg-[#F08A00] animate-pulse"></span>
					<span id="announcement-text" class="transition-opacity duration-300">{announcements[0]}</span>
				</div>
			</div>
			)}

			<nav
				class="w-full max-w-7xl mx-auto px-4 lg:px-6 py-3.5 flex items-center justify-between transition-all duration-500"
				id="main-nav"
				aria-label="Global navigation"
			>
				<!-- Logo (General Sans 700) -->
				<a
					href="/"
					class="flex items-center gap-2.5 group outline-none focus-visible:ring-2 focus-visible:ring-accent-blue rounded-md px-2 py-1"
					id="nav-logo"
				>
					<img
						src="/images/Tesca_logo.png"
						alt="TESCA"
						class="h-14 w-auto"
						id="nav-logo-icon"
					/>
				</a>

				<!-- Menu Links (Plus Jakarta Sans 500) -->
				<ul
					class="hidden md:flex items-center gap-1 text-sm font-medium font-sans tracking-wide"
					id="nav-links"
				>
					<li>
						<a
							href="/"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 font-sans text-sm font-medium"
							>Home</a
						>
					</li>

					{/* Study Destinations Dropdown */}
					<li class="relative group">
						<a
							href="/countries"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 flex items-center gap-1.5 cursor-pointer font-sans text-sm font-medium outline-none no-underline"
						>
							Study Destinations</a
						>

						{/* Mega Menu Dropdown */}
						<div
							class="absolute left-1/2 top-full pt-3 hidden group-hover:block w-[780px] z-50 animate-dropdown"
						>
							<div
								class="shadow-2xl rounded-2xl p-6 bg-white border border-slate-100 grid grid-cols-12 gap-6 text-slate-800"
							>
								{/* Countries Grid (9 cols) */}
								<div class="col-span-9 grid grid-cols-3 gap-3">
									{
										[
											{
												name: "Australia",
												code: "au",
												id: "au",
											},
											{
												name: "New Zealand",
												code: "nz",
												id: "nz",
											},
											{
												name: "United Kingdom",
												code: "gb",
												id: "uk",
											},
											{
												name: "Ireland",
												code: "ie",
												id: "ie",
											},
											{
												name: "Germany",
												code: "de",
												id: "de",
											},
											{
												name: "Europe",
												code: "eu",
												id: "eu",
											},
											{
												name: "USA",
												code: "us",
												id: "us",
											},
											{
												name: "Canada",
												code: "ca",
												id: "ca",
											},
											{
												name: "Singapore",
												code: "sg",
												id: "sg",
											},
											{
												name: "Dubai",
												code: "ae",
												id: "ae",
											},
											{
												name: "Malaysia",
												code: "my",
												id: "my",
											},
											{
												name: "Switzerland",
												code: "ch",
												id: "ch",
											},
										].map((c) => (
											<a
												href={`/countries#${c.id}`}
												class="flex items-center gap-3 p-2.5 rounded-xl border border-slate-100 bg-slate-50/50 hover:bg-accent-blue/5 hover:border-accent-blue/20 hover:text-accent-indigo transition-all duration-200 group/cell"
											>
												<img
													src={`https://flagcdn.com/w40/${c.code}.png`}
													alt={`${c.name} flag`}
													class="w-7 h-5 rounded-sm object-cover shadow-sm"
													loading="lazy"
												/>
												<span class="text-xs font-semibold font-sans tracking-wide">
													Study in {c.name}
												</span>
											</a>
										))
									}
								</div>

								{/* Action Buttons Sidebar (3 cols) */}
								<div
									class="col-span-3 border-l border-slate-100 pl-6 flex flex-col justify-center gap-4"
								>
									<a
										href="/countries"
										class="flex items-center justify-between p-3 rounded-xl border border-slate-100 bg-slate-50/60 hover:bg-accent-blue hover:text-white transition-all duration-200 group/action text-xs font-bold font-sans tracking-wide text-left"
									>
										<span>Explore Destinations</span>
										<span set:html={NavIcons.ArrowRight} class="group-hover/action:translate-x-0.5 transition-transform" />
									</a>

									<a
										href="/universities"
										class="flex items-center justify-between p-3 rounded-xl border border-slate-100 bg-slate-50/60 hover:bg-accent-blue hover:text-white transition-all duration-200 group/action text-xs font-bold font-sans tracking-wide text-left"
									>
										<span>Explore Universities</span>
										<span set:html={NavIcons.ArrowRight} class="group-hover/action:translate-x-0.5 transition-transform" />
									</a>
								</div>
							</div>
						</div>
					</li>

					{/* Services Dropdown */}
					<li class="relative group">
						<a
							href="/services"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 flex items-center gap-1.5 cursor-pointer font-sans text-sm font-medium outline-none no-underline"
						>
							Services</a
						>

						{/* Mega Menu Dropdown */}
						<div
							class="absolute left-1/2 top-full pt-3 hidden group-hover:block w-[780px] z-50 animate-dropdown"
						>
							<div
								class="shadow-2xl rounded-2xl p-6 bg-white border border-slate-100 flex flex-col gap-6 text-slate-800"
							>
								{/* Services Grid (3 columns) */}
								<div class="grid grid-cols-3 gap-3">
										{
											[
												{ name: "Expert Counselling", iconSvg: NavIcons.User, id: "counselling", color: "bg-blue-100 text-blue-600" },
												{ name: "University Admission Process", iconSvg: NavIcons.GraduationCap, id: "admission", color: "bg-emerald-100 text-emerald-600" },
												{ name: "SOP & Documentation", iconSvg: NavIcons.FileText, id: "sop", color: "bg-amber-100 text-amber-600" },
												{ name: "Scholarship Guidance", iconSvg: NavIcons.Award, id: "scholarships", color: "bg-purple-100 text-purple-600" },
												{ name: "Test Prep & Coaching", iconSvg: NavIcons.BookOpen, id: "testprep", color: "bg-rose-100 text-rose-600" },
												{ name: "Expert Visa Assistance", iconSvg: NavIcons.Briefcase, id: "visa", color: "bg-teal-100 text-teal-600" },
												{ name: "Health Insurance", iconSvg: NavIcons.Heart, id: "insurance", color: "bg-pink-100 text-pink-600" },
												{ name: "Financial & Loan Guidance", iconSvg: NavIcons.Landmark, id: "financial", color: "bg-orange-100 text-orange-600" },
												{ name: "Accommodation Assistance", iconSvg: NavIcons.Home, id: "accommodation", color: "bg-indigo-100 text-indigo-600" },
												{ name: "Pre & Post Departure Services", iconSvg: NavIcons.Plane, id: "departure", color: "bg-cyan-100 text-cyan-600" },
											].map((srv) => (
												<a
													href={srv.id === 'testprep' ? '/services/testprep' : `/services#${srv.id}`}
													class="flex items-center gap-3.5 p-3 rounded-xl border border-slate-100 bg-slate-50/50 hover:bg-accent-blue/5 hover:border-accent-blue/20 hover:text-accent-indigo transition-all duration-200"
												>
													<div class={"p-2 rounded-lg shrink-0 " + srv.color}>
														<span set:html={srv.iconSvg} />
													</div>
													<span class="text-xs font-semibold font-sans tracking-wide leading-tight">{srv.name}</span>
												</a>
											))
										}
								</div>

								{/* Bottom Button "View All ->" (Centered) */}
								<div
									class="border-t border-slate-100 pt-4 flex justify-center"
								>
									<a
										href="/services"
										class="flex items-center gap-1.5 px-6 py-2 rounded-full border border-slate-200 bg-slate-50 hover:bg-accent-blue hover:text-white transition-all duration-200 text-xs font-bold font-sans tracking-wide cursor-pointer"
									>
										<span>View All Services</span>
										<span set:html={NavIcons.ArrowRight} />
									</a>
								</div>
							</div>
						</div>
					</li>

					<li>
						<a
							href="/gallery"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 font-sans text-sm font-medium"
							>Gallery</a
						>
					</li>

					<li>
						<a
							href="/calculators"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 font-sans text-sm font-medium"
							>Study Calculator</a
						>
					</li>

					<li>
						<a
							href="/eligibility"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 font-sans text-sm font-medium"
							>Check Eligibility</a
						>
					</li>
				</ul>

				<!-- CTA Button: Speak to Our Counsellor & Hamburger Toggle -->
				<div class="flex items-center gap-2 sm:gap-3">
					<button
						id="nav-cta"
						onclick="window.openCounsellorForm?.()"
						class="hidden sm:flex text-xs font-semibold font-sans tracking-wide bg-[#F08A00] hover:bg-[#C06E00] rounded-full px-4 py-1.5 text-white items-center gap-1.5 transition-all duration-300 outline-none focus-visible:ring-2 focus-visible:ring-[#F08A00] cursor-pointer shadow-sm hover:shadow-md hover:scale-[1.02]"
					>
						<span set:html={NavIcons.Phone} />
						Speak to Our Counsellor
					</button>
					<a
						href="tel:9824152731"
						class="hidden md:flex text-[11px] font-semibold text-support-slate hover:text-accent-blue transition-colors items-center gap-1 no-underline"
						id="nav-phone-link"
					>
						<span class="opacity-70 text-[10px] font-medium font-sans">Or Call:</span>
						<span class="font-sans font-bold text-[11px] sm:text-xs">9824152731</span>
					</a>
					
