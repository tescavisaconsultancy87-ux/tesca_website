---
import "../styles/global.css";
import CounsellorForm from "../components/CounsellorForm";
import PromoPopup from "../components/PromoPopup.astro";
import { ClientRouter } from "astro:transitions";
import { ensureCsrfToken } from "../utils/csrf";
// Inline SVG helpers — no lucide-react in .astro (SSR hook errors)
const _svg = (d: string, size = 16) => `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const NavIcons = {
	User: _svg('<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>'),
	GraduationCap: _svg('<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>'),
	FileText: _svg('<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>'),
	Award: _svg('<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>'),
	BookOpen: _svg('<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>'),
	Briefcase: _svg('<rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>'),
	Heart: _svg('<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>'),
	Landmark: _svg('<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="22"/><line x1="10" x2="10" y1="18" y2="22"/><line x1="14" x2="14" y1="18" y2="22"/><line x1="18" x2="18" y1="18" y2="22"/><polygon points="12 2 20 7 4 7"/>'),
	Home: _svg('<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>'),
	Plane: _svg('<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21 4 19 4c-2 0-2.5 2.5-3.5 3.5L11 11 2.8 6.2l-.7.8 4 6L4 15l-2-1-.7.7 1.5 2.5L5.3 19l2.5 1.5.7-.7-1-2 1.8-2.1 6 4 .8-.7-4.8-8.2L18.6 8l2 4.8-2.8 6.4z"/>'),
	ArrowRight: _svg('<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>'),
	Phone: _svg('<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4a2 2 0 0 1 2-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>'),
};

interface Props {
	title?: string;
	description?: string;
	showNavFooter?: boolean;
	noindex?: boolean;
	image?: string;
}

const {
	title = "TESCA | Premium Study Abroad & Visa Consultancy",
	description = "Premium admissions evaluation, financial analysis tools, and visa compliance checking by TESCA Visa Consultancy.",
	showNavFooter = true,
	noindex = false,
	image = "/images/Tesca_logo.png",
} = Astro.props;

// Canonical URL is always the apex host, regardless of how the request arrived.
// Normalized to lowercase with trailing slashes removed (matching the sitemap) to prevent canonical mismatch indexing issues.
let normalizedPathname = Astro.url.pathname.toLowerCase();
if (normalizedPathname.length > 1 && normalizedPathname.endsWith("/")) {
	normalizedPathname = normalizedPathname.slice(0, -1);
}
const canonicalURL = new URL(normalizedPathname, "https://tescavisa.com").href;
const ogImage = new URL(image, "https://tescavisa.com").href;

// Organization / local-business structured data (helps Google Knowledge Panel
// and local "near me" search for the Surat branches).
const structuredData = {
	"@context": "https://schema.org",
	"@type": "EducationalOrganization",
	name: "TESCA Visa Consultancy",
	url: "https://tescavisa.com",
	logo: "https://tescavisa.com/images/Tesca_logo.png",
	image: "https://tescavisa.com/images/Tesca_logo.png",
	description: "Study abroad, university admissions, IELTS/PTE coaching, education loan assistance and student-visa services since 2005.",
	foundingDate: "2005",
	telephone: "+91-9824152731",
	email: "tescavisaconsultancy87@gmail.com",
	address: [
		{
			"@type": "PostalAddress",
			streetAddress: "110, 111, 112, Royal Arcade, Simada Naka",
			addressLocality: "Surat",
			addressRegion: "Gujarat",
			postalCode: "395013",
			addressCountry: "IN",
		},
		{
			"@type": "PostalAddress",
			streetAddress: "Ambika Pinnacle, 106-107, Lajamni Chowk, Mota Varachha",
			addressLocality: "Surat",
			addressRegion: "Gujarat",
			postalCode: "394101",
			addressCountry: "IN",
		},
	],
	sameAs: [
		"https://www.facebook.com/tescavisaconsultancy",
		"https://www.instagram.com/tesca_visaconsultancy",
		"https://youtube.com/@tescavisaconsultancy",
	],
};

// Announcements are loaded client-side from /api/announcements so this layout
// (and therefore every page) can be statically prerendered and edge-cached.
const gaId = import.meta.env.PUBLIC_GA4_ID || "G-2HW0JXMF2Y";

let csrfToken = "";
if (Astro.url.pathname.startsWith("/admin")) {
	csrfToken = ensureCsrfToken(Astro.cookies);
}
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Integrated Google Analytics (GA4) -->
		<script is:inline define:vars={{ gaId }}>
			window.PUBLIC_GA4_ID = gaId;

			// Setup GTM/GA4 dataLayer and gtag
			window.dataLayer = window.dataLayer || [];
			window.gtag = function() { window.dataLayer.push(arguments); };
			window.gtag('js', new Date());
			window.gtag('config', gaId);

			// Dynamically inject GA4 script to support dynamic ID
			const gaScript = document.createElement('script');
			gaScript.async = true;
			gaScript.src = `https://www.googletagmanager.com/gtag/js?id=${gaId}`;
			document.head.appendChild(gaScript);

			// Global tracking helpers
			window.trackLeadEvent = function(source) {
				if (window.gtag) {
					window.gtag('event', 'generate_lead', {
						event_category: 'engagement',
						event_label: source
					});
					
					// Conversion Key Event: consultation_form_submit
					window.gtag('event', 'consultation_form_submit', {
						event_category: 'conversion',
						form_name: source
					});
					
					console.log(`[Tracking] GA4 generate_lead & consultation_form_submit fired: ${source}`);
				}
			};

			window.trackClickEvent = function(type, destination) {
				if (window.gtag) {
					window.gtag('event', type === 'whatsapp' ? 'whatsapp_click' : 'phone_call_click', {
						event_category: 'engagement',
						destination: destination
					});
					console.log(`[Tracking] GA4 Click fired: ${type} -> ${destination}`);
				}
			};

			// Global listener for tel:, mailto:, wa.me clicks, and consultation button clicks
			document.addEventListener('click', (e) => {
				const target = e.target;
				if (!target) return;

				// 1. Link Clicks
				const link = target.closest('a');
				if (link) {
					const href = link.getAttribute('href') || '';
					if (href.startsWith('tel:')) {
						window.trackClickEvent('call', href);
					} else if (href.startsWith('mailto:')) {
						if (window.gtag) {
							window.gtag('event', 'email_click', {
								event_category: 'engagement',
								destination: href
							});
						}
						console.log(`[Tracking] GA4 email_click fired: ${href}`);
					} else if (href.includes('wa.me') || href.includes('api.whatsapp.com') || href.includes('whatsapp://')) {
						window.trackClickEvent('whatsapp', href);
					}
				}

				// 2. Consultation Buttons
				const clickable = target.closest('button, a, [onclick]');
				if (clickable) {
					const text = (clickable.textContent || '').trim().toLowerCase();
					const onclickAttr = clickable.getAttribute('onclick') || '';
					if (
						text.includes('book free consultation') ||
						text.includes('book consultation') ||
						text.includes('free consultation') ||
						onclickAttr.includes('openCounsellorForm')
					) {
						if (window.gtag) {
							window.gtag('event', 'book_consultation_click', {
								event_category: 'engagement',
								button_text: text || 'Book Free Consultation'
							});
						}
						console.log(`[Tracking] GA4 book_consultation_click fired`);
					}
				}
			}, { passive: true });

			// Client router transition tracking
			let loaderTimeout;
			document.addEventListener('astro:before-preparation', () => {
				clearTimeout(loaderTimeout);
				loaderTimeout = window.setTimeout(() => {
					const loader = document.getElementById('global-page-loader');
					if (loader) {
						loader.classList.remove('opacity-0', 'pointer-events-none');
					}
				}, 150); // Delay showing the loader to prevent flashing on fast page loads
			});

			const hideLoader = () => {
				clearTimeout(loaderTimeout);
				const loader = document.getElementById('global-page-loader');
				if (loader) {
					loader.classList.add('opacity-0', 'pointer-events-none');
				}
			};

			document.addEventListener('astro:after-swap', hideLoader);

			document.addEventListener('astro:page-load', () => {
				hideLoader();
				if (window.gtag) {
					window.gtag('event', 'page_view', {
						page_path: window.location.pathname
					});
				}
			});

			// Global client-side error reporting to tescavisaconsultancy87@gmail.com
			window.reportClientError = function(type, error, context = {}) {
				try {
					const message = error instanceof Error ? error.message : String(error);
					const stack = error instanceof Error ? error.stack : undefined;
					
					// Ignore lists for common noisy browser extension/third-party/autofill/transition errors
					const IGNORED_ERRORS = [
						'AutofillCallbackHandler',
						'chrome-extension://',
						'moz-extension://',
						'safari-extension://',
						'safari-web-extension://',
						'__gaOptOutExtension',
						'webkitAudioContext',
						'ResizeObserver loop limit exceeded',
						'ResizeObserver loop completed with undelivered notifications',
						'Script error.',
						'window.webkit.messageHandlers',
						'Extensions/',
						'fbq is not defined',
						'transition was aborted',
						'the transition was aborted',
						'invalid state',
						'aborterror',
						'the user aborted a request'
					];
					
					const errorStr = `${message} ${stack || ''}`.toLowerCase();
					const shouldIgnore = IGNORED_ERRORS.some(pattern => errorStr.includes(pattern.toLowerCase()));
					
					if (shouldIgnore) {
						console.log(`[Error Logger] Ignored noisy/extension error: "${message}"`);
						return;
					}

					fetch('/api/report-client-error', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							type: type,
							message: message,
							stack: stack,
							url: window.location.href,
							context: context,
							userAgent: navigator.userAgent
						})
					}).catch(err => console.warn('Failed to send error email:', err));
				} catch (reportingErr) {
					console.error('Error reporting system failed:', reportingErr);
				}
			};

			window.addEventListener('error', (event) => {
				if (!event.error && !event.message) return;
				window.reportClientError('Unhandled Runtime Error', event.error || event.message, {
					filename: event.filename,
					lineno: event.lineno,
					colno: event.colno
				});
			});

			window.addEventListener('unhandledrejection', (event) => {
				if (!event.reason) return;
				const reasonStr = String(event.reason?.message || event.reason || '').toLowerCase();
				if (
					reasonStr.includes('transition was aborted') ||
					reasonStr.includes('invalid state') ||
					reasonStr.includes('aborterror')
				) {
					console.log('[Error Logger] Ignored benign view transition cancellation:', event.reason);
					return;
				}
				window.reportClientError('Unhandled Promise Rejection', event.reason);
			});
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Performance: warm up third-party origins -->
		<link rel="preconnect" href="https://zlsauoosumpnbyouhdfk.supabase.co" crossorigin />
		<link rel="preconnect" href="https://api.fontshare.com" crossorigin />
		<link rel="dns-prefetch" href="https://flagcdn.com" />

		<!-- OpenGraph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="TESCA Visa Consultancy" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Structured data (Organization / local business) -->
		<script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

		<ClientRouter />
		{csrfToken && (
			<meta name="csrf-token" content={csrfToken} />
			<script is:inline>
				(function() {
					// 1. Intercept standard browser form submits
					document.addEventListener("submit", function(e) {
						const form = e.target;
						if (form && form.method && form.method.toUpperCase() === "POST") {
							if (!form.querySelector('input[name="csrf_token"]')) {
								const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content");
								if (token) {
									const input = document.createElement("input");
									input.type = "hidden";
									input.name = "csrf_token";
									input.value = token;
									form.appendChild(input);
								}
							}
						}
					});

					// 2. Intercept fetch API calls
					const originalFetch = window.fetch;
					window.fetch = function(input, init) {
						const isPost = init && init.method && init.method.toUpperCase() === "POST";
						if (isPost) {
							const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content");
							if (token) {
								if (!init.headers) {
									init.headers = {};
								}
								if (init.headers instanceof Headers) {
									if (!init.headers.has("x-csrf-token")) {
										init.headers.set("x-csrf-token", token);
									}
								} else if (Array.isArray(init.headers)) {
									const hasCsrf = init.headers.some(function(pair) {
										return pair[0].toLowerCase() === "x-csrf-token";
									});
									if (!hasCsrf) {
										init.headers.push(["x-csrf-token", token]);
									}
								} else {
									if (!init.headers["x-csrf-token"]) {
										init.headers["x-csrf-token"] = token;
									}
								}
							}
						}
						return originalFetch.call(this, input, init);
					};
				})();
			</script>
		)}
		<style is:global>
			/* Custom Premium Toast Styles */
			#custom-toast-container {
				position: fixed;
				bottom: 24px;
				right: 24px;
				z-index: 99999;
				display: flex;
				flex-direction: column;
				gap: 12px;
				pointer-events: none;
			}
			.custom-toast-popup {
				pointer-events: auto;
				background: rgba(31, 41, 55, 0.95);
				color: #ffffff;
				border: 1px solid rgba(255, 255, 255, 0.1);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				padding: 14px 20px;
				border-radius: 16px;
				box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.2), 0 0 1px 1px rgba(255, 255, 255, 0.05);
				font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
				font-size: 13px;
				font-weight: 600;
				max-width: 350px;
				min-width: 280px;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.toast-icon-bg {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 28px;
				height: 28px;
				border-radius: 50%;
				background: rgba(10, 120, 128, 0.2);
				color: #F08A00;
				flex-shrink: 0;
			}
			.toast-message {
				line-height: 1.4;
				letter-spacing: 0.01em;
			}

			/* Animations for Toasts */
			@keyframes toastIn {
				from {
					opacity: 0;
					transform: translateY(20px) scale(0.95);
				}
				to {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}
			@keyframes toastOut {
				from {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
				to {
					opacity: 0;
					transform: translateY(10px) scale(0.95);
				}
			}
			.animate-toast-in {
				animation: toastIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}
			.animate-toast-out {
				animation: toastOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}

			/* Global Page Skeleton Loader Overlay */
			#global-page-skeleton {
				position: fixed;
				inset: 0;
				z-index: 999999;
				background-color: #FFFFFF;
				display: flex;
				flex-direction: column;
				padding: 24px;
				pointer-events: none;
				transition: opacity 0.5s ease-out;
			}
			@media (min-width: 768px) {
				#global-page-skeleton {
					padding: 48px;
				}
			}
			.shimmer {
				background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
				background-size: 200% 100%;
				animation: shimmerRun 1.5s infinite linear;
			}
			@keyframes shimmerRun {
				0% { background-position: 200% 0; }
				100% { background-position: -200% 0; }
			}

		</style>
	</head>
	<body
		class="bg-white text-support-slate min-h-screen flex flex-col antialiased selection:bg-accent-cyan/10 selection:text-accent-blue font-sans"
	>
		<!-- Global Page Skeleton Loader Overlay -->
		<div id="global-page-skeleton">
			<div class="max-w-7xl mx-auto w-full flex items-center justify-between animate-pulse mb-12">
				<div class="w-32 h-8 bg-slate-100 rounded-lg shimmer"></div>
				<div class="hidden md:flex gap-6">
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
				</div>
				<div class="w-32 h-10 bg-slate-100 rounded-full shimmer"></div>
			</div>
			<div class="max-w-7xl mx-auto w-full flex-grow space-y-12 animate-pulse">
				<div class="h-64 bg-slate-50 border border-slate-100 rounded-3xl w-full flex flex-col justify-center p-8 space-y-4">
					<div class="h-8 bg-slate-100 rounded-md w-1/3 shimmer"></div>
					<div class="h-4 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					<div class="h-4 bg-slate-100 rounded-md w-1/4 shimmer"></div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
				</div>
			</div>
		</div>
		<!-- Skip to Content Accessibility -->
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2.5 focus:bg-accent-blue focus:text-white focus:font-semibold focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-accent-cyan"
		>
			Skip to content
		</a>

		<!-- Floating Navigation Header -->
		{showNavFooter && (
		<header
			id="main-header"
			class="fixed top-0 left-0 right-0 z-40 transition-all duration-500 bg-white/80 backdrop-blur-md border-b border-slate-200/60 shadow-sm flex flex-col"
		>
			<!-- Rotating Announcement Bar (text populated client-side from /api/announcements) -->
			<div
				id="announcement-bar"
				class="w-full bg-[#075E64] text-white py-1 px-4 transition-all duration-500 overflow-hidden relative z-50 text-center text-[11px] sm:text-xs font-semibold font-sans tracking-wide shrink-0"
				style="max-height: 56px; box-sizing: border-box;"
