---
import "../styles/global.css";
import CounsellorForm from "../components/CounsellorForm";
import { ClientRouter } from "astro:transitions";
import {
	ArrowRight,
	ChevronDown,
	Phone,
	User,
	GraduationCap,
	FileText,
	Award,
	BookOpen,
	Briefcase,
	Heart,
	Shield,
	Landmark,
	Home,
	Plane,
} from "lucide-react";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "TESCA | Premium Study Abroad & Visa Consultancy",
	description = "Premium admissions evaluation, financial analysis tools, and visa compliance checking by TESCA Visa Consultancy.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/images/Tesca_logo.svg" />
		<link rel="shortcut icon" href="/images/Tesca_logo.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<ClientRouter />
		<style is:global>
			/* Custom Premium Toast Styles */
			#custom-toast-container {
				position: fixed;
				bottom: 24px;
				right: 24px;
				z-index: 99999;
				display: flex;
				flex-direction: column;
				gap: 12px;
				pointer-events: none;
			}
			.custom-toast-popup {
				pointer-events: auto;
				background: rgba(31, 41, 55, 0.95);
				color: #ffffff;
				border: 1px solid rgba(255, 255, 255, 0.1);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				padding: 14px 20px;
				border-radius: 16px;
				box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.2), 0 0 1px 1px rgba(255, 255, 255, 0.05);
				font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
				font-size: 13px;
				font-weight: 600;
				max-width: 350px;
				min-width: 280px;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.toast-icon-bg {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 28px;
				height: 28px;
				border-radius: 50%;
				background: rgba(10, 120, 128, 0.2);
				color: #F08A00;
				flex-shrink: 0;
			}
			.toast-message {
				line-height: 1.4;
				letter-spacing: 0.01em;
			}

			/* Animations for Toasts */
			@keyframes toastIn {
				from {
					opacity: 0;
					transform: translateY(20px) scale(0.95);
				}
				to {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
			}
			@keyframes toastOut {
				from {
					opacity: 1;
					transform: translateY(0) scale(1);
				}
				to {
					opacity: 0;
					transform: translateY(10px) scale(0.95);
				}
			}
			.animate-toast-in {
				animation: toastIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}
			.animate-toast-out {
				animation: toastOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}

			/* Global Page Skeleton Loader Overlay */
			#global-page-skeleton {
				position: fixed;
				inset: 0;
				z-index: 999999;
				background-color: #FFFFFF;
				display: flex;
				flex-direction: column;
				padding: 24px;
				pointer-events: none;
				transition: opacity 0.5s ease-out;
			}
			@media (min-width: 768px) {
				#global-page-skeleton {
					padding: 48px;
				}
			}
			.shimmer {
				background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
				background-size: 200% 100%;
				animation: shimmerRun 1.5s infinite linear;
			}
			@keyframes shimmerRun {
				0% { background-position: 200% 0; }
				100% { background-position: -200% 0; }
			}
		</style>
	</head>
	<body
		class="bg-white text-support-slate min-h-screen flex flex-col antialiased selection:bg-accent-cyan/10 selection:text-accent-blue font-sans"
	>
		<!-- Global Page Skeleton Loader Overlay -->
		<div id="global-page-skeleton">
			<div class="max-w-7xl mx-auto w-full flex items-center justify-between animate-pulse mb-12">
				<div class="w-32 h-8 bg-slate-100 rounded-lg shimmer"></div>
				<div class="hidden md:flex gap-6">
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
					<div class="w-20 h-4 bg-slate-100 rounded-md shimmer"></div>
				</div>
				<div class="w-32 h-10 bg-slate-100 rounded-full shimmer"></div>
			</div>
			<div class="max-w-7xl mx-auto w-full flex-grow space-y-12 animate-pulse">
				<div class="h-64 bg-slate-50 border border-slate-100 rounded-3xl w-full flex flex-col justify-center p-8 space-y-4">
					<div class="h-8 bg-slate-100 rounded-md w-1/3 shimmer"></div>
					<div class="h-4 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					<div class="h-4 bg-slate-100 rounded-md w-1/4 shimmer"></div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
					<div class="h-48 bg-slate-50 border border-slate-100 rounded-2xl p-6 space-y-4">
						<div class="w-12 h-12 bg-slate-100 rounded-xl shimmer"></div>
						<div class="h-4 bg-slate-100 rounded-md w-3/4 shimmer"></div>
						<div class="h-3 bg-slate-100 rounded-md w-1/2 shimmer"></div>
					</div>
				</div>
			</div>
		</div>
		<!-- Skip to Content Accessibility -->
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2.5 focus:bg-accent-blue focus:text-white focus:font-semibold focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-accent-cyan"
		>
			Skip to content
		</a>

		<!-- Floating Navigation Header -->
		<header
			id="main-header"
			class="fixed top-0 left-0 right-0 z-40 transition-all duration-500 bg-white/80 backdrop-blur-md border-b border-slate-200/60 shadow-sm flex flex-col"
		>
			<!-- Rotating Announcement Bar -->
			<div
				id="announcement-bar"
				class="w-full bg-[#075E64] text-white py-2 px-4 transition-all duration-500 overflow-hidden relative z-50 text-center text-[12px] sm:text-xs font-semibold font-sans tracking-wide shrink-0"
				style="max-height: 40px; box-sizing: border-box;"
			>
				<div class="flex items-center justify-center gap-2 max-w-7xl mx-auto">
					<span class="inline-flex h-2 w-2 rounded-full bg-[#F08A00] animate-pulse"></span>
					<span id="announcement-text" class="transition-opacity duration-300">September 2025 UK intake — only 12 consultation slots left this week.</span>
				</div>
			</div>

			<nav
				class="max-w-7xl mx-auto px-6 py-3.5 flex items-center justify-between transition-all duration-500"
				id="main-nav"
				aria-label="Global navigation"
			>
				<!-- Logo (General Sans 700) -->
				<a
					href="/"
					class="flex items-center gap-2.5 group outline-none focus-visible:ring-2 focus-visible:ring-accent-blue rounded-md px-2 py-1"
					id="nav-logo"
				>
					<img
						src="/images/Tesca_logo.svg"
						alt="TESCA"
						class="h-9 w-auto"
						id="nav-logo-icon"
					/>
				</a>

				<!-- Menu Links (Plus Jakarta Sans 500) -->
				<ul
					class="hidden md:flex items-center gap-1 text-sm font-medium font-sans tracking-wide"
					id="nav-links"
				>
					<li>
						<a
							href="/"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 font-sans text-sm font-medium"
							>Home</a
						>
					</li>

					{/* Study Destinations Dropdown */}
					<li class="relative group">
						<a
							href="/countries"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 flex items-center gap-1.5 cursor-pointer font-sans text-sm font-medium outline-none no-underline"
						>
							Study Destinations</a
						>

						{/* Mega Menu Dropdown */}
						<div
							class="absolute left-1/2 top-full pt-3 hidden group-hover:block w-[780px] z-50 animate-dropdown"
						>
							<div
								class="shadow-2xl rounded-2xl p-6 bg-white border border-slate-100 grid grid-cols-12 gap-6 text-slate-800"
							>
								{/* Countries Grid (9 cols) */}
								<div class="col-span-9 grid grid-cols-3 gap-3">
									{
										[
											{
												name: "Australia",
												code: "au",
												id: "au",
											},
											{
												name: "New Zealand",
												code: "nz",
												id: "nz",
											},
											{
												name: "United Kingdom",
												code: "gb",
												id: "uk",
											},
											{
												name: "Ireland",
												code: "ie",
												id: "ie",
											},
											{
												name: "Germany",
												code: "de",
												id: "de",
											},
											{
												name: "Europe",
												code: "eu",
												id: "eu",
											},
											{
												name: "USA",
												code: "us",
												id: "us",
											},
											{
												name: "Canada",
												code: "ca",
												id: "ca",
											},
											{
												name: "Singapore",
												code: "sg",
												id: "sg",
											},
											{
												name: "Dubai",
												code: "ae",
												id: "ae",
											},
											{
												name: "Malaysia",
												code: "my",
												id: "my",
											},
											{
												name: "Switzerland",
												code: "ch",
												id: "ch",
											},
										].map((c) => (
											<a
												href={`/countries#${c.id}`}
												class="flex items-center gap-3 p-2.5 rounded-xl border border-slate-100 bg-slate-50/50 hover:bg-accent-blue/5 hover:border-accent-blue/20 hover:text-accent-indigo transition-all duration-200 group/cell"
											>
												<img
													src={`https://flagcdn.com/w40/${c.code}.png`}
													alt={`${c.name} flag`}
													class="w-7 h-5 rounded-sm object-cover shadow-sm"
													loading="lazy"
												/>
												<span class="text-xs font-semibold font-sans tracking-wide">
													Study in {c.name}
												</span>
											</a>
										))
									}
								</div>

								{/* Action Buttons Sidebar (3 cols) */}
								<div
									class="col-span-3 border-l border-slate-100 pl-6 flex flex-col justify-center gap-4"
								>
									<a
										href="/countries"
										class="flex items-center justify-between p-3 rounded-xl border border-slate-100 bg-slate-50/60 hover:bg-accent-blue hover:text-white transition-all duration-200 group/action text-xs font-bold font-sans tracking-wide text-left"
									>
										<span>Explore Destinations</span>
										<ArrowRight
											class="w-4 h-4 group-hover/action:translate-x-0.5 transition-transform"
										/>
									</a>

									<a
										href="/universities"
										class="flex items-center justify-between p-3 rounded-xl border border-slate-100 bg-slate-50/60 hover:bg-accent-blue hover:text-white transition-all duration-200 group/action text-xs font-bold font-sans tracking-wide text-left"
									>
										<span>Explore Universities</span>
										<ArrowRight
											class="w-4 h-4 group-hover/action:translate-x-0.5 transition-transform"
										/>
									</a>
								</div>
							</div>
						</div>
					</li>

					{/* Services Dropdown */}
					<li class="relative group">
						<a
							href="/services"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 flex items-center gap-1.5 cursor-pointer font-sans text-sm font-medium outline-none no-underline"
						>
							Services</a
						>

						{/* Mega Menu Dropdown */}
						<div
							class="absolute left-1/2 top-full pt-3 hidden group-hover:block w-[780px] z-50 animate-dropdown"
						>
							<div
								class="shadow-2xl rounded-2xl p-6 bg-white border border-slate-100 flex flex-col gap-6 text-slate-800"
							>
								{/* Services Grid (3 columns) */}
								<div class="grid grid-cols-3 gap-3">
									{
										[
											{
												name: "Expert Counselling",
												icon: User,
												id: "counselling",
												color: "bg-blue-100 text-blue-600",
											},
											{
												name: "University Admission Process",
												icon: GraduationCap,
												id: "admission",
												color: "bg-emerald-100 text-emerald-600",
											},
											{
												name: "SOP & Documentation",
												icon: FileText,
												id: "sop",
												color: "bg-amber-100 text-amber-600",
											},
											{
												name: "Scholarship Guidance",
												icon: Award,
												id: "scholarships",
												color: "bg-purple-100 text-purple-600",
											},
											{
												name: "Test Prep & Coaching",
												icon: BookOpen,
												id: "testprep",
												color: "bg-rose-100 text-rose-600",
											},
											{
												name: "Expert Visa Assistance",
												icon: Briefcase,
												id: "visa",
												color: "bg-teal-100 text-teal-600",
											},
											{
												name: "Health Insurance",
												icon: Heart,
												id: "insurance",
												color: "bg-pink-100 text-pink-600",
											},
											{
												name: "Financial & Loan Guidance",
												icon: Landmark,
												id: "financial",
												color: "bg-orange-100 text-orange-600",
											},
											{
												name: "Accommodation Assistance",
												icon: Home,
												id: "accommodation",
												color: "bg-indigo-100 text-indigo-600",
											},
											{
												name: "Pre & Post Departure Services",
												icon: Plane,
												id: "departure",
												color: "bg-cyan-100 text-cyan-600",
											},
										].map((srv) => {
											const IconComponent = srv.icon;
											return (
												<a
													href={`/services#${srv.id}`}
													class="flex items-center gap-3.5 p-3 rounded-xl border border-slate-100 bg-slate-50/50 hover:bg-accent-blue/5 hover:border-accent-blue/20 hover:text-accent-indigo transition-all duration-200"
												>
													<div
														class={
															"p-2 rounded-lg shrink-0 " +
															srv.color
														}
													>
														<IconComponent class="w-4 h-4" />
													</div>
													<span class="text-xs font-semibold font-sans tracking-wide leading-tight">
														{srv.name}
													</span>
												</a>
											);
										})
									}
								</div>

								{/* Bottom Button "View All ->" (Centered) */}
								<div
									class="border-t border-slate-100 pt-4 flex justify-center"
								>
									<a
										href="/services"
										class="flex items-center gap-1.5 px-6 py-2 rounded-full border border-slate-200 bg-slate-50 hover:bg-accent-blue hover:text-white transition-all duration-200 text-xs font-bold font-sans tracking-wide cursor-pointer"
									>
										<span>View All Services</span>
										<ArrowRight class="w-3.5 h-3.5" />
									</a>
								</div>
							</div>
						</div>
					</li>

					{/* Test Prep Dropdown */}
					<li class="relative group">
						<a
							href="/TestPrep"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 flex items-center gap-1.5 cursor-pointer font-sans text-sm font-medium outline-none no-underline"
						>
							Test Prep</a
						>

						{/* Test Prep Mega Menu Dropdown */}
						<div
							class="absolute left-1/2 top-full pt-3 hidden group-hover:block w-[240px] z-50 animate-dropdown"
						>
							<div
								class="shadow-2xl rounded-2xl p-3 bg-white border border-slate-100 flex flex-col gap-1 text-slate-800"
							>
								{
									[
										{
											name: "IELTS",
											icon: BookOpen,
											id: "ielts",
											color: "bg-accent-blue/10 text-accent-blue",
										},
										{
											name: "PTE",
											icon: BookOpen,
											id: "pte",
											color: "bg-blue-100 text-blue-600",
										},
										{
											name: "German",
											icon: BookOpen,
											id: "german",
											color: "bg-amber-100 text-amber-600",
										},
										{
											name: "Spoken English",
											icon: BookOpen,
											id: "spoken-english",
											color: "bg-purple-100 text-purple-600",
										},
										{
											name: "French",
											icon: BookOpen,
											id: "french",
											color: "bg-indigo-100 text-indigo-600",
										},
									].map((t) => {
										const IconComponent = t.icon;
										return (
											<a
												href={`/services#${t.id}`}
												class="flex items-center gap-3 p-2.5 rounded-xl hover:bg-accent-blue/5 hover:text-accent-indigo transition-all duration-200 text-sm font-sans font-medium"
											>
												<div
													class={
														"p-1.5 rounded-lg shrink-0 " +
														t.color
													}
												>
													<IconComponent class="w-4 h-4" />
												</div>
												<span>{t.name}</span>
											</a>
										);
									})
								}
							</div>
						</div>
					</li>

					<li>
						<a
							href="/gallery"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 font-sans text-sm font-medium"
							>Gallery</a
						>
					</li>

					<li>
						<a
							href="/calculators"
							class="nav-link px-3.5 py-2 rounded-lg text-support-slate hover:bg-accent-blue hover:text-white transition-all duration-200 font-sans text-sm font-medium"
							>Study Calculator</a
						>
					</li>
				</ul>

				<!-- CTA Button: Speak to Our Counsellor & Hamburger Toggle -->
				<div class="flex items-center gap-2 sm:gap-3">
					<button
						id="nav-cta"
						onclick="window.openCounsellorForm?.()"
						class="hidden sm:flex text-xs font-semibold font-sans tracking-wide bg-[#F08A00] hover:bg-[#C06E00] rounded-full px-4 py-1.5 text-white items-center gap-1.5 transition-all duration-300 outline-none focus-visible:ring-2 focus-visible:ring-[#F08A00] cursor-pointer shadow-sm hover:shadow-md hover:scale-[1.02]"
					>
						<Phone class="w-3.5 h-3.5" />
						Speak to Our Counsellor
					</button>
					<a
						href="tel:9824152731"
						class="hidden md:flex text-[11px] font-semibold text-support-slate hover:text-accent-blue transition-colors items-center gap-1 no-underline"
						id="nav-phone-link"
					>
						<span class="opacity-70 text-[10px] font-medium font-sans">Or Call:</span>
						<span class="font-sans font-bold text-[11px] sm:text-xs">9824152731</span>
					</a>
					
					<!-- Hamburger button for mobile -->
					<button 
						id="mobile-menu-btn" 
						class="md:hidden p-2 rounded-xl border border-slate-200/80 hover:bg-slate-50 text-support-slate hover:text-slate-800 transition-all cursor-pointer flex items-center justify-center" 
						aria-label="Toggle mobile menu"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
					</button>
				</div>
			</nav>
		</header>

		<!-- Mobile Menu Drawer Overlay -->
		<div id="mobile-menu-drawer" class="fixed inset-0 z-50 bg-slate-900/50 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300">
			<div id="mobile-menu-panel" class="absolute right-0 top-0 bottom-0 w-[280px] bg-white shadow-2xl p-6 flex flex-col justify-between translate-x-full transition-transform duration-300 border-l border-slate-100">
