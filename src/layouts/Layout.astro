		<!-- Scroll-Triggered Navbar Color Shift & Optimized Lenis script -->
		<script>
			import Lenis from "lenis";

			function initPage() {
				const isAdminRoute = window.location.pathname.startsWith("/admin");
				// Mobile Menu Drawer Handlers
				const mobileMenuBtn = document.getElementById("mobile-menu-btn");
				const mobileMenuDrawer = document.getElementById("mobile-menu-drawer");
				const mobileMenuPanel = document.getElementById("mobile-menu-panel");
				const mobileMenuClose = document.getElementById("mobile-menu-close");

				const openMobileMenu = () => {
					mobileMenuDrawer?.classList.remove("hidden");
					setTimeout(() => {
						mobileMenuDrawer?.classList.add("opacity-100");
						mobileMenuPanel?.classList.remove("translate-x-full");
					}, 10);
					(window as any).lenis?.stop();
				};

				const closeMobileMenu = () => {
					mobileMenuDrawer?.classList.remove("opacity-100");
					mobileMenuPanel?.classList.add("translate-x-full");
					setTimeout(() => {
						mobileMenuDrawer?.classList.add("hidden");
					}, 300);
					(window as any).lenis?.start();
				};

				mobileMenuBtn?.addEventListener("click", openMobileMenu);
				mobileMenuDrawer?.addEventListener("click", closeMobileMenu);
				mobileMenuPanel?.addEventListener("click", (e) => e.stopPropagation());
				mobileMenuClose?.addEventListener("click", closeMobileMenu);

				// 1. Interactive Navbar Morphing Script — White→Teal/Teal-glass on scroll
				const header = document.getElementById("main-header");
				const nav = document.getElementById("main-nav");
				const navLinks = document.querySelectorAll(".nav-link");
				const navLogoIcon = document.getElementById("nav-logo-icon");
				const navPhoneLink = document.getElementById("nav-phone-link");
				const announcementBar = document.getElementById("announcement-bar");

				const handleScroll = () => {
					if (window.scrollY > 20) {
						// Collapse announcement bar
						if (announcementBar) {
							announcementBar.style.maxHeight = "0px";
							announcementBar.style.paddingTop = "0px";
							announcementBar.style.paddingBottom = "0px";
							announcementBar.style.opacity = "0";
						}
						
						// Scrolled: Premium white glassmorphism background
						header?.classList.add("scrolled-header");
						header?.classList.remove(
							"bg-white/80",
							"backdrop-blur-md",
							"border-b",
							"border-slate-200/60",
							"shadow-sm",
						);
						nav?.classList.remove("py-3.5");
						nav?.classList.add("py-2.5");

					} else {
						// Expand announcement bar
						if (announcementBar) {
							announcementBar.style.maxHeight = "56px";
							announcementBar.style.paddingTop = "8px";
							announcementBar.style.paddingBottom = "8px";
							announcementBar.style.opacity = "1";
						}
						
						// Top: White background, dark text
						header?.classList.remove("scrolled-header");
						header?.classList.add(
							"bg-white/80",
							"backdrop-blur-md",
							"border-b",
							"border-slate-200/60",
							"shadow-sm",
						);
						nav?.classList.remove("py-2.5");
						nav?.classList.add("py-3.5");
					}
				};

				window.addEventListener("scroll", handleScroll);
				handleScroll(); // Trigger immediately to sync layout

				// Announcement Bar Text Rotation
				const announcementBarEl = document.getElementById("announcement-bar");
				const announcements = announcementBarEl ? JSON.parse(announcementBarEl.getAttribute("data-announcements") || "[]") : [];
				let currentAnnIndex = 0;
				const annTextEl = document.getElementById("announcement-text");
				let rotationInterval: any;

				if (annTextEl && announcements.length > 1) {
					rotationInterval = setInterval(() => {
						annTextEl.style.opacity = "0";
						setTimeout(() => {
							currentAnnIndex = (currentAnnIndex + 1) % announcements.length;
							annTextEl.innerText = announcements[currentAnnIndex];
							annTextEl.style.opacity = "1";
						}, 300);
					}, 4000);
				}

				// Establish stable openCounsellorForm function
				if (typeof window !== "undefined") {
					(window as any).openCounsellorForm = function() {
						window.dispatchEvent(new CustomEvent("open-counsellor-form"));
					};
				}

				// Soft Modal logic: show after 45s without click on CTA
				let hasClickedCTA = false;
				let softModalTimer: any;
				
				const urlParams = new URLSearchParams(window.location.search);
				const isTestMode = urlParams.get("test-modal") === "true";
				const isModalShown = !isTestMode && localStorage.getItem("softModalShown") === "true";

				console.log("[Soft Modal] isModalShown:", isModalShown, "isTestMode:", isTestMode);

				const showSoftModal = () => {
					console.log("[Soft Modal] Showing soft modal.");
					const modal = document.getElementById("soft-cta-modal");
					const card = document.getElementById("soft-cta-card");
					if (modal && card) {
						modal.classList.remove("pointer-events-none", "opacity-0");
						modal.classList.add("opacity-100");
						card.classList.remove("scale-95", "opacity-0");
						card.classList.add("scale-100", "opacity-100");
						(window as any).lenis?.stop();
					}
				};

				const closeSoftModal = () => {
					console.log("[Soft Modal] Closing soft modal.");
					const modal = document.getElementById("soft-cta-modal");
					const card = document.getElementById("soft-cta-card");
					if (modal && card) {
						modal.classList.remove("opacity-100");
						modal.classList.add("opacity-0", "pointer-events-none");
						card.classList.remove("scale-100", "opacity-100");
						card.classList.add("scale-95", "opacity-0");
						(window as any).lenis?.start();
						localStorage.setItem("softModalShown", "true");
					}
				};

				const cancelSoftModal = () => {
					if (softModalTimer) {
						console.log("[Soft Modal] Timer cancelled.");
						clearTimeout(softModalTimer);
						softModalTimer = null;
					}
					hasClickedCTA = true;
					if (!isTestMode) {
						localStorage.setItem("softModalShown", "true");
					}
				};

				let handleCtaClick: any;

				if (!isModalShown && !isAdminRoute) {
					console.log("[Soft Modal] Initializing 45s timer.");
					// Detect standard CTA click
					handleCtaClick = (e: MouseEvent) => {
						const target = e.target as HTMLElement;
						const isCta = target.closest('button, a, [onclick*="CounsellorForm"], input[type="submit"]');
						if (isCta) {
							const href = (isCta as HTMLAnchorElement).href || "";
							const onclickAttr = isCta.getAttribute("onclick") || "";
							if (
								isCta.id === "nav-cta" ||
								isCta.id === "soft-cta-btn" ||
								isCta.getAttribute("type") === "submit" ||
								isCta.closest("form") ||
								href.includes("inquiry") ||
								href.includes("tel:") ||
								href.includes("wa.me") ||
								href.includes("whatsapp") ||
								onclickAttr.includes("openCounsellorForm")
							) {
								console.log("[Soft Modal] CTA click detected:", isCta);
								cancelSoftModal();
							}
						}
					};

					document.addEventListener("click", handleCtaClick);

					// Hook into open-counsellor-form event
					window.addEventListener("open-counsellor-form", cancelSoftModal);

					// Trigger timer
					softModalTimer = setTimeout(() => {
						if (!hasClickedCTA) {
							showSoftModal();
						}
					}, 45000);

					// Close handles
					const closeBtn = document.getElementById("soft-cta-close");
					const secCloseBtn = document.getElementById("soft-cta-secondary-close");
					const modalOverlay = document.getElementById("soft-cta-modal");
					const softCtaBtn = document.getElementById("soft-cta-btn");

					closeBtn?.addEventListener("click", closeSoftModal);
					secCloseBtn?.addEventListener("click", closeSoftModal);
					modalOverlay?.addEventListener("click", (e) => {
						if (e.target === modalOverlay) {
							closeSoftModal();
						}
					});
					softCtaBtn?.addEventListener("click", () => {
						closeSoftModal();
						(window as any).openCounsellorForm?.();
					});
				}

				// 2. Fast & Responsive Lenis Scroll Configuration
				let rafId: number;
				
				if (isAdminRoute) {
					if ((window as any).lenis) {
						(window as any).lenis.destroy();
						(window as any).lenis = null;
					}
				} else {
					if ((window as any).lenis) {
						(window as any).lenis.destroy();
					}
					const lenis = new Lenis({
						duration: 0.9,
						easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
						gestureOrientation: "vertical",
						smoothWheel: true,
						wheelMultiplier: 1.15,
					});
					(window as any).lenis = lenis;

					const raf = (time: number) => {
						lenis.raf(time);
						rafId = requestAnimationFrame(raf);
					};
					rafId = requestAnimationFrame(raf);
				}

				// 3. Global Page Skeleton Fade Out
				const skeleton = document.getElementById("global-page-skeleton");
				if (skeleton) {
					setTimeout(() => {
						skeleton.style.opacity = "0";
						setTimeout(() => {
							skeleton.remove();
						}, 500);
					}, 450);
				}

				// 4. Alert Auto-Fade & Session Storage Alerts
				const handleAlerts = () => {
					const mainEl = document.querySelector("main");
					if (!mainEl) return;

					// Target actual alert banners using the specific .admin-alert-banner class
					const alertBanners = mainEl.querySelectorAll(".admin-alert-banner");

					alertBanners.forEach(banner => {
						if ((banner as any)._autoFading) return;
						(banner as any)._autoFading = true;
						const isError = banner.classList.contains("bg-rose-50");
						setTimeout(() => {
							(banner as HTMLElement).style.transition = "opacity 0.5s ease, max-height 0.5s ease, padding 0.5s ease, margin 0.5s ease";
							(banner as HTMLElement).style.opacity = "0";
							(banner as HTMLElement).style.maxHeight = "0";
							(banner as HTMLElement).style.padding = "0";
							(banner as HTMLElement).style.margin = "0";
							(banner as HTMLElement).style.overflow = "hidden";
							setTimeout(() => (banner as HTMLElement).remove(), 500);
						}, isError ? 3000 : 2000);
					});

					// Handle alerts stored in sessionStorage across page reloads
					const savedAlert = sessionStorage.getItem("admin_alert");
					if (savedAlert) {
						sessionStorage.removeItem("admin_alert");
						try {
							const { type, message } = JSON.parse(savedAlert);
							if (mainEl) {
								const alertDiv = document.createElement("div");
								alertDiv.className = `admin-alert-banner p-4 ${type === 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-600' : 'bg-rose-50 border-rose-200 text-rose-600'} border rounded-2xl text-xs font-semibold mb-6 flex items-center gap-2`;
								alertDiv.innerHTML = `<span>${message}</span>`;
								alertDiv.style.transition = "opacity 0.5s ease, max-height 0.5s ease, padding 0.5s ease, margin 0.5s ease";
								// Insert after the title block
								const titleBlock = mainEl.querySelector("div.mb-10, div.mb-8");
								if (titleBlock && titleBlock.parentNode) {
									titleBlock.parentNode.insertBefore(alertDiv, titleBlock.nextSibling);
								} else {
									mainEl.insertBefore(alertDiv, mainEl.firstChild);
								}

								setTimeout(() => {
									alertDiv.style.opacity = "0";
									alertDiv.style.maxHeight = "0";
									alertDiv.style.padding = "0";
									alertDiv.style.margin = "0";
									alertDiv.style.overflow = "hidden";
									setTimeout(() => alertDiv.remove(), 500);
								}, 2000);
							}
						} catch (e) {
							console.error(e);
						}
					}
				};

				handleAlerts();

				// Clean up resources on page hide
				document.addEventListener("astro:before-swap", () => {
					window.removeEventListener("scroll", handleScroll);
					if (handleCtaClick) document.removeEventListener("click", handleCtaClick);
					if (cancelSoftModal) window.removeEventListener("open-counsellor-form", cancelSoftModal);
					if (rafId) cancelAnimationFrame(rafId);
					if ((window as any).lenis) {
						(window as any).lenis.destroy();
						(window as any).lenis = null;
					}
					if (rotationInterval) clearInterval(rotationInterval);
					if (softModalTimer) clearTimeout(softModalTimer);
				}, { once: true });
			}

			// Bind page initialization to Astro page load event
			document.addEventListener("astro:page-load", initPage);

			// 4. Global button loader helper for all pages
			if (typeof window !== "undefined" && !(window as any).hasBtnLoader) {
				(window as any).hasBtnLoader = true;
				const SPINNER_HTML = '<svg class="btn-spinner" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4 31.4" stroke-linecap="round" /></svg>';

				(window as any).showBtnLoader = function(btn: HTMLElement, label?: string) {
					if (!btn) return;
					(btn as any)._originalHTML = btn.innerHTML;
					btn.innerHTML = SPINNER_HTML + (label ? ' ' + label : '');
					setTimeout(() => {
						(btn as HTMLButtonElement).disabled = true;
					}, 0);
				};

				(window as any).hideBtnLoader = function(btn: HTMLElement) {
					if (!btn) return;
					(btn as HTMLButtonElement).disabled = false;
					const orig = (btn as any)._originalHTML;
					if (orig) btn.innerHTML = orig;
				};

				// Global form submission handler for non-AJAX forms
				document.addEventListener("submit", (e) => {
					const form = e.target as HTMLFormElement;
					const btn = form.querySelector('button[type="submit"]') as HTMLElement;
					if (btn && !(form as any)._ajaxBound && !btn.closest('[data-no-loader]')) {
						(window as any).showBtnLoader(btn);
					}
				});
			}

			// 5. Auto-dismiss success messages after 2 seconds
			function dismissSuccessMessages() {
				document.querySelectorAll('[class*="bg-emerald-50"][class*="text-emerald"]').forEach(el => {
					setTimeout(() => {
						el.classList.add("opacity-0", "transition-opacity", "duration-500");
						setTimeout(() => el.remove(), 500);
					}, 2000);
				});
			}
			dismissSuccessMessages();
			document.addEventListener("astro:page-load", dismissSuccessMessages);

			// 6. Custom Alert Toast Override (Runs once globally)
			if (typeof window !== "undefined" && !(window as any).hasToastOverride) {
				(window as any).hasToastOverride = true;
				const toastContainer = document.createElement("div");
				toastContainer.id = "custom-toast-container";
				document.body.appendChild(toastContainer);

				window.alert = function (message) {
					const toast = document.createElement("div");
					toast.className = "custom-toast-popup animate-toast-in";
					toast.innerHTML = `
						<div style="display: flex; align-items: center; gap: 10px;">
							<div class="toast-icon-bg">
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="toast-icon"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
							</div>
							<span class="toast-message"></span>
						</div>
					`;
					const msgSpan = toast.querySelector(".toast-message");
					if (msgSpan) msgSpan.textContent = message;
					toastContainer.appendChild(toast);

					setTimeout(() => {
						toast.classList.remove("animate-toast-in");
						toast.classList.add("animate-toast-out");
						setTimeout(() => {
							toast.remove();
						}, 300);
					}, 2000);
				};
			}

		</script>

		<!-- Soft CTA Popup Modal -->
		<div
			id="soft-cta-modal"
			class="fixed inset-0 z-[99999] flex items-center justify-center bg-slate-900/60 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500"
		>
			<div
				id="soft-cta-card"
				class="relative w-full max-w-lg bg-white border border-slate-200 shadow-2xl rounded-[2rem] p-8 md:p-10 transform scale-95 opacity-0 transition-all duration-500 text-left font-sans mx-4"
			>
				<!-- Close Button -->
				<button
					id="soft-cta-close"
					class="absolute top-6 right-6 p-2 rounded-full border border-slate-100 hover:bg-slate-50 text-slate-400 hover:text-slate-600 transition-colors cursor-pointer"
					aria-label="Close popup"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
				</button>

				<!-- Content -->
				<div class="space-y-6">
					<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-accent-blue/10 border border-accent-blue/20 text-xs font-bold text-accent-indigo font-sans">
						<span class="w-1.5 h-1.5 rounded-full bg-accent-blue animate-ping"></span>
						Still exploring?
					</span>
					
					<div class="space-y-3">
						<h3 class="text-2xl sm:text-3xl font-extrabold font-display text-slate-800 tracking-tight leading-tight">
							Book a free counseling call.
						</h3>
						<p class="text-sm text-slate-500 leading-relaxed font-sans font-normal">
							Our senior admissions experts are here to help. Get a personalized profile evaluation and country comparison list — 100% free, no strings attached.
						</p>
					</div>

					{/* Trust stats */}
					<div class="grid grid-cols-3 gap-4 border-y border-slate-100 py-4 text-center font-sans">
						<div>
							<span class="block text-lg font-bold text-slate-800 font-display">30K+</span>
							<span class="block text-[10px] text-slate-400 font-semibold uppercase tracking-wider">Students Placed</span>
						</div>
						<div>
							<span class="block text-lg font-bold text-[#0A7880] font-display">97%</span>
							<span class="block text-[10px] text-slate-400 font-semibold uppercase tracking-wider">Visa Success</span>
						</div>
						<div>
							<span class="block text-lg font-bold text-[#F08A00] font-display">100%</span>
							<span class="block text-[10px] text-slate-400 font-semibold uppercase tracking-wider">Free Advice</span>
						</div>
					</div>

					<!-- Actions -->
					<div class="flex flex-col sm:flex-row gap-3 pt-2 font-sans">
						<button
							id="soft-cta-btn"
							class="flex-grow py-3 px-6 rounded-full bg-[#0A7880] hover:bg-[#075E64] text-white font-bold text-sm transition-all text-center justify-center flex items-center gap-2 cursor-pointer shadow-md shadow-[#0A7880]/10"
						>
							Book Free Call
						</button>
						<button
							id="soft-cta-secondary-close"
							class="py-3 px-6 rounded-full bg-slate-50 border border-slate-200 hover:bg-slate-100 text-slate-700 font-semibold text-sm transition-all cursor-pointer text-center"
						>
							Maybe Later
						</button>
					</div>
				</div>
			</div>
		</div>

		<CounsellorForm client:only="react" />


	</body>
</html>
